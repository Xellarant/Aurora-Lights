<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:Builder.Presentation"
                    xmlns:metro="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
                    xmlns:controls="clr-namespace:Builder.Presentation.Controls"
                    xmlns:metroConverters="http://metro.mahapps.com/winfx/xaml/shared"
                    xmlns:system="clr-namespace:System;assembly=mscorlib"
                    xmlns:converters="clr-namespace:Builder.Presentation.Converters">
  <ResourceDictionary.MergedDictionaries>
    <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/styles/controls.xaml"/>
    <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/styles/colors.xaml"/>
    <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/styles/fonts.xaml"/>
  </ResourceDictionary.MergedDictionaries>
  <metroConverters:ToUpperConverter x:Key="UpperCaseConverter"/>
  <converters:LocalImageSourceConverter x:Key="LocalImageSourceConverter"/>
  <Style TargetType="{x:Type controls:CharacterProfileButton}">
    <Setter Property="Control.Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type controls:CharacterProfileButton}">
          <Border Background="{TemplateBinding Control.Background}"
                  BorderBrush="{TemplateBinding Control.BorderBrush}"
                  BorderThickness="{TemplateBinding Control.BorderThickness}">
            <StackPanel Orientation="Horizontal">
              <StackPanel Margin="0,0,10,0" VerticalAlignment="Center">
                <TextBlock FontSize="13" HorizontalAlignment="Right" FontWeight="SemiBold"
                           Foreground="{DynamicResource GrayBrush5}"
                           Text="{TemplateBinding CharacterName, Converter={StaticResource UpperCaseConverter}}"/>
                <TextBlock FontSize="10" HorizontalAlignment="Right" FontWeight="Normal"
                           Foreground="{DynamicResource GrayBrush5}"
                           Text="{TemplateBinding CharacterBuild, Converter={StaticResource UpperCaseConverter}}"/>
              </StackPanel>
              <Grid Width="{TemplateBinding controls:CharacterProfileButton.ImageSize}"
                    Height="{TemplateBinding controls:CharacterProfileButton.ImageSize}">
                <Button x:Name="ProfileButton"
                        Visibility="{TemplateBinding controls:CharacterProfileButton.PortraitVisibility}" Padding="0"
                        BorderBrush="Transparent" Margin="1" Background="{DynamicResource HighlightBrush}">
                  <UIElement.OpacityMask>
                    <VisualBrush Stretch="Uniform">
                      <VisualBrush.Visual>
                        <Ellipse Fill="{DynamicResource BlackBrush}" Width="10" Height="10"/>
                      </VisualBrush.Visual>
                    </VisualBrush>
                  </UIElement.OpacityMask>
                  <ContentControl.Content>
                    <Grid>
                      <Image HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="None"
                             RenderTransformOrigin="0.5,0.5"
                             Source="{TemplateBinding CharacterImagePath, Converter={StaticResource LocalImageSourceConverter}}">
                        <FrameworkElement.LayoutTransform>
                          <TransformGroup>
                            <ScaleTransform ScaleY="{Binding PortraitScale, RelativeSource={RelativeSource TemplatedParent}}"
                                            ScaleX="{Binding PortraitScale, RelativeSource={RelativeSource TemplatedParent}}"/>
                          </TransformGroup>
                        </FrameworkElement.LayoutTransform>
                      </Image>
                    </Grid>
                  </ContentControl.Content>
                </Button>
                <Button x:Name="NewCharacterButton" Content=""
                        Command="{TemplateBinding controls:CharacterProfileButton.NewCharacterCommand}"
                        Width="{TemplateBinding controls:CharacterProfileButton.ImageSize}"
                        Height="{TemplateBinding controls:CharacterProfileButton.ImageSize}"
                        Foreground="{DynamicResource NewNotificationIndicatorForegroundColorBrush}"
                        ToolTip="Create New Character" FontSize="16" FontFamily="Segoe UI Symbol"
                        VerticalAlignment="Center" HorizontalAlignment="Center"
                        Style="{StaticResource ChromelessButtonStyle}" Padding="1,0,0,0" Margin="0"
                        Visibility="{TemplateBinding controls:CharacterProfileButton.NewCharacterCommandButtonVisibility}"/>
                <Ellipse StrokeThickness="1" Margin="0" Stroke="{DynamicResource HighlightBrush}"
                         Width="{TemplateBinding controls:CharacterProfileButton.ImageSize}"
                         Height="{TemplateBinding controls:CharacterProfileButton.ImageSize}">
                  <UIElement.Effect>
                    <DropShadowEffect BlurRadius="3" Opacity="1" ShadowDepth="1"/>
                  </UIElement.Effect>
                </Ellipse>
              </Grid>
            </StackPanel>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
</ResourceDictionary>