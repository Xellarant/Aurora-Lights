<div class="source-restrictions-editor">
    @if (ShowDefaultActions)
    {
        <div class="source-restrictions-toolbar">
            <button type="button"
                    class="source-restrictions-button"
                    @onclick="OnLoadDefaults"
                    disabled="@Busy">
                Load Default
            </button>
            <button type="button"
                    class="source-restrictions-button primary"
                    @onclick="OnSaveDefaults"
                    disabled="@Busy">
                Save as Default
            </button>
        </div>
    }

    @* Search filter *@
    <div style="margin-bottom: 10px;">
        <input class="source-restrictions-search"
               type="search"
               placeholder="Filter sources…"
               value="@_search"
               @oninput="e => _search = e.Value?.ToString() ?? string.Empty" />
    </div>

    @foreach (SourceRestrictionGroupModel group in FilteredGroups)
    {
        int enabledCount = group.Sources.Count(s => s.IsChecked == true);
        var visibleItems = FilteredItems(group);
        if (visibleItems.Count == 0) continue;

        <section class="source-restrictions-group">
            <div class="source-restrictions-group-header">
                <button type="button"
                        class="source-restrictions-toggle"
                        @onclick="() => OnToggleGroup.InvokeAsync(group.Id)"
                        disabled="@Busy || !group.AllowUnchecking">
                    <span class="source-restrictions-checkbox @(GetCheckClass(group.IsChecked, group.AllowUnchecking))"></span>
                    <span style="display: flex; align-items: center; gap: 8px; flex: 1; min-width: 0;">
                        <strong>@group.Name</strong>
                        <span class="source-restrictions-count">@enabledCount / @group.Sources.Count</span>
                    </span>
                </button>
            </div>

            <div class="source-restrictions-items">
                @foreach (SourceRestrictionItemModel item in visibleItems)
                {
                    <button type="button"
                            class="source-restrictions-item @(item.AllowUnchecking ? string.Empty : "locked")"
                            @onclick="() => OnToggleItem.InvokeAsync(item.Id)"
                            disabled="@Busy || !item.AllowUnchecking">
                        <span class="source-restrictions-checkbox @(GetCheckClass(item.IsChecked, item.AllowUnchecking))"></span>
                        <span class="source-restrictions-item-name">@item.Name</span>
                        @if (item.IsCore)
                        {
                            <span class="source-restrictions-core">core</span>
                        }
                    </button>
                }
            </div>
        </section>
    }

    @if (FilteredGroups.All(g => FilteredItems(g).Count == 0))
    {
        <p style="color: #6c7086; font-size: 13px; padding: 8px 0;">No sources match "@_search".</p>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public IReadOnlyList<SourceRestrictionGroupModel> Groups { get; set; } = [];

    [Parameter]
    public bool Busy { get; set; }

    [Parameter]
    public bool ShowDefaultActions { get; set; }

    [Parameter]
    public EventCallback<string> OnToggleGroup { get; set; }

    [Parameter]
    public EventCallback<string> OnToggleItem { get; set; }

    [Parameter]
    public EventCallback OnLoadDefaults { get; set; }

    [Parameter]
    public EventCallback OnSaveDefaults { get; set; }

    private string _search = "";

    private IReadOnlyList<SourceRestrictionGroupModel> FilteredGroups =>
        string.IsNullOrWhiteSpace(_search) ? Groups :
        Groups.Where(g => g.Name.Contains(_search, StringComparison.OrdinalIgnoreCase)
                       || g.Sources.Any(s => s.Name.Contains(_search, StringComparison.OrdinalIgnoreCase)))
              .ToList();

    private List<SourceRestrictionItemModel> FilteredItems(SourceRestrictionGroupModel group) =>
        string.IsNullOrWhiteSpace(_search) ? group.Sources.ToList() :
        group.Sources.Where(s => s.Name.Contains(_search, StringComparison.OrdinalIgnoreCase)
                              || group.Name.Contains(_search, StringComparison.OrdinalIgnoreCase))
             .ToList();

    private static string GetCheckClass(bool? value, bool allowUnchecking)
    {
        if (!allowUnchecking) return "checked locked";
        if (!value.HasValue)  return "mixed";
        return value.Value ? "checked" : "unchecked";
    }
}
