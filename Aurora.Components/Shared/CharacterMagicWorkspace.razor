<div class="character-magic-workspace">
    @if (!Model.HasSpellcasting)
    {
        <p class="magic-empty">This character has no spellcasting.</p>
    }
    else
    {
    <section class="magic-stats-strip">
        <div class="magic-stat">
            <span class="magic-stat-value">@Model.SpellcastingClass</span>
            <span class="magic-stat-label">Class</span>
        </div>
        <div class="magic-stat">
            <span class="magic-stat-value">@Model.SpellcastingAbility</span>
            <span class="magic-stat-label">Ability</span>
        </div>
        <div class="magic-stat">
            <span class="magic-stat-value">@Model.SpellcastingDc</span>
            <span class="magic-stat-label">Spell DC</span>
        </div>
        <div class="magic-stat">
            <span class="magic-stat-value">@Model.SpellcastingAttack</span>
            <span class="magic-stat-label">Spell Attack</span>
        </div>
        @if (Model.IsPreparedCaster && Model.MaxPrepared > 0)
        {
            <div class="magic-stat">
                <span class="magic-stat-value @(Model.PreparedCount >= Model.MaxPrepared ? "full" : string.Empty)">
                    @Model.PreparedCount / @Model.MaxPrepared
                </span>
                <span class="magic-stat-label">Prepared</span>
            </div>
        }
    </section>

    @if (Model.KnownSpellGroups.Count > 0)
    {
        @foreach (MagicKnownSpellGroupModel group in Model.KnownSpellGroups)
        {
            <section class="magic-section">
                <div class="magic-section-label">@($"{group.Label} - Known Spells")</div>
                <div class="magic-known-list">
                    @foreach (MagicKnownSpellEntryModel entry in group.Entries)
                    {
                        <div class="magic-known-row">
                            <div class="magic-known-label">@entry.Label</div>
                            <div class="magic-known-value @(string.IsNullOrWhiteSpace(entry.CurrentName) ? "empty" : string.Empty)">
                                @(entry.CurrentName ?? "-")
                            </div>
                            @if (OnChangeKnownSpell.HasDelegate)
                            {
                                <button type="button"
                                        class="magic-action-button"
                                        disabled="@Busy"
                                        @onclick="() => OnChangeKnownSpell.InvokeAsync(entry.Id)">
                                    Change
                                </button>
                            }
                        </div>
                    }
                </div>
            </section>
        }
    }

    <div class="magic-layout">
        <section class="magic-list">
            @if (Model.Cantrips.Count > 0)
            {
                <div class="magic-level-header">
                    <span class="magic-section-label">Cantrips</span>
                </div>
                @foreach (MagicSpellListEntryModel cantrip in Model.Cantrips)
                {
                    <button type="button"
                            class="magic-spell-row magic-spell-select @(SelectedSpellId == cantrip.Id ? "selected" : string.Empty)"
                            @onclick="() => OnSelectSpell.InvokeAsync(cantrip.Id)">
                        <span class="magic-spell-dot cantrip"></span>
                        <span class="magic-spell-name">@cantrip.Name</span>
                    </button>
                }
            }

            @foreach (MagicSpellLevelModel level in Model.SpellLevels)
            {
                <div class="magic-level-header">
                    <span class="magic-section-label">@Ordinal(level.Level) Level</span>
                    @if (level.TotalSlots > 0)
                    {
                        <div class="magic-slot-track">
                            @for (int i = 0; i < level.TotalSlots; i++)
                            {
                                int levelValue = level.Level;
                                int slotIndex = i;
                                bool used = slotIndex < level.UsedSlots;
                                <button type="button"
                                        class="magic-slot-bubble @(used ? "used" : string.Empty)"
                                        disabled="@(!OnToggleSlot.HasDelegate || Busy)"
                                        @onclick="() => OnToggleSlot.InvokeAsync(new MagicSlotToggleModel(levelValue, slotIndex))">
                                </button>
                            }
                            <span class="magic-slot-count">@(level.TotalSlots - level.UsedSlots)/@level.TotalSlots</span>
                        </div>
                    }
                </div>

                @foreach (MagicSpellListEntryModel spell in level.Spells)
                {
                    <div class="magic-spell-row @(SelectedSpellId == spell.Id ? "selected" : string.Empty)">
                        <button type="button"
                                class="magic-spell-select"
                                @onclick="() => OnSelectSpell.InvokeAsync(spell.Id)">
                            <input type="checkbox"
                                   checked="@spell.IsPrepared"
                                   disabled="@IsPreparationDisabled(spell)"
                                   @onchange="args => ChangePreparedAsync(spell.Id, args)" />
                            <span class="magic-spell-name @(spell.IsPrepared ? "prepared" : string.Empty)">@spell.Name</span>
                        </button>
                    </div>
                }
            }
        </section>

        <section class="magic-detail">
            @if (SelectedSpell is null)
            {
                <p class="magic-empty">Select a spell to see details.</p>
            }
            else
            {
                var spellDetail = SelectedSpell!;
                <div class="magic-detail-name">@spellDetail.Name</div>
                <div class="magic-detail-meta">
                    @if (!string.IsNullOrWhiteSpace(spellDetail.Subtitle))
                    {
                        <span>@spellDetail.Subtitle</span>
                    }
                    @if (!string.IsNullOrWhiteSpace(spellDetail.Source))
                    {
                        <span>@spellDetail.Source</span>
                    }
                </div>

                @if (!string.IsNullOrWhiteSpace(spellDetail.CastingTime) ||
                     !string.IsNullOrWhiteSpace(spellDetail.Range) ||
                     !string.IsNullOrWhiteSpace(spellDetail.Components) ||
                     !string.IsNullOrWhiteSpace(spellDetail.Duration))
                {
                    <div class="magic-detail-props">
                        @SpellPropRow("Casting Time", spellDetail.CastingTime)
                        @SpellPropRow("Range", spellDetail.Range)
                        @SpellPropRow("Components", spellDetail.Components)
                        @SpellPropRow("Duration", spellDetail.Duration)
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(spellDetail.Description))
                {
                    <div class="magic-detail-description">@spellDetail.Description</div>
                }
            }
        </section>
    </div>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public MagicOverviewModel Model { get; set; } = new();

    [Parameter]
    public string? SelectedSpellId { get; set; }

    [Parameter]
    public MagicSpellDetailModel? SelectedSpell { get; set; }

    [Parameter]
    public bool Busy { get; set; }

    [Parameter]
    public EventCallback<string> OnSelectSpell { get; set; }

    [Parameter]
    public EventCallback<string> OnChangeKnownSpell { get; set; }

    [Parameter]
    public EventCallback<MagicPreparedChangeModel> OnPreparedChanged { get; set; }

    [Parameter]
    public EventCallback<MagicSlotToggleModel> OnToggleSlot { get; set; }

    private bool IsPreparationDisabled(MagicSpellListEntryModel spell)
    {
        if (!OnPreparedChanged.HasDelegate || Busy || spell.IsAlwaysPrepared)
        {
            return true;
        }

        return !spell.IsPrepared
               && Model.IsPreparedCaster
               && Model.MaxPrepared > 0
               && Model.PreparedCount >= Model.MaxPrepared;
    }

    private Task ChangePreparedAsync(string spellId, ChangeEventArgs args)
    {
        if (!OnPreparedChanged.HasDelegate)
        {
            return Task.CompletedTask;
        }

        bool value = args.Value is bool boolValue
            ? boolValue
            : string.Equals(args.Value?.ToString(), "true", StringComparison.OrdinalIgnoreCase)
              || string.Equals(args.Value?.ToString(), "on", StringComparison.OrdinalIgnoreCase);

        return OnPreparedChanged.InvokeAsync(new MagicPreparedChangeModel(spellId, value));
    }

    private RenderFragment SpellPropRow(string label, string value) => builder =>
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return;
        }

        builder.OpenElement(0, "div");
        builder.AddAttribute(1, "class", "magic-prop-row");
        builder.OpenElement(2, "span");
        builder.AddAttribute(3, "class", "magic-prop-label");
        builder.AddContent(4, label);
        builder.CloseElement();
        builder.OpenElement(5, "span");
        builder.AddAttribute(6, "class", "magic-prop-value");
        builder.AddContent(7, value);
        builder.CloseElement();
        builder.CloseElement();
    };

    private static string Ordinal(int level) => level switch
    {
        1 => "1st",
        2 => "2nd",
        3 => "3rd",
        _ => $"{level}th",
    };
}
