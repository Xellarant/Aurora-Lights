      <stat name="multiclass:spellcasting:slot:5" value="1" level="9" />
      <stat name="multiclass:spellcasting:slot:5" value="1" level="10" />
      <stat name="multiclass:spellcasting:slot:5" value="1" level="18" />

      <stat name="multiclass:spellcasting:slot:6" value="1" level="11" />
      <stat name="multiclass:spellcasting:slot:6" value="1" level="19" />

      <stat name="multiclass:spellcasting:slot:7" value="1" level="13" />
