        <Border Background="{DynamicResource HighlightBrush}" BorderThickness="1"
                BorderBrush="{DynamicResource AccentColorBrush}" Grid.Row="1" Grid.ColumnSpan="2">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <FrameworkElement.Resources>
              <Style x:Key="HeaderTextBlockStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="FrameworkElement.VerticalAlignment" Value="Center"/>
                <Setter Property="TextBlock.FontWeight" Value="SemiBold"/>
                <Setter Property="TextBlock.Foreground" Value="{DynamicResource IdealForegroundColorBrush}"/>
                <Setter Property="TextBlock.Text" Value="{Binding Converter={StaticResource ToUpperConverter}}"/>
              </Style>
            </FrameworkElement.Resources>
            <TextBlock Text="INVENTORY (MORE OPTIONS IN NEW INVENTORY TAB)" Style="{StaticResource HeaderTextBlockStyle}"
                       Margin="5,4,0,5"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,1">
              <FrameworkElement.Resources>
                <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource HeaderTextBlockStyle}">
                  <Setter Property="TextBlock.FontWeight" Value="Normal"/>
                  <Setter Property="TextBlock.FontSize" Value="10"/>
                  <Setter Property="TextBlock.LineHeight" Value="12"/>
                  <Setter Property="TextBlock.Foreground" Value="{DynamicResource GrayBrush6}"/>
                  <Setter Property="FrameworkElement.Margin" Value="0,0,8,0"/>
                </Style>
              </FrameworkElement.Resources>
              <TextBlock FontWeight="SemiBold" Text="ATTUNED ITEMS:" Margin="10,0,5,0"/>
              <TextBlock FontWeight="SemiBold" Margin="0" Foreground="{DynamicResource AuroraGoldColorBrush}"
                         ToolTip="The number of currently attuned items."
                         Text="{Binding Inventory.AttunedItemCount, Mode=OneWay}"/>
              <TextBlock Text="/" Margin="2,0"/>
              <TextBlock Margin="0" ToolTip="You can attune 3 items to your character by default."
                         Text="{Binding Inventory.MaxAttunedItemCount, Mode=OneWay}"/>
              <TextBlock FontWeight="SemiBold" Text="WEIGHT:" Margin="25,0,5,0"/>
              <TextBlock Foreground="{DynamicResource AuroraGoldColorBrush}" Margin="0,0,2,0"
                         Text="{Binding Inventory.EquipmentWeight, Mode=OneWay, Converter={StaticResource UpperCaseConverter}}"/>
              <TextBlock Text="lb."/>
            </StackPanel>
          </Grid>
        </Border>
        <Border Visibility="Collapsed" Grid.Row="4" Background="{DynamicResource HighlightBrush}"
                BorderThickness="1" BorderBrush="{DynamicResource AccentColorBrush}" Grid.ColumnSpan="2">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <FrameworkElement.Resources>
              <Style x:Key="HeaderTextBlockStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="FrameworkElement.VerticalAlignment" Value="Center"/>
                <Setter Property="TextBlock.FontWeight" Value="SemiBold"/>
                <Setter Property="TextBlock.Foreground" Value="{DynamicResource IdealForegroundColorBrush}"/>
                <Setter Property="TextBlock.Text" Value="{Binding Converter={StaticResource ToUpperConverter}}"/>
              </Style>
              <Style TargetType="{x:Type Button}" BasedOn="{StaticResource StatusBarButtonStyle}">
                <Setter Property="Control.FontSize" Value="11"/>
                <Setter Property="FrameworkElement.Margin" Value="0,0,0,0"/>
                <Setter Property="Control.Foreground" Value="{DynamicResource GrayBrush8}"/>
                <Style.Triggers>
                  <Trigger Property="UIElement.IsMouseOver" Value="true">
                    <Setter Property="Control.Background" Value="{DynamicResource StatusBarButtonOpacityColorBrush2}"/>
                  </Trigger>
                  <Trigger Property="UIElement.IsMouseOver" Value="false"/>
                  <Trigger Property="UIElement.IsEnabled" Value="false">
                    <Setter Property="Control.Foreground" Value="{DynamicResource GrayBrush2}"/>
                  </Trigger>
                </Style.Triggers>
              </Style>
              <Style TargetType="{x:Type iconPacks:PackIconFontAwesome}">
                <Setter Property="FrameworkElement.Width" Value="16"/>
                <Setter Property="FrameworkElement.Height" Value="16"/>
                <Setter Property="FrameworkElement.Margin" Value="0,0,0,0"/>
                <Setter Property="Control.Padding" Value="0,1"/>
              </Style>
            </FrameworkElement.Resources>
            <TextBlock Text="" Style="{StaticResource HeaderTextBlockStyle}" Margin="5,4,0,5" Grid.Column="1"/>
