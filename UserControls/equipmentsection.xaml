                      <TransformGroup>
                        <ScaleTransform/>
                        <SkewTransform/>
                        <RotateTransform Angle="90"/>
                        <TranslateTransform/>
                      </TransformGroup>
                    </UIElement.RenderTransform>
                  </iconPacks:PackIconFontAwesome>
