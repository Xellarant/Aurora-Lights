                <StackPanel Orientation="Horizontal">
                  <iconPacks:PackIconFontAwesome Kind="SignInAltSolid" Margin="0,0,4,0" RenderTransformOrigin="0.5,0.5">
                    <UIElement.RenderTransform>
                      <TransformGroup>
                        <ScaleTransform/>
                        <SkewTransform/>
                        <RotateTransform Angle="90"/>
                        <TranslateTransform/>
                      </TransformGroup>
                    </UIElement.RenderTransform>
                  </iconPacks:PackIconFontAwesome>
                  <TextBlock Text="EQUIP VERSATILE" FontSize="10" VerticalAlignment="Center" Margin="0,0,0,1"/>
