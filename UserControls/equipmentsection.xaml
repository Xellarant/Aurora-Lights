                <StackPanel Orientation="Horizontal">
                  <iconPacks:PackIconFontAwesome Kind="LinkSolid" Margin="0,0,4,0" RenderTransformOrigin="0.5,0.5"/>
                  <TextBlock Text="TOGGLE ATTUNEMENT" FontSize="10" VerticalAlignment="Center" Margin="0,0,0,1"/>
                </StackPanel>
              </Button>
            </StackPanel>
          </Grid>
        </Border>
      </Grid>
    </Grid>
    <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="0,5,0,10" HorizontalAlignment="Left">
      <FrameworkElement.Resources>
        <Style TargetType="{x:Type iconPacks:PackIconFontAwesome}"
               BasedOn="{StaticResource FullSizeFontAwesomeStyle}"/>
      </FrameworkElement.Resources>
      <controls1:CommandButton Style="{StaticResource TextIconCommandButtonStyle}"
                               Visibility="{Binding AllowExtractEquipmentItem, Converter={StaticResource BooleanToVisibilityConverter}}"
                               CommandText="{Binding SelectedEquipmentItem.DisplayName, StringFormat='EXTRACT {0}', Converter={StaticResource UpperCaseConverter}}"
                               Command="{Binding ExtractEquipmentItemCommand}">
        <iconPacks:PackIconMaterial Kind="PackageUp" Height="12" Width="12"/>
      </controls1:CommandButton>
      <Separator Style="{StaticResource IconSeperatorStyle}"
                 Visibility="{Binding AllowExtractEquipmentItem, Converter={StaticResource BooleanToVisibilityConverter}}"/>
      <controls1:CommandButton CommandText="DETAILS" Style="{StaticResource TextIconCommandButtonStyle}"
                               Command="{Binding ManageEquipmentItemCommand}">
        <iconPacks:PackIconMaterial Kind="Pencil" Height="12" Width="12"/>
      </controls1:CommandButton>
      <Separator Style="{StaticResource IconSeperatorStyle}"
                 Visibility="{Binding AllowEquipmentItemAddToAttacks, Converter={StaticResource BooleanToVisibilityConverter}}"/>
      <controls1:CommandButton Style="{StaticResource TextIconCommandButtonStyle}"
                               Visibility="{Binding AllowEquipmentItemAddToAttacks, Converter={StaticResource BooleanToVisibilityConverter}}"
                               CommandText="{Binding SelectedEquipmentItem.DisplayName, StringFormat='ADD {0} TO ATTACKS', Converter={StaticResource UpperCaseConverter}}"
                               Command="{Binding AddToAttacksCommand}">
        <iconPacks:PackIconMaterial Kind="SwordCross" Height="12" Width="12"/>
      </controls1:CommandButton>
      <Separator Style="{StaticResource IconSeperatorStyle}"/>
      <controls1:CommandButton CommandText="UP" Style="{StaticResource TextIconCommandButtonStyle}"
                               Command="{Binding MoveSelectedEquipmentItemUpCommand}">
        <iconPacks:PackIconMaterial Kind="ArrowUp" Height="12" Width="12"/>
      </controls1:CommandButton>
      <controls1:CommandButton CommandText="DOWN" Style="{StaticResource TextIconCommandButtonStyle}"
                               Command="{Binding MoveSelectedEquipmentItemDownCommand}">
        <iconPacks:PackIconMaterial Kind="ArrowDown" Height="12" Width="12"/>
      </controls1:CommandButton>
      <Separator Style="{StaticResource IconSeperatorStyle}"/>
      <controls1:CommandButton CommandText="DELETE" Style="{StaticResource DangerTextIconCommandButtonStyle}"
                               Command="{Binding DeleteSelectedEquipmentCommand}">
        <iconPacks:PackIconMaterial Kind="CloseBox" Height="12" Width="12"/>
      </controls1:CommandButton>
      <controls1:CommandButton CommandText="DELETE ALL" Style="{StaticResource DangerTextIconCommandButtonStyle}"
                               Visibility="{Binding SelectedEquipmentItem.IsStackable, Converter={StaticResource BooleanToVisibilityConverter}}"
                               Command="{Binding DeleteAllSelectedEquipmentCommand}">
        <iconPacks:PackIconMaterial Kind="CloseBox" Height="12" Width="12"/>
      </controls1:CommandButton>
      <StatusBar Background="{DynamicResource TransparentWhiteBrush}"/>
    </StackPanel>
    <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="0,5,0,10" HorizontalAlignment="Right">
      <controls1:CommandButton CommandText="EQUIP" Style="{StaticResource SuccessTextIconCommandButtonStyle}"
                               Visibility="{Binding AllowEquipEquipmentItem, Converter={StaticResource BooleanToVisibilityConverter}}"
                               Command="{Binding EquipEquipmentItemCommand}">
        <iconPacks:PackIconMaterial Kind="CheckboxMultipleMarked" Height="12" Width="12"/>
      </controls1:CommandButton>
      <controls1:CommandButton CommandText="EQUIP PRIMARY" Style="{StaticResource SuccessTextIconCommandButtonStyle}"
                               Visibility="{Binding AllowEquipPrimaryEquipmentItem, Converter={StaticResource BooleanToVisibilityConverter}}"
                               Command="{Binding EquipPrimaryEquipmentItemCommand}">
        <iconPacks:PackIconMaterial Kind="Numeric1Box" Height="12" Width="12"/>
      </controls1:CommandButton>
      <controls1:CommandButton CommandText="EQUIP SECONDARY" Style="{StaticResource SuccessTextIconCommandButtonStyle}"
                               Visibility="{Binding AllowEquipSecondaryEquipmentItem, Converter={StaticResource BooleanToVisibilityConverter}}"
                               Command="{Binding EquipSecondaryEquipmentItemCommand}">
        <iconPacks:PackIconMaterial Kind="Numeric2Box" Height="12" Width="12"/>
      </controls1:CommandButton>
      <controls1:CommandButton CommandText="EQUIP VERSATILE" Style="{StaticResource SuccessTextIconCommandButtonStyle}"
                               Visibility="{Binding AllowEquipVersatileEquipmentItem, Converter={StaticResource BooleanToVisibilityConverter}}"
                               Command="{Binding EquipVersatileEquipmentItemCommand}">
        <iconPacks:PackIconMaterial Kind="Numeric1BoxMultipleOutline" Height="12" Width="12"/>
      </controls1:CommandButton>
      <Separator Style="{StaticResource IconSeperatorStyle}"
                 Visibility="{Binding AllowToggleAttunementEquipmentItem, Converter={StaticResource BooleanToVisibilityConverter}}"/>
      <controls1:CommandButton CommandText="ATTUNEMENT" Style="{StaticResource SuccessTextIconCommandButtonStyle}"
                               Visibility="{Binding AllowToggleAttunementEquipmentItem, Converter={StaticResource BooleanToVisibilityConverter}}"
                               Command="{Binding ToggleAttunementEquipmentItemCommand}">
        <iconPacks:PackIconMaterial Kind="MultiplicationBox" Height="12" Width="12"/>
      </controls1:CommandButton>
    </StackPanel>
  </Grid>
</UserControl>