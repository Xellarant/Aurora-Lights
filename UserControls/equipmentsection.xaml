<UserControl x:Class="Builder.Presentation.UserControls.EquipmentSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Builder.Presentation.UserControls"
             xmlns:items="clr-namespace:Builder.Presentation.ViewModels.Shell.Items"
             xmlns:controls="clr-namespace:Builder.Presentation.Controls"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:equipment="clr-namespace:Builder.Presentation.UserControls.Equipment"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:system="clr-namespace:System;assembly=mscorlib"
             xmlns:converters="clr-namespace:Builder.Presentation.Converters"
             xmlns:controls1="clr-namespace:Aurora.Presentation.Controls;assembly=Aurora.Presentation"
             x:Name="UserControl">
  <FrameworkElement.Resources>
    <system:Double x:Key="RowHeight">21</system:Double>
    <converters:ElementProficiencyValueConvereter x:Key="ElementProficiencyValueConvereter"/>
    <converters:ElementProficiencyValueConvereter x:Key="InvertedElementProficiencyValueConvereter" Invert="true"/>
    <converters:ElementProficiencyBrushValueConvereter x:Key="ElementProficiencyBrushValueConvereter"/>
    <Style x:Key="BaseDataGridColumnHeader" TargetType="{x:Type DataGridColumnHeader}"
           BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
      <Setter Property="Control.FontSize" Value="11"/>
      <Setter Property="Control.FontWeight" Value="SemiBold"/>
      <Setter Property="Control.Padding" Value="5,5,5,5"/>
      <Setter Property="Control.Foreground" Value="{DynamicResource GrayBrush1}"/>
      <Setter Property="Control.Background" Value="{DynamicResource GrayBrush8}"/>
      <Setter Property="Control.BorderThickness" Value="0,0,0,1"/>
      <Setter Property="Control.BorderBrush" Value="{DynamicResource AccentColorBrush4}"/>
    </Style>
    <Style x:Key="ReItemsDataGridStyle" TargetType="{x:Type DataGrid}"
           BasedOn="{StaticResource {x:Type DataGrid}}">
      <Setter Property="DataGrid.IsReadOnly" Value="true"/>
      <Setter Property="DataGrid.AutoGenerateColumns" Value="false"/>
      <Setter Property="DataGrid.HeadersVisibility" Value="Column"/>
      <Setter Property="DataGrid.CanUserReorderColumns" Value="false"/>
      <Setter Property="DataGrid.CanUserResizeRows" Value="false"/>
      <Setter Property="Control.BorderThickness" Value="1"/>
      <Setter Property="Control.BorderBrush" Value="{DynamicResource AccentColorBrush4}"/>
      <Setter Property="DataGrid.GridLinesVisibility" Value="None"/>
      <Setter Property="DataGrid.MinRowHeight" Value="20"/>
      <Setter Property="DataGrid.ColumnHeaderStyle" Value="{StaticResource BaseDataGridColumnHeader}"/>
    </Style>
    <Style x:Key="LeftAlignedDataGridColumnHeaderStyle" TargetType="{x:Type DataGridColumnHeader}"
           BasedOn="{StaticResource BaseDataGridColumnHeader}">
      <Setter Property="Control.Foreground" Value="{DynamicResource HighlightBrush}"/>
      <Setter Property="Control.Background" Value="{DynamicResource GrayBrush8}"/>
      <Setter Property="Control.BorderThickness" Value="0,0,0,1"/>
      <Setter Property="Control.BorderBrush" Value="{DynamicResource AccentColorBrush4}"/>
    </Style>
    <Style x:Key="RightAlignedDataGridColumnHeaderStyle" TargetType="{x:Type DataGridColumnHeader}"
           BasedOn="{StaticResource LeftAlignedDataGridColumnHeaderStyle}">
      <Setter Property="Control.HorizontalContentAlignment" Value="Right"/>
    </Style>
    <Style x:Key="HeaderTextBlockStyle" TargetType="{x:Type TextBlock}">
      <Setter Property="FrameworkElement.VerticalAlignment" Value="Center"/>
      <Setter Property="TextBlock.FontWeight" Value="SemiBold"/>
      <Setter Property="TextBlock.Foreground" Value="{DynamicResource IdealForegroundColorBrush}"/>
      <Setter Property="TextBlock.Text" Value="{Binding Converter={StaticResource ToUpperConverter}}"/>
    </Style>
    <Style x:Key="EquipmentDataGridColumnHeaderStyle" TargetType="{x:Type DataGridColumnHeader}"
           BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
      <Setter Property="Control.HorizontalContentAlignment" Value="Center"/>
      <Setter Property="Control.FontSize" Value="9"/>
      <Setter Property="Control.FontWeight" Value="SemiBold"/>
      <Setter Property="FrameworkElement.MinWidth" Value="50"/>
      <Setter Property="FrameworkElement.Width" Value="Auto"/>
      <Setter Property="Control.Padding" Value="2,2,2,2"/>
      <Setter Property="Control.Background" Value="{DynamicResource AccentColorBrush}"/>
      <Setter Property="Control.Foreground" Value="{DynamicResource IdealForegroundColorBrush}"/>
    </Style>
  </FrameworkElement.Resources>
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="Auto"/>
      <ColumnDefinition/>
      <ColumnDefinition Width="Auto" MinWidth="0"/>
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="200" MinHeight="160"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <Grid Column="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>
      <Grid.RowDefinitions>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>
      <Grid Column="0">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <DataGrid x:Name="CategoriesDataGrid" Grid.Row="1" BorderBrush="{DynamicResource AccentColorBrush}"
                  BorderThickness="1,0,1,1" mah:DataGridRowHelper.SelectionUnit="FullRow" CanUserSortColumns="false"
                  SelectionMode="Single" GridLinesVisibility="Horizontal" Margin="0"
                  HorizontalGridLinesBrush="#09000000" Style="{StaticResource SelectionRuleExpanderGridStyle}"
                  MinRowHeight="{StaticResource RowHeight}" HeadersVisibility="Column"
                  ItemsSource="{Binding CategoriesCollectionView}"
                  SelectedItem="{Binding SelectedEquipmentCategory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
          <DataGrid.ColumnHeaderStyle>
            <Style TargetType="{x:Type DataGridColumnHeader}" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
              <Setter Property="Control.BorderBrush" Value="{DynamicResource HighlightBrush}"/>
              <Setter Property="Control.BorderThickness" Value="0,0,0,1"/>
              <Setter Property="UIElement.SnapsToDevicePixels" Value="true"/>
              <Setter Property="Control.FontSize" Value="9"/>
              <Setter Property="Control.FontWeight" Value="SemiBold"/>
              <Setter Property="Control.Padding" Value="5,2,5,2"/>
              <Setter Property="Control.Background" Value="{DynamicResource AccentColorBrush}"/>
              <Setter Property="Control.Foreground" Value="{DynamicResource IdealForegroundColorBrush}"/>
            </Style>
          </DataGrid.ColumnHeaderStyle>
          <DataGrid.Columns>
            <DataGridTextColumn x:Name="categoryColumn" Header="CATEGORY" Width="Auto" MinWidth="150" MaxWidth="150"
                                Binding="{Binding DisplayName}">
              <DataGridColumn.CellStyle>
                <Style TargetType="{x:Type DataGridCell}" BasedOn="{StaticResource {x:Type DataGridCell}}">
                  <Setter Property="Control.Padding" Value="5,0"/>
                  <Setter Property="ContentControl.ContentTemplate">
                    <Setter.Value>
                      <DataTemplate>
                        <StackPanel VerticalAlignment="Center">
                          <TextBlock Margin="0,0" TextWrapping="NoWrap" Text="{Binding}"/>
                        </StackPanel>
                      </DataTemplate>
                    </Setter.Value>
                  </Setter>
                </Style>
              </DataGridColumn.CellStyle>
            </DataGridTextColumn>
          </DataGrid.Columns>
        </DataGrid>
        <Border Grid.Row="0" Background="{DynamicResource HighlightBrush}" BorderThickness="1"
                BorderBrush="{DynamicResource AccentColorBrush}">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <FrameworkElement.Resources>
              <Style x:Key="HeaderTextBlockStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="FrameworkElement.VerticalAlignment" Value="Center"/>
                <Setter Property="TextBlock.FontWeight" Value="SemiBold"/>
                <Setter Property="TextBlock.Foreground" Value="{DynamicResource IdealForegroundColorBrush}"/>
                <Setter Property="TextBlock.Text" Value="{Binding Converter={StaticResource ToUpperConverter}}"/>
              </Style>
            </FrameworkElement.Resources>
            <TextBlock Text="CATEGORIES" Style="{StaticResource HeaderTextBlockStyle}" Margin="5,4,0,5"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,1" Visibility="Collapsed">
              <FrameworkElement.Resources>
                <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource HeaderTextBlockStyle}">
                  <Setter Property="TextBlock.FontWeight" Value="Normal"/>
                  <Setter Property="TextBlock.FontSize" Value="10"/>
                  <Setter Property="TextBlock.LineHeight" Value="12"/>
                  <Setter Property="TextBlock.Foreground" Value="{DynamicResource GrayBrush6}"/>
                  <Setter Property="FrameworkElement.Margin" Value="0,0,8,0"/>
                </Style>
              </FrameworkElement.Resources>
              <TextBlock FontWeight="SemiBold" Text="CATEGORIES:" Margin="0,0,5,0"/>
              <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource AuroraGoldColorBrush}"
                         Text="{Binding EquipmentCategories.Count}"/>
            </StackPanel>
            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,0,1" Visibility="Collapsed">
              <FrameworkElement.Resources>
                <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource HeaderTextBlockStyle}">
                  <Setter Property="TextBlock.FontWeight" Value="SemiBold"/>
                  <Setter Property="TextBlock.FontSize" Value="10"/>
                  <Setter Property="TextBlock.LineHeight" Value="12"/>
                  <Setter Property="FrameworkElement.Margin" Value="0,0,4,0"/>
                  <Setter Property="TextBlock.Foreground" Value="{DynamicResource AuroraGoldColorBrush}"/>
                  <Style.Triggers>
                    <Trigger Property="TextBlock.Text" Value="0">
                      <Setter Property="UIElement.Opacity" Value="0.25"/>
                      <Setter Property="TextBlock.FontWeight" Value="Normal"/>
                      <Setter Property="TextBlock.Foreground" Value="{DynamicResource GrayBrush6}"/>
                    </Trigger>
                  </Style.Triggers>
                </Style>
              </FrameworkElement.Resources>
              <iconPacks:PackIconFontAwesome Kind="ExclamationTriangleSolid" Foreground="{DynamicResource DangerColorBrush}" Margin="0,0,8,0"
                                             Width="16" Height="16" ToolTip="DANGER! DANGER!"/>
            </StackPanel>
          </Grid>
        </Border>
      </Grid>
      <Grid Column="1" Margin="10,0,0,0" IsEnabled="{Binding IsArmorSelection}"
            Visibility="{Binding IsArmorSelection, Converter={StaticResource BooleanToVisibilityConverter}}">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <DataGrid x:Name="ArmorCollectionDataGrid" Grid.Row="1" BorderBrush="{DynamicResource AccentColorBrush}"
                  BorderThickness="1,0,1,1" SnapsToDevicePixels="true" mah:DataGridRowHelper.SelectionUnit="FullRow"
                  SelectionMode="Single" GridLinesVisibility="Horizontal" Margin="0" CanUserReorderColumns="false"
                  HorizontalGridLinesBrush="#07000000" Style="{StaticResource SelectionRuleExpanderGridStyle}"
                  MinRowHeight="{StaticResource RowHeight}" HeadersVisibility="Column"
                  ItemsSource="{Binding ArmorCollection}"
                  SelectedItem="{Binding SelectedArmorElement, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
          <DataGrid.ColumnHeaderStyle>
            <Style TargetType="{x:Type DataGridColumnHeader}" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
              <Setter Property="Control.BorderBrush" Value="{DynamicResource HighlightBrush}"/>
              <Setter Property="Control.BorderThickness" Value="0,0,0,1"/>
              <Setter Property="UIElement.SnapsToDevicePixels" Value="true"/>
              <Setter Property="Control.FontSize" Value="9"/>
              <Setter Property="Control.FontWeight" Value="SemiBold"/>
              <Setter Property="Control.Padding" Value="5,2,5,2"/>
              <Setter Property="Control.Background" Value="{DynamicResource AccentColorBrush}"/>
              <Setter Property="Control.Foreground" Value="{DynamicResource IdealForegroundColorBrush}"/>
            </Style>
          </DataGrid.ColumnHeaderStyle>
          <DataGrid.Columns>
            <DataGridTextColumn x:Name="armorNameColumn" Header="ARMOR" Width="Auto" MinWidth="150" MaxWidth="150"
                                Binding="{Binding Name}">
              <DataGridColumn.CellStyle>
                <Style TargetType="{x:Type DataGridCell}" BasedOn="{StaticResource {x:Type DataGridCell}}">
                  <Setter Property="Control.Padding" Value="5,0"/>
                  <Setter Property="ContentControl.ContentTemplate">
                    <Setter.Value>
                      <DataTemplate>
                        <StackPanel IsHitTestVisible="false" Orientation="Horizontal">
                          <TextBlock Margin="0,0" VerticalAlignment="Center" Text="{Binding Name}"
                                     Visibility="{Binding Converter={StaticResource InvertedElementProficiencyValueConvereter}}"/>
                          <TextBlock Margin="0,0" VerticalAlignment="Center" FontStyle="Italic" FontWeight="SemiBold"
                                     Text="{Binding Name}"
                                     Visibility="{Binding Converter={StaticResource ElementProficiencyValueConvereter}}"/>
                        </StackPanel>
                      </DataTemplate>
                    </Setter.Value>
                  </Setter>
                </Style>
              </DataGridColumn.CellStyle>
            </DataGridTextColumn>
          </DataGrid.Columns>
        </DataGrid>
        <Border Grid.Row="0" Background="{DynamicResource HighlightBrush}" BorderThickness="1"
                BorderBrush="{DynamicResource AccentColorBrush}">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <FrameworkElement.Resources>
              <Style x:Key="HeaderTextBlockStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="FrameworkElement.VerticalAlignment" Value="Center"/>
                <Setter Property="TextBlock.FontWeight" Value="SemiBold"/>
                <Setter Property="TextBlock.Foreground" Value="{DynamicResource IdealForegroundColorBrush}"/>
                <Setter Property="TextBlock.Text" Value="{Binding Converter={StaticResource ToUpperConverter}}"/>
              </Style>
            </FrameworkElement.Resources>
            <TextBlock Text="ARMOR" Style="{StaticResource HeaderTextBlockStyle}" Margin="5,4,0,5"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,1" Visibility="Collapsed">
              <FrameworkElement.Resources>
                <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource HeaderTextBlockStyle}">
                  <Setter Property="TextBlock.FontWeight" Value="Normal"/>
                  <Setter Property="TextBlock.FontSize" Value="10"/>
                  <Setter Property="TextBlock.LineHeight" Value="12"/>
                  <Setter Property="TextBlock.Foreground" Value="{DynamicResource GrayBrush6}"/>
                  <Setter Property="FrameworkElement.Margin" Value="0,0,8,0"/>
                </Style>
              </FrameworkElement.Resources>
              <TextBlock FontWeight="SemiBold" Text="ARMOR:" Margin="0,0,5,0"/>
              <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource AuroraGoldColorBrush}"
                         Text="{Binding ArmorCollection.Count}"/>
            </StackPanel>
            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,0,1" Visibility="Collapsed">
              <FrameworkElement.Resources>
                <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource HeaderTextBlockStyle}">
                  <Setter Property="TextBlock.FontWeight" Value="SemiBold"/>
                  <Setter Property="TextBlock.FontSize" Value="10"/>
                  <Setter Property="TextBlock.LineHeight" Value="12"/>
                  <Setter Property="FrameworkElement.Margin" Value="0,0,4,0"/>
                  <Setter Property="TextBlock.Foreground" Value="{DynamicResource AuroraGoldColorBrush}"/>
                  <Style.Triggers>
                    <Trigger Property="TextBlock.Text" Value="0">
                      <Setter Property="UIElement.Opacity" Value="0.25"/>
                      <Setter Property="TextBlock.FontWeight" Value="Normal"/>
                      <Setter Property="TextBlock.Foreground" Value="{DynamicResource GrayBrush6}"/>
                    </Trigger>
                  </Style.Triggers>
                </Style>
              </FrameworkElement.Resources>
              <iconPacks:PackIconFontAwesome Kind="ExclamationTriangleSolid" Foreground="{DynamicResource DangerColorBrush}" Margin="0,0,8,0"
                                             Width="16" Height="16" ToolTip="DANGER! DANGER!"/>
            </StackPanel>
          </Grid>
        </Border>
      </Grid>
      <Grid Column="2" Margin="10,0,0,0" IsEnabled="{Binding IsWeaponSelection}"
            Visibility="{Binding IsWeaponSelection, Converter={StaticResource BooleanToVisibilityConverter}}">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <DataGrid x:Name="WeaponsCollectionDataGrid" Grid.Row="1" BorderBrush="{DynamicResource AccentColorBrush}"
                  BorderThickness="1,0,1,1" SnapsToDevicePixels="true" mah:DataGridRowHelper.SelectionUnit="FullRow"
                  SelectionMode="Single" GridLinesVisibility="Horizontal" Margin="0" CanUserReorderColumns="false"
                  HorizontalGridLinesBrush="#07000000" Style="{StaticResource SelectionRuleExpanderGridStyle}"
                  MinRowHeight="{StaticResource RowHeight}" HeadersVisibility="Column"
                  ItemsSource="{Binding WeaponsCollection}"
                  SelectedItem="{Binding SelectedWeaponElement, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
          <DataGrid.ColumnHeaderStyle>
            <Style TargetType="{x:Type DataGridColumnHeader}" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
              <Setter Property="Control.BorderBrush" Value="{DynamicResource HighlightBrush}"/>
              <Setter Property="Control.BorderThickness" Value="0,0,0,1"/>
              <Setter Property="UIElement.SnapsToDevicePixels" Value="true"/>
              <Setter Property="Control.FontSize" Value="9"/>
              <Setter Property="Control.FontWeight" Value="SemiBold"/>
              <Setter Property="Control.Padding" Value="5,2,5,2"/>
              <Setter Property="Control.Background" Value="{DynamicResource AccentColorBrush}"/>
              <Setter Property="Control.Foreground" Value="{DynamicResource IdealForegroundColorBrush}"/>
            </Style>
          </DataGrid.ColumnHeaderStyle>
          <DataGrid.Columns>
            <DataGridTextColumn x:Name="weaponsNameColumn" Header="WEAPON" Width="Auto" MinWidth="150" MaxWidth="150"
                                Binding="{Binding Name}">
              <DataGridColumn.CellStyle>
                <Style TargetType="{x:Type DataGridCell}" BasedOn="{StaticResource {x:Type DataGridCell}}">
                  <Setter Property="Control.Padding" Value="5,0"/>
                  <Setter Property="ContentControl.ContentTemplate">
                    <Setter.Value>
                      <DataTemplate>
                        <StackPanel IsHitTestVisible="false" Orientation="Horizontal">
                          <TextBlock Margin="0,0" VerticalAlignment="Center" Text="{Binding Name}"
                                     Visibility="{Binding Converter={StaticResource InvertedElementProficiencyValueConvereter}}"/>
                          <TextBlock Margin="0,0" VerticalAlignment="Center" FontStyle="Italic" FontWeight="SemiBold"
                                     Text="{Binding Name}"
                                     Visibility="{Binding Converter={StaticResource ElementProficiencyValueConvereter}}"/>
                        </StackPanel>
                      </DataTemplate>
                    </Setter.Value>
                  </Setter>
                </Style>
              </DataGridColumn.CellStyle>
            </DataGridTextColumn>
          </DataGrid.Columns>
        </DataGrid>
        <Border Grid.Row="0" Background="{DynamicResource HighlightBrush}" BorderThickness="1"
                BorderBrush="{DynamicResource AccentColorBrush}">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <FrameworkElement.Resources>
              <Style x:Key="HeaderTextBlockStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="FrameworkElement.VerticalAlignment" Value="Center"/>
                <Setter Property="TextBlock.FontWeight" Value="SemiBold"/>
                <Setter Property="TextBlock.Foreground" Value="{DynamicResource IdealForegroundColorBrush}"/>
                <Setter Property="TextBlock.Text" Value="{Binding Converter={StaticResource ToUpperConverter}}"/>
              </Style>
            </FrameworkElement.Resources>
            <TextBlock Text="WEAPONS" Style="{StaticResource HeaderTextBlockStyle}" Margin="5,4,0,5"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,1" Visibility="Collapsed">
              <FrameworkElement.Resources>
                <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource HeaderTextBlockStyle}">
                  <Setter Property="TextBlock.FontWeight" Value="Normal"/>
                  <Setter Property="TextBlock.FontSize" Value="10"/>
                  <Setter Property="TextBlock.LineHeight" Value="12"/>
                  <Setter Property="TextBlock.Foreground" Value="{DynamicResource GrayBrush6}"/>
                  <Setter Property="FrameworkElement.Margin" Value="0,0,8,0"/>
                </Style>
              </FrameworkElement.Resources>
              <TextBlock FontWeight="SemiBold" Text="WEAPONS:" Margin="0,0,5,0"/>
              <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource AuroraGoldColorBrush}"
                         Text="{Binding WeaponsCollection.Count}"/>
            </StackPanel>
            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,0,1" Visibility="Collapsed">
              <FrameworkElement.Resources>
                <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource HeaderTextBlockStyle}">
                  <Setter Property="TextBlock.FontWeight" Value="SemiBold"/>
                  <Setter Property="TextBlock.FontSize" Value="10"/>
                  <Setter Property="TextBlock.LineHeight" Value="12"/>
                  <Setter Property="FrameworkElement.Margin" Value="0,0,4,0"/>
                  <Setter Property="TextBlock.Foreground" Value="{DynamicResource AuroraGoldColorBrush}"/>
                  <Style.Triggers>
                    <Trigger Property="TextBlock.Text" Value="0">
                      <Setter Property="UIElement.Opacity" Value="0.25"/>
                      <Setter Property="TextBlock.FontWeight" Value="Normal"/>
                      <Setter Property="TextBlock.Foreground" Value="{DynamicResource GrayBrush6}"/>
                    </Trigger>
                  </Style.Triggers>
                </Style>
              </FrameworkElement.Resources>
              <iconPacks:PackIconFontAwesome Kind="ExclamationTriangleSolid" Foreground="{DynamicResource DangerColorBrush}" Margin="0,0,8,0"
                                             Width="16" Height="16" ToolTip="DANGER! DANGER!"/>
            </StackPanel>
          </Grid>
        </Border>
      </Grid>
      <Grid x:Name="ItemsGrid" Row="0" Column="3" Margin="10,0,0,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="0"/>
          <RowDefinition/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto" MaxHeight="190"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border x:Name="VisualFocusQue" BorderThickness="0" Width="4" BorderBrush="{DynamicResource GrayBrush1}"
                Margin="0,0,10,0" Background="{DynamicResource HighlightBrush}" SnapsToDevicePixels="true"
                Visibility="Collapsed" Grid.Column="0" Grid.RowSpan="4">
          <FrameworkElement.Triggers>
            <EventTrigger RoutedEvent="Border.RequestBringIntoView">
              <BeginStoryboard>
                <Storyboard>
                  <DoubleAnimation From="1" To="0" AutoReverse="true" Duration="0:0:0.75" Storyboard.TargetName="VisualFocusQue"
                                   Storyboard.TargetProperty="Opacity" RepeatBehavior="3x"/>
                </Storyboard>
              </BeginStoryboard>
            </EventTrigger>
          </FrameworkElement.Triggers>
        </Border>
        <DataGrid PreviewKeyDown="SelectionElementsDataGrid_OnPreviewKeyDown" x:Name="SelectionElementsDataGrid"
                  Grid.Row="2" Grid.Column="1" BorderBrush="{DynamicResource AccentColorBrush}"
                  BorderThickness="1,0,1,1" mah:DataGridRowHelper.SelectionUnit="FullRow" SelectionMode="Single"
                  Margin="0" CanUserReorderColumns="false" GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#09000000" Style="{StaticResource SelectionRuleExpanderGridStyle}"
                  MinRowHeight="{StaticResource RowHeight}" HeadersVisibility="Column"
                  ItemsSource="{Binding ItemsCollection}"
                  SelectedItem="{Binding SelectedItem, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
          <FrameworkElement.ContextMenu>
            <ContextMenu>
              <MenuItem Header="ADD" Command="{Binding AddSelectedItemCommand}"/>
              <MenuItem Header="BUY" Command="{Binding BuySelectedItemCommand}"/>
            </ContextMenu>
          </FrameworkElement.ContextMenu>
          <DataGrid.RowStyle>
            <Style TargetType="{x:Type DataGridRow}">
            </Style>
          </DataGrid.RowStyle>
          <DataGrid.ColumnHeaderStyle>
            <Style TargetType="{x:Type DataGridColumnHeader}" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
              <Setter Property="Control.BorderBrush" Value="{DynamicResource HighlightBrush}"/>
              <Setter Property="Control.BorderThickness" Value="0,0,0,1"/>
              <Setter Property="UIElement.SnapsToDevicePixels" Value="true"/>
              <Setter Property="Control.FontSize" Value="9"/>
              <Setter Property="Control.FontWeight" Value="SemiBold"/>
              <Setter Property="Control.Padding" Value="5,2,5,2"/>
              <Setter Property="Control.Background" Value="{DynamicResource AccentColorBrush}"/>
              <Setter Property="Control.Foreground" Value="{DynamicResource IdealForegroundColorBrush}"/>
            </Style>
          </DataGrid.ColumnHeaderStyle>
          <FrameworkElement.Resources>
            <ResourceDictionary/>
          </FrameworkElement.Resources>
          <DataGrid.Columns>
            <DataGridTextColumn x:Name="NameColumn" Header="NAME" Width="*" MinWidth="100" Binding="{Binding Name}">
              <DataGridColumn.CellStyle>
                <Style TargetType="{x:Type DataGridCell}" BasedOn="{StaticResource {x:Type DataGridCell}}">
                  <Setter Property="Control.Padding" Value="5,0"/>
                  <Setter Property="ContentControl.ContentTemplate">
                    <Setter.Value>
                      <DataTemplate>
                        <StackPanel IsHitTestVisible="false" Orientation="Horizontal">
                          <TextBlock Margin="0,0" VerticalAlignment="Center" Text="{Binding Name}"
                                     Visibility="{Binding Converter={StaticResource InvertedElementProficiencyValueConvereter}}"/>
                          <TextBlock Margin="0,0" VerticalAlignment="Center" FontStyle="Italic" FontWeight="SemiBold"
                                     Text="{Binding Name}"
                                     Visibility="{Binding Converter={StaticResource ElementProficiencyValueConvereter}}"/>
                        </StackPanel>
                      </DataTemplate>
                    </Setter.Value>
                  </Setter>
                </Style>
              </DataGridColumn.CellStyle>
            </DataGridTextColumn>
            <DataGridTextColumn x:Name="ItemPriceColumn" Header="PRICE"
                                HeaderStyle="{StaticResource EquipmentDataGridColumnHeaderStyle}" MinWidth="60"
                                Binding="{Binding DisplayPrice}">
              <DataGridColumn.CellStyle>
                <Style TargetType="{x:Type DataGridCell}" BasedOn="{StaticResource {x:Type DataGridCell}}">
                  <Setter Property="Control.Padding" Value="5,0"/>
                  <Setter Property="ContentControl.ContentTemplate">
                    <Setter.Value>
                      <DataTemplate>
                        <TextBlock Opacity="0.8" VerticalAlignment="Center" HorizontalAlignment="Center" Text="{Binding DisplayPrice}"/>
                      </DataTemplate>
                    </Setter.Value>
                  </Setter>
                </Style>
              </DataGridColumn.CellStyle>
            </DataGridTextColumn>
            <DataGridTextColumn x:Name="ItemWeightColumn" Header="WEIGHT" MinWidth="50"
                                HeaderStyle="{StaticResource EquipmentDataGridColumnHeaderStyle}"
                                Binding="{Binding CalculatableWeight}">
              <DataGridColumn.CellStyle>
