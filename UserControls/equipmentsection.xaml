              <Button ToolTip="Move Item Up" Command="{Binding MoveSelectedEquipmentItemUpCommand}">
                <StackPanel Orientation="Horizontal">
                  <iconPacks:PackIconFontAwesome Kind="ArrowAltCircleUpRegular"/>
                </StackPanel>
              </Button>
              <Button ToolTip="Move Item Down" Margin="0,0,10,0" Command="{Binding MoveSelectedEquipmentItemDownCommand}">
                <StackPanel Orientation="Horizontal">
                  <iconPacks:PackIconFontAwesome Kind="ArrowAltCircleDownRegular"/>
                </StackPanel>
              </Button>
              <Button ToolTip="Delete the selected item." Command="{Binding DeleteSelectedEquipmentCommand}">
                <StackPanel Orientation="Horizontal">
                  <iconPacks:PackIconFontAwesome Kind="TrashAltRegular" Margin="0,0,0,0"/>
                </StackPanel>
              </Button>
              <Button ToolTip="Delete the full amount of the selected item at once."
                      Command="{Binding DeleteAllSelectedEquipmentCommand}">
                <StackPanel Orientation="Horizontal">
                  <iconPacks:PackIconFontAwesome Kind="TrashAltRegular" Margin="0,0,4,0"/>
                  <TextBlock Text="ALL" FontSize="10" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>
