<UserControl x:Class="Builder.Presentation.UserControls.SelectionRuleComboBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:viewModels="clr-namespace:Builder.Presentation.ViewModels"
             xmlns:converters="clr-namespace:Builder.Presentation.Converters"
             xmlns:extensions="clr-namespace:Builder.Presentation.Extensions"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:controls="clr-namespace:Aurora.Presentation.Controls;assembly=Aurora.Presentation"
             IsEnabled="{Binding IsEnabled}">
  <FrameworkElement.DataContext>
    <viewModels:SelectionRuleComboBoxViewModel/>
  </FrameworkElement.DataContext>
  <FrameworkElement.Resources>
    <ResourceDictionary/>
  </FrameworkElement.Resources>
  <Grid Margin="0">
    <StackPanel>
      <StackPanel Orientation="Horizontal">
        <TextBlock x:Name="VisualFocusQue" Style="{StaticResource FieldHeaderTextBlockStyle}"
                   Text="{Binding Header, Converter={StaticResource UpperCaseConverter}}">
          <FrameworkElement.Triggers>
            <EventTrigger RoutedEvent="TextBlock.RequestBringIntoView">
              <BeginStoryboard>
                <Storyboard>
                  <ColorAnimation To="Goldenrod" Storyboard.TargetName="VisualFocusQue"
                                  Storyboard.TargetProperty="(Foreground).(SolidColorBrush.Color)" AutoReverse="true"
                                  Duration="0:0:0.75" RepeatBehavior="3x"/>
                </Storyboard>
              </BeginStoryboard>
            </EventTrigger>
          </FrameworkElement.Triggers>
        </TextBlock>
        <TextBlock Text="" FontFamily="Segoe UI Symbol" Style="{StaticResource FieldHeaderTextBlockStyle}"
                   Foreground="{DynamicResource NewNotificationIndicatorForegroundColorBrush}" Margin="5,10,0,0"
                   Visibility="{Binding ElementRegistered, Converter={StaticResource BooleanToVisibilityConverter}}"/>
      </StackPanel>
      <Grid>
        <ComboBox Height="28" ItemsSource="{Binding SelectionElementsCollection}"
                  SelectedItem="{Binding SelectedSelectionElement, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                  Text="{Binding SelectedSelectionElement.Element.Name, Mode=OneWay}">
          <ItemsControl.ItemContainerStyle>
            <Style TargetType="{x:Type ComboBoxItem}" BasedOn="{StaticResource {x:Type ComboBoxItem}}">
              <Setter Property="Control.HorizontalContentAlignment" Value="Stretch"/>
            </Style>
          </ItemsControl.ItemContainerStyle>
          <ItemsControl.ItemTemplateSelector>
            <extensions:ComboBoxItemTemplateSelector>
              <extensions:ComboBoxItemTemplateSelector.ItemTemplate>
                <DataTemplate>
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding DisplayName}"/>
                    <TextBlock Grid.Column="1" HorizontalAlignment="Right" Text="{Binding DisplaySource}"/>
                  </Grid>
                </DataTemplate>
              </extensions:ComboBoxItemTemplateSelector.ItemTemplate>
              <extensions:ComboBoxItemTemplateSelector.SelectedItemTemplate>
                <DataTemplate>
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Margin="0,0,0,0" Text="{Binding DisplayName}"/>
                  </Grid>
                </DataTemplate>
              </extensions:ComboBoxItemTemplateSelector.SelectedItemTemplate>
            </extensions:ComboBoxItemTemplateSelector>
          </ItemsControl.ItemTemplateSelector>
        </ComboBox>
      </Grid>
    </StackPanel>
    <controls:CommandButton HorizontalAlignment="Right" Margin="0,0,2,30" VerticalAlignment="Bottom" ToolTip="Remove Selection"
                            Style="{StaticResource DangerIconCommandButtonStyle}"
                            Visibility="{Binding ElementRegistered, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Command="{Binding UnregisterElementCommand}">
      <iconPacks:FontAwesome Kind="MinusSolid" Height="8" Width="8"/>
    </controls:CommandButton>
  </Grid>
</UserControl>