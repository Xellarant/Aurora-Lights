<UserControl x:Class="Builder.Presentation.UserControls.DescriptionCheckBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Builder.Presentation.UserControls"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/shared"
             x:Name="Main">
  <FrameworkElement.Resources>
    <mah:ToUpperConverter x:Key="UpperCaseConverter"/>
  </FrameworkElement.Resources>
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="31*"/>
      <RowDefinition Height="12*"/>
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="24"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>
    <CheckBox FontSize="11" Foreground="{DynamicResource PrimaryTextBrush}" FontFamily="Segoe UI SemiBold"
              VerticalAlignment="Top" Grid.ColumnSpan="2" Margin="0,0,0,0"
              Content="{Binding Header, ElementName=Main, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource UpperCaseConverter}}"
              IsChecked="{Binding IsChecked, ElementName=Main, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
    <StackPanel Grid.Column="1" Grid.Row="1" Grid.RowSpan="1">
      <TextBlock Style="{StaticResource SectionSubHeaderTextBlockStyle}" Margin="0,0,0,0"
                 Text="{Binding Description, ElementName=Main, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
    </StackPanel>
  </Grid>
</UserControl>