<UserControl x:Class="Builder.Presentation.UserControls.SpellcastingExpanderContent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:viewModels="clr-namespace:Builder.Presentation.ViewModels"
             xmlns:content="clr-namespace:Builder.Presentation.ViewModels.Content"
             xmlns:userControls="clr-namespace:Builder.Presentation.UserControls"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:system="clr-namespace:System;assembly=mscorlib"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:converters="clr-namespace:Builder.Presentation.Converters"
             Padding="0,0,0,0" IsEnabled="{Binding HasSelectionRules}">
  <FrameworkElement.Resources>
    <Style x:Key="HeaderTextBlockStyle" TargetType="{x:Type TextBlock}">
      <Setter Property="FrameworkElement.VerticalAlignment" Value="Center"/>
      <Setter Property="TextBlock.FontWeight" Value="SemiBold"/>
      <Setter Property="TextBlock.Foreground" Value="{DynamicResource IdealForegroundColorBrush}"/>
      <Setter Property="TextBlock.Text" Value="{Binding Converter={StaticResource ToUpperConverter}}"/>
    </Style>
    <converters:IsSpellReplacedValueConverter x:Key="IsSpellReplacedValueConverter"/>
  </FrameworkElement.Resources>
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="Auto"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*" MaxHeight="190"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <Border x:Name="VisualFocusQue" BorderThickness="0" Width="4" BorderBrush="{DynamicResource GrayBrush1}"
            Margin="0,0,10,0" Background="{DynamicResource HighlightBrush}" SnapsToDevicePixels="true"
            Visibility="Collapsed" Grid.Column="0" Grid.RowSpan="4">
      <FrameworkElement.Triggers>
        <EventTrigger RoutedEvent="Border.RequestBringIntoView">
          <BeginStoryboard>
            <Storyboard>
              <DoubleAnimation From="1" To="0" AutoReverse="true" Duration="0:0:0.75" Storyboard.TargetName="VisualFocusQue"
                               Storyboard.TargetProperty="Opacity" RepeatBehavior="3x"/>
            </Storyboard>
          </BeginStoryboard>
        </EventTrigger>
      </FrameworkElement.Triggers>
    </Border>
    <DataGrid KeyDown="ElementsGridKeyDown" MouseDoubleClick="ElementsGridMouseDoubleClick"
              x:Name="SelectionElementsDataGrid" Grid.Row="1" Grid.Column="1"
              BorderBrush="{DynamicResource AccentColorBrush}" BorderThickness="1,0,1,1"
              SnapsToDevicePixels="true" mah:DataGridRowHelper.SelectionUnit="FullRow" SelectionMode="Single"
              GridLinesVisibility="Horizontal" Margin="0" CanUserReorderColumns="false"
              HorizontalGridLinesBrush="#07000000" Style="{StaticResource SelectionRuleExpanderGridStyle}"
              MinRowHeight="21" HeadersVisibility="Column" IsEnabled="{Binding HasSelectionRules}"
              ItemsSource="{Binding SelectionElementsCollection}"
              SelectedItem="{Binding SelectedSelectionElement, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
      <DataGrid.ColumnHeaderStyle>
        <Style TargetType="{x:Type DataGridColumnHeader}" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
          <Setter Property="Control.BorderBrush" Value="{DynamicResource HighlightBrush}"/>
          <Setter Property="Control.BorderThickness" Value="0,0,0,1"/>
          <Setter Property="UIElement.SnapsToDevicePixels" Value="true"/>
          <Setter Property="Control.FontSize" Value="9"/>
          <Setter Property="Control.FontWeight" Value="SemiBold"/>
          <Setter Property="Control.Padding" Value="5,2,5,2"/>
          <Setter Property="Control.Background" Value="{DynamicResource AccentColorBrush}"/>
          <Setter Property="Control.Foreground" Value="{DynamicResource GrayBrush2}"/>
        </Style>
      </DataGrid.ColumnHeaderStyle>
      <DataGrid.Columns>
        <DataGridTextColumn x:Name="registeredColumn" Header="" Width="Auto" Binding="{Binding DisplayPrerequisites}">
          <DataGridColumn.HeaderStyle>
            <Style TargetType="{x:Type DataGridColumnHeader}" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
              <Setter Property="Control.HorizontalContentAlignment" Value="Center"/>
              <Setter Property="Control.FontSize" Value="9"/>
              <Setter Property="Control.FontWeight" Value="SemiBold"/>
              <Setter Property="Control.Padding" Value="3,2,3,2"/>
              <Setter Property="Control.Background" Value="{DynamicResource AccentColorBrush}"/>
              <Setter Property="Control.Foreground" Value="{DynamicResource GrayBrush2}"/>
            </Style>
          </DataGridColumn.HeaderStyle>
          <DataGridColumn.CellStyle>
            <Style TargetType="{x:Type DataGridCell}" BasedOn="{StaticResource {x:Type DataGridCell}}">
              <Setter Property="Control.Padding" Value="5,0"/>
              <Setter Property="ContentControl.ContentTemplate">
                <Setter.Value>
                  <DataTemplate>
                    <Grid>
                      <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Foreground="{DynamicResource SuccessColorBrush}" Padding="0" Opacity="1" Text=""
                                   FontFamily="Segoe UI Symbol" Margin="0,0" VerticalAlignment="Center"
                                   Visibility="{Binding IsChosen, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                      </StackPanel>
                    </Grid>
                  </DataTemplate>
                </Setter.Value>
              </Setter>
            </Style>
          </DataGridColumn.CellStyle>
        </DataGridTextColumn>
        <DataGridTextColumn x:Name="NameColumn" Header="NAME" Width="*" MinWidth="200" Binding="{Binding DisplayName}">
          <DataGridColumn.CellStyle>
            <Style TargetType="{x:Type DataGridCell}" BasedOn="{StaticResource {x:Type DataGridCell}}">
              <Setter Property="Control.Padding" Value="5,0"/>
              <Setter Property="ContentControl.ContentTemplate">
                <Setter.Value>
                  <DataTemplate>
                    <StackPanel IsHitTestVisible="false" Orientation="Horizontal">
                      <TextBlock Margin="0,0" VerticalAlignment="Center"
                                 Foreground="{DynamicResource DragonHeadForegroundColorBrush}" Text="{Binding DisplayName}"
                                 Visibility="{Binding IsEnabled, Converter={StaticResource InvertedBooleanToVisibilityConverter}}"/>
                      <TextBlock Margin="0,0" VerticalAlignment="Center" Text="{Binding DisplayName}"
                                 Visibility="{Binding IsEnabled, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </StackPanel>
                  </DataTemplate>
                </Setter.Value>
              </Setter>
            </Style>
          </DataGridColumn.CellStyle>
        </DataGridTextColumn>
        <DataGridTextColumn x:Name="ShortDescriptionColumn" Header="LEVEL &amp; SCHOOL" Width="*" MinWidth="200"
                            Binding="{Binding DisplayShortDescription}">
          <DataGridColumn.CellStyle>
            <Style TargetType="{x:Type DataGridCell}" BasedOn="{StaticResource {x:Type DataGridCell}}">
              <Setter Property="Control.Padding" Value="5,0"/>
              <Setter Property="ContentControl.ContentTemplate">
                <Setter.Value>
                  <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                      <TextBlock FontStyle="Italic" Margin="0,0" VerticalAlignment="Center" Text="{Binding DisplayShortDescription}"/>
                    </StackPanel>
                  </DataTemplate>
                </Setter.Value>
              </Setter>
            </Style>
          </DataGridColumn.CellStyle>
        </DataGridTextColumn>
        <DataGridTextColumn x:Name="verbal" Header="VERBAL" Width="75" Binding="{Binding DisplayPrerequisites}">
          <DataGridColumn.HeaderStyle>
            <Style TargetType="{x:Type DataGridColumnHeader}" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
              <Setter Property="Control.HorizontalContentAlignment" Value="Center"/>
              <Setter Property="Control.FontSize" Value="9"/>
              <Setter Property="Control.FontWeight" Value="SemiBold"/>
              <Setter Property="Control.Padding" Value="5,2,5,2"/>
              <Setter Property="Control.Background" Value="{DynamicResource AccentColorBrush}"/>
              <Setter Property="Control.Foreground" Value="{DynamicResource GrayBrush2}"/>
            </Style>
          </DataGridColumn.HeaderStyle>
          <DataGridColumn.CellStyle>
            <Style TargetType="{x:Type DataGridCell}" BasedOn="{StaticResource {x:Type DataGridCell}}">
              <Setter Property="Control.Padding" Value="5,0"/>
              <Setter Property="ContentControl.ContentTemplate">
                <Setter.Value>
                  <DataTemplate>
                    <Grid>
                      <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Opacity="0.8" Text="" FontFamily="Segoe UI Symbol" Margin="0,0" VerticalAlignment="Center"
                                   Visibility="{Binding Element.HasVerbalComponent, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                      </StackPanel>
                    </Grid>
                  </DataTemplate>
                </Setter.Value>
              </Setter>
            </Style>
          </DataGridColumn.CellStyle>
        </DataGridTextColumn>
        <DataGridTextColumn x:Name="somatic" Header="SOMATIC" Width="75" Binding="{Binding DisplayPrerequisites}">
          <DataGridColumn.HeaderStyle>
            <Style TargetType="{x:Type DataGridColumnHeader}" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
              <Setter Property="Control.HorizontalContentAlignment" Value="Center"/>
              <Setter Property="Control.FontSize" Value="9"/>
              <Setter Property="Control.FontWeight" Value="SemiBold"/>
              <Setter Property="Control.Padding" Value="5,2,5,2"/>
              <Setter Property="Control.Background" Value="{DynamicResource AccentColorBrush}"/>
              <Setter Property="Control.Foreground" Value="{DynamicResource GrayBrush2}"/>
            </Style>
          </DataGridColumn.HeaderStyle>
          <DataGridColumn.CellStyle>
            <Style TargetType="{x:Type DataGridCell}" BasedOn="{StaticResource {x:Type DataGridCell}}">
              <Setter Property="Control.Padding" Value="5,0"/>
              <Setter Property="ContentControl.ContentTemplate">
                <Setter.Value>
                  <DataTemplate>
                    <Grid>
                      <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Opacity="0.8" Text="" FontFamily="Segoe UI Symbol" Margin="0,0" VerticalAlignment="Center"
                                   Visibility="{Binding Element.HasSomaticComponent, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                      </StackPanel>
                    </Grid>
                  </DataTemplate>
                </Setter.Value>
              </Setter>
            </Style>
          </DataGridColumn.CellStyle>
        </DataGridTextColumn>
        <DataGridTextColumn x:Name="material" Header="MATERIAL" Width="75" Binding="{Binding DisplayPrerequisites}">
          <DataGridColumn.HeaderStyle>
            <Style TargetType="{x:Type DataGridColumnHeader}" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
              <Setter Property="Control.HorizontalContentAlignment" Value="Center"/>
              <Setter Property="Control.FontSize" Value="9"/>
              <Setter Property="Control.FontWeight" Value="SemiBold"/>
              <Setter Property="Control.Padding" Value="5,2,5,2"/>
              <Setter Property="Control.Background" Value="{DynamicResource AccentColorBrush}"/>
              <Setter Property="Control.Foreground" Value="{DynamicResource GrayBrush2}"/>
            </Style>
          </DataGridColumn.HeaderStyle>
          <DataGridColumn.CellStyle>
            <Style TargetType="{x:Type DataGridCell}" BasedOn="{StaticResource {x:Type DataGridCell}}">
              <Setter Property="Control.Padding" Value="5,0"/>
              <Setter Property="ContentControl.ContentTemplate">
                <Setter.Value>
                  <DataTemplate>
                    <Grid>
                      <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Opacity="0.8" Text="" FontFamily="Segoe UI Symbol" Margin="0,0" VerticalAlignment="Center"
                                   Visibility="{Binding Element.HasMaterialComponent, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                      </StackPanel>
                    </Grid>
                  </DataTemplate>
                </Setter.Value>
              </Setter>
            </Style>
          </DataGridColumn.CellStyle>
        </DataGridTextColumn>
        <DataGridTextColumn x:Name="SourceColumn" Header="SOURCE" Width="*" MinWidth="180" Binding="{Binding DisplaySource}">
          <DataGridColumn.HeaderStyle>
            <Style TargetType="{x:Type DataGridColumnHeader}" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
              <Setter Property="Control.HorizontalContentAlignment" Value="Right"/>
              <Setter Property="Control.FontSize" Value="9"/>
              <Setter Property="Control.FontWeight" Value="SemiBold"/>
              <Setter Property="Control.Padding" Value="5,2,5,2"/>
              <Setter Property="Control.Background" Value="{DynamicResource AccentColorBrush}"/>
              <Setter Property="Control.Foreground" Value="{DynamicResource GrayBrush2}"/>
            </Style>
          </DataGridColumn.HeaderStyle>
          <DataGridColumn.CellStyle>
            <Style TargetType="{x:Type DataGridCell}" BasedOn="{StaticResource {x:Type DataGridCell}}">
              <Setter Property="Control.Padding" Value="5,0"/>
              <Setter Property="ContentControl.ContentTemplate">
                <Setter.Value>
                  <DataTemplate>
                    <TextBlock Margin="0,0" VerticalAlignment="Center" HorizontalAlignment="Right" Text="{Binding DisplaySource}"/>
                  </DataTemplate>
                </Setter.Value>
              </Setter>
            </Style>
          </DataGridColumn.CellStyle>
        </DataGridTextColumn>
      </DataGrid.Columns>
    </DataGrid>
    <Border Background="{DynamicResource HighlightBrush}" BorderThickness="1,1,1,1"
            BorderBrush="{DynamicResource AccentColorBrush}" Margin="0,0,0,0" Grid.Row="0" Grid.Column="1">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBlock Style="{StaticResource HeaderTextBlockStyle}" Margin="5,4,0,5"
                   Text="{Binding InformationHeader.Header, Converter={StaticResource UpperCaseConverter}}"/>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,1">
          <FrameworkElement.Resources>
            <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource HeaderTextBlockStyle}">
              <Setter Property="TextBlock.FontWeight" Value="Normal"/>
              <Setter Property="TextBlock.FontSize" Value="10"/>
              <Setter Property="TextBlock.Foreground" Value="{DynamicResource GrayBrush6}"/>
              <Setter Property="FrameworkElement.Margin" Value="0,0,15,0"/>
            </Style>
          </FrameworkElement.Resources>
          <TextBlock FontWeight="SemiBold" Text="ABILITY:" Margin="0,0,5,0"/>
          <TextBlock ToolTip="The ability used to cast the spell." Foreground="{DynamicResource AuroraGoldColorBrush}"
                     Text="{Binding InformationHeader.SpellcastingAbilityName, Converter={StaticResource UpperCaseConverter}}"/>
          <TextBlock FontWeight="SemiBold" Text="ATTACK MODIFIER:" Margin="0,0,5,0"/>
          <TextBlock ToolTip="Spellcasting attack modifier" Foreground="{DynamicResource AuroraGoldColorBrush}"
                     Text="{Binding InformationHeader.SpellAttackModifier, Converter={StaticResource UpperCaseConverter}, StringFormat=+{0}}"/>
          <TextBlock FontWeight="SemiBold" Text="SAVE DC:" Margin="0,0,5,0"/>
          <TextBlock ToolTip="Spellcasting save DC" Foreground="{DynamicResource AuroraGoldColorBrush}"
                     Text="{Binding InformationHeader.SpellSaveDc, Converter={StaticResource UpperCaseConverter}}"/>
        </StackPanel>
        <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,0,1">
          <FrameworkElement.Resources>
            <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource HeaderTextBlockStyle}">
              <Setter Property="TextBlock.FontWeight" Value="SemiBold"/>
              <Setter Property="TextBlock.FontSize" Value="10"/>
              <Setter Property="FrameworkElement.Margin" Value="0,0,4,0"/>
              <Setter Property="TextBlock.Foreground" Value="{DynamicResource AuroraGoldColorBrush}"/>
              <Style.Triggers>
                <Trigger Property="TextBlock.Text" Value="0">
                  <Setter Property="UIElement.Opacity" Value="0.25"/>
                  <Setter Property="TextBlock.FontWeight" Value="Normal"/>
                  <Setter Property="TextBlock.Foreground" Value="{DynamicResource GrayBrush6}"/>
                </Trigger>
              </Style.Triggers>
            </Style>
          </FrameworkElement.Resources>
          <TextBlock Text="SPELL SLOTS:" FontWeight="SemiBold" Margin="0,0,5,0"
                     Foreground="{DynamicResource GrayBrush6}"/>
          <TextBlock ToolTip="1st-level spell slots" Text="{Binding InformationHeader.Slot1}"/>
          <TextBlock ToolTip="2nd-level spell slots" Text="{Binding InformationHeader.Slot2}"/>
          <TextBlock ToolTip="3rd-level spell slots" Text="{Binding InformationHeader.Slot3}"/>
          <TextBlock ToolTip="4th-level spell slots" Text="{Binding InformationHeader.Slot4}"/>
          <TextBlock ToolTip="5th-level spell slots" Text="{Binding InformationHeader.Slot5}"/>
          <TextBlock ToolTip="6th-level spell slots" Text="{Binding InformationHeader.Slot6}"/>
          <TextBlock ToolTip="7th-level spell slots" Text="{Binding InformationHeader.Slot7}"/>
          <TextBlock ToolTip="8th-level spell slots" Text="{Binding InformationHeader.Slot8}"/>
          <TextBlock ToolTip="9th-level spell slots" Margin="0,0,8,0" Text="{Binding InformationHeader.Slot9}"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Grid.Column="3" Margin="0,0,0,1">
          <FrameworkElement.Resources>
            <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource HeaderTextBlockStyle}">
              <Setter Property="TextBlock.FontWeight" Value="Normal"/>
              <Setter Property="TextBlock.FontSize" Value="10"/>
              <Setter Property="FrameworkElement.Margin" Value="0,0,4,0"/>
              <Setter Property="TextBlock.Foreground" Value="{DynamicResource GrayBrush6}"/>
            </Style>
          </FrameworkElement.Resources>
          <StackPanel Margin="7,0,4,0" Orientation="Horizontal"
                      Visibility="{Binding FilterNotification.IsActive, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Text="" Foreground="{DynamicResource AuroraGoldColorBrush}" FontSize="11"
                       FontFamily="Segoe UI Symbol"/>
            <TextBlock FontWeight="SemiBold" Text="FILTER:" Foreground="{DynamicResource GrayBrush6}"/>
            <TextBlock Foreground="{DynamicResource AuroraGoldColorBrush}" Margin="0,0,0,0"
                       Text="{Binding FilteredElementsCount}"/>
            <TextBlock Text="/" Margin="2,0" Foreground="{DynamicResource GrayBrush6}"/>
            <TextBlock Foreground="{DynamicResource GrayBrush6}" Text="{Binding SelectionElementsCount}"/>
          </StackPanel>
          <TextBlock Text="" Foreground="{DynamicResource DragonHeadForegroundColorBrush}" FontSize="14"
                     FontFamily="Segoe UI Symbol" Margin="7,0" Padding="0,0"
                     Visibility="{Binding Notification.IsActive, Converter={StaticResource BooleanToVisibilityConverter}}">
            <FrameworkElement.ToolTip>
              <StackPanel MaxWidth="300">
                <TextBlock Padding="5" Text="{Binding Notification.Title}"/>
                <TextBlock Padding="5" TextWrapping="Wrap" Text="{Binding Notification.Message}"/>
              </StackPanel>
            </FrameworkElement.ToolTip>
          </TextBlock>
        </StackPanel>
      </Grid>
    </Border>
    <Grid Row="2" Margin="0,5,0,0" Column="1" IsEnabled="{Binding HasSelectionRules}">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition MinWidth="100" Width="*"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <FrameworkElement.Resources>
        <Style TargetType="{x:Type ToggleButton}" BasedOn="{StaticResource MetroFlatToggleButton}">
          <Setter Property="FrameworkElement.Margin" Value="0,0,2,0"/>
          <Setter Property="Control.FontWeight" Value="SemiBold"/>
          <Setter Property="Control.FontSize" Value="10"/>
          <Style.Triggers>
            <Trigger Property="ToggleButton.IsChecked" Value="True"/>
            <Trigger Property="ToggleButton.IsChecked" Value="False">
              <Setter Property="UIElement.Opacity" Value=".75"/>
            </Trigger>
          </Style.Triggers>
        </Style>
      </FrameworkElement.Resources>
      <ToggleButton Grid.Row="1" Margin="0,0,5,0" Padding="0,0" Width="26" Content="" FontFamily="Segoe UI Symbol"
                    FontSize="13" FontWeight="Normal"
                    ToolTip="You can pin the filter so it will apply directly when changing selection. The number of items filtered from the available list is show in the spellcasting information bar."
                    IsChecked="{Binding SpellcastingFilter.IsLocked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
      <TextBox MinWidth="100" ToolTip="Part of the name of the spell."
               mah:TextBoxHelper.Watermark="filter name and keywords..." Grid.Column="1" Margin="0,0,0,0"
               Grid.Row="1"
               Text="{Binding SpellcastingFilter.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
      <ComboBox MinWidth="100" Grid.Column="2" IsTextSearchEnabled="true" Margin="10,0,0,0" Grid.Row="1"
                Visibility="{Binding SpellcastingFilter.IsSchoolFilterAvailable, Converter={StaticResource BooleanToVisibilityConverter}}"
                ItemsSource="{Binding SpellcastingFilter.SchoolCollection}"
                SelectedItem="{Binding SpellcastingFilter.School, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
      <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="10,0,0,0" Grid.Row="1">
        <ToggleButton Width="26" Padding="6,2" Content="0" ToolTip="Cantrips"
                      IsChecked="{Binding SpellcastingFilter.IncludeCantrips, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
        <ToggleButton Width="26" Padding="8,2" Content="1" ToolTip="1st-level spells"
                      IsChecked="{Binding SpellcastingFilter.Include1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
        <ToggleButton Width="26" Padding="8,2" Content="2" ToolTip="2nd-level spells"
                      IsChecked="{Binding SpellcastingFilter.Include2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
        <ToggleButton Width="26" Padding="8,2" Content="3" ToolTip="3rd-level spells"
                      IsChecked="{Binding SpellcastingFilter.Include3, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
        <ToggleButton Width="26" Padding="8,2" Content="4" ToolTip="4th-level spells"
                      IsChecked="{Binding SpellcastingFilter.Include4, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
        <ToggleButton Width="26" Padding="8,2" Content="5" ToolTip="5th-level spells"
                      IsChecked="{Binding SpellcastingFilter.Include5, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
        <ToggleButton Width="26" Padding="8,2" Content="6" ToolTip="6th-level spells"
                      IsChecked="{Binding SpellcastingFilter.Include6, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
        <ToggleButton Width="26" Padding="8,2" Content="7" ToolTip="7th-level spells"
                      IsChecked="{Binding SpellcastingFilter.Include7, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
        <ToggleButton Width="26" Padding="8,2" Content="8" ToolTip="8th-level spells"
                      IsChecked="{Binding SpellcastingFilter.Include8, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
        <ToggleButton Width="26" Padding="8,2" Content="9" ToolTip="9th-level spells" Margin="0"
                      IsChecked="{Binding SpellcastingFilter.Include9, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
      </StackPanel>
      <StackPanel Grid.Column="4" Orientation="Horizontal" Margin="10,0,0,0" Grid.Row="1">
        <ToggleButton Padding="6,2" Content="RITUAL" ToolTip="Can be cast as a ritual" Margin="0,0,10,0"
                      IsChecked="{Binding SpellcastingFilter.IsRitual, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
        <ToggleButton Padding="6,2" Content="CONCENTRATION" ToolTip="Requires concentration" Margin="0"
                      IsChecked="{Binding SpellcastingFilter.IsConcentration, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
      </StackPanel>
      <ComboBox MinWidth="150" Margin="10,0,0,0" Grid.Column="6" Grid.Row="1"
                Visibility="{Binding SpellcastingFilter.IsSourceFilterAvailable, Converter={StaticResource BooleanToVisibilityConverter}}"
                ItemsSource="{Binding SpellcastingFilter.SourceCollection}"
                SelectedItem="{Binding SpellcastingFilter.Source, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
    </Grid>
    <Grid Row="3" Column="1" Margin="0,20,0,0">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>
      <Border Background="{DynamicResource HighlightBrush}" BorderThickness="1,1,1,1"
              BorderBrush="{DynamicResource AccentColorBrush}">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <TextBlock Text="SELECTIONS" Style="{StaticResource HeaderTextBlockStyle}" Margin="5,4,0,5"/>
          <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,1">
            <FrameworkElement.Resources>
              <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource HeaderTextBlockStyle}">
                <Setter Property="TextBlock.FontWeight" Value="Normal"/>
                <Setter Property="TextBlock.FontSize" Value="10"/>
                <Setter Property="TextBlock.Foreground" Value="{DynamicResource GrayBrush6}"/>
                <Setter Property="FrameworkElement.Margin" Value="0,0,10,0"/>
              </Style>
            </FrameworkElement.Resources>
            <TextBlock FontWeight="SemiBold" Text="AVAILABLE:" Margin="0,0,5,0"/>
            <TextBlock Foreground="{DynamicResource AuroraGoldColorBrush}" Margin="0,0,0,0"
                       Text="{Binding RequiredSelectionCount}"/>
            <TextBlock Text="/" Margin="2,0"/>
            <TextBlock Text="{Binding SelectionCount}"/>
          </StackPanel>
          <Button Margin="10,0,8,0" Grid.Column="3" Style="{StaticResource LightChromelessButtonStyle}"
                  Command="{Binding RetrainSelectionRuleCommand}"
                  Visibility="{Binding AllowRetrainSelectedSpell, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal">
              <iconPacks:PackIconMaterial Kind="LibraryPlus" Margin="0,0,4,0" Height="15"/>
              <TextBlock Text="REPLACE SPELL" FontSize="10" Margin="0,1,0,0" FontWeight="SemiBold"/>
            </StackPanel>
          </Button>
        </Grid>
      </Border>
      <DataGrid SelectionChanged="SelectionPickerGrid_OnSelectionChanged" KeyDown="SelectionsGridKeyDown"
                PreviewKeyDown="SelectionsGridPreviewKeyDown" x:Name="SelectionPickerGrid" Grid.Row="1"
                Grid.Column="0" BorderBrush="{DynamicResource AccentColorBrush}" BorderThickness="1,0,1,1"
                SnapsToDevicePixels="true" SelectionMode="Single" GridLinesVisibility="Horizontal" Margin="0"
                CanUserReorderColumns="false" VirtualizingPanel.IsVirtualizing="false"
                HorizontalGridLinesBrush="#07000000" Style="{StaticResource SelectionRuleExpanderGridStyle}"
                MinRowHeight="21" HeadersVisibility="Column" ItemsSource="{Binding Expanders}"
                IsEnabled="{Binding HasSelectionRules}"
                SelectedItem="{Binding SelectedExpander, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
        <DataGrid.ColumnHeaderStyle>
          <Style TargetType="{x:Type DataGridColumnHeader}" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
            <Setter Property="Control.BorderBrush" Value="{DynamicResource HighlightBrush}"/>
            <Setter Property="Control.BorderThickness" Value="0,0,0,1"/>
            <Setter Property="UIElement.SnapsToDevicePixels" Value="true"/>
            <Setter Property="Control.FontSize" Value="9"/>
            <Setter Property="Control.FontWeight" Value="SemiBold"/>
            <Setter Property="Control.Padding" Value="5,2,5,2"/>
            <Setter Property="Control.Background" Value="{DynamicResource AccentColorBrush}"/>
            <Setter Property="Control.Foreground" Value="{DynamicResource GrayBrush2}"/>
          </Style>
        </DataGrid.ColumnHeaderStyle>
        <DataGrid.Columns>
          <DataGridTextColumn x:Name="registeredColumn2" Header="" Width="Auto" Binding="{Binding DisplayPrerequisites}">
            <DataGridColumn.HeaderStyle>
              <Style TargetType="{x:Type DataGridColumnHeader}" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                <Setter Property="Control.HorizontalContentAlignment" Value="Center"/>
                <Setter Property="Control.FontSize" Value="9"/>
                <Setter Property="Control.FontWeight" Value="SemiBold"/>
                <Setter Property="Control.Padding" Value="3,2,3,2"/>
                <Setter Property="Control.Background" Value="{DynamicResource AccentColorBrush}"/>
                <Setter Property="Control.Foreground" Value="{DynamicResource GrayBrush2}"/>
              </Style>
            </DataGridColumn.HeaderStyle>
            <DataGridColumn.CellStyle>
              <Style TargetType="{x:Type DataGridCell}" BasedOn="{StaticResource {x:Type DataGridCell}}">
                <Setter Property="Control.Padding" Value="5,0"/>
                <Setter Property="ContentControl.ContentTemplate">
                  <Setter.Value>
                    <DataTemplate>
                      <Grid>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                          <iconPacks:PackIconMaterial Kind="CheckCircle" Width="13" Height="13" Foreground="{DynamicResource SuccessColorBrush}"
                                                      Opacity="0.9"
                                                      Visibility="{Binding ViewModel.ElementRegistered, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </StackPanel>
                      </Grid>
                    </DataTemplate>
                  </Setter.Value>
                </Setter>
              </Style>
            </DataGridColumn.CellStyle>
          </DataGridTextColumn>
          <DataGridTextColumn Header="NAME" Width="*" Binding="{Binding SelectionRule.Attributes.Name}">
            <DataGridColumn.CellStyle>
              <Style TargetType="{x:Type DataGridCell}" BasedOn="{StaticResource {x:Type DataGridCell}}">
                <Setter Property="Control.Padding" Value="5,0"/>
                <Setter Property="ContentControl.ContentTemplate">
                  <Setter.Value>
                    <DataTemplate>
                      <StackPanel Orientation="Horizontal">
                        <TextBlock Margin="0,0" VerticalAlignment="Center" Text="{Binding SelectionRule.Attributes.Name}"/>
                      </StackPanel>
                    </DataTemplate>
                  </Setter.Value>
                </Setter>
                <Style.Triggers>
                  <Trigger Property="ContentControl.Content" Value="">
                    <Setter Property="Control.Background" Value="Red"/>
                  </Trigger>
                </Style.Triggers>
              </Style>
            </DataGridColumn.CellStyle>
          </DataGridTextColumn>
          <DataGridTextColumn Header="SELECTED SPELL" Width="*" Binding="{Binding ViewModel.RegisteredElement.Name}">
            <DataGridColumn.CellStyle>
              <Style TargetType="{x:Type DataGridCell}" BasedOn="{StaticResource {x:Type DataGridCell}}">
                <Setter Property="Control.Padding" Value="5,0"/>
                <Setter Property="ContentControl.ContentTemplate">
                  <Setter.Value>
                    <DataTemplate>
                      <StackPanel Orientation="Horizontal">
                        <TextBlock FontStyle="Normal" Margin="0,0" VerticalAlignment="Center"
                                   Text="{Binding ViewModel.RegisteredElement.Name}"/>
                      </StackPanel>
                    </DataTemplate>
                  </Setter.Value>
                </Setter>
              </Style>
            </DataGridColumn.CellStyle>
          </DataGridTextColumn>
          <DataGridTextColumn Header="GAINED ON LEVEL" Width="Auto"
                              Binding="{Binding SelectionRule.Attributes.RequiredLevel, Mode=OneWay}">
            <DataGridColumn.CellStyle>
              <Style TargetType="{x:Type DataGridCell}" BasedOn="{StaticResource {x:Type DataGridCell}}">
                <Setter Property="Control.Padding" Value="5,0"/>
                <Setter Property="ContentControl.ContentTemplate">
                  <Setter.Value>
                    <DataTemplate>
                      <Grid>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                          <TextBlock Margin="0,0" VerticalAlignment="Center" Text="{Binding SelectionRule.Attributes.RequiredLevel}"/>
                        </StackPanel>
                      </Grid>
                    </DataTemplate>
                  </Setter.Value>
                </Setter>
              </Style>
            </DataGridColumn.CellStyle>
          </DataGridTextColumn>
          <DataGridTextColumn Header="REPLACED" Width="Auto" Binding="{Binding ViewModel.RetrainLevel, Mode=OneWay}">
            <DataGridColumn.CellStyle>
              <Style TargetType="{x:Type DataGridCell}" BasedOn="{StaticResource {x:Type DataGridCell}}">
                <Setter Property="Control.Padding" Value="5,0"/>
                <Setter Property="ContentControl.ContentTemplate">
                  <Setter.Value>
                    <DataTemplate>
                      <Grid>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                    Visibility="{Binding ViewModel.RetrainLevel, Converter={StaticResource IsSpellReplacedValueConverter}}">
                          <TextBlock Text="on " FontWeight="SemiBold" FontStyle="Italic" Margin="0,0" VerticalAlignment="Center"/>
                          <TextBlock FontWeight="SemiBold" FontStyle="Italic" Margin="0,0" VerticalAlignment="Center"
                                     Text="{Binding ViewModel.RetrainLevel}"/>
                        </StackPanel>
                      </Grid>
                    </DataTemplate>
                  </Setter.Value>
                </Setter>
              </Style>
            </DataGridColumn.CellStyle>
          </DataGridTextColumn>
          <DataGridTextColumn Header="SPELLCASTING SOURCE" Width="Auto" MinWidth="180"
                              Binding="{Binding SelectionRule.Attributes.SpellcastingName}">
            <DataGridColumn.HeaderStyle>
              <Style TargetType="{x:Type DataGridColumnHeader}" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                <Setter Property="Control.HorizontalContentAlignment" Value="Right"/>
                <Setter Property="Control.FontSize" Value="9"/>
                <Setter Property="Control.FontWeight" Value="SemiBold"/>
                <Setter Property="Control.Padding" Value="5,2,5,2"/>
                <Setter Property="Control.Background" Value="{DynamicResource AccentColorBrush}"/>
                <Setter Property="Control.Foreground" Value="{DynamicResource GrayBrush2}"/>
              </Style>
            </DataGridColumn.HeaderStyle>
            <DataGridColumn.CellStyle>
              <Style TargetType="{x:Type DataGridCell}" BasedOn="{StaticResource {x:Type DataGridCell}}">
                <Setter Property="Control.Padding" Value="5,0"/>
                <Setter Property="ContentControl.ContentTemplate">
                  <Setter.Value>
                    <DataTemplate>
                      <TextBlock Margin="0,0" VerticalAlignment="Center" HorizontalAlignment="Right"
                                 Text="{Binding SelectionRule.Attributes.SpellcastingName}"/>
                    </DataTemplate>
                  </Setter.Value>
                </Setter>
              </Style>
            </DataGridColumn.CellStyle>
          </DataGridTextColumn>
        </DataGrid.Columns>
      </DataGrid>
    </Grid>
  </Grid>
</UserControl>