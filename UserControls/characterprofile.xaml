<UserControl x:Class="Builder.Presentation.UserControls.CharacterProfile"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Builder.Presentation.UserControls"
             xmlns:shell="clr-namespace:Builder.Presentation.ViewModels.Shell"
             xmlns:converters="http://metro.mahapps.com/winfx/xaml/shared"
             xmlns:converters1="clr-namespace:Builder.Presentation.Converters"
             xmlns:system="clr-namespace:System;assembly=mscorlib"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks">
  <FrameworkElement.Resources>
    <converters:ToUpperConverter x:Key="UpperCaseConverter"/>
    <converters1:LocalImageSourceConverter x:Key="LocalImageSourceConverter"/>
    <system:Double x:Key="PortraitSize">45</system:Double>
  </FrameworkElement.Resources>
  <Grid>
    <Border>
      <StackPanel Orientation="Horizontal">
        <StackPanel Margin="0,0,10,0" VerticalAlignment="Center">
          <Button x:Name="CharacterNameButton" FontSize="13" HorizontalAlignment="Right" FontWeight="SemiBold"
                  Padding="0" Margin="0,0,0,0" Background="Transparent" BorderThickness="0" Foreground="#C1C1C1"
                  Content="{Binding Character.Name, Converter={StaticResource UpperCaseConverter}}">
            <FrameworkElement.Style>
              <Style TargetType="{x:Type Button}" BasedOn="{StaticResource MetroFlatButton}">
                <Style.Triggers>
                  <Trigger Property="UIElement.IsMouseOver" Value="true">
                    <TriggerBase.EnterActions>
                      <BeginStoryboard>
                        <Storyboard>
                          <DoubleAnimation From=".75" To="1" Storyboard.TargetProperty="Opacity" Duration="0:0:0.25"/>
                        </Storyboard>
                      </BeginStoryboard>
                    </TriggerBase.EnterActions>
                    <TriggerBase.ExitActions>
                      <BeginStoryboard>
                        <Storyboard>
                          <DoubleAnimation From="1" To=".75" Storyboard.TargetProperty="Opacity" Duration="0:0:0.25"/>
                        </Storyboard>
                      </BeginStoryboard>
                    </TriggerBase.ExitActions>
                  </Trigger>
                  <Trigger Property="UIElement.IsMouseOver" Value="false">
                    <Setter Property="Control.Foreground" Value="{DynamicResource DangerColorBrush}"/>
                  </Trigger>
                </Style.Triggers>
              </Style>
            </FrameworkElement.Style>
          </Button>
          <TextBlock FontSize="10" HorizontalAlignment="Right" FontWeight="Normal"
                     Foreground="{DynamicResource GrayBrush6}"
                     Text="{Binding CharacterBuild, Converter={StaticResource UpperCaseConverter}}"/>
        </StackPanel>
        <Grid Width="{StaticResource PortraitSize}" Height="{StaticResource PortraitSize}">
          <TextBlock Text="🔍" FontSize="16" Style="{StaticResource FieldHeaderCheckTextBlockStyle}"
                     HorizontalAlignment="Center" VerticalAlignment="Center" Margin="1,0,0,1"
                     Foreground="{DynamicResource PinnedCharacterIconColorBrush}"
                     Visibility="{Binding IsCharacterLoaded, Converter={StaticResource BooleanToVisibilityConverter}}"/>
          <Button x:Name="ProfileButton" Padding="0" BorderThickness="0" Margin="1" Background="#111113">
            <UIElement.OpacityMask>
              <VisualBrush Stretch="Uniform">
                <VisualBrush.Visual>
                  <Ellipse Fill="{DynamicResource BlackBrush}" Width="10" Height="10"/>
                </VisualBrush.Visual>
              </VisualBrush>
            </UIElement.OpacityMask>
            <ContentControl.Content>
              <Grid Visibility="{Binding IsCharacterLoaded, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Image HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="None"
                       RenderTransformOrigin="0.5,0.5"
                       Source="{Binding Character.PortraitFilename, Converter={StaticResource LocalImageSourceConverter}}">
                  <FrameworkElement.LayoutTransform>
                    <TransformGroup>
                      <ScaleTransform ScaleY="0.25" ScaleX="0.25"/>
                    </TransformGroup>
                  </FrameworkElement.LayoutTransform>
                </Image>
              </Grid>
            </ContentControl.Content>
            <FrameworkElement.Style>
              <Style TargetType="{x:Type Button}">
                <Style.Triggers>
                  <Trigger Property="UIElement.IsMouseOver" Value="true">
                    <TriggerBase.EnterActions>
                      <BeginStoryboard>
                        <Storyboard>
                          <DoubleAnimation From="1" To="0.25" Storyboard.TargetProperty="Opacity" Duration="0:0:0.25"/>
                        </Storyboard>
                      </BeginStoryboard>
                    </TriggerBase.EnterActions>
                    <TriggerBase.ExitActions>
                      <BeginStoryboard>
                        <Storyboard>
                          <DoubleAnimation From=".25" To="1" Storyboard.TargetProperty="Opacity" Duration="0:0:0.25"/>
                        </Storyboard>
                      </BeginStoryboard>
                    </TriggerBase.ExitActions>
                  </Trigger>
                </Style.Triggers>
              </Style>
            </FrameworkElement.Style>
          </Button>
          <Button x:Name="NewCharacterButton" Width="{StaticResource PortraitSize}"
                  Height="{StaticResource PortraitSize}" Foreground="{DynamicResource SuccessColorBrush}"
                  ToolTip="New Character" FontSize="19" FontFamily="Segoe UI Symbol" VerticalAlignment="Center"
                  HorizontalAlignment="Center" Style="{StaticResource ChromelessButtonStyle}" Padding="0,0,0,0"
                  Margin="0"
                  Visibility="{Binding IsCharacterLoaded, Converter={StaticResource InvertedBooleanToVisibilityConverter}}">
            <iconPacks:PackIconMaterial Kind="Plus" Height="21" Width="21" Margin="0,0,0,0"/>
          </Button>
          <Ellipse IsHitTestVisible="false" StrokeThickness="2" Margin="0" Stroke="{DynamicResource HighlightBrush}"
                   Width="{StaticResource PortraitSize}" Height="{StaticResource PortraitSize}">
            <UIElement.Effect>
              <DropShadowEffect BlurRadius="4" Opacity="1" ShadowDepth="1" Color="{DynamicResource AuroraBlackColor}"/>
            </UIElement.Effect>
          </Ellipse>
        </Grid>
      </StackPanel>
    </Border>
  </Grid>
</UserControl>