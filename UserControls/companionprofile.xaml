<UserControl x:Class="Builder.Presentation.UserControls.CompanionProfile"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Builder.Presentation.UserControls"
             xmlns:models="clr-namespace:Builder.Presentation.Models">
  <StackPanel x:Name="InfoStackPanel" Orientation="Horizontal">
    <StackPanel Margin="0,0,10,0" VerticalAlignment="Center">
      <TextBlock FontSize="13" HorizontalAlignment="Right" FontWeight="SemiBold"
                 Foreground="{DynamicResource GrayBrush5}"
                 Text="{Binding DisplayName, Converter={StaticResource ToUpperConverter}}"/>
      <TextBlock FontSize="10" HorizontalAlignment="Right" FontWeight="Normal"
                 Foreground="{DynamicResource GrayBrush5}"
                 Text="{Binding DisplayBuild, Converter={StaticResource ToUpperConverter}}"/>
    </StackPanel>
    <Grid>
      <Button x:Name="PortraitImage" Style="{StaticResource PortraitButtonStyle}" Margin="1"
              Background="{DynamicResource HighlightBrush}">
        <ContentControl.Content>
          <Grid>
            <Image HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="None" ToolTip="Open Quickview"
                   RenderTransformOrigin="0.5,0.5" Source="{Binding Portrait}">
              <FrameworkElement.LayoutTransform>
                <TransformGroup>
                  <ScaleTransform ScaleY="0.25" ScaleX="0.25"/>
                  <SkewTransform/>
                  <RotateTransform/>
                  <TranslateTransform/>
                </TransformGroup>
              </FrameworkElement.LayoutTransform>
            </Image>
          </Grid>
        </ContentControl.Content>
      </Button>
      <Ellipse StrokeThickness="1" Margin="0" Stroke="{DynamicResource HighlightBrush}">
        <UIElement.Effect>
          <DropShadowEffect BlurRadius="3" Opacity="1" ShadowDepth="1"/>
        </UIElement.Effect>
      </Ellipse>
    </Grid>
  </StackPanel>
</UserControl>