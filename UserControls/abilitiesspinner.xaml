<UserControl x:Class="Builder.Presentation.UserControls.AbilitiesSpinner"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Builder.Presentation.UserControls"
             xmlns:models="clr-namespace:Builder.Presentation.Models"
             Width="110">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="24"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="34"/>
    </Grid.RowDefinitions>
    <FrameworkElement.Resources>
      <Style TargetType="{x:Type TextBlock}">
        <Setter Property="FrameworkElement.HorizontalAlignment" Value="Center"/>
        <Setter Property="FrameworkElement.VerticalAlignment" Value="Center"/>
        <Setter Property="TextBlock.Foreground" Value="{DynamicResource TextBrush}"/>
        <Setter Property="TextBlock.FontWeight" Value="SemiBold"/>
        <Setter Property="TextBlock.FontSize" Value="15"/>
      </Style>
    </FrameworkElement.Resources>
    <Image Source="../Resources/assets/ui/abilities-backdrop.png" Grid.RowSpan="3" Margin="0,0,0,0"
           Stretch="UniformToFill" Opacity=".9"/>
    <TextBlock Grid.Row="0" FontSize="11" VerticalAlignment="Bottom"
               Text="{Binding Name, Converter={StaticResource UpperCaseConverter}}"/>
    <TextBlock Grid.Row="1" FontSize="40" Margin="0,0,0,10" Text="{Binding FinalScore}"/>
    <TextBlock Grid.Row="2" VerticalAlignment="Top" Text="{Binding ModifierString}"/>
  </Grid>
</UserControl>