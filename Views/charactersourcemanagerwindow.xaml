<mah:MetroWindow x:Class="Builder.Presentation.Views.CharacterSourceManagerWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:local="clr-namespace:Builder.Presentation.Views"
                 xmlns:viewModels="clr-namespace:Builder.Presentation.ViewModels"
                 xmlns:converters="clr-namespace:Builder.Presentation.Converters"
                 xmlns:i="clr-namespace:System.Windows.Interactivity;assembly=System.Windows.Interactivity"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
                 xmlns:sources="clr-namespace:Builder.Presentation.Models.Sources"
                 Title="CharacterSourceManagerWindow" Height="450" Width="872.992">
  <FrameworkElement.Resources>
    <converters:CampaignSourceConverter x:Key="CampaignSourceConverter"/>
    <HierarchicalDataTemplate  DataType="{x:Type sources:SourcesGroup}"
                              ItemsSource="{Binding Sources}">
      <StackPanel Orientation="Horizontal">
        <CheckBox Focusable="false" IsThreeState="false" IsChecked="{Binding IsChecked}"/>
        <TextBlock Text="{Binding}"/>
      </StackPanel>
    </HierarchicalDataTemplate>
    <HierarchicalDataTemplate  DataType="{x:Type sources:SourceItem}">
      <StackPanel Orientation="Horizontal">
        <CheckBox Focusable="false" IsThreeState="false" IsChecked="{Binding IsChecked}"/>
        <TextBlock Text="{Binding}"/>
      </StackPanel>
    </HierarchicalDataTemplate>
    <DataTemplate x:Key="RootTemplate">
      <Border BorderBrush="#FF242424" Background="{DynamicResource LightColor1Brush}" BorderThickness="0"
              Padding="0" Margin="0,0,0,0">
        <Grid Margin="0,0,0,0">
          <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <Border BorderThickness="2" BorderBrush="{DynamicResource SuccessColorBrush}" Opacity="0.5"
                  Grid.RowSpan="3" Margin="0,0,10,0"/>
          <Border BorderThickness="2" BorderBrush="{DynamicResource DangerColorBrush}" Grid.RowSpan="3"
                  Margin="0,0,10,0"
                  Visibility="{Binding IsChecked, Converter={StaticResource InvertedBooleanToVisibilityConverter}}"/>
          <Border BorderThickness="2" BorderBrush="{DynamicResource SuccessColorBrush}" Grid.RowSpan="3"
                  Margin="0,0,10,0"
                  Visibility="{Binding IsChecked, Converter={StaticResource BooleanToVisibilityConverter}}"/>
          <Grid Row="0" Column="1" RowSpan="3" Margin="0,0,10,0">
            <Grid.RowDefinitions>
              <RowDefinition Height="*"/>
              <RowDefinition Height="*"/>
              <RowDefinition Height="*"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="10"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,5">
              <StackPanel Orientation="Horizontal">
                <CheckBox Margin="0,0,0,0" IsChecked="{Binding IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Style="{StaticResource SectionPrimaryTextBlockStyle}" Margin="0,0,4,0"
                           Text="{Binding Converter={StaticResource UpperCaseConverter}}"/>
              </StackPanel>
            </StackPanel>
          </Grid>
        </Grid>
      </Border>
      <DataTemplate.Triggers>
      </DataTemplate.Triggers>
    </DataTemplate>
    <DataTemplate x:Key="SourceGroupTemplate">
      <Border BorderBrush="#FF242424" Background="{DynamicResource LightColor1Brush}" BorderThickness="0"
              Padding="0" Margin="0,0,0,0">
        <Grid Margin="0,0,0,0">
          <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <Border BorderThickness="2" BorderBrush="{DynamicResource SuccessColorBrush}" Opacity="0.4"
                  Grid.RowSpan="3" Margin="0,0,10,0"/>
          <Border BorderThickness="2" BorderBrush="{DynamicResource DangerColorBrush}" Grid.RowSpan="3"
                  Margin="0,0,10,0"
                  Visibility="{Binding IsChecked, Converter={StaticResource InvertedBooleanToVisibilityConverter}}"/>
          <Border BorderThickness="2" BorderBrush="{DynamicResource SuccessColorBrush}" Grid.RowSpan="3"
                  Margin="0,0,10,0"
                  Visibility="{Binding IsChecked, Converter={StaticResource BooleanToVisibilityConverter}}"/>
          <Grid Row="0" Column="1" RowSpan="3" Margin="0,0,10,0">
            <Grid.RowDefinitions>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,5">
              <StackPanel Orientation="Horizontal">
                <TextBlock Style="{StaticResource SectionPrimaryTextBlockStyle}" Margin="0,0,4,0"
                           Text="{Binding Name, Converter={StaticResource UpperCaseConverter}}"/>
              </StackPanel>
              <StackPanel>
                <TextBlock FontStyle="Italic" Style="{StaticResource SectionSecondaryTextBlockStyle}" Margin="0,0,0,0"
                           Text="{Binding Underline}"/>
              </StackPanel>
            </StackPanel>
            <CheckBox Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" Margin="0,0,0,0"
                      IsChecked="{Binding IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      Visibility="{Binding AllowUnchecking, Converter={StaticResource BooleanToVisibilityConverter}}"/>
          </Grid>
        </Grid>
      </Border>
      <DataTemplate.Triggers>
      </DataTemplate.Triggers>
    </DataTemplate>
    <DataTemplate x:Key="SourceItemTemplate">
      <Border BorderBrush="#FF242424" Background="{DynamicResource LightColor1Brush}" BorderThickness="0"
              Padding="0" Margin="0,0,0,0">
        <Grid Margin="0,0,0,0">
          <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <Border BorderThickness="2" BorderBrush="{DynamicResource DangerColorBrush}" Grid.RowSpan="3"
                  Margin="0,0,10,0"
                  Visibility="{Binding IsChecked, Converter={StaticResource InvertedBooleanToVisibilityConverter}}"/>
          <Border BorderThickness="2" BorderBrush="{DynamicResource SuccessColorBrush}" Grid.RowSpan="3"
                  Margin="0,0,10,0"
                  Visibility="{Binding IsChecked, Converter={StaticResource BooleanToVisibilityConverter}}"/>
          <Grid Row="0" Column="1" RowSpan="3" Margin="0,0,10,0">
            <Grid.RowDefinitions>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,5">
              <StackPanel Orientation="Horizontal">
                <TextBlock Style="{StaticResource SectionPrimaryTextBlockStyle}" Margin="0,0,4,0"
                           Text="{Binding Converter={StaticResource UpperCaseConverter}}"/>
                <TextBlock Style="{StaticResource SectionSecondaryTextBlockStyle}" Margin="0,2,4,0"
                           Text="{Binding Elements.Count, Converter={StaticResource UpperCaseConverter}, StringFormat=({0})}"/>
              </StackPanel>
              <StackPanel Orientation="Horizontal">
                <TextBlock FontStyle="Italic" Style="{StaticResource SectionSecondaryTextBlockStyle}" Margin="0,0,0,0"
                           Text="{Binding Source.Author}"/>
                <TextBlock Text="•" FontStyle="Italic" Style="{StaticResource SectionSecondaryTextBlockStyle}" Margin="5,0"
                           Visibility="{Binding Source.IsPlaytestContent, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                <TextBlock Text="Playtest Material" Foreground="{DynamicResource WarningColorBrush}" FontStyle="Italic"
                           Style="{StaticResource SectionSecondaryTextBlockStyle}" Margin="0,0,0,0"
                           Visibility="{Binding Source.IsPlaytestContent, Converter={StaticResource BooleanToVisibilityConverter}}"/>
              </StackPanel>
            </StackPanel>
            <CheckBox Grid.Column="1" Margin="0,0,0,0"
                      IsChecked="{Binding IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      Visibility="{Binding AllowUnchecking, Converter={StaticResource BooleanToVisibilityConverter}}"/>
          </Grid>
        </Grid>
      </Border>
      <DataTemplate.Triggers>
      </DataTemplate.Triggers>
    </DataTemplate>
    <DataTemplate x:Key="ElementHeaderTemplate">
      <Border BorderBrush="#FF242424" Background="{DynamicResource LightColor1Brush}" BorderThickness="0"
              Padding="0" Margin="0,0,0,0">
        <Grid Margin="0,0,0,0">
          <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <Border BorderThickness="2" BorderBrush="{DynamicResource SuccessColorBrush}" Opacity="0.25"
                  Grid.RowSpan="3" Margin="0,0,10,0"/>
          <Grid Row="0" Column="1" RowSpan="3" Margin="0,0,10,0">
            <Grid.RowDefinitions>
              <RowDefinition Height="*"/>
              <RowDefinition Height="*"/>
              <RowDefinition Height="*"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="10"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,5">
              <StackPanel Orientation="Horizontal">
                <TextBlock Style="{StaticResource SectionPrimaryTextBlockStyle}" Margin="0,0,4,0"
                           Text="{Binding Name, Converter={StaticResource UpperCaseConverter}}"/>
              </StackPanel>
            </StackPanel>
          </Grid>
        </Grid>
      </Border>
      <DataTemplate.Triggers>
      </DataTemplate.Triggers>
    </DataTemplate>
  </FrameworkElement.Resources>
  <FrameworkElement.DataContext>
    <viewModels:CampaignManagerViewModel/>
  </FrameworkElement.DataContext>
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="0"/>
      <ColumnDefinition Width="0"/>
      <ColumnDefinition Width="200*"/>
      <ColumnDefinition Width="203*"/>
      <ColumnDefinition Width="404*"/>
      <ColumnDefinition Width="403*"/>
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <StackPanel Margin="10,10,190,10" Grid.ColumnSpan="3">
      <TextBlock Text="Campaign Name"/>
      <TextBox Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
    </StackPanel>
    <TreeView x:Name="SourcesTree" FontSize="12" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,200,0"
              ItemsSource="{Binding RootGroups}">
      <i:Interaction.Triggers>
        <i:EventTrigger EventName="SelectedItemChanged">
          <i:InvokeCommandAction Command="{Binding SelectedItemChangedCommand}"
                               CommandParameter="{Binding ElementName=SourcesTree, Path=SelectedItem}"/>
        </i:EventTrigger>
      </i:Interaction.Triggers>
    </TreeView>
    <ListView Grid.Column="2" Margin="5" ItemTemplate="{StaticResource SourceGroupTemplate}"
              Style="{StaticResource DefaultListView}" Grid.ColumnSpan="2" ItemsSource="{Binding RootGroups}"
              SelectedItem="{Binding SelectedSourcesGroup}"/>
    <ListView Grid.Column="4" Margin="5" ItemTemplate="{StaticResource SourceItemTemplate}"
              Style="{StaticResource DefaultListView}" ItemsSource="{Binding SelectedSourcesGroup.Sources}"
              SelectedItem="{Binding SelectedSourceItem}"/>
    <StackPanel Grid.Row="0" Grid.Column="5" Margin="5">
      <Image Stretch="UniformToFill" Height="300" Width="240"
             Source="{Binding SelectedSourceItem.Source.ImageUrl}"/>
    </StackPanel>
    <StackPanel Orientation="Horizontal" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                HorizontalAlignment="Left" Margin="5,5,0,5">
      <Button Content="Save" Command="{Binding SaveSourceConfigurationCommand}"/>
      <Button Content="Load" Margin="10,0,0,0" Command="{Binding LoadSourceConfigurationCommand}"/>
    </StackPanel>
  </Grid>
</mah:MetroWindow>