<controls:MetroWindow x:Class="Builder.Presentation.Views.Dialogs.SaveCharacterDialog"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                      xmlns:local="clr-namespace:Builder.Presentation.Views.Dialogs"
                      xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
                      Title="SaveCharacterDialog" Height="300" Width="300">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="60"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <Border Grid.Row="2" Background="{DynamicResource HighlightBrush}"/>
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Row="2">
      <Button Content="SAVE" Style="{StaticResource MetroFlatButton}" FontSize="12" Margin="10,10,0,10"/>
      <Button Content="CANCEL" Style="{StaticResource MetroFlatButton}" FontSize="12" Margin="10,10,10,10"/>
    </StackPanel>
  </Grid>
</controls:MetroWindow>