<mah:MetroWindow x:Class="Builder.Presentation.Views.Dialogs.ExtractItemWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:controls="clr-namespace:Aurora.Presentation.Controls;assembly=Aurora.Presentation"
                 xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
                 xmlns:dialogs="clr-namespace:Builder.Presentation.Views.Dialogs"
                 ResizeMode="NoResize" Height="400" Width="350" MinHeight="100" MinWidth="100"
                 Style="{StaticResource IconlessCharacterBuilderWindowStyle}"
                 TitleTemplate="{StaticResource IconlessCharacterBuilderWindowTitleDataTemplate}"
                 WindowStartupLocation="CenterScreen" Title="{Binding Title, StringFormat='Extract {0}'}">
  <FrameworkElement.DataContext>
    <dialogs:ExtractableItemDialogViewModel/>
  </FrameworkElement.DataContext>
  <Grid Background="{DynamicResource WhiteBrush}" Margin="0,1,0,0">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <StackPanel Margin="20,20,20,0">
      <TextBlock x:Name="PrimaryTextBlock" TextWrapping="Wrap" Style="{StaticResource SectionPrimaryTextBlockStyle}"
                 Text="{Binding Title}"/>
      <TextBlock x:Name="SecondaryTextBlock" Text="The following items will be added to your inventory:"
                 TextWrapping="Wrap" Style="{StaticResource SectionSecondaryTextBlockStyle}" FontSize="12"/>
    </StackPanel>
    <ScrollViewer Grid.Row="1" Margin="20,0,5,10" VerticalScrollBarVisibility="Auto">
      <ItemsControl ItemsSource="{Binding Extractables}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Grid>
              <TextBlock Style="{StaticResource SectionPrimaryTextBlockStyle}" FontSize="12" Margin="0,0,0,5"
                         Text="{Binding}"/>
            </Grid>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
    <Border Background="{DynamicResource DescriptionPanelBackgroundBrush}" Grid.Row="2"
            SnapsToDevicePixels="true" BorderThickness="0,1,0,0"
            BorderBrush="{DynamicResource LightColor1Brush}">
      <FrameworkElement.Resources>
        <Style TargetType="{x:Type Button}" BasedOn="{StaticResource MetroFlatButton}">
          <Setter Property="UIElement.SnapsToDevicePixels" Value="true"/>
          <Setter Property="FrameworkElement.Margin" Value="10"/>
          <Setter Property="Control.FontSize" Value="11"/>
          <Setter Property="FrameworkElement.MinWidth" Value="70"/>
          <Setter Property="FrameworkElement.MaxHeight" Value="25"/>
          <Setter Property="Control.Padding" Value="10,5"/>
        </Style>
      </FrameworkElement.Resources>
      <Grid Margin="0">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0">
          <controls:CommandButton Click="OnSaveClicked" CommandText="Extract" Style="{DynamicResource SuccessCommandButtonStyle}"
                                  Margin="0,10,10,10" MinWidth="75" IsDefault="true"/>
          <controls:CommandButton Click="OnCancelClicked" CommandText="Cancel" Style="{DynamicResource CommandButtonDefaultStyle}"
                                  Margin="0,10,10,10" MinWidth="75" IsCancel="true"/>
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</mah:MetroWindow>