<controls:MetroWindow x:Class="Builder.Presentation.Views.Development.DeveloperTools"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                      xmlns:local="clr-namespace:Builder.Presentation.Views.Development"
                      xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
                      xmlns:userControls="clr-namespace:Builder.Presentation.UserControls"
                      xmlns:wpf="clr-namespace:TheArtOfDev.HtmlRenderer.WPF;assembly=HtmlRenderer.WPF"
                      Title="Developer Tools" MinHeight="200" MinWidth="200" Height="900" Width="1440"
                      Style="{StaticResource IconlessCharacterBuilderWindowStyle}"
                      TitleTemplate="{StaticResource IconlessCharacterBuilderWindowTitleDataTemplate}"
                      WindowStartupLocation="CenterScreen">
  <FrameworkElement.DataContext>
    <local:DeveloperToolsViewModel/>
  </FrameworkElement.DataContext>
  <controls:MetroWindow.RightWindowCommands>
    <controls:WindowCommands ShowSeparators="false" Foreground="{StaticResource WhiteBrush}">
      <Button Click="UpdateNotificationButtonClicked" x:Name="UpdateNotificationButton" ToolTip="Notifications"
              Style="{StaticResource CommandButtonStyle}" Background="{DynamicResource AccentColorBrush}"
              Visibility="{Binding UpdateAvailable, Converter={StaticResource BooleanToVisibilityConverter}}">
        <TextBlock Text="" Foreground="{DynamicResource NewNotificationIndicatorForegroundColorBrush}"
                   Style="{StaticResource CommandTextStyle}" Margin="10,0,10,0">
          <UIElement.RenderTransform>
            <TranslateTransform x:Name="NotificationArrow" Y="-30"/>
          </UIElement.RenderTransform>
          <FrameworkElement.Triggers>
            <EventTrigger RoutedEvent="TextBlock.Loaded">
              <BeginStoryboard>
                <Storyboard>
                  <DoubleAnimation From="-30" To="0" Duration="0:0:2" Storyboard.TargetName="NotificationArrow"
                                   Storyboard.TargetProperty="Y" RepeatBehavior="3x"/>
                </Storyboard>
              </BeginStoryboard>
            </EventTrigger>
          </FrameworkElement.Triggers>
        </TextBlock>
      </Button>
    </controls:WindowCommands>
  </controls:MetroWindow.RightWindowCommands>
  <Grid>
    <FrameworkElement.Resources>
      <Style TargetType="{x:Type controls:MetroTabControl}"
             BasedOn="{StaticResource MainNavigationTabControlStyle}"/>
      <Style TargetType="{x:Type controls:MetroTabItem}" BasedOn="{StaticResource MainNavigationTabItemStyle}"/>
    </FrameworkElement.Resources>
    <Grid.RowDefinitions>
      <RowDefinition Height="60"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <Border Style="{StaticResource OverlayBorderStyle}" BorderThickness="0" Height="Auto" Margin="3,0,0,0">
      <FrameworkElement.Resources>
        <ResourceDictionary Source="/Styles/Builder/MenuStyle.xaml"/>
      </FrameworkElement.Resources>
      <Menu Background="{StaticResource TransparentWhiteBrush}" VerticalAlignment="Bottom">
        <MenuItem Header="FILE">
          <MenuItem Click="ExitClick" Header="Exit Application"/>
        </MenuItem>
        <MenuItem Header="WINDOW">
          <MenuItem Click="OpenSupportTesterWindow" Header="SUPPORT TEST WINDOW"/>
        </MenuItem>
      </Menu>
    </Border>
    <Grid Row="1" Background="{StaticResource WhiteBrush}">
      <FrameworkElement.Resources>
        <Style TargetType="{x:Type controls:MetroTabControl}"
               BasedOn="{StaticResource MainNavigationTabControlStyle}"/>
        <Style TargetType="{x:Type controls:MetroTabItem}"
               BasedOn="{StaticResource MainNavigationChildTabItemStyle}"/>
      </FrameworkElement.Resources>
      <Border Style="{StaticResource UnderlayBorderStyle}"/>
      <controls:MetroTabControl Grid.Column="0" Margin="0,0,0,0">
        <controls:MetroTabItem Header="ELEMENTS BROWSER" DataContext="{Binding ElementsViewerViewModel}">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="0"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid Row="2" Background="White">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="2*"/>
              </Grid.ColumnDefinitions>
              <Grid Margin="10,1,0,0" DataContext="{Binding}">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid Row="1">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0" Grid.ColumnSpan="3">
                    <TextBlock Text="TYPE" FontSize="10" Foreground="{DynamicResource GrayBrush2}" Margin="0,10,0,5"/>
                    <ComboBox ItemsSource="{Binding Types}"
                              SelectedItem="{Binding SelectedType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                  </StackPanel>
                  <StackPanel Grid.Column="4" Grid.ColumnSpan="3">
                    <TextBlock Text="SOURCE" FontSize="10" Foreground="{DynamicResource GrayBrush2}" Margin="0,10,0,5"/>
                    <ComboBox ItemsSource="{Binding Sources}"
                              SelectedItem="{Binding SelectedSource, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                  </StackPanel>
                </Grid>
                <StackPanel Grid.Row="2" Margin="0,0,0,0">
                  <TextBlock Text="NAME/ID FILTER" FontSize="10" Foreground="{DynamicResource GrayBrush2}" Margin="0,10,0,5"/>
                  <TextBox Margin="0,0,0,5" controls:TextBoxHelper.Watermark="Search"
                           controls:TextBoxHelper.UseFloatingWatermark="true"
                           Text="{Binding FilterName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                  <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="RESET" Margin="0,0,10,0" Style="{StaticResource ChromelessButtonStyle}" FontSize="11"
                            Command="{Binding ResetCommand}"/>
                    <Button Content="FILTER" Margin="0,0,0,0" Style="{StaticResource ChromelessButtonStyle}" FontSize="11"
                            Command="{Binding FilterCommand}"/>
                  </StackPanel>
                </StackPanel>
                <ListView Grid.Row="3" BorderThickness="0" Margin="0,10,0,10" ItemsSource="{Binding FilteredElements}"
                          SelectedItem="{Binding SelectedElement}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*"/>
                          <ColumnDefinition Width="*"/>
                          <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <FrameworkElement.Resources>
                          <Style TargetType="{x:Type TextBlock}">
                            <Setter Property="FrameworkElement.VerticalAlignment" Value="Center"/>
                            <Setter Property="FrameworkElement.Margin" Value="10,0,10,0"/>
                          </Style>
                        </FrameworkElement.Resources>
                        <TextBlock Text="{Binding Name}"/>
                        <TextBlock Grid.Column="1" Text="{Binding Type}"/>
                        <TextBlock Grid.Column="2" HorizontalAlignment="Right" Text="{Binding Source}"/>
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ListView>
              </Grid>
              <Grid Column="1">
                <Grid.RowDefinitions>
                  <RowDefinition Height="2*"/>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="2*"/>
                  <RowDefinition Height="3*"/>
                </Grid.RowDefinitions>
                <TextBox Grid.Row="0" Margin="10,10,10,10" TextWrapping="Wrap" AcceptsReturn="true" AcceptsTab="true"
                         VerticalScrollBarVisibility="Visible" Text="{Binding SelectedElement.ElementNodeString}"/>
                <TextBox Grid.Row="1" Margin="10,0,10,0" Text="{Binding SelectedElement.Id, Mode=OneWay}"/>
                <TextBox Grid.Row="2" Margin="10,10,10,0" TextWrapping="Wrap" AcceptsReturn="true" AcceptsTab="true"
                         VerticalScrollBarVisibility="Visible"
                         Text="{Binding StyleSheet, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBox Grid.Row="3" Margin="10,10,10,10" TextWrapping="Wrap" AcceptsReturn="true" AcceptsTab="true"
                         VerticalScrollBarVisibility="Visible"
                         Text="{Binding Input, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
              </Grid>
              <ScrollViewer Grid.Column="2" Margin="0,20,10,10">
                <userControls:DescriptionPanel/>
              </ScrollViewer>
              <ScrollViewer x:Name="WebScrollView" Grid.Column="3" Margin="0,10,10,10">
                <wpf:HtmlPanel x:Name="html" ScrollViewer.VerticalScrollBarVisibility="Disabled" Foreground="Red"
                               Text="{Binding Output, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                               IsSelectionEnabled="{Binding IsSelectionEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                               IsContextMenuEnabled="{Binding IsContextMenuEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                               BaseStylesheet="{Binding StyleSheet}"/>
              </ScrollViewer>
            </Grid>
          </Grid>
        </controls:MetroTabItem>
      </controls:MetroTabControl>
      <Border Style="{StaticResource OverlayBorderStyle}"/>
    </Grid>
    <Grid Row="2" Column="0" Background="{StaticResource WhiteBrush}">
      <Border BorderThickness="0,0,0,0" BorderBrush="{DynamicResource AccentColorBrush}"
              SnapsToDevicePixels="true">
        <StatusBar x:Name="StatusBar" Style="{StaticResource StatusBarDefaultStyle}">
          <StatusBarItem>
            <TextBlock Style="{StaticResource StatusBarStatusMessageStyle}" TextWrapping="NoWrap"
                       Text="{Binding StatusMessage}"/>
          </StatusBarItem>
          <StatusBarItem HorizontalContentAlignment="Right" HorizontalAlignment="Right" DockPanel.Dock="Right">
            <controls:MetroProgressBar x:Name="ProgressBarMain" Style="{StaticResource StatusBarProgressBarStyle}"
                                       Value="{Binding ProgressPercentage}"/>
          </StatusBarItem>
        </StatusBar>
      </Border>
    </Grid>
  </Grid>
</controls:MetroWindow>