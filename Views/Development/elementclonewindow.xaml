<Window x:Class="Builder.Presentation.Views.Development.ElementCloneWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Builder.Presentation.Views.Development"
        Title="ElementCloneWindow" Height="509" Width="797">
  <FrameworkElement.DataContext>
    <local:ElementCloneViewModel/>
  </FrameworkElement.DataContext>
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <Border Grid.Row="0" Grid.ColumnSpan="2" Grid.RowSpan="3" Grid.Column="0" Background="Green"
            Visibility="{Binding IsMatch, Converter={StaticResource BooleanToVisibilityConverter}}"/>
    <CheckBox IsEnabled="false" Margin="10" IsChecked="{Binding IsMatch}">Is Match</CheckBox>
    <StackPanel Grid.Column="1">
      <ComboBox Margin="10" ItemsSource="{Binding Elements}"
                SelectedItem="{Binding SelectedElement, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
    </StackPanel>
    <TextBox Grid.Row="1" Grid.Column="0" Margin="10" AcceptsReturn="true" AcceptsTab="true"
             VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"
             Text="{Binding Left, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
    <TextBox Grid.Row="1" Grid.Column="1" Margin="10" AcceptsReturn="true" AcceptsTab="true"
             VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"
             Text="{Binding Right, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
    <StackPanel Margin="10" Grid.Row="2" Grid.Column="0">
      <TextBlock Text="{Binding Left.Length}"/>
    </StackPanel>
    <StackPanel Margin="10" Grid.Row="2" Grid.Column="1">
      <TextBlock Text="{Binding Right.Length}"/>
    </StackPanel>
  </Grid>
</Window>