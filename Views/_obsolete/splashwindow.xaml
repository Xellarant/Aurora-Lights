<mah:MetroWindow x:Class="Builder.Presentation.Views.SplashWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:local="clr-namespace:Builder.Presentation.Views"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 ResizeMode="NoResize" Width="400" Height="650" Title="" MinHeight="0" Background="#151516"
                 Style="{StaticResource CharacterBuilderWindowStyle}"
                 TitleTemplate="{StaticResource WindowTitleTemplate}" ShowIconOnTitleBar="false"
                 WindowStartupLocation="CenterScreen">
  <Grid Margin="0">
    <Grid.RowDefinitions>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="30"/>
    </Grid.RowDefinitions>
    <FrameworkElement.Resources>
      <Style x:Key="HeaderStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="TextBlock.FontSize" Value="36"/>
        <Setter Property="TextBlock.FontFamily" Value="Segoe UI SemiBold"/>
        <Setter Property="TextBlock.TextWrapping" Value="Wrap"/>
        <Setter Property="TextBlock.Foreground" Value="{DynamicResource GrayBrush6}"/>
      </Style>
      <Style x:Key="DefaultInformationStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="TextBlock.FontSize" Value="14"/>
        <Setter Property="TextBlock.FontFamily" Value="Segoe UI Light"/>
        <Setter Property="TextBlock.TextWrapping" Value="Wrap"/>
        <Setter Property="TextBlock.Foreground" Value="{DynamicResource IdealForegroundDisabledBrush}"/>
      </Style>
      <Style x:Key="VersionTextBlockStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="TextBlock.FontSize" Value="12"/>
        <Setter Property="TextBlock.FontFamily" Value="Segoe UI Normal"/>
        <Setter Property="TextBlock.TextWrapping" Value="Wrap"/>
        <Setter Property="FrameworkElement.HorizontalAlignment" Value="Center"/>
        <Setter Property="TextBlock.Foreground" Value="{DynamicResource DangerColorBrush}"/>
      </Style>
    </FrameworkElement.Resources>
    <Image Source="../Resources/assets/aurora-illithid.png" Stretch="Uniform" Grid.RowSpan="2" Opacity="0.25"
           Grid.ColumnSpan="1" RenderTransformOrigin="0.5,0.5" Margin="0,-100,0,0">
      <UIElement.RenderTransform>
        <TransformGroup>
          <ScaleTransform ScaleX="0.6" ScaleY="0.6"/>
          <SkewTransform/>
          <RotateTransform/>
          <TranslateTransform/>
        </TransformGroup>
      </UIElement.RenderTransform>
    </Image>
    <Image Source="../Resources/assets/logo.png" Stretch="None" Grid.Row="0" Grid.ColumnSpan="2"
           HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0"/>
    <TextBlock Grid.Row="0" Style="{StaticResource VersionTextBlockStyle}"
               Foreground="{DynamicResource GrayBrush5}" FontSize="11" Margin="10" HorizontalAlignment="Right"
               VerticalAlignment="Bottom"
               Text="{Binding Version, StringFormat={0}, FallbackValue='Fallback Version 1.0-BETA'}"/>
    <StackPanel Grid.Row="1">
      <StackPanel Grid.Row="3" Margin="10,13,10,6" Grid.ColumnSpan="2" Grid.Column="0">
        <TextBlock Style="{StaticResource DefaultInformationStyle}" FontSize="11" TextWrapping="Wrap"
                   Text="{Binding ProgressMessage, StringFormat={0}, FallbackValue='Fallback StatusMessage'}"/>
        <mah:MetroProgressBar Margin="0,5,0,10" Foreground="{DynamicResource SuccessDarkColorBrush}" SnapsToDevicePixels="true"
                              Value="{Binding ProgressPercentage, FallbackValue=67}"/>
      </StackPanel>
    </StackPanel>
    <Border Grid.Row="2" Grid.Column="0" Background="{DynamicResource AccentColorBrush4}">
      <Grid>
        <StackPanel Margin="10,0,10,0" VerticalAlignment="Center">
          <TextBlock Text="© 2018 Bas Driessen. All rights reserved." Style="{StaticResource DefaultInformationStyle}"
                     FontSize="12" LineHeight="12" TextWrapping="NoWrap" Margin="0,0,0,0"/>
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</mah:MetroWindow>