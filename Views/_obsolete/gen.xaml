<Window x:Class="Builder.Presentation.Views._obsolete.Gen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Builder.Presentation.Views._obsolete"
        Title="Gen" Height="450" Width="1227.824">
  <FrameworkElement.DataContext>
    <local:GenViewModel/>
  </FrameworkElement.DataContext>
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*"/>
      <ColumnDefinition Width="*"/>
      <ColumnDefinition Width="2*"/>
    </Grid.ColumnDefinitions>
    <StackPanel Margin="10">
      <TextBlock>name</TextBlock>
      <TextBox Text="{Binding GenName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
      <TextBlock>type</TextBlock>
      <ComboBox IsEditable="true" Text="{Binding SelectedType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                ItemsSource="{Binding Types}"/>
      <TextBlock>source</TextBlock>
      <ComboBox SelectedItem="{Binding SelectedSource, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                ItemsSource="{Binding Sources}"/>
      <TextBlock>id</TextBlock>
      <TextBox Text="{Binding GenId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
      <Button Margin="0,5" Command="{Binding AddGenCommand}">generate</Button>
      <Button Margin="0,0" Command="{Binding RemoveGenCommand}">remove</Button>
      <Button Margin="0,5" Command="{Binding OutputGensCommand}">output gens</Button>
    </StackPanel>
    <ListView Grid.Column="1" Margin="10" ItemsSource="{Binding GenElements}"/>
    <TextBox Grid.Column="2" Margin="10" AcceptsReturn="true"
             Text="{Binding Output, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
    </TextBox>
  </Grid>
</Window>