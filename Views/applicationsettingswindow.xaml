                </TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
                  Open Game License v 1.0a Copyright 2000, Wizards of the Coast, LLC. System Reference Document 5.1 Copyright 2016, Wizards of the Coast, Inc.; Authors Mike Mearls, Jeremy Crawford, Chris Perkins, Rodney Thompson, Peter Lee, James Wyatt, Robert J. Schwalb, Bruce R. Cordell, Chris Sims, and Steve Townshend, based on original material by E. Gary Gygax and Dave Arneson.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">END OF LICENSE</TextBlock>
              </StackPanel>
            </ScrollViewer>
          </Grid>
        </controls:MetroTabItem>
        <controls:MetroTabItem Header="About">
          <ScrollViewer Style="{StaticResource SettingsSectionScrollViewerStyle}">
            <Grid>
              <StackPanel Margin="0,5,20,0">
                <TextBlock Text="AURORA" Style="{StaticResource SectionHeaderTextBlockStyle}" Margin="0,0,0,0"/>
                <TextBlock Style="{StaticResource SectionSubHeaderTextBlockStyle}"
                           Foreground="{DynamicResource DeveloperIndicatorForegroundColorBrush}"
                           Text="{Binding Version, StringFormat=v{0}}"/>
                <TextBlock Text="Aurora is a free tool that lets you create characters for your dungeons and dragons game using the bundled content, your own content, and content created by others."
                           Style="{StaticResource SectionSubHeaderTextBlockStyle}" FontSize="12"/>
                <aurora:CommandButton Click="BrowseDiscordChannelClick" CommandText="Discord Channel" Margin="0,10,10,0" MinWidth="75"/>
                <aurora:CommandButton Click="BrowsePatreonPageClick" CommandText="Support on Patreon" Margin="0,10,10,0" MinWidth="75"/>
              </StackPanel>
              <StackPanel VerticalAlignment="Bottom" Margin="0">
                <TextBlock Margin="0,0,0,2" Text="© 2020 BAS DRIESSEN. ALL RIGHTS RESERVED"
                           Style="{StaticResource SectionSubHeaderTextBlockStyle}" FontSize="11"/>
              </StackPanel>
            </Grid>
          </ScrollViewer>
        </controls:MetroTabItem>
        <controls:MetroTabItem Header="DEFAULT SECTION" Visibility="Collapsed">
          <ScrollViewer Style="{StaticResource SettingsSectionScrollViewerStyle}">
            <StackPanel Margin="0,5,10,0">
              <TextBlock Text="DEFAULT SECTION" Style="{StaticResource SectionHeaderTextBlockStyle}" Margin="0,0,0,0"/>
              <TextBlock Text="This is the default section layout. Copy this MetroTabItem to start a new section."
                         Style="{StaticResource SectionSubHeaderTextBlockStyle}"/>
            </StackPanel>
          </ScrollViewer>
        </controls:MetroTabItem>
      </controls:MetroTabControl>
    </Border>
    <Border Background="{DynamicResource DescriptionPanelBackgroundBrush}" Grid.Row="2"
            SnapsToDevicePixels="true" BorderThickness="0,1,0,0"
            BorderBrush="{DynamicResource LightColor1Brush}">
      <FrameworkElement.Resources>
        <Style TargetType="{x:Type Button}" BasedOn="{StaticResource MetroFlatButton}">
          <Setter Property="UIElement.SnapsToDevicePixels" Value="true"/>
          <Setter Property="FrameworkElement.Margin" Value="10"/>
          <Setter Property="Control.FontSize" Value="11"/>
          <Setter Property="FrameworkElement.MinWidth" Value="70"/>
          <Setter Property="FrameworkElement.MaxHeight" Value="25"/>
          <Setter Property="Control.Padding" Value="10,5"/>
        </Style>
      </FrameworkElement.Resources>
      <Grid Margin="0">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0">
          <aurora:CommandButton CommandText="Restore Defaults" Margin="10,0,0,0" Command="{Binding SetDefaultsSettingsCommand}">
            <iconPacks:PackIconMaterial Kind="BackupRestore"/>
          </aurora:CommandButton>
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0">
          <aurora:CommandButton Click="OnSaveClicked" CommandText="Save" Style="{DynamicResource SuccessCommandButtonStyle}"
                                Margin="0,10,10,10" MinWidth="75" IsDefault="true" Command="{Binding SaveSettingsCommand}"/>
          <aurora:CommandButton Click="OnCancelClicked" CommandText="Cancel"
                                Style="{DynamicResource DangerClearCommandButtonStyle}" Margin="0,10,10,10" MinWidth="75"
                                IsCancel="true" Command="{Binding CancelSettingsCommand}"/>
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</controls:MetroWindow>