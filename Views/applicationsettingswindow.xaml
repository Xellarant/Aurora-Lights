<controls:MetroWindow x:Class="Builder.Presentation.Views.ApplicationSettingsWindow"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                      xmlns:local="clr-namespace:Builder.Presentation.Views"
                      xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
                      xmlns:system="clr-namespace:System;assembly=mscorlib"
                      xmlns:wpf="clr-namespace:TheArtOfDev.HtmlRenderer.WPF;assembly=HtmlRenderer.WPF"
                      xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
                      xmlns:viewModels="clr-namespace:Builder.Presentation.ViewModels"
                      xmlns:converters="clr-namespace:Builder.Presentation.Converters"
                      xmlns:userControls="clr-namespace:Builder.Presentation.UserControls"
                      xmlns:aurora="clr-namespace:Aurora.Presentation.Controls;assembly=Aurora.Presentation"
                      Title="Application Settings" ResizeMode="NoResize"
                      Style="{StaticResource IconlessCharacterBuilderWindowStyle}"
                      TitleTemplate="{StaticResource IconlessCharacterBuilderWindowTitleDataTemplate}"
                      WindowStartupLocation="CenterScreen" Height="600" Width="425" MinHeight="600" MinWidth="500"
                      MaxHeight="700" MaxWidth="700">
  <FrameworkElement.DataContext>
    <viewModels:SettingsWindowViewModel/>
  </FrameworkElement.DataContext>
  <FrameworkElement.Resources>
    <converters:AccentColorConverter x:Key="AccentColorConverter"/>
    <converters:ThemeColorConverter x:Key="ThemeColorConverter"/>
    <converters:InvertedThemeColorConverter x:Key="InvertedThemeColorConverter"/>
  </FrameworkElement.Resources>
  <Grid Background="{DynamicResource WhiteBrush}" Margin="0,1,0,0">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <Border Grid.Row="1">
      <controls:MetroTabControl x:Name="SettingsTabControl" TabStripPlacement="Left" Margin="0,10,0,10"
                                controls:TabControlHelper.Underlined="TabPanel"
                                Background="{DynamicResource TransparentWhiteBrush}"
                                Style="{DynamicResource SettingsTabControlStyle}">
        <FrameworkElement.Resources>
          <Style TargetType="{x:Type controls:MetroTabItem}" BasedOn="{StaticResource MetroTabItem}">
            <Setter Property="controls:TabControlHelper.UnderlineSelectedBrush"
                    Value="{DynamicResource HighlightBrush}"/>
            <Setter Property="controls:ControlsHelper.ContentCharacterCasing" Value="Upper"/>
            <Setter Property="HeaderedContentControl.HeaderTemplate">
              <Setter.Value>
                <DataTemplate>
                  <TextBlock Margin="0" FontSize="12" Padding="10,5,10,5" FontWeight="SemiBold"
                             Text="{Binding Converter={StaticResource UpperCaseConverter}}"/>
                </DataTemplate>
              </Setter.Value>
            </Setter>
          </Style>
          <Style x:Key="SettingsSectionScrollViewerStyle" TargetType="{x:Type ScrollViewer}">
            <Setter Property="FrameworkElement.Margin" Value="20,0,0,0"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
          </Style>
        </FrameworkElement.Resources>
        <controls:MetroTabItem Header="GENERAL">
          <ScrollViewer Style="{StaticResource SettingsSectionScrollViewerStyle}">
            <StackPanel Margin="0,5,20,0">
              <TextBlock Text="APPLICATION SETTINGS" Style="{StaticResource SectionPrimaryTextBlockStyle}"/>
              <TextBlock Text="The behaviour of the application and its UI elements."
                         Style="{StaticResource SectionSecondaryTextBlockStyle}"/>
              <TextBlock Text="PLAYER NAME" Style="{StaticResource FieldHeaderTextBlockStyle}"/>
              <TextBox Margin="0" Text="{Binding DefaultPlayerName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
              <TextBlock Text="ABILITY SCORE GENERATION OPTION" Style="{StaticResource FieldHeaderTextBlockStyle}"/>
              <ComboBox ItemsSource="{Binding AbilitiesGenerationSelectionItems}"
                        SelectedItem="{Binding SelectedAbilityGenerateOption, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
              <TextBlock Text="SELECTION PICKERS" Style="{StaticResource SectionPrimaryTextBlockStyle}" Margin="0,25,0,0"/>
              <TextBlock Text="ROW HEIGHT" Style="{StaticResource FieldHeaderTextBlockStyle}"/>
              <ComboBox Margin="0" ItemsSource="{Binding SelectionExpanderItemsSize}"
                        SelectedItem="{Binding SelectedSelectionExpanderItemsSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
              <TextBlock Text="Reduce the height of the rows to fit more content on your screen."
                         Style="{StaticResource SectionSecondaryTextBlockStyle}" FontSize="10"/>
              <userControls:DescriptionCheckBox Header="Selection Flow" Margin="0,10,0,0"
                                                Description="Automatically navigate to the next available selection. Alternatively, toggle this behaviour from the status bar."
                                                IsChecked="{Binding AutoNavigateNextSelectionWhenAvailable, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
              <TextBlock Text="CHARACTER INFORMATION PANEL" Style="{StaticResource SectionPrimaryTextBlockStyle}"
                         Margin="0,25,0,0"/>
              <TextBlock Text="Click the character portrait at the top of the main window to open the character information panel."
                         Style="{StaticResource SectionSubHeaderTextBlockStyle}"/>
              <userControls:DescriptionCheckBox Header="Skills Panel Expanded" Margin="0,0,0,10"
                                                Description="Expand by default when the application loads."
                                                IsChecked="{Binding CharacterPanelSkillsIsExpanded, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
              <userControls:DescriptionCheckBox Header="Saving Throws Expanded" Margin="0,0,0,0"
                                                Description="Expand by default when the application loads."
                                                IsChecked="{Binding CharacterPanelSavingThrowsIsExpanded, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
              <TextBlock Text="CHARACTER ADVANCEMENT" Style="{StaticResource SectionPrimaryTextBlockStyle}"
                         Margin="0,25,0,0"/>
              <userControls:DescriptionCheckBox Header="'Remove Level' Confirmation" Margin="0,10,0,10"
                                                Description="Display a confirmation box when removing the last level of your character."
                                                IsChecked="{Binding DisplayRemoveLevelConfirmation, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
          </ScrollViewer>
        </controls:MetroTabItem>
        <controls:MetroTabItem Header="Appearance">
          <ScrollViewer Style="{StaticResource SettingsSectionScrollViewerStyle}">
            <StackPanel Margin="0,5,10,0">
              <TextBlock Text="APPEARANCE" Style="{StaticResource SectionHeaderTextBlockStyle}" Margin="0,0,0,0"/>
              <TextBlock Text="Customize the appearance of the application."
                         Style="{StaticResource SectionSubHeaderTextBlockStyle}"/>
              <TextBlock Text="SELECT YOUR ACCENT COLOR" Style="{StaticResource FieldHeaderTextBlockStyle}"/>
              <ListView BorderThickness="0" Padding="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                        ScrollViewer.VerticalScrollBarVisibility="Auto" Margin="0,0,0,10" ItemsSource="{Binding Accents}"
                        SelectedItem="{Binding SelectedAccent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                <ItemsControl.ItemContainerStyle>
                  <Style TargetType="{x:Type ListViewItem}" BasedOn="{StaticResource {x:Type ListViewItem}}">
                    <Setter Property="FrameworkElement.Margin" Value="2"/>
                    <Setter Property="Control.Padding" Value="0"/>
                  </Style>
                </ItemsControl.ItemContainerStyle>
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <WrapPanel/>
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border BorderBrush="{DynamicResource GrayHoverBrush}" BorderThickness="0" SnapsToDevicePixels="true"
                            Width="50" Height="50" Margin="2"
                            Background="{Binding Converter={StaticResource AccentColorConverter}}"/>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ListView>
              <TextBlock Text="SELECT YOUR THEME COLOR" Style="{StaticResource FieldHeaderTextBlockStyle}"/>
              <ListView BorderThickness="0" Padding="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                        ScrollViewer.VerticalScrollBarVisibility="Auto" Margin="0,0,0,20" ItemsSource="{Binding Themes}"
                        SelectedItem="{Binding SelectedTheme, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                <ItemsControl.ItemContainerStyle>
                  <Style TargetType="{x:Type ListViewItem}" BasedOn="{StaticResource {x:Type ListViewItem}}">
                    <Setter Property="FrameworkElement.Margin" Value="2"/>
                    <Setter Property="Control.Padding" Value="0"/>
                  </Style>
                </ItemsControl.ItemContainerStyle>
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <WrapPanel/>
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border BorderBrush="{DynamicResource GrayHoverBrush}" BorderThickness="0" SnapsToDevicePixels="true"
                            Width="50" Height="50" Margin="2"
                            Background="{Binding Converter={StaticResource ThemeColorConverter}}">
                      <Path x:Name="ContrastDragonPath" Width="28" Height="28" HorizontalAlignment="Center"
                            VerticalAlignment="Center" Margin="2" Style="{StaticResource DragonHeadPathStyle}"
                            Fill="{Binding Converter={StaticResource InvertedThemeColorConverter}}"/>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ListView>
              <TextBlock Style="{StaticResource FieldHeaderTextBlockStyle}"
                         Text="{Binding CharactersCollectionSize, StringFormat='CHARACTER COLLECTION PORTRAIT SIZE ({0}px)'}"/>
              <Slider Minimum="125" Maximum="175" SmallChange="5" LargeChange="10" TickFrequency="25"
                      TickPlacement="BottomRight" IsSnapToTickEnabled="true" Margin="0,5,0,0"
                      Value="{Binding CharactersCollectionSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
          </ScrollViewer>
        </controls:MetroTabItem>
        <controls:MetroTabItem Header="CHARACTER BUILD">
          <ScrollViewer Style="{StaticResource SettingsSectionScrollViewerStyle}">
            <StackPanel Margin="0,5,20,0">
              <TextBlock Text="BUILD" Style="{StaticResource SectionPrimaryTextBlockStyle}"/>
              <TextBlock Text="The behaviour of character creation." Style="{StaticResource SectionSecondaryTextBlockStyle}"/>
              <TextBlock Text="ABILITY SCORE GENERATION OPTION" Style="{StaticResource FieldHeaderTextBlockStyle}"/>
              <ComboBox Margin="0,0,0,10" ItemsSource="{Binding AbilitiesGenerationSelectionItems}"
                        SelectedItem="{Binding SelectedAbilityGenerateOption, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
              <userControls:DescriptionCheckBox Header="Ability Score Maximum (default)" Margin="0,10,0,0"
                                                Description="You ability score can't exceed the maximum of 20. This can still be increased by certain features or items."
                                                IsChecked="{Binding UseDefaultAbilityScoreMaximum, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
          </ScrollViewer>
        </controls:MetroTabItem>
        <controls:MetroTabItem Header="DATA FILES">
          <ScrollViewer Style="{StaticResource SettingsSectionScrollViewerStyle}">
            <StackPanel Margin="0,5,20,0">
              <TextBlock Text="DATA FILES" Style="{StaticResource SectionPrimaryTextBlockStyle}"/>
              <TextBlock Text="Your data directories and additional content settings."
                         Style="{StaticResource SectionSecondaryTextBlockStyle}"/>
              <TextBlock Text="DOCUMENTS DIRECTORY" Style="{StaticResource FieldHeaderTextBlockStyle}"/>
              <TextBox IsReadOnly="true" controls:TextBoxHelper.TextButton="true"
                       Style="{DynamicResource MetroButtonTextBox}" Text="{Binding CustomRootDirectory}"
                       controls:TextBoxHelper.ButtonCommand="{Binding BrowseCustomRootDirectoryCommand}">
                <controls:TextBoxHelper.ButtonContent>
                  <iconPacks:PackIconMaterial Kind="FolderSearch" Width="14" Height="14"/>
                </controls:TextBoxHelper.ButtonContent>
              </TextBox>
              <TextBlock Text="The directory where your characters and gallery images are stored."
                         Style="{StaticResource SectionSecondaryTextBlockStyle}" FontSize="10"/>
              <TextBlock Text="ADDITIONAL CONTENT" Style="{StaticResource SectionPrimaryTextBlockStyle}" Margin="0,25,0,0"/>
              <TextBlock Text="Manage additional content added through index files."
                         Style="{StaticResource SectionSecondaryTextBlockStyle}"/>
              <userControls:DescriptionCheckBox Header="Automatic Updates" Margin="0,10"
                                                Description="Check for updates to additional content at startup."
                                                IsChecked="{Binding StartupCheckForContentUpdated, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
              <TextBlock Text="SECONDARY CONTENT DIRECTORY" Style="{StaticResource FieldHeaderTextBlockStyle}"/>
              <TextBox IsReadOnly="true" controls:TextBoxHelper.TextButton="true"
                       Style="{DynamicResource MetroButtonTextBox}" Text="{Binding AdditionalCustomDirectory}"
                       controls:TextBoxHelper.ButtonCommand="{Binding BrowseAdditionalCustomDirectoryCommand}">
                <controls:TextBoxHelper.ButtonContent>
                  <iconPacks:PackIconMaterial Kind="FolderSearch" Width="14" Height="14"/>
                </controls:TextBoxHelper.ButtonContent>
              </TextBox>
              <TextBlock Text="A separate directory where custom files can be loaded from. An ideal place for your own custom content."
                         Style="{StaticResource SectionSecondaryTextBlockStyle}" FontSize="10"/>
              <aurora:CommandButton CommandText="UNLINK SECONDARY DIRECTORY" Style="{StaticResource TextIconCommandButtonStyle}"
                                    HorizontalAlignment="Right" Margin="0,0,0,10"
                                    Command="{Binding ClearAdditionalCustomDirectoryCommand}">
                <iconPacks:PackIconMaterial Kind="FolderRemove" Width="14" Height="14"/>
              </aurora:CommandButton>
              <aurora:CommandButton Click="ClearNewsArticlesCache" x:Name="ClearNewsCacheButton"
                                    CommandText="Clear News Articles Cache" Margin="0,20,0,0" MinWidth="75"/>
            </StackPanel>
          </ScrollViewer>
        </controls:MetroTabItem>
        <controls:MetroTabItem Header="Equipment">
          <ScrollViewer Style="{StaticResource SettingsSectionScrollViewerStyle}">
            <StackPanel Margin="0,5,10,0">
              <TextBlock Text="EQUIPMENT" Style="{StaticResource SectionHeaderTextBlockStyle}" Margin="0,0,0,0"/>
              <TextBlock Text="General behaviour of the equipment section and your inventory."
                         Style="{StaticResource SectionSubHeaderTextBlockStyle}"/>
              <userControls:DescriptionCheckBox Header="'Add Weapon to Attacks' Confirmation" Margin="0,10,0,10"
                                                Description="Display a confirmation box when equipping a weapon that is not included in your 'Attacks' section to add it."
                                                IsChecked="{Binding RequestAddAttackWhenEquippingWeapon, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
          </ScrollViewer>
        </controls:MetroTabItem>
        <controls:MetroTabItem Header="Character" Visibility="Collapsed">
          <ScrollViewer>
            <StackPanel Margin="0,5,20,0">
              <TextBlock Text="CHARACTER GENERATION OPTIONS" Style="{StaticResource SectionHeaderTextBlockStyle}"
                         Margin="0,0,0,0"/>
              <TextBlock Text="Configue the character options for new characters. You can still change the options for each character individually after creating it."
                         Style="{StaticResource SectionSubHeaderTextBlockStyle}"/>
              <TextBlock Text="DEFAULT PLAYER NAME" Style="{StaticResource FieldHeaderTextBlockStyle}"/>
              <TextBox Text="{Binding DefaultPlayerName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
              <TextBlock Text="ABILITY SCORE GENERATION OPTION" Style="{StaticResource FieldHeaderTextBlockStyle}"/>
              <ComboBox ItemsSource="{Binding AbilitiesGenerationSelectionItems}"
                        SelectedItem="{Binding SelectedAbilityGenerateOption, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
              <TextBlock Text="Access and edit more options for your character from the menu with your characters name."
                         Style="{StaticResource SectionSubHeaderTextBlockStyle}"/>
            </StackPanel>
          </ScrollViewer>
        </controls:MetroTabItem>
        <controls:MetroTabItem Header="Character Sheet">
          <ScrollViewer Style="{StaticResource SettingsSectionScrollViewerStyle}">
            <StackPanel Margin="0,5,10,0">
              <TextBlock Text="CHARACTER SHEET" Style="{StaticResource SectionHeaderTextBlockStyle}" Margin="0"/>
              <TextBlock Text="Manage some aspects of the output of your character sheet."
                         Style="{StaticResource SectionSubHeaderTextBlockStyle}"/>
              <userControls:DescriptionCheckBox Header="Form Fillable" Description="Generate the sheet as form fillable so you can edit fields."
                                                Margin="0,10,0,10"
                                                IsChecked="{Binding AllowEditableSheet, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
              <userControls:DescriptionCheckBox Header="Style Formatting (Recommended)"
                                                Description="Apply some styling for certain fields such as Features &amp; Traits to improve readability. This option can be used in combination with form-fillable."
                                                Margin="0,0,0,10"
                                                IsChecked="{Binding IncludeFormatting, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
              <userControls:DescriptionCheckBox Header="Invert Ability Score"
                                                Description="This will switch the location of the ability score and modifier. This includes the companion page if you have it."
                                                Margin="0,0,0,0"
                                                IsChecked="{Binding FlippedAbilities, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
              <TextBlock Text="SPELLCASTING PAGE" Style="{StaticResource SectionPrimaryTextBlockStyle}" Margin="0,25,0,0"/>
              <TextBlock Text="Options specific to the spellcasting page."
                         Style="{StaticResource SectionSubHeaderTextBlockStyle}"/>
              <userControls:DescriptionCheckBox Header="Include Non-Prepared Spells"
                                                Description="When you need to prepare spells you can include spells you have not prepared to the spellcasting page. With the dynamic spellcasting page there is room for all the unprepared spells."
                                                Margin="0,0,0,0"
                                                IsChecked="{Binding SheetIncludeNonPreparedSpells, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
              <TextBlock Text="GENERATED CARDS" Style="{StaticResource SectionPrimaryTextBlockStyle}" Margin="0,25,0,0"/>
              <TextBlock Text="Include some of the additional custom generated cards."
                         Style="{StaticResource SectionSubHeaderTextBlockStyle}"/>
              <userControls:DescriptionCheckBox Header="Spell cards" Margin="0,0,0,10"
                                                Description="A description of the spell as well as the casting time, range, duration, and required components."
                                                IsChecked="{Binding IncludeSpellcards, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
              <userControls:DescriptionCheckBox Header="Item cards" Margin="0,0,0,10" Description="A description, details, and added notes."
                                                IsChecked="{Binding IncludeItemcards, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
              <userControls:DescriptionCheckBox Header="Start Item Cards on a New Page" Margin="20,0,0,0"
                                                Visibility="{Binding IncludeItemcards, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                IsChecked="{Binding StartItemCardsOnNewPage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
              <userControls:DescriptionCheckBox Header="Attack Cards" Margin="0,0,0,10"
                                                Description="Detailed attack cards for your weapon(s). Not to be confused with item cards for your weapons."
                                                IsChecked="{Binding IncludeAttackCards, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
              <userControls:DescriptionCheckBox Header="Start Attack Cards on a New Page" Margin="20,0,0,0"
                                                Visibility="{Binding IncludeAttackCards, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                IsChecked="{Binding StartAttackCardsOnNewPage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
              <userControls:DescriptionCheckBox Header="Feature Cards" Margin="0,0,0,10"
                                                Description="Detailed description for features such as racial traits, class and archetype features, and feats."
                                                IsChecked="{Binding IncludeFeatureCards, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
              <userControls:DescriptionCheckBox Header="Start Feature Cards on a New Page" Margin="20,0,0,0"
                                                Visibility="{Binding IncludeFeatureCards, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                IsChecked="{Binding StartFeatureCardsOnNewPage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
              <TextBlock Text="LEGACY" Style="{StaticResource SectionPrimaryTextBlockStyle}" Margin="0,25,0,0"/>
              <TextBlock Text="While the Aurora sheets are not yet finalized the legacy pages are still available should you choose to use it."
                         Style="{StaticResource SectionSubHeaderTextBlockStyle}"/>
              <userControls:DescriptionCheckBox Header="Legacy Spellcasting Page" Margin="0,0,0,10"
                                                Description="Use the single page basic spellcasting page layout. It's best not to use the non-prepared spells option when using this option due to limited space for spells."
                                                IsChecked="{Binding UseLegacySpellcastingPage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
          </ScrollViewer>
        </controls:MetroTabItem>
        <controls:MetroTabItem Header="Developer"
                               Visibility="{Binding IsInDeveloperMode, Converter={StaticResource BooleanToVisibilityConverter}}">
          <ScrollViewer Style="{StaticResource SettingsSectionScrollViewerStyle}">
            <StackPanel Margin="0,5,20,0">
              <TextBlock Text="SO YOU'RE A DEVELOPER NOW?" Style="{StaticResource SectionHeaderTextBlockStyle}"
                         Margin="0,0,0,0"/>
              <TextBlock Text="In the future you might find some special settings here, for now I'll only use this while debugging. :)"
                         Style="{StaticResource SectionSubHeaderTextBlockStyle}"/>
              <TextBlock Text="There is no priority on the developer window at the moment so this will be outdated and has limited usage."
                         Style="{StaticResource SectionSubHeaderTextBlockStyle}"/>
              <TextBlock Text="It's recommended not to use developer mode for normal usage as it does some extra's behind the scenes that might slow down the application. It's best to create one shortcut for normal use and one for developer mode."
                         Style="{StaticResource SectionSubHeaderTextBlockStyle}"/>
              <aurora:CommandButton Click="OnBrowseGitHubClick" CommandText="GitHub Repository" Margin="0,10,10,10" MinWidth="75"/>
            </StackPanel>
          </ScrollViewer>
        </controls:MetroTabItem>
        <controls:MetroTabItem Header="License">
