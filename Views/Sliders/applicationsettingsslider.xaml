<controls:Flyout x:Class="Builder.Presentation.Views.Sliders.ApplicationSettingsSlider"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:local="clr-namespace:Builder.Presentation.Views.Sliders"
                 xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:userControls="clr-namespace:Builder.Presentation.UserControls"
                 Theme="Light" VerticalAlignment="Center" VerticalContentAlignment="Center"
                 Background="{DynamicResource GrayBrush10}" CloseButtonVisibility="Collapsed"
                 IsAutoCloseEnabled="false" AutoCloseInterval="5000" TitleVisibility="Collapsed" Width="300"
                 Position="Right" IsModal="false" IsPinned="false" AreAnimationsEnabled="true" AnimateOpacity="true"
                 Margin="0,90,0,26" BorderBrush="{DynamicResource HighlightBrush}">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <Grid Background="{DynamicResource HighlightBrush}" Margin="20" Visibility="Collapsed">
      <StackPanel Margin="20,8">
        <TextBlock TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                   Style="{StaticResource WindowHeaderTextBlockStyle}" Foreground="{DynamicResource GrayBrush5}"
                   Text="{Binding Character.Name, Converter={StaticResource UpperCaseConverter}}"/>
      </StackPanel>
    </Grid>
    <StackPanel Grid.Row="1" Margin="0,0,0,0" Visibility="Collapsed"
                Background="{DynamicResource AuroraDarkColorBrush}">
      <Grid Margin="0,40,0,0">
        <Button Style="{StaticResource PortraitButtonStyle}" Margin="0"
                Background="{DynamicResource HighlightBrush}" Width="148" Height="148">
          <ContentControl.Content>
            <Grid>
              <Image HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="UniformToFill"
                     RenderTransformOrigin="0.5,0.5"
                     Source="{Binding Character.PortraitFilename, Converter={StaticResource ImageSourceConverter}}">
                <FrameworkElement.LayoutTransform>
                  <TransformGroup>
                    <ScaleTransform ScaleY="0.5" ScaleX="0.5"/>
                    <SkewTransform/>
                    <RotateTransform/>
                    <TranslateTransform/>
                  </TransformGroup>
                </FrameworkElement.LayoutTransform>
              </Image>
            </Grid>
          </ContentControl.Content>
        </Button>
        <Ellipse StrokeThickness="3" Margin="0" Stroke="{DynamicResource HighlightBrush}" Width="150" Height="150">
          <UIElement.Effect>
            <DropShadowEffect BlurRadius="5" Opacity="1" ShadowDepth="0"/>
          </UIElement.Effect>
        </Ellipse>
      </Grid>
      <TextBlock FontSize="26" HorizontalAlignment="Center" FontWeight="Normal"
                 Foreground="{DynamicResource GrayBrush5}" Margin="20,10,20,0" TextWrapping="Wrap"
                 TextAlignment="Center" Text="{Binding Character.Name, Converter={StaticResource ToUpperConverter}}"
                 Visibility="{Binding IsFavorite, Converter={StaticResource InvertedBooleanToVisibilityConverter}}"/>
      <TextBlock FontSize="11" HorizontalAlignment="Center" FontWeight="Normal"
                 Foreground="{DynamicResource GrayBrush6}" Margin="0,0,0,20"
                 Text="{Binding CharacterBuild, Converter={StaticResource ToUpperConverter}}"/>
    </StackPanel>
    <Grid Row="2">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource SectionTopBorder}" BorderThickness="0">
          <Grid Margin="0,10,0,10">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Text="STR" Style="{StaticResource PopupAttributeTextBlockStyle}" Grid.Column="0"/>
            <TextBlock Text="DEX" Style="{StaticResource PopupAttributeTextBlockStyle}" Grid.Column="1"/>
            <TextBlock Text="CON" Style="{StaticResource PopupAttributeTextBlockStyle}" Grid.Column="2"/>
            <TextBlock Text="INT" Style="{StaticResource PopupAttributeTextBlockStyle}" Grid.Column="3"/>
            <TextBlock Text="WIS" Style="{StaticResource PopupAttributeTextBlockStyle}" Grid.Column="4"/>
            <TextBlock Text="CHA" Style="{StaticResource PopupAttributeTextBlockStyle}" Grid.Column="5"/>
            <TextBlock Style="{StaticResource PopupScoreTextBlockStyle}" Grid.Column="0" Grid.Row="1"
                       Text="{Binding Character.Abilities.Strength.AbilityAndModifierString}"/>
            <TextBlock Style="{StaticResource PopupScoreTextBlockStyle}" Grid.Column="1" Grid.Row="1"
                       Text="{Binding Character.Abilities.Dexterity.AbilityAndModifierString}"/>
            <TextBlock Style="{StaticResource PopupScoreTextBlockStyle}" Grid.Column="2" Grid.Row="1"
                       Text="{Binding Character.Abilities.Constitution.AbilityAndModifierString}"/>
            <TextBlock Style="{StaticResource PopupScoreTextBlockStyle}" Grid.Column="3" Grid.Row="1"
                       Text="{Binding Character.Abilities.Intelligence.AbilityAndModifierString}"/>
            <TextBlock Style="{StaticResource PopupScoreTextBlockStyle}" Grid.Column="4" Grid.Row="1"
                       Text="{Binding Character.Abilities.Wisdom.AbilityAndModifierString}"/>
            <TextBlock Style="{StaticResource PopupScoreTextBlockStyle}" Grid.Column="5" Grid.Row="1"
                       Text="{Binding Character.Abilities.Charisma.AbilityAndModifierString}"/>
          </Grid>
        </Border>
        <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource SectionTopBorder}" BorderThickness="0,0,0,0">
          <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Text="AC" Style="{StaticResource PopupAttributeTextBlockStyle}" Grid.Row="0" Grid.Column="0"/>
            <TextBlock Text="INITIATIVE" Style="{StaticResource PopupAttributeTextBlockStyle}" Grid.Row="0"
                       Grid.Column="1" Grid.ColumnSpan="2"/>
            <TextBlock Text="SPEED" Style="{StaticResource PopupAttributeTextBlockStyle}" Grid.Row="0" Grid.Column="3"
                       Grid.ColumnSpan="2"/>
            <TextBlock Text="HP" Style="{StaticResource PopupAttributeTextBlockStyle}" Grid.Row="0" Grid.Column="5"/>
            <TextBlock Style="{StaticResource PopupScoreTextBlockStyle}" Grid.Column="0" Grid.Row="1"
                       ToolTip="Armor Class (AC). Armor protects its wearer from attacks. The armor (and shield) you wear determines your base Armor Class."
                       Text="{Binding Character.ArmorClass}"/>
            <TextBlock Style="{StaticResource PopupScoreTextBlockStyle}" Grid.Column="1" Grid.Row="1" Grid.ColumnSpan="2"
                       Text="{Binding Character.Initiative, Mode=OneWay, Converter={StaticResource BonusStringValueConverter}}"/>
            <TextBlock Style="{StaticResource PopupScoreTextBlockStyle}" Grid.Column="3" Grid.Row="1" Grid.ColumnSpan="2"
                       Text="{Binding Character.Speed, StringFormat={0}ft.}"/>
            <TextBlock Style="{StaticResource PopupScoreTextBlockStyle}" Grid.Column="5" Grid.Row="1"
                       Text="{Binding Character.MaxHp}"/>
          </Grid>
        </Border>
        <Border Grid.Row="3" Grid.Column="0" Style="{StaticResource SectionTopBorder}">
          <Expander x:Name="ExpanderSavingThrows" Header="Saving Throws" Style="{StaticResource WhiteExpanderStyle}">
            <userControls:SavingThrowsPanelContent Margin="5,0,0,5"/>
          </Expander>
        </Border>
        <Border Grid.Row="4" Grid.Column="0" Style="{StaticResource SectionTopBorder}">
          <Expander x:Name="ExpanderSkills" Header="Skills" Style="{StaticResource WhiteExpanderStyle}">
            <userControls:SkillsPanelContent Margin="5,0,0,5"/>
          </Expander>
        </Border>
        <Border Grid.Row="5" Grid.Column="0" Style="{StaticResource SectionTopBorder}">
          <Expander Header="Spells" Style="{StaticResource WhiteExpanderStyle}">
            <userControls:SpellsPanelContent Margin="5,0,0,5"/>
          </Expander>
        </Border>
        <Border Grid.Row="6" Grid.Column="0" Style="{StaticResource SectionTopBorder}"/>
      </Grid>
    </Grid>
    <Border BorderThickness="1,0,0,0" BorderBrush="{DynamicResource GrayBrush5}" Grid.Row="2" Grid.RowSpan="4"
            IsHitTestVisible="false"/>
  </Grid>
</controls:Flyout>