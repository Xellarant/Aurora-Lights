<metro:MetroWindow x:Class="Builder.Presentation.Views.ShellWindow"
                   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                   xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                   xmlns:metro="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
                   xmlns:converters="clr-namespace:Builder.Presentation.Converters"
                   xmlns:userControls="clr-namespace:Builder.Presentation.UserControls"
                   xmlns:viewModels="clr-namespace:Builder.Presentation.ViewModels"
                   xmlns:contentViewModels="clr-namespace:Builder.Presentation.ViewModels.Content"
                   xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
                   xmlns:start="clr-namespace:Builder.Presentation.ViewModels.Shell.Start"
                   xmlns:shell="clr-namespace:Builder.Presentation.ViewModels.Shell"
                   xmlns:items="clr-namespace:Builder.Presentation.ViewModels.Shell.Items"
                   xmlns:manage="clr-namespace:Builder.Presentation.ViewModels.Shell.Manage"
                   xmlns:controls="clr-namespace:Builder.Presentation.Controls"
                   xmlns:sliders="clr-namespace:Builder.Presentation.Views.Sliders"
                   xmlns:spellcasting="clr-namespace:Builder.Presentation.UserControls.Spellcasting"
                   xmlns:aurora="clr-namespace:Aurora.Presentation.Controls;assembly=Aurora.Presentation"
                   xmlns:i="clr-namespace:System.Windows.Interactivity;assembly=System.Windows.Interactivity"
                   xmlns:models="clr-namespace:Builder.Presentation.Models"
                   xmlns:manage1="clr-namespace:Builder.Presentation.UserControls.Manage"
                   xmlns:syndication="clr-namespace:Builder.Presentation.UserControls.Syndication"
                   xmlns:local="clr-namespace:Builder.Presentation"
                   xmlns:inventory="clr-namespace:Builder.Presentation.UserControls.Inventory"
                   xmlns:flyouts="clr-namespace:Builder.Presentation.Views.Flyouts"
                   xmlns:content="clr-namespace:Builder.Presentation.Views.Sliders.Content"
                   LocationChanged="ShellWindow_OnLocationChanged" SizeChanged="ShellWindow_OnSizeChanged"
                   Loaded="ShellWindow_OnLoaded" Closing="ShellWindow_OnClosing" x:Name="MainWindow" Width="1280"
                   Height="700" MinWidth="1090" MinHeight="580" ShowInTaskbar="true" Title="Aurora"
                   ResizeMode="CanResize" Style="{StaticResource CharacterBuilderWindowStyle}" TitleAlignment="Center"
                   RightWindowCommandsOverlayBehavior="Never" WindowButtonCommandsOverlayBehavior="Never"
                   LeftWindowCommandsOverlayBehavior="Never">
  <metro:MetroWindow.TitleTemplate>
    <DataTemplate>
      <Grid>
        <TextBlock FontSize="12" FontFamily="Segoe UI SemiBold" Foreground="{DynamicResource GrayBrush5}"
                   VerticalAlignment="Center" Margin="20,0,0,0" Text="{Binding}"/>
      </Grid>
    </DataTemplate>
  </metro:MetroWindow.TitleTemplate>
  <FrameworkElement.DataContext>
    <shell:ShellWindowViewModel/>
  </FrameworkElement.DataContext>
  <metro:MetroWindow.Flyouts>
    <metro:FlyoutsControl>
      <sliders:CharacterInformationSlider x:Name="NewPopupSlider"/>
      <sliders:ReleaseSlider x:Name="LoadingCharacterSlider" DataContext="{x:Null}"/>
      <sliders:CompendiumSlider x:Name="CompendiumSlider"/>
      <sliders:ManageCoinageSlider x:Name="ManageCoinageSlider"/>
      <sliders:NewCharacterSlider x:Name="NewCharacterSlider"/>
      <sliders:SaveCharacterSlider x:Name="SaveCharacterSlider"/>
      <sliders:AdvancementSlider x:Name="AdvancementSlider"/>
      <sliders:UpdateNotificationSlider x:Name="UpdateNotificationSlider"/>
      <sliders:ManageCharacterOptionsSlider x:Name="ManageCharacterOptionsSlider"/>
      <sliders:PortraitsGallerySlider x:Name="SelectPortraitSlider"/>
      <sliders:CompanionGallerySlider x:Name="CompanionGallerySlider"/>
      <sliders:SymbolsGallerySlider x:Name="SymbolsGallerySlider"/>
      <content:BundleContentFlyout x:Name="BundleContentFlyout"/>
      <flyouts:EditEquipmentItemFlyout x:Name="EditEquipmentItemFlyout"/>
      <sliders:SelectionFlowNotificationSlider x:Name="SelectionFlowNotificationSlider"/>
    </metro:FlyoutsControl>
  </metro:MetroWindow.Flyouts>
  <UIElement.InputBindings>
    <KeyBinding Key="F1" Command="{Binding KeyBindingOpenCompendiumCommand, ElementName=MainWindow}"/>
    <KeyBinding Key="F8" Command="{Binding ToggleCharacterOptionsCommand, ElementName=MainWindow}"/>
    <KeyBinding Key="Q" Modifiers="Alt" Command="{Binding KeyBindingQuickSearchBarCommand, ElementName=MainWindow}"/>
    <KeyBinding Key="OemTilde" Modifiers="Control" Command="{Binding EnableBundlesCommand, ElementName=MainWindow}"/>
    <KeyBinding Key="Space" Modifiers="Control" Command="{Binding EnableBundlesCommand, ElementName=MainWindow}"/>
    <KeyBinding Key="B" Modifiers="Alt" Command="{Binding EnableBundlesCommand, ElementName=MainWindow}"/>
    <KeyBinding Modifiers="Control" Key="N"
                Command="{Binding KeyBindingNewCharacterCommand, ElementName=MainWindow}"/>
    <KeyBinding Modifiers="Control" Key="S"
                Command="{Binding KeyBindingSaveCharacterCommand, ElementName=MainWindow}"/>
    <KeyBinding Modifiers="Control" Key="P"
                Command="{Binding KeyBindingPortraitsGalleryCommand, ElementName=MainWindow}"/>
    <KeyBinding Modifiers="Control" Key="V"
                Command="{Binding KeyBindingSheetViewerCommand, ElementName=MainWindow}"/>
    <KeyBinding Key="F9" Command="{Binding OpenToolsCommand}"/>
    <KeyBinding Key="F12" Command="{Binding OpenDeveloperToolsCommand}"/>
  </UIElement.InputBindings>
  <FrameworkElement.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="../Styles/CollectionDataTemplates/CharacterFileDataTemplates.xaml"/>
      </ResourceDictionary.MergedDictionaries>
      <Storyboard x:Key="SidePanelStoryboard1" TargetName="SideStackPanel" Duration="00:00:02">
        <DoubleAnimation From="30" To="300" Storyboard.TargetProperty="Width">
          <DoubleAnimation.EasingFunction>
            <PowerEase/>
          </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
      </Storyboard>
      <Storyboard x:Key="SidePanelStoryboard2" TargetName="SideStackPanel" Duration="00:00:02">
        <DoubleAnimation From="300" To="30" Storyboard.TargetProperty="Width">
          <DoubleAnimation.EasingFunction>
            <PowerEase/>
          </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
      </Storyboard>
      <Storyboard x:Key="SidePanelStoryboard1a" TargetName="SidePanelHost" Duration="00:00:04">
        <DoubleAnimation From="0" To="300" Storyboard.TargetProperty="Width">
          <DoubleAnimation.EasingFunction>
            <PowerEase/>
          </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
        <DoubleAnimation From="0" To="1" Storyboard.TargetProperty="Opacity">
          <DoubleAnimation.EasingFunction>
            <PowerEase/>
          </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
      </Storyboard>
      <Storyboard x:Key="SidePanelStoryboard2a" TargetName="SidePanelHost" Duration="00:00:04">
        <DoubleAnimation From="300" To="0" Storyboard.TargetProperty="Width">
          <DoubleAnimation.EasingFunction>
            <PowerEase/>
          </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
        <DoubleAnimation From="1" To="0" Storyboard.TargetProperty="Opacity">
          <DoubleAnimation.EasingFunction>
            <PowerEase/>
          </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
      </Storyboard>
      <DataTemplate x:Key="CharacterCollectionDataTemplate">
        <Border x:Name="CollectionItemBorder" BorderThickness="3" Background="{DynamicResource HighlightBrush}"
                BorderBrush="{DynamicResource HighlightBrush}" Margin="5" VerticalAlignment="Top">
          <Grid Margin="0" ToolTip="{Binding FilePath}">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="{Binding DataContext.ListViewItemSize, ElementName=MainTabContol, FallbackValue=160}"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="{Binding DataContext.ListViewItemSize, ElementName=MainTabContol, FallbackValue=160}"/>
            </Grid.RowDefinitions>
            <Border BorderThickness="0" BorderBrush="{DynamicResource AccentColorBrush}"
                    Background="{DynamicResource AccentColorBrush}" Margin="0" Grid.Row="0" SnapsToDevicePixels="true">
              <Image x:Name="Img" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center"
                     Source="{Binding DisplayPortraitFilePath}"/>
            </Border>
            <StackPanel VerticalAlignment="Bottom" Margin="0" Background="{DynamicResource AccentColorBrush}">
              <TextBlock Foreground="{DynamicResource PinnedCharacterIconColorBrush}" FontSize="14" TextWrapping="Wrap"
                         FontWeight="SemiBold" Margin="5"
                         Text="{Binding DisplayName, Converter={StaticResource ToUpperConverter}}"
                         Visibility="{Binding IsFavorite, Converter={StaticResource BooleanToVisibilityConverter}}"/>
              <TextBlock Foreground="{DynamicResource GrayBrush6}" FontSize="14" TextWrapping="Wrap" FontWeight="SemiBold"
                         Margin="5" Text="{Binding DisplayName, Converter={StaticResource ToUpperConverter}}"
                         Visibility="{Binding IsFavorite, Converter={StaticResource InvertedBooleanToVisibilityConverter}}"/>
              <TextBlock Foreground="{DynamicResource GrayBrush5}" FontSize="10" TextWrapping="Wrap" FontWeight="Normal"
                         Margin="5,-5,5,5" Text="{Binding DisplayBuild, Converter={StaticResource ToUpperConverter}}"/>
            </StackPanel>
            <Grid x:Name="IsSelectedPanel" VerticalAlignment="Top" Margin="0" Visibility="Collapsed">
              <TextBlock Margin="4,2,0,0" Foreground="{DynamicResource WhiteBrush}"
                         Style="{StaticResource FieldHeaderTextBlockStyle}" Text="{Binding DisplayVersion}">
                <UIElement.Effect>
                  <DropShadowEffect BlurRadius="10" Direction="0" ShadowDepth="0" Color="Black"/>
                </UIElement.Effect>
              </TextBlock>
              <Button x:Name="DeleteCharacterButton" Style="{StaticResource NewChromelessButtonStyle}"
                      BorderThickness="0" Background="{DynamicResource TransparentWhiteBrush}"
                      HorizontalAlignment="Right" ToolTip="Retire Character" VerticalAlignment="Top" Margin="0"
                      Padding="0" Foreground="{DynamicResource DragonHeadForegroundColorBrush}" FontSize="20"
                      FontFamily="Segoe UI Symbol"
                      Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type metro:MetroWindow}}}">
                <ContentControl.Content>
                  <iconPacks:PackIconMaterial Kind="CloseBox" Margin="4" Height="16" Width="16"/>
                </ContentControl.Content>
              </Button>
            </Grid>
          </Grid>
        </Border>
        <DataTemplate.Triggers>
          <DataTrigger Value="True"
                       Binding="{Binding Path=IsSelected, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ListBoxItem}}}">
            <Setter TargetName="IsSelectedPanel" Property="UIElement.Visibility" Value="Visible"/>
            <Setter TargetName="CollectionItemBorder" Property="FrameworkElement.Margin" Value="5"/>
            <Setter TargetName="CollectionItemBorder" Property="Border.Padding" Value="3"/>
            <Setter TargetName="CollectionItemBorder" Property="Border.BorderThickness" Value="0"/>
            <Setter TargetName="CollectionItemBorder" Value="{DynamicResource AuroraGoldColorBrush}"
                    Property="Border.BorderBrush"/>
          </DataTrigger>
        </DataTemplate.Triggers>
      </DataTemplate>
      <DataTemplate x:Key="RefactoredCharacterCollectionDataTemplate">
        <Border x:Name="CollectionItemBorder" Background="{DynamicResource White1Brush}" BorderThickness="2"
                BorderBrush="{DynamicResource White2Brush}" Margin="0" Cursor="Hand" VerticalAlignment="Top"
                Padding="5"
                Height="{Binding DataContext.ListViewItemSize, ElementName=MainTabContol, FallbackValue=140}"
                Width="{Binding DataContext.ListViewItemSize, ElementName=MainTabContol, FallbackValue=140}">
          <Grid Margin="0" ToolTip="{Binding FilePath}">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border BorderThickness="0" BorderBrush="{DynamicResource WhiteBrush}"
                    Background="{DynamicResource AuroraDarkBrush}" Grid.Row="0" SnapsToDevicePixels="true">
              <Image x:Name="Img" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center"
                     Margin="0" Opacity="0.5" Source="{Binding DisplayPortraitFilePath}"/>
            </Border>
            <StackPanel x:Name="CharacterCollectionItemOverlay" Grid.Row="0" VerticalAlignment="Bottom" Margin="0"
                        Background="#66000000">
              <TextBlock Foreground="{DynamicResource PinnedCharacterIconColorBrush}" FontSize="14" TextWrapping="Wrap"
                         FontWeight="SemiBold" Margin="5,5,5,5"
                         Text="{Binding DisplayName, Converter={StaticResource ToUpperConverter}}"
                         Visibility="{Binding IsFavorite, Converter={StaticResource BooleanToVisibilityConverter}}"/>
              <TextBlock Foreground="{DynamicResource AuroraLightBrush}" FontSize="14" TextWrapping="Wrap"
                         FontWeight="SemiBold" Margin="5,5,5,5"
                         Text="{Binding DisplayName, Converter={StaticResource ToUpperConverter}}"
                         Visibility="{Binding IsFavorite, Converter={StaticResource InvertedBooleanToVisibilityConverter}}"/>
              <TextBlock Foreground="{DynamicResource GrayBrush7}" FontSize="10" TextWrapping="Wrap" FontWeight="Normal"
                         Margin="5,-5,5,5" Text="{Binding DisplayBuild, Converter={StaticResource ToUpperConverter}}"/>
            </StackPanel>
            <Grid x:Name="IsSelectedPanel" Row="0" Margin="0" Visibility="Collapsed">
              <Button x:Name="DeleteCharacterButton" Style="{StaticResource NewChromelessButtonStyle}"
                      VerticalAlignment="Top" HorizontalAlignment="Right"
                      Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type metro:MetroWindow}}}">
                <ContentControl.Content>
                  <iconPacks:PackIconMaterial Kind="CloseBox" Margin="5,8" Width="16" Foreground="{DynamicResource DangerColorBrush}"/>
                </ContentControl.Content>
              </Button>
              <StackPanel Grid.Column="0" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="7,5,0,0">
                <TextBlock Foreground="{DynamicResource TextBrush}" FontSize="10" TextWrapping="Wrap" FontWeight="SemiBold"
                           Margin="0" Text="{Binding DisplayVersion, Converter={StaticResource ToUpperConverter}}"/>
              </StackPanel>
            </Grid>
          </Grid>
        </Border>
        <DataTemplate.Triggers>
          <DataTrigger Value="True"
                       Binding="{Binding Path=IsSelected, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ListBoxItem}}}">
            <Setter TargetName="IsSelectedPanel" Property="UIElement.Visibility" Value="Visible"/>
            <Setter TargetName="CollectionItemBorder" Property="FrameworkElement.Margin" Value="0"/>
            <Setter TargetName="CollectionItemBorder" Property="Border.Padding" Value="5"/>
            <Setter TargetName="Img" Property="UIElement.Opacity" Value="1"/>
            <Setter TargetName="Img" Property="FrameworkElement.Margin" Value="0"/>
            <Setter TargetName="CharacterCollectionItemOverlay" Property="FrameworkElement.Margin" Value="0"/>
          </DataTrigger>
        </DataTemplate.Triggers>
      </DataTemplate>
      <DataTemplate x:Key="ListCharacterCollectionDataTemplate">
        <Border x:Name="CollectionItemBorder" Background="{DynamicResource White1Brush}" BorderThickness="2"
                BorderBrush="{DynamicResource White2Brush}" Margin="5" Cursor="Hand" VerticalAlignment="Top">
          <Grid Margin="0" ToolTip="{Binding FilePath}">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="60"/>
              <ColumnDefinition Width="500"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="60"/>
            </Grid.RowDefinitions>
            <Border BorderThickness="0,0,0,0" BorderBrush="{DynamicResource White2Brush}"
                    Background="{DynamicResource AuroraDarkBrush}" Margin="2" Grid.Row="0" SnapsToDevicePixels="true">
              <Image x:Name="Img" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center"
                     Opacity="0.5" Source="{Binding DisplayPortraitFilePath}"/>
            </Border>
            <StackPanel Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" Margin="5">
              <TextBlock Foreground="{DynamicResource PinnedCharacterIconColorBrush}" FontSize="14" TextWrapping="Wrap"
                         FontWeight="SemiBold" Margin="5,5,5,5"
                         Text="{Binding DisplayName, Converter={StaticResource ToUpperConverter}}"
                         Visibility="{Binding IsFavorite, Converter={StaticResource BooleanToVisibilityConverter}}"/>
              <TextBlock Foreground="{DynamicResource AuroraLightBrush}" FontSize="14" TextWrapping="Wrap"
                         FontWeight="SemiBold" Margin="5,5,5,5"
                         Text="{Binding DisplayName, Converter={StaticResource ToUpperConverter}}"
                         Visibility="{Binding IsFavorite, Converter={StaticResource InvertedBooleanToVisibilityConverter}}"/>
              <TextBlock Foreground="{DynamicResource GrayBrush7}" FontSize="10" TextWrapping="Wrap" FontWeight="Normal"
                         Margin="5,-5,5,5" Text="{Binding DisplayBuild, Converter={StaticResource ToUpperConverter}}"/>
            </StackPanel>
            <Grid x:Name="IsSelectedPanel" Row="0" Column="1" Margin="0" Visibility="Collapsed">
              <Button x:Name="DeleteCharacterButton" Style="{StaticResource NewChromelessButtonStyle}"
                      VerticalAlignment="Top" HorizontalAlignment="Right"
                      Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type metro:MetroWindow}}}">
                <ContentControl.Content>
                  <iconPacks:PackIconMaterial Kind="CloseBox" Margin="5,8" Width="16" Foreground="{DynamicResource DangerColorBrush}"/>
                </ContentControl.Content>
              </Button>
              <StackPanel Grid.Column="0" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="7,5,5,5">
                <TextBlock Foreground="{DynamicResource TextBrush}" FontSize="10" TextWrapping="Wrap" FontWeight="SemiBold"
                           Margin="0" Text="{Binding DisplayVersion, Converter={StaticResource ToUpperConverter}}"/>
              </StackPanel>
            </Grid>
          </Grid>
        </Border>
        <DataTemplate.Triggers>
          <DataTrigger Value="True"
                       Binding="{Binding Path=IsSelected, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ListBoxItem}}}">
            <Setter TargetName="IsSelectedPanel" Property="UIElement.Visibility" Value="Visible"/>
            <Setter TargetName="CollectionItemBorder" Property="FrameworkElement.Margin" Value="5"/>
            <Setter TargetName="CollectionItemBorder" Property="Border.Padding" Value="0"/>
            <Setter TargetName="Img" Property="UIElement.Opacity" Value="1"/>
          </DataTrigger>
        </DataTemplate.Triggers>
      </DataTemplate>
      <DataTemplate x:Key="CharacterFileCleanTemplate">
        <Border x:Name="ItemBorder" Background="{DynamicResource WhiteColorBrush}" BorderThickness="2"
                BorderBrush="#FF242424" CornerRadius="2" Margin="0" Padding="3"
                Height="{Binding DataContext.ListViewItemSize, ElementName=MainTabContol, FallbackValue=140}"
                Width="{Binding DataContext.ListViewItemSize, ElementName=MainTabContol, FallbackValue=140}">
          <Grid Margin="0" ToolTip="{Binding FilePath}">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border x:Name="ImageContainer" BorderThickness="0" BorderBrush="{DynamicResource WhiteBrush}"
                    Background="{DynamicResource AuroraDarkBrush}" Grid.Row="0" SnapsToDevicePixels="true">
              <Image x:Name="Img" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center"
                     Margin="0" Opacity="0.5" Source="{Binding DisplayPortraitFilePath}"/>
            </Border>
            <StackPanel x:Name="CharacterCollectionItemOverlay" Grid.Row="0" VerticalAlignment="Bottom" Margin="0"
                        Background="#66000000">
              <TextBlock Foreground="{DynamicResource PinnedCharacterIconColorBrush}" FontSize="14" TextWrapping="Wrap"
                         FontWeight="SemiBold" Margin="5,5,5,5"
                         Text="{Binding DisplayName, Converter={StaticResource ToUpperConverter}}"
                         Visibility="{Binding IsFavorite, Converter={StaticResource BooleanToVisibilityConverter}}"/>
              <TextBlock Foreground="{DynamicResource AuroraLightBrush}" FontSize="14" TextWrapping="Wrap"
                         FontWeight="SemiBold" Margin="5,5,5,5"
                         Text="{Binding DisplayName, Converter={StaticResource ToUpperConverter}}"
                         Visibility="{Binding IsFavorite, Converter={StaticResource InvertedBooleanToVisibilityConverter}}"/>
              <TextBlock Foreground="{DynamicResource GrayBrush7}" FontSize="10" TextWrapping="Wrap" FontWeight="Normal"
                         Margin="5,-5,5,5" Text="{Binding DisplayBuild, Converter={StaticResource ToUpperConverter}}"/>
            </StackPanel>
            <Grid x:Name="IsSelectedPanel" Row="0" Margin="0" Visibility="Collapsed">
              <aurora:CommandButton x:Name="DeleteCharacterButton" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="2"
                                    Style="{StaticResource DangerCommandButtonStyle}" MinWidth="20" Height="20"
                                    Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type metro:MetroWindow}}}">
                <iconPacks:PackIconMaterial Kind="Close" Height="10" Width="10"/>
              </aurora:CommandButton>
              <StackPanel Grid.Column="0" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="7,5,0,0"
                          Visibility="Collapsed">
                <TextBlock Foreground="{DynamicResource TextBrush}" FontSize="10" TextWrapping="Wrap" FontWeight="SemiBold"
                           Margin="0" Text="{Binding DisplayVersion, Converter={StaticResource ToUpperConverter}}"/>
              </StackPanel>
            </Grid>
          </Grid>
        </Border>
        <DataTemplate.Triggers>
          <DataTrigger Value="True"
                       Binding="{Binding Path=IsSelected, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ListBoxItem}}}">
            <Setter TargetName="IsSelectedPanel" Property="UIElement.Visibility" Value="Visible"/>
            <Setter TargetName="ItemBorder" Property="FrameworkElement.Margin" Value="0"/>
            <Setter TargetName="ItemBorder" Property="Border.Padding" Value="0"/>
            <Setter TargetName="ItemBorder" Property="Border.BorderThickness" Value="2"/>
            <Setter TargetName="Img" Property="UIElement.Opacity" Value="1"/>
            <Setter TargetName="Img" Property="FrameworkElement.Margin" Value="0"/>
            <Setter TargetName="CharacterCollectionItemOverlay" Property="FrameworkElement.Margin" Value="0"/>
          </DataTrigger>
        </DataTemplate.Triggers>
      </DataTemplate>
      <DataTemplate x:Key="CharacterFileItemTemplate">
        <Border x:Name="ItemBorder" Background="{DynamicResource WhiteColorBrush}" BorderThickness="2"
                BorderBrush="#FF242425" Margin="0" Padding="3"
                Height="{Binding DataContext.ListViewItemSize, ElementName=MainTabContol, FallbackValue=140}"
                Width="{Binding DataContext.ListViewItemSize, ElementName=MainTabContol, FallbackValue=140}">
          <Grid Margin="0" ToolTip="{Binding FilePath}">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border x:Name="ImageContainer" BorderThickness="0" BorderBrush="{DynamicResource WhiteBrush}"
                    Background="{DynamicResource AuroraDarkBrush}" Grid.Row="0" SnapsToDevicePixels="true">
              <Image x:Name="Img" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center"
                     Margin="0" Opacity="0.5" Source="{Binding DisplayPortraitFilePath}"/>
            </Border>
            <StackPanel x:Name="CharacterCollectionItemOverlay" Grid.Row="0" VerticalAlignment="Bottom" Margin="0"
                        Background="#66000000">
              <TextBlock Foreground="{DynamicResource PinnedCharacterIconColorBrush}" FontSize="14" TextWrapping="Wrap"
                         FontWeight="SemiBold" Margin="5,5,5,5"
                         Text="{Binding DisplayName, Converter={StaticResource ToUpperConverter}}"
                         Visibility="{Binding IsFavorite, Converter={StaticResource BooleanToVisibilityConverter}}"/>
              <TextBlock Foreground="{DynamicResource AuroraLightBrush}" FontSize="14" TextWrapping="Wrap"
                         FontWeight="SemiBold" Margin="5,5,5,5"
                         Text="{Binding DisplayName, Converter={StaticResource ToUpperConverter}}"
                         Visibility="{Binding IsFavorite, Converter={StaticResource InvertedBooleanToVisibilityConverter}}"/>
              <TextBlock Foreground="{DynamicResource GrayBrush7}" FontSize="10" TextWrapping="Wrap" FontWeight="Normal"
                         Margin="5,-5,5,5" Text="{Binding DisplayBuild, Converter={StaticResource ToUpperConverter}}"/>
            </StackPanel>
            <Grid x:Name="IsSelectedPanel" Row="0" Margin="0" Visibility="Collapsed">
              <StackPanel Orientation="Horizontal" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="2">
                <aurora:CommandButton VerticalAlignment="Top" HorizontalAlignment="Left" ToolTip="Set the group for this character."
                                      MinWidth="20" Height="20"
                                      Command="{Binding DataContext.EditCharacterGroupCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type metro:MetroWindow}}}"
                                      CommandParameter="{Binding}">
                  <iconPacks:PackIconMaterial Kind="Pencil" Height="10" Width="10"/>
                </aurora:CommandButton>
              </StackPanel>
              <StackPanel Orientation="Horizontal" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="2">
                <aurora:CommandButton x:Name="DeleteCharacterButton" Style="{StaticResource DangerCommandButtonStyle}" MinWidth="20"
                                      Height="20" Margin="5,0,0,0"
                                      Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type metro:MetroWindow}}}">
                  <iconPacks:PackIconMaterial Kind="Close" Height="10" Width="10"/>
                </aurora:CommandButton>
              </StackPanel>
              <StackPanel Grid.Column="0" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="7,5,0,0"
                          Visibility="Collapsed">
                <TextBlock Foreground="{DynamicResource TextBrush}" FontSize="10" TextWrapping="Wrap" FontWeight="SemiBold"
                           Margin="0" Text="{Binding DisplayVersion, Converter={StaticResource ToUpperConverter}}"/>
              </StackPanel>
            </Grid>
          </Grid>
        </Border>
        <DataTemplate.Triggers>
          <DataTrigger Value="True"
                       Binding="{Binding Path=IsSelected, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ListBoxItem}}}">
            <Setter TargetName="IsSelectedPanel" Property="UIElement.Visibility" Value="Visible"/>
            <Setter TargetName="ItemBorder" Property="FrameworkElement.Margin" Value="0"/>
            <Setter TargetName="ItemBorder" Property="Border.Padding" Value="0"/>
            <Setter TargetName="ItemBorder" Property="Border.BorderThickness" Value="2"/>
            <Setter TargetName="Img" Property="UIElement.Opacity" Value="1"/>
            <Setter TargetName="Img" Property="FrameworkElement.Margin" Value="0"/>
            <Setter TargetName="CharacterCollectionItemOverlay" Property="FrameworkElement.Margin" Value="0"/>
            <Setter TargetName="CharacterCollectionItemOverlay" Property="Panel.Background" Value="#DD111113"/>
          </DataTrigger>
        </DataTemplate.Triggers>
      </DataTemplate>
    </ResourceDictionary>
  </FrameworkElement.Resources>
  <metro:MetroWindow.LeftWindowCommands>
    <metro:WindowCommands ShowSeparators="false" Foreground="{StaticResource WhiteBrush}">
      <Grid>
        <FrameworkElement.Resources>
          <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
              <ResourceDictionary Source="/Styles/Builder/MenuStyle.xaml"/>
              <ResourceDictionary Source="/Styles/Builder/MenuIcons.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style TargetType="{x:Type MenuItem}" BasedOn="{StaticResource AuroraMenuItem}">
              <Setter Property="Control.FontWeight" Value="Normal"/>
            </Style>
          </ResourceDictionary>
        </FrameworkElement.Resources>
        <Menu Margin="10,1,0,0" Background="{DynamicResource TransparentWhiteBrush}">
