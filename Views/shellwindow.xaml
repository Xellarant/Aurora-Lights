                  <TextBlock Text="Aurora comes bundled with all content that is included in the System Reference Document released under the Open Gaming License. On the 'Additional Content' page on the website you can read and learn how to extend the content."
                             Style="{StaticResource FlavorDescriptionTextBlockStyle}" FontSize="13" TextWrapping="Wrap"
                             Margin="0,0,0,10"/>
                  <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
                    <aurora:CommandButton Click="BrowseContentClick" CommandText="Visit Website" Margin="0,0,10,0" HorizontalAlignment="Left"
                                          MinWidth="110"/>
                  </StackPanel>
                  <TextBlock Text="INDEX FILES" Style="{StaticResource SectionPrimaryTextBlockStyle}" FontSize="13"
                             Margin="0,0,0,5"/>
                  <TextBlock Text="Index files allow the creator to update his or her files and allow Aurora to automatically download and update the content. When you've obtained the URL of the .index file; enter it in the field below and click 'Download' and then click 'Update Content Files'."
