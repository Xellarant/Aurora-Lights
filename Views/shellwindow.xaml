                <StackPanel Grid.ColumnSpan="1" Margin="0,10,20,10" HorizontalAlignment="Left">
                  <TextBlock Text="EXTENDING THE CONTENT" FontSize="14" Style="{StaticResource SectionPrimaryTextBlockStyle}"
