                      <StackPanel Grid.Row="12" Grid.Column="0" Grid.ColumnSpan="5" Margin="0,0,0,10">
                        <TextBlock Text="ADDITIONAL FEATURES" Style="{StaticResource SectionHeaderTextBlockStyle}" Margin="0,40,0,0"/>
                        <TextBlock Text="Does your character have any additional features that are from a different source than your race, class, or background?"
                                   Style="{StaticResource SectionSubHeaderTextBlockStyle}"/>
                        <TextBlock Text="ADDITIONAL FEATURES" Style="{StaticResource FieldHeaderTextBlockStyle}"/>
                        <TextBox AcceptsTab="true" AcceptsReturn="true" MinHeight="100" TextWrapping="Wrap"
                                 Text="{Binding Character.AdditionalFeatures, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                      </StackPanel>
                    </Grid>
                  </StackPanel>
                </ScrollViewer>
              </Grid>
            </metro:MetroTabItem>
            <metro:MetroTabItem Header="BACKSTORY">
              <Grid Margin="10,2,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="3*"/>
                      <ColumnDefinition Width="20"/>
                      <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    <Grid Column="2" Margin="0,10,20,0">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                      </Grid.ColumnDefinitions>
                      <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                      </Grid.RowDefinitions>
                      <StackPanel Grid.Row="0" Grid.RowSpan="1" Grid.Column="0">
                        <StackPanel>
                          <TextBlock Text="BACKSTORY" Style="{StaticResource SectionHeaderTextBlockStyle}" Margin="0"/>
                          <TextBlock Text="Every story has a beginning. Your character's background reveals where you came from, how you became an adventurer, and your place in the world."
                                     Style="{StaticResource SectionSubHeaderTextBlockStyle}"/>
                        </StackPanel>
                        <userControls:FillableFieldTextBox Grid.Row="1" Header="Write your story" MinContentHeight="208"
                                                           DataContext="{Binding Character.BackgroundStory}"/>
                      </StackPanel>
                    </Grid>
                    <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="1" Margin="0,10,0,10">
                      <TextBlock Text="BACKGROUND CHARACTERISTICS" Style="{StaticResource SectionHeaderTextBlockStyle}" Margin="0"/>
                      <TextBlock Text="Fleshing out your character's personality—the array of traits, mannerisms, habits, beliefs, and flaws that give a person a unique identity—will help you bring him or her to life as you play the game."
                                 Style="{StaticResource SectionSubHeaderTextBlockStyle}"/>
                      <userControls:FillableFieldTextBox Header="Personality Traits"
                                                         DataContext="{Binding Character.FillableBackgroundCharacteristics.Traits}"/>
                      <userControls:FillableFieldTextBox Header="Ideal" DataContext="{Binding Character.FillableBackgroundCharacteristics.Ideals}"/>
                      <userControls:FillableFieldTextBox Header="Bond" DataContext="{Binding Character.FillableBackgroundCharacteristics.Bonds}"/>
                      <userControls:FillableFieldTextBox Header="Flaw" DataContext="{Binding Character.FillableBackgroundCharacteristics.Flaws}"/>
                      <TextBlock Text="TRINKET" Style="{StaticResource SectionHeaderTextBlockStyle}"/>
                      <TextBlock Text="When you make your character, you can roll once on the Trinkets table to gain a trinket, a simple item lightly touched by mystery."
                                 Style="{StaticResource SectionSubHeaderTextBlockStyle}"/>
                      <TextBlock Text="PICK A TRINKET" Style="{StaticResource FieldHeaderTextBlockStyle}"/>
                      <ComboBox IsEditable="true"
                                Text="{Binding Character.Trinket.Content, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                ItemsSource="{Binding Trinkets}"/>
                      <aurora:CommandButton Margin="0,2,0,0" CommandText="CLICK TO RANDOMIZE A TRINKET"
                                            Style="{StaticResource TextIconCommandButtonStyle}" HorizontalAlignment="Right"
                                            Command="{Binding RandomizeTrinketCommand}">
                        <iconPacks:PackIconFontAwesome Kind="RandomSolid"/>
                      </aurora:CommandButton>
                      <StackPanel Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="5">
                        <TextBlock Text="BACKGROUND FEATURE" Style="{StaticResource SectionHeaderTextBlockStyle}" Margin="0,15,0,0"/>
                        <userControls:FillableFieldTextBox Header="Feature Name"
                                                           Tooltip="The change you made here overrides the value set automatically. You can clear the field to restore the original value."
                                                           DataContext="{Binding Character.BackgroundFeatureName}"/>
                        <userControls:FillableFieldTextBox Header="Description" MinContentHeight="52"
                                                           DataContext="{Binding Character.BackgroundFeatureDescription}"/>
                      </StackPanel>
                    </StackPanel>
                  </Grid>
                </ScrollViewer>
              </Grid>
            </metro:MetroTabItem>
            <metro:MetroTabItem Header="NOTES">
              <Grid Margin="10,10,20,20">
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                  </Grid.RowDefinitions>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="Optional notes that will be included in the character sheet. The notes sheet will only be included if there is something in the notes."
                             Grid.ColumnSpan="3" Style="{StaticResource FlavorDescriptionTextBlockStyle}" Margin="0,0,0,20"/>
                  <StackPanel Grid.Row="1" Grid.Column="0">
                    <TextBox AcceptsTab="false" AcceptsReturn="true" Padding="4"
                             metro:TextBoxHelper.Watermark="Add notes to the left column..."
                             BorderBrush="{DynamicResource Aurora.Brushes.Light2}" TextBlock.LineHeight="20"
                             VerticalScrollBarVisibility="Auto" MinHeight="200" MaxHeight="400" TextWrapping="Wrap"
                             Text="{Binding Character.Notes1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                  </StackPanel>
                  <StackPanel Grid.Column="2" Grid.Row="1">
                    <TextBox AcceptsTab="false" AcceptsReturn="true" Padding="4"
                             metro:TextBoxHelper.Watermark="Add notes to the right column..."
                             BorderBrush="{DynamicResource Aurora.Brushes.Light2}" TextBlock.LineHeight="20"
                             VerticalScrollBarVisibility="Auto" MinHeight="200" MaxHeight="400" TextWrapping="Wrap"
                             Text="{Binding Character.Notes2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                  </StackPanel>
                </Grid>
              </Grid>
            </metro:MetroTabItem>
            <metro:MetroTabItem Header="ALLIES &amp; ORGANIZATIONS">
              <Grid Margin="10,2,0,0">
                <FrameworkElement.Resources>
                  <Style TargetType="{x:Type TextBox}" BasedOn="{StaticResource {x:Type TextBox}}">
                    <Setter Property="FrameworkElement.Margin" Value="0,0,0,10"/>
                  </Style>
                </FrameworkElement.Resources>
                <StackPanel>
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="20"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.ColumnSpan="2" Margin="0,0,0,10">
                      <TextBlock Text="ORGANIZATION" Style="{StaticResource SectionPrimaryTextBlockStyle}" Margin="0,10,0,0"/>
                      <TextBlock Text="Does your character belong to any organization?"
                                 Style="{StaticResource SectionSecondaryTextBlockStyle}"/>
                    </StackPanel>
                    <Border Background="{StaticResource AuroraDarkBrush}" Grid.Row="1" Grid.Column="0" Height="150" Width="150"
                            BorderBrush="#FF242424" BorderThickness="2" Margin="0,0,10,0">
                      <Image Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center"
                             Source="{Binding Character.OrganisationSymbol}"/>
                    </Border>
                    <StackPanel Grid.Row="1" Grid.ColumnSpan="1" Grid.Column="1" Margin="0,0,0,29" Width="300"
                                HorizontalAlignment="Left">
                      <TextBlock Text="ORGANIZATION" Style="{StaticResource FieldHeaderTextBlockStyle}" Margin="0,0,0,2"/>
                      <ComboBox IsEditable="true" HorizontalAlignment="Left" Width="300" Margin="0,0,0,2"
                                Text="{Binding Character.OrganisationName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                ItemsSource="{Binding Organizations}"/>
                      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <aurora:CommandButton CommandText="SELECT ORGANIZATION SYMBOL" Margin="0,0,10,0"
                                              Style="{StaticResource TextIconCommandButtonStyle}" Command="{Binding ShowSymbolsGalleryCommand}">
                          <iconPacks:PackIconMaterial Kind="ImageSearch" Width="12" Height="12"/>
                        </aurora:CommandButton>
                        <aurora:CommandButton CommandText="REMOVE SYMBOL" Style="{StaticResource DangerTextIconCommandButtonStyle}"
                                              Margin="0,0,0,0" Command="{Binding ClearSymbolCommand}">
                          <iconPacks:PackIconMaterial Kind="ImageOff" Width="12" Height="11"/>
                        </aurora:CommandButton>
                      </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="0,0,0,29">
                      <TextBlock Text="ALLIES" Style="{StaticResource SectionPrimaryTextBlockStyle}" Margin="0,25,0,0"/>
                      <TextBlock Text="Are there specific allies worth mentioning?"
                                 Style="{StaticResource SectionSecondaryTextBlockStyle}"/>
                      <TextBlock Text="MENTION YOUR ALLIES" Style="{StaticResource FieldHeaderTextBlockStyle}"/>
                      <TextBox AcceptsTab="false" AcceptsReturn="true" MinHeight="100" TextWrapping="Wrap"
                               Text="{Binding Character.Allies, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                  </Grid>
                </StackPanel>
              </Grid>
            </metro:MetroTabItem>
            <metro:MetroTabItem Header="COMPANION"
                                Visibility="{Binding CharacterManager.Status.HasCompanion, Converter={StaticResource BooleanToVisibilityConverter}}">
              <Grid Margin="10,0,0,0">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="11*" MinWidth="775"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ScrollViewer Margin="0,2,0,0">
                  <StackPanel Margin="0,00,10,0">
                    <TextBlock Text="COMPANION" Style="{StaticResource SectionHeaderTextBlockStyle}" Margin="0,10,0,0"/>
                    <TextBlock Text="A companion that accompanies you on your adventures and is trained to fight alongside you."
                               Style="{StaticResource SectionSubHeaderTextBlockStyle}"/>
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                      </Grid.ColumnDefinitions>
                      <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto" MinHeight="10"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                      </Grid.RowDefinitions>
                      <StackPanel>
                        <userControls:FillableFieldTextBox Header="Companion Name" DataContext="{Binding Character.Companion.CompanionName}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                          <aurora:CommandButton CommandText="Companions Gallery" Margin="0,0,10,10"
                                                Command="{Binding ShowCompanionsGalleryCommand}">
                            <iconPacks:PackIconMaterial Kind="ImageSearch"/>
                          </aurora:CommandButton>
                        </StackPanel>
                      </StackPanel>
                      <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="1" Margin="0,10,0,0" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="3">
                          <userControls:AbilitiesSpinner Margin="10" DataContext="{Binding Character.Companion.Abilities.Strength}"/>
                          <userControls:AbilitiesSpinner Margin="10" DataContext="{Binding Character.Companion.Abilities.Dexterity}"/>
                          <userControls:AbilitiesSpinner Margin="10" DataContext="{Binding Character.Companion.Abilities.Constitution}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="3">
                          <userControls:AbilitiesSpinner Margin="10" DataContext="{Binding Character.Companion.Abilities.Intelligence}"/>
                          <userControls:AbilitiesSpinner Margin="10" DataContext="{Binding Character.Companion.Abilities.Wisdom}"/>
                          <userControls:AbilitiesSpinner Margin="10" DataContext="{Binding Character.Companion.Abilities.Charisma}"/>
                        </StackPanel>
                      </StackPanel>
                    </Grid>
                  </StackPanel>
                </ScrollViewer>
                <GridSplitter Grid.Column="0" Width="2" Background="{DynamicResource AccentColorBrush4}"/>
                <ScrollViewer Grid.Row="0" Grid.Column="1" Margin="0,10,10,10" Visibility="Collapsed">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource SectionTopBorder}" BorderThickness="0">
                      <Expander Header="Ability Scores" IsExpanded="true" Style="{StaticResource WhiteExpanderStyle}">
                        <Grid Margin="0,0,0,10">
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                          </Grid.ColumnDefinitions>
                          <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                          </Grid.RowDefinitions>
                          <TextBlock Text="STR" Style="{StaticResource PopupAttributeTextBlockStyle}" Grid.Column="0"/>
                          <TextBlock Text="DEX" Style="{StaticResource PopupAttributeTextBlockStyle}" Grid.Column="1"/>
                          <TextBlock Text="CON" Style="{StaticResource PopupAttributeTextBlockStyle}" Grid.Column="2"/>
                          <TextBlock Text="INT" Style="{StaticResource PopupAttributeTextBlockStyle}" Grid.Column="3"/>
                          <TextBlock Text="WIS" Style="{StaticResource PopupAttributeTextBlockStyle}" Grid.Column="4"/>
                          <TextBlock Text="CHA" Style="{StaticResource PopupAttributeTextBlockStyle}" Grid.Column="5"/>
                          <TextBlock Style="{StaticResource PopupScoreTextBlockStyle}" Grid.Column="0" Grid.Row="1"
                                     Text="{Binding Character.Abilities.Strength.AbilityAndModifierString}"/>
                          <TextBlock Style="{StaticResource PopupScoreTextBlockStyle}" Grid.Column="1" Grid.Row="1"
                                     Text="{Binding Character.Abilities.Dexterity.AbilityAndModifierString}"/>
                          <TextBlock Style="{StaticResource PopupScoreTextBlockStyle}" Grid.Column="2" Grid.Row="1"
                                     Text="{Binding Character.Abilities.Constitution.AbilityAndModifierString}"/>
                          <TextBlock Style="{StaticResource PopupScoreTextBlockStyle}" Grid.Column="3" Grid.Row="1"
                                     Text="{Binding Character.Abilities.Intelligence.AbilityAndModifierString}"/>
                          <TextBlock Style="{StaticResource PopupScoreTextBlockStyle}" Grid.Column="4" Grid.Row="1"
                                     Text="{Binding Character.Abilities.Wisdom.AbilityAndModifierString}"/>
                          <TextBlock Style="{StaticResource PopupScoreTextBlockStyle}" Grid.Column="5" Grid.Row="1"
                                     Text="{Binding Character.Abilities.Charisma.AbilityAndModifierString}"/>
                        </Grid>
                      </Expander>
                    </Border>
                    <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource SectionTopBorder}">
                      <Expander Header="Statistics" IsExpanded="true" Style="{StaticResource WhiteExpanderStyle}">
                        <Grid Margin="0,0,0,10">
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                          </Grid.ColumnDefinitions>
                          <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                          </Grid.RowDefinitions>
                          <TextBlock Text="AC" Style="{StaticResource PopupAttributeTextBlockStyle}" Grid.Row="0" Grid.Column="0"/>
                          <TextBlock Text="INITIATIVE" Style="{StaticResource PopupAttributeTextBlockStyle}" Grid.Row="0"
                                     Grid.Column="1" Grid.ColumnSpan="2"/>
                          <TextBlock Text="SPEED" Style="{StaticResource PopupAttributeTextBlockStyle}" Grid.Row="0" Grid.Column="3"
                                     Grid.ColumnSpan="2"/>
                          <TextBlock Text="HP" Style="{StaticResource PopupAttributeTextBlockStyle}" Grid.Row="0" Grid.Column="5"/>
                          <TextBlock Style="{StaticResource PopupScoreTextBlockStyle}" Grid.Column="0" Grid.Row="1"
                                     ToolTip="Armor Class (AC). Armor protects its wearer from attacks. The armor (and shield) you wear determines your base Armor Class."
                                     Text="{Binding Character.ArmorClass}"/>
                          <TextBlock Style="{StaticResource PopupScoreTextBlockStyle}" Grid.Column="1" Grid.Row="1" Grid.ColumnSpan="2"
                                     Text="{Binding Character.Initiative, Mode=OneWay, Converter={StaticResource BonusStringValueConverter}}"/>
                          <TextBlock Style="{StaticResource PopupScoreTextBlockStyle}" Grid.Column="3" Grid.Row="1" Grid.ColumnSpan="2"
                                     Text="{Binding Character.Speed, StringFormat={}{0}ft.}"/>
                          <TextBlock Style="{StaticResource PopupScoreTextBlockStyle}" Grid.Column="5" Grid.Row="1"
                                     Text="{Binding Character.MaxHp}"/>
                        </Grid>
                      </Expander>
                    </Border>
                    <Border Grid.Row="3" Grid.Column="0" Style="{StaticResource SectionTopBorder}">
                      <Expander Header="Saving Throws" IsExpanded="true" Style="{StaticResource WhiteExpanderStyle}">
                        <userControls:SavingThrowsPanelContent Margin="5,0,0,5"/>
                      </Expander>
                    </Border>
                    <Border Grid.Row="4" Grid.Column="0" Style="{StaticResource SectionTopBorder}">
                      <Expander Header="Skills" IsExpanded="true" Style="{StaticResource WhiteExpanderStyle}">
                        <userControls:SkillsPanelContent Margin="5,0,0,5"/>
                      </Expander>
                    </Border>
                  </Grid>
                </ScrollViewer>
              </Grid>
            </metro:MetroTabItem>
            <metro:MetroTabItem Header="ATTACKS &amp; SPELLCASTING">
              <FrameworkElement.DataContext>
                <manage:ManageAttacksViewModel/>
              </FrameworkElement.DataContext>
              <Grid Margin="10,2,0,0">
                <manage1:ManageAttacksSection Margin="0,0,0,0"/>
              </Grid>
            </metro:MetroTabItem>
            <metro:MetroTabItem Header="ADVENTURE NOTES" Visibility="Collapsed">
              <Grid Margin="10,10,20,0">
                <FrameworkElement.Resources>
                  <Style TargetType="{x:Type TextBox}" BasedOn="{StaticResource {x:Type TextBox}}">
                    <Setter Property="FrameworkElement.Margin" Value="0,0,0,10"/>
                  </Style>
                  <Style TargetType="{x:Type TextBlock}">
                    <Setter Property="TextBlock.FontFamily" Value="Segoe UI Light"/>
                    <Setter Property="FrameworkElement.Margin" Value="0,0,0,10"/>
                    <Setter Property="TextBlock.TextWrapping" Value="Wrap"/>
                  </Style>
                </FrameworkElement.Resources>
                <StackPanel>
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="20"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="20"/>
                      <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Grid.ColumnSpan="5">
                      <TextBlock Text="ADVENTURE NOTES" Style="{StaticResource SectionHeaderTextBlockStyle}" Margin="0,0,0,0"/>
                      <TextBlock Text="Keep track of the events, rewards, npc's, loctions, allies, and enemies you come across in your adventures in a journal."
                                 Style="{StaticResource SectionSubHeaderTextBlockStyle}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="0">
                      <TextBlock Text="SESSION NAME" Style="{StaticResource FieldHeaderTextBlockStyle}"/>
                      <TextBox Text=""/>
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="5">
                      <TextBlock Text="SESSION NOTES" Style="{StaticResource FieldHeaderTextBlockStyle}"/>
                      <TextBox Text="" AcceptsTab="true" AcceptsReturn="true" MinHeight="100" TextWrapping="Wrap"/>
                    </StackPanel>
                  </Grid>
                </StackPanel>
              </Grid>
            </metro:MetroTabItem>
          </metro:MetroTabControl>
        </Grid>
      </metro:MetroTabItem>
      <metro:MetroTabItem Header="CHARACTER SHEET" IsEnabled="{Binding IsCharacterLoaded}">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="8*" MinWidth="400"/>
            <ColumnDefinition Width="11*" MinWidth="300"/>
          </Grid.ColumnDefinitions>
          <FrameworkElement.Resources>
            <Style TargetType="{x:Type metro:MetroTabItem}" BasedOn="{StaticResource MainNavigationChildTabItemStyle}"/>
          </FrameworkElement.Resources>
          <metro:MetroTabControl SelectionChanged="CharacterSheetTabControlSelectionChanged" Margin="10,0,0,0" Grid.Column="0"
                                 Grid.Row="0" Grid.RowSpan="2">
            <metro:MetroTabItem Header="CHARACTER SHEET" Visibility="Visible">
              <Grid Margin="10,2,10,0">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel HorizontalAlignment="Left" Margin="0,10,0,0">
                  <TextBlock Text="GENERATE PREVIEW" Style="{StaticResource SectionPrimaryTextBlockStyle}"/>
                  <TextBlock Text="Generate a preview of the character sheet or save as a PDF Document. In the application settings you can enable/disable whether you want the sheet to be 'Form Fillable', if you want spell cards, item cards, attack cards, and feature cards."
                             Style="{StaticResource SectionSecondaryTextBlockStyle}" Margin="0,0,0,10"/>
                  <aurora:CommandButton Click="OpenSheetSettingsWindowClicked" CommandText="CHARACTER SHEET SETTINGS"
                                        HorizontalAlignment="Right" Margin="0,0,0,25" Style="{StaticResource TextIconCommandButtonStyle}">
                    <iconPacks:PackIconMaterial Kind="Settings" Height="10" Width="10"/>
                  </aurora:CommandButton>
                  <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
                    <aurora:CommandButton CommandText="Generate Preview" Margin="0,0,10,0" Command="{Binding CreateCharacterSheetCommand}"
                                          IsEnabled="{Binding IsCharacterLoaded}">
                      <iconPacks:PackIconMaterial Kind="FileFind"/>
                    </aurora:CommandButton>
                    <aurora:CommandButton CommandText="Save Character Sheet" Margin="0,0,0,0"
                                          Style="{StaticResource SuccessCommandButtonStyle}" Command="{Binding SaveDocumentAsCommand}"
                                          IsEnabled="{Binding IsCharacterLoaded}">
                      <iconPacks:PackIconModern Kind="PageFilePdfTag"/>
                    </aurora:CommandButton>
                  </StackPanel>
                  <TextBlock Text="ADDITIONAL FIELDS" Style="{StaticResource SectionPrimaryTextBlockStyle}"/>
                  <TextBlock Text="Some fields on the new custom character sheet are not fully implemented yet and can temporary be populated here."
                             Style="{StaticResource SectionSecondaryTextBlockStyle}" Margin="0,0,0,10"/>
                  <userControls:FillableFieldTextBox Header="ARMOR CLASS (CONDITIONAL FIELD)" MinContentHeight="42"
                                                     DataContext="{Binding Character.ConditionalArmorClassField}"/>
                </StackPanel>
              </Grid>
            </metro:MetroTabItem>
          </metro:MetroTabControl>
          <GridSplitter Grid.Row="1" Grid.Column="0" Width="2" Background="{DynamicResource AccentColorBrush4}"/>
          <Border Grid.Row="1" Grid.Column="1" Background="{DynamicResource DescriptionPanelBackgroundBrush}">
            <userControls:CharacterSheetPreviewPanel/>
          </Border>
        </Grid>
      </metro:MetroTabItem>
    </metro:MetroTabControl>
    <Grid Row="2" Column="1" ColumnSpan="2" Visibility="Collapsed">
      <FrameworkElement.Resources>
        <Style TargetType="{x:Type StackPanel}">
          <Setter Property="FrameworkElement.HorizontalAlignment" Value="Right"/>
          <Setter Property="FrameworkElement.VerticalAlignment" Value="Top"/>
          <Setter Property="StackPanel.Orientation" Value="Horizontal"/>
          <Setter Property="UIElement.IsEnabled" Value="{Binding ApplicationInitialized}"/>
        </Style>
        <Style TargetType="{x:Type Button}" BasedOn="{StaticResource MetroFlatButton}">
          <Setter Property="Control.Padding" Value="5,1,5,0"/>
          <Setter Property="UIElement.SnapsToDevicePixels" Value="true"/>
          <Setter Property="ContentControl.Content" Value=" DEFAULT CONTENT"/>
          <Setter Property="Control.FontFamily" Value="Segoe UI Symbol"/>
          <Setter Property="FrameworkElement.Height" Value="28"/>
          <Setter Property="FrameworkElement.MinWidth" Value="29"/>
          <Setter Property="Control.FontSize" Value="10"/>
          <Setter Property="FrameworkElement.Margin" Value="0,0,0,0"/>
          <Setter Property="Control.BorderThickness" Value="0,0,0,0"/>
          <Setter Property="Control.BorderBrush" Value="{DynamicResource AccentColorBrush}"/>
          <Style.Triggers>
            <Trigger Property="UIElement.IsMouseOver" Value="true">
              <Setter Property="Control.Foreground" Value="{DynamicResource GrayBrush1}"/>
              <Setter Property="Control.Background" Value="{DynamicResource SemiTransparentWhiteBrush}"/>
            </Trigger>
            <Trigger Property="UIElement.IsMouseOver" Value="false">
              <Setter Property="Control.Foreground" Value="{DynamicResource HighlightBrush}"/>
            </Trigger>
            <MultiTrigger>
              <MultiTrigger.Conditions>
                <Condition Property="UIElement.IsMouseOver" Value="true"/>
                <Condition Property="ButtonBase.IsPressed" Value="true"/>
              </MultiTrigger.Conditions>
              <Setter Property="Control.Foreground" Value="{DynamicResource GrayBrush1}"/>
              <Setter Property="Control.Background" Value="{DynamicResource WhiteBrush}"/>
            </MultiTrigger>
          </Style.Triggers>
        </Style>
        <Style TargetType="{x:Type ToggleButton}">
          <Setter Property="Control.Padding" Value="5,1,5,0"/>
          <Setter Property="UIElement.SnapsToDevicePixels" Value="true"/>
          <Setter Property="ContentControl.Content" Value=" DEFAULT CONTENT"/>
          <Setter Property="Control.FontFamily" Value="Segoe UI Symbol"/>
          <Setter Property="FrameworkElement.Height" Value="28"/>
          <Setter Property="FrameworkElement.MinWidth" Value="29"/>
          <Setter Property="Control.FontSize" Value="12"/>
          <Setter Property="FrameworkElement.Margin" Value="0,0,0,0"/>
          <Setter Property="Control.BorderThickness" Value="0,0,0,0"/>
          <Setter Property="Control.BorderBrush" Value="{DynamicResource AccentColorBrush}"/>
          <Style.Triggers>
            <Trigger Property="UIElement.IsMouseOver" Value="true">
              <Setter Property="Control.Foreground" Value="{DynamicResource GrayBrush1}"/>
              <Setter Property="Control.Background" Value="{DynamicResource SemiTransparentWhiteBrush}"/>
            </Trigger>
            <Trigger Property="UIElement.IsMouseOver" Value="false"/>
            <MultiTrigger>
              <MultiTrigger.Conditions>
                <Condition Property="UIElement.IsMouseOver" Value="true"/>
                <Condition Property="ButtonBase.IsPressed" Value="true"/>
              </MultiTrigger.Conditions>
              <Setter Property="Control.Foreground" Value="{DynamicResource GrayBrush1}"/>
              <Setter Property="Control.Background" Value="{DynamicResource WhiteBrush}"/>
            </MultiTrigger>
          </Style.Triggers>
        </Style>
        <Style TargetType="{x:Type Border}">
          <Setter Property="FrameworkElement.Margin" Value="3,7"/>
          <Setter Property="Border.BorderThickness" Value="1,0,0,0"/>
          <Setter Property="Border.BorderBrush" Value="{StaticResource AccentColorBrush4}"/>
        </Style>
      </FrameworkElement.Resources>
      <StackPanel>
        <Button Content="SAVE CHARACTER" Foreground="{DynamicResource HighlightBrush}" ToolTip="Save Character"
                IsEnabled="{Binding IsCharacterLoaded}" Command="{Binding SaveCommand}"/>
        <Border BorderThickness="1,0,0,0" BorderBrush="{StaticResource AccentColorBrush4}" Margin="3,8,3,7"/>
        <Button Content="LEVEL UP" Foreground="{DynamicResource HighlightBrush}" ToolTip="Level Up"
                IsEnabled="{Binding IsCharacterLoaded}" Command="{Binding LevelUpCommand}"/>
        <Border BorderThickness="1,0,0,0" BorderBrush="{StaticResource AccentColorBrush4}" Margin="3,8,3,7"/>
        <Button Content=" GENERATE PDF" Foreground="{DynamicResource HighlightBrush}"
                ToolTip="Generate Sheet (Update Viewer)" Margin="0,0,5,0" IsEnabled="{Binding IsCharacterLoaded}"
                Command="{Binding CreateCharacterSheetCommand}"/>
        <iconPacks:PackIconFontAwesome Kind="SaveSolid"/>
      </StackPanel>
    </Grid>
    <Grid Row="2" Column="1" ColumnSpan="2" Height="28" VerticalAlignment="Top">
      <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
        <metro:Badged BadgePlacementMode="TopLeft" BadgeBackground="{DynamicResource SuccessColorBrush}" Margin="0,0,0,0"
                      Visibility="{Binding IsContentUpdated, Converter={StaticResource BooleanToVisibilityConverter}}"
                      Badge="{Binding ContentUpdatedMessage}">
          <StackPanel Orientation="Horizontal">
            <aurora:CommandButton Click="NavigateCustomContent" ToolTip="Your content files have been updated." CommandText=""
                                  Style="{StaticResource IconCommandButtonStyle}" Margin="0,0,0,0">
              <iconPacks:PackIconMaterial Kind="Restart" Width="14" Height="14" Foreground="{DynamicResource SuccessColorBrush}"/>
            </aurora:CommandButton>
          </StackPanel>
        </metro:Badged>
        <Separator Style="{StaticResource IconSeperatorStyle}"
                   Visibility="{Binding IsContentUpdated, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        <aurora:CommandButton Click="NewCharacterClick" CommandText="NEW CHARACTER"
                              Style="{StaticResource SuccessTextIconCommandButtonStyle}"
                              Visibility="{Binding IsCharacterLoaded, Converter={StaticResource InvertedBooleanToVisibilityConverter}}">
          <iconPacks:PackIconMaterial Kind="Plus" Width="10" Height="10"/>
        </aurora:CommandButton>
        <aurora:CommandButton Click="QuickSaveClicked" CommandText="SAVE"
                              Style="{StaticResource SuccessTextIconCommandButtonStyle}"
                              Visibility="{Binding IsCharacterLoaded, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        <Separator Style="{StaticResource IconSeperatorStyle}"/>
        <aurora:CommandButton Click="OpenAdvancementSliderClick" CommandText="LEVEL UP &amp; HP"
                              Style="{StaticResource TextIconCommandButtonStyle}" IsEnabled="{Binding IsCharacterLoaded}"/>
        <Separator Style="{StaticResource IconSeparatorStyle}"/>
        <aurora:CommandButton Click="ToggleCharacterOptionsClick" CommandText="CHARACTER OPTIONS"
                              Style="{StaticResource TextIconCommandButtonStyle}" IsEnabled="{Binding IsCharacterLoaded}"/>
        <aurora:CommandButton Click="OpenAdvancementSliderClick" Visibility="Collapsed" ToolTip="Remove Last Level"
                              Style="{StaticResource DangerIconCommandButtonStyle}" IsEnabled="{Binding IsCharacterLoaded}">
          <iconPacks:PackIconFontAwesome Kind="LevelDownAltSolid"/>
        </aurora:CommandButton>
        <Separator Style="{StaticResource IconSeperatorStyle}"/>
        <aurora:CommandButton Click="NavigateSheet" CommandText="SHEET" ToolTip="Preview Character Sheet"
                              Style="{StaticResource TextIconCommandButtonStyle}" IsEnabled="{Binding IsCharacterLoaded}"/>
        <aurora:CommandButton Click="ManageAttacksClick" ToolTip="Attacks &amp; Spellcasting"
                              Style="{StaticResource IconCommandButtonStyle}" IsEnabled="{Binding IsCharacterLoaded}">
          <iconPacks:PackIconMaterial Kind="SwordCross" Width="12" Height="12"/>
        </aurora:CommandButton>
        <Separator Style="{StaticResource IconSeperatorStyle}"/>
        <aurora:CommandButton Click="OnPortraitClick" Style="{StaticResource IconCommandButtonStyle}" Margin="0,0,5,0"
                              IsEnabled="{Binding IsCharacterLoaded}">
          <iconPacks:PackIconFontAwesome Kind="BarsSolid"/>
        </aurora:CommandButton>
      </StackPanel>
    </Grid>
    <Border Style="{StaticResource OverlayBorderStyle}"
            BorderBrush="{DynamicResource SecondaryNavigationBottomBorderBrush}" Grid.Column="0" Grid.Row="2"
            Grid.ColumnSpan="3" BorderThickness="0,0,0,2"/>
    <Grid Row="4" Column="0" ColumnSpan="3" Background="Black">
      <Border BorderThickness="0,0,0,0" BorderBrush="{DynamicResource AccentColorBrush}"
              SnapsToDevicePixels="true">
        <StatusBar x:Name="StatusBar" Style="{StaticResource StatusBarDefaultStyle}">
          <StatusBarItem>
            <StackPanel Orientation="Horizontal">
              <TextBlock x:Name="MainStatusMessageTextBlock" Foreground="{DynamicResource GrayBrush5}"
                         Style="{StaticResource StatusBarStatusMessageStyle}" FontSize="11" TextWrapping="NoWrap"
                         Margin="5,0,5,0" Text="{Binding StatusMessage, Converter={StaticResource UpperCaseConverter}}"/>
            </StackPanel>
          </StatusBarItem>
          <StatusBarItem DockPanel.Dock="Right"
                         Visibility="{Binding IsProgressVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <metro:MetroProgressBar x:Name="ProgressBarMain" Style="{StaticResource StatusBarProgressBarStyle}"
                                    Value="{Binding ProgressPercentage}" IsIndeterminate="{Binding IsProgressIndeterminate}"/>
          </StatusBarItem>
          <Separator Style="{StaticResource StatusBarSeperatorStyle}" DockPanel.Dock="Right"
                     Visibility="{Binding IsProgressVisible, Converter={StaticResource BooleanToVisibilityConverter}}"/>
          <StatusBarItem HorizontalContentAlignment="Right" HorizontalAlignment="Right" DockPanel.Dock="Right">
            <Button Click="BrowseChangelogClick" Foreground="{DynamicResource GrayBrush5}"
                    Style="{StaticResource StatusBarButtonStyle}" FontSize="11" ToolTip="View Releases">
              <TextBlock Text="{Binding Version}"/>
            </Button>
          </StatusBarItem>
          <Separator HorizontalAlignment="Right" DockPanel.Dock="Right" Style="{StaticResource StatusBarSeperatorStyle}"/>
          <StatusBarItem HorizontalContentAlignment="Right" HorizontalAlignment="Right" DockPanel.Dock="Right">
            <Button Content=" SELECTION FLOW" ToolTip="Navigate to the next available selection when enabled."
                    Style="{StaticResource StatusBarButtonStyle}"
                    Foreground="{Binding Settings.AutoNavigateNextSelectionWhenAvailable, Converter={StaticResource SuccessColorBrushConverter}}"
                    Command="{Binding Settings.ToggleAutoSelectionNavigationCommand}"/>
          </StatusBarItem>
          <Separator DockPanel.Dock="Right" Style="{StaticResource StatusBarSeperatorStyle}"
                     Visibility="{Binding SelectionRuleNavigationService.IsNextAvailable, Converter={StaticResource BooleanToVisibilityConverter}}"/>
          <StatusBarItem HorizontalContentAlignment="Right" HorizontalAlignment="Right" DockPanel.Dock="Right"
                         Visibility="{Binding SelectionRuleNavigationService.IsNextAvailable, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Button Foreground="{DynamicResource AuroraGoldColorBrush}" Style="{StaticResource StatusBarButtonStyle}"
                    IsEnabled="{Binding SelectionRuleNavigationService.IsNextAvailable}"
                    Command="{Binding SelectionRuleNavigationService.NavigateNextCommand}">
              <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="SelectionAvailableVisualQue" Text=" NEXT SELECTION">
                  <UIElement.RenderTransform>
                    <TranslateTransform x:Name="IsNextAvailableArrow" X="0"/>
                  </UIElement.RenderTransform>
                  <FrameworkElement.Triggers>
                    <EventTrigger RoutedEvent="TextBlock.RequestBringIntoView">
                      <BeginStoryboard>
                        <Storyboard>
                          <DoubleAnimation From="1" To="0.05" Duration="0:0:0.75" Storyboard.TargetProperty="Opacity" RepeatBehavior="5x"
                                           AutoReverse="true"/>
                        </Storyboard>
                      </BeginStoryboard>
                    </EventTrigger>
                  </FrameworkElement.Triggers>
                </TextBlock>
              </StackPanel>
            </Button>
          </StatusBarItem>
          <Separator DockPanel.Dock="Right" Style="{StaticResource StatusBarSeperatorStyle}"
                     Visibility="{Binding IsCharacterLoaded, Converter={StaticResource BooleanToVisibilityConverter}}"/>
          <StatusBarItem HorizontalContentAlignment="Right" HorizontalAlignment="Right" DockPanel.Dock="Right" Padding="0">
            <TextBlock x:Name="TextBlockInfo" Margin="0,0,5,0" TextAlignment="Right" FontFamily="Segoe UI Symbol"
                       TextWrapping="NoWrap" Foreground="{StaticResource GrayBrush5}" FontSize="11"
                       Text="{Binding LoadedFilepath, Converter={StaticResource UpperCaseConverter}, StringFormat=' {0}', FallbackValue=}"/>
          </StatusBarItem>
        </StatusBar>
      </Border>
    </Grid>
  </Grid>
</metro:MetroWindow>