              <MenuItem Header="Create Spell Collection"/>
              <Separator/>
              <MenuItem Header="Xarriz' Spells"/>
              <MenuItem Header="Empty Slot 2"/>
              <MenuItem Header="Empty Slot 3"/>
              <MenuItem Header="Empty Slot 4"/>
              <MenuItem Header="Empty Slot 5"/>
            </MenuItem>
            <MenuItem Header="Adventure Notes" IsEnabled="false">
              <MenuItem Header="Create Adventure Note"/>
            </MenuItem>
          </MenuItem>
          <MenuItem Header="VIEW" FontWeight="SemiBold">
            <MenuItem Click="TogglePortraitsGallerySlider" Header="Portraits Gallery" InputGestureText="Ctrl+P"
                      IsEnabled="{Binding IsCharacterLoaded}"/>
            <MenuItem Click="OpenViewerClick" Header="Character Sheet View" InputGestureText="Ctrl+V"
                      IsEnabled="{Binding IsCharacterLoaded}"/>
            <MenuItem Click="ToggleCompendiumClick" Header="Compendium"/>
            <Separator/>
            <MenuItem Header="Next Selection" Icon="{StaticResource ExpanderSelectionNextIcon}"
                      Command="{Binding SelectionRuleNavigationService.NavigateNextCommand}"
                      IsEnabled="{Binding SelectionRuleNavigationService.IsNextAvailable}"/>
            <MenuItem IsCheckable="true" Header="Enable Selection Flow"
                      IsChecked="{Binding Settings.AutoNavigateNextSelectionWhenAvailable, Mode=OneWay}"
                      IsEnabled="{Binding IsCharacterLoaded}"
                      Command="{Binding Settings.ToggleAutoSelectionNavigationCommand}"/>
            <Separator/>
            <MenuItem Click="OpenSettingsWindowClicked" Header="Application Settings"/>
          </MenuItem>
          <MenuItem Header="CHARACTER" FontWeight="SemiBold" Visibility="Collapsed">
            <MenuItem Click="OpenAdvancementSliderClick" Header="Level Up &amp; Multiclassing"
                      IsEnabled="{Binding IsCharacterLoaded}"/>
            <Separator/>
            <MenuItem Click="ToggleCharacterOptionsClick" Header="Character Options"
                      IsEnabled="{Binding IsCharacterLoaded}"/>
            <Separator/>
            <MenuItem Header="Generate Character Summary" Command="{Binding CharacterSummery}"
                      IsEnabled="{Binding IsCharacterLoaded}"/>
            <MenuItem Header="Character Sheet">
              <MenuItem Header="Update Character Sheet" Command="{Binding CreateCharacterSheetCommand}"
                        IsEnabled="{Binding IsCharacterLoaded}"/>
              <Separator/>
              <MenuItem IsCheckable="true" Header="Editable Character Sheet"
                        IsChecked="{Binding Settings.AllowEditableSheet, Mode=OneWay}"
                        IsEnabled="{Binding IsCharacterLoaded}"
                        Command="{Binding Settings.ToggleAllowEditableSheetCommand}"/>
              <MenuItem IsCheckable="true" Header="Automatic Generate Character Sheet"
                        IsChecked="{Binding Settings.GenerateSheetOnCharacterChangedRegistered, Mode=OneWay}"
                        IsEnabled="{Binding IsCharacterLoaded}" Command="{Binding Settings.ToggleAutoGenerateSheetCommand}"/>
            </MenuItem>
          </MenuItem>
          <MenuItem Header="HELP" FontWeight="SemiBold">
            <MenuItem Click="BrowseGetStartedPageClick" Header="Get Started" ToolTip="Get started with Aurora"/>
            <MenuItem Click="BrowseNewsClick" Header="News"/>
            <MenuItem Click="BrowseContentClick" Header="Additional Content"/>
            <Separator/>
            <MenuItem Click="BrowseChangelogClick" Header="Releases"/>
            <MenuItem Click="BrowseSupportPageClick" Header="Support Page" ToolTip="Browse to the support page."/>
            <Separator/>
            <MenuItem Click="BrowseDonatePageClick" Header="Make a Donation" ToolTip="Support the project."/>
          </MenuItem>
          <MenuItem FontWeight="SemiBold" Foreground="{DynamicResource AuroraGoldColorBrush}"
                    Header="{Binding Character.Name, Converter={StaticResource UpperCaseConverter}, FallbackValue=CHARACTER}"
                    Visibility="{Binding IsCharacterLoaded, Converter={StaticResource BooleanToVisibilityConverter}}">
            <HeaderedItemsControl.HeaderTemplate>
              <DataTemplate>
                <TextBlock TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" MaxWidth="200" Text="{Binding}"/>
              </DataTemplate>
            </HeaderedItemsControl.HeaderTemplate>
            <MenuItem Click="QuickSaveClicked" Header="Save Character" InputGestureText="Ctrl+S"
                      IsEnabled="{Binding IsCharacterLoaded}"/>
            <MenuItem Header="Save Character Sheet (.pdf)" Command="{Binding SaveDocumentAsCommand}"
                      IsEnabled="{Binding IsCharacterLoaded}"/>
            <Separator/>
            <MenuItem Click="OpenAdvancementSliderClick" Header="Level Up, HP, &amp; Multiclass"
                      IsEnabled="{Binding IsCharacterLoaded}"/>
            <MenuItem Click="ToggleCharacterOptionsClick" Header="Manage Character Options"
                      IsEnabled="{Binding IsCharacterLoaded}"/>
            <MenuItem Click="ManageCampaignClick" Header="Manage Sources" IsEnabled="{Binding IsCharacterLoaded}"/>
            <MenuItem Click="ToggleManageCoinageClick" Header="Manage Coins" IsEnabled="{Binding IsCharacterLoaded}"/>
            <Separator/>
            <MenuItem Header="Update Sheet Preview" Command="{Binding CreateCharacterSheetCommand}"
                      IsEnabled="{Binding IsCharacterLoaded}"/>
          </MenuItem>
        </Menu>
      </Grid>
    </metro:WindowCommands>
  </metro:MetroWindow.LeftWindowCommands>
  <metro:MetroWindow.RightWindowCommands>
    <metro:WindowCommands ShowSeparators="false" Foreground="{StaticResource WhiteBrush}">
      <TextBox LostFocus="QuickSearchBar_OnLostFocus" TextChanged="QuickSearchBar_OnTextChanged"
               KeyDown="QuickSearchBar_OnKeyDown" x:Name="QuickSearchBar" Text=""
               CaretBrush="{DynamicResource GrayBrush5}"
               metro:TextBoxHelper.Watermark=" Compendium Search  (Alt+Q)" FontFamily="Segoe UI Symbol"
               MaxWidth="275" MinWidth="225" Background="#AA111113" FontSize="11" BorderThickness="0"
               Margin="20,5,20,2" VerticalContentAlignment="Center" VerticalAlignment="Center"
               Visibility="{Binding IsQuickSearchBarEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
        <FrameworkElement.Style>
          <Style TargetType="{x:Type TextBox}" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="metro:TextBoxHelper.ButtonTemplate" Value="{StaticResource ChromelessButtonTemplate}"/>
            <Setter Property="metro:TextBoxHelper.ButtonFontFamily" Value="Segoe UI Symbol"/>
            <Setter Property="metro:TextBoxHelper.ButtonFontSize" Value="13"/>
            <Setter Property="metro:TextBoxHelper.ButtonCommand" Value="{Binding QuickSearchCommand}"/>
            <Style.Triggers>
              <Trigger Property="UIElement.IsMouseOver" Value="true">
                <Setter Property="UIElement.Opacity" Value="1"/>
              </Trigger>
              <Trigger Property="UIElement.IsFocused" Value="false">
                <Setter Property="UIElement.Opacity" Value=".5"/>
                <Setter Property="Control.Foreground" Value="{StaticResource IdealForegroundColorBrush}"/>
              </Trigger>
              <Trigger Property="UIElement.IsFocused" Value="true">
                <Setter Property="UIElement.Opacity" Value="1"/>
                <Setter Property="Control.Foreground" Value="{StaticResource DarkIdealForegroundDisabledBrush}"/>
              </Trigger>
            </Style.Triggers>
          </Style>
        </FrameworkElement.Style>
      </TextBox>
      <Button x:Name="DevButton" ToolTip="Developer Tools" Style="{StaticResource CommandButtonStyle}"
              Background="{DynamicResource AccentColorBrush}" Command="{Binding OpenDeveloperToolsCommand}"
              Visibility="{Binding EnableDeveloperTools, Converter={StaticResource BooleanToVisibilityConverter}}">
        <iconPacks:PackIconFontAwesome Kind="CodeSolid" Height="16" Width="16" Margin="10,0"
                                       Foreground="{DynamicResource DeveloperIndicatorForegroundColorBrush}"/>
      </Button>
      <Button Click="OpenViewerClick" ToolTip="Open Detachable Sheet" Style="{StaticResource CommandButtonStyle}"
              Background="{DynamicResource AccentColorBrush}"
              Visibility="{Binding IsCharacterLoaded, Converter={StaticResource BooleanToVisibilityConverter}}">
        <iconPacks:PackIconMaterial Kind="OpenInApp" Height="14" Width="14" Margin="10,0"
                                    Foreground="{DynamicResource AuroraWhiteBrush}"/>
      </Button>
      <Button Click="OpenSettingsWindowClicked" ToolTip="Settings" Style="{StaticResource CommandButtonStyle}"
              Background="{DynamicResource AccentColorBrush}">
        <iconPacks:PackIconFontAwesome Kind="CogSolid" Height="14" Width="14" Margin="10,0"
                                       Foreground="{DynamicResource AuroraWhiteBrush}"/>
      </Button>
      <Button Click="UpdateNotificationButtonClicked" x:Name="UpdateNotificationButton"
              ToolTip="Update Available" Style="{StaticResource CommandButtonStyle}"
              Background="{DynamicResource AccentColorBrush}"
              Visibility="{Binding UpdateAvailable, Converter={StaticResource BooleanToVisibilityConverter}}">
        <StackPanel Orientation="Horizontal">
          <iconPacks:PackIconFontAwesome Kind="AngleDoubleDownSolid" Margin="10,0" Height="14" Width="14"
                                         Foreground="{DynamicResource NewNotificationIndicatorForegroundColorBrush}">
            <UIElement.RenderTransform>
              <TranslateTransform x:Name="NotificationIcon" Y="0"/>
            </UIElement.RenderTransform>
            <FrameworkElement.Triggers>
              <EventTrigger RoutedEvent="StackPanel.Loaded">
                <BeginStoryboard>
                  <Storyboard x:Name="UpdateNotificationStoryBoard">
                    <DoubleAnimation From="-30" To="0" Duration="0:0:1.25" Storyboard.TargetName="NotificationIcon"
                                     Storyboard.TargetProperty="Y" RepeatBehavior="100x"/>
                  </Storyboard>
                </BeginStoryboard>
              </EventTrigger>
            </FrameworkElement.Triggers>
          </iconPacks:PackIconFontAwesome>
        </StackPanel>
      </Button>
      <Button Click="BrowseHomepageClick" ToolTip="Aurora Website"
              Style="{StaticResource RightCommandButtonStyle}" Margin="2,0,30,0"
              Background="{DynamicResource AccentColorBrush}">
        <iconPacks:PackIconFontAwesome Kind="GlobeSolid" Height="14" Width="14" Margin="10,0"
                                       Foreground="{DynamicResource AuroraWhiteBrush}"/>
      </Button>
      <Button Click="BrowseDonatePageClick" Style="{StaticResource RightCommandButtonStyle}"
              Background="{DynamicResource AccentColorBrush}"
              Visibility="{Binding ShowDonateButton, Converter={StaticResource BooleanToVisibilityConverter}}">
        <TextBlock Text="SUPPORT THE PROJECT" FontFamily="Segoe UI SemiBold" FontSize="11"
                   Style="{StaticResource CommandTextStyle}" Foreground="{DynamicResource AuroraWhiteBrush}"/>
      </Button>
    </metro:WindowCommands>
  </metro:MetroWindow.RightWindowCommands>
  <Grid x:Name="ShellGrid" Margin="0">
    <Grid.ColumnDefinitions>
      <ColumnDefinition x:Name="SideBarColumn" MinWidth="30" Width="Auto" MaxWidth="300"/>
      <ColumnDefinition Width="*"/>
      <ColumnDefinition Width="0"/>
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="24"/>
      <RowDefinition Height="36"/>
      <RowDefinition Height="30"/>
      <RowDefinition/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <FrameworkElement.Resources>
      <Style TargetType="{x:Type metro:MetroTabControl}"
             BasedOn="{StaticResource MainNavigationTabControlStyle}"/>
      <Style TargetType="{x:Type metro:MetroTabItem}" BasedOn="{StaticResource MainNavigationTabItemStyle}"/>
    </FrameworkElement.Resources>
    <Border Grid.Row="2" Grid.RowSpan="2" Grid.ColumnSpan="3" Grid.Column="0"
            Background="{DynamicResource WhiteBrush}"/>
    <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Grid.RowSpan="2" Visibility="Collapsed">
      <Image Source="../Resources/viking_hill.jpg" Stretch="UniformToFill" VerticalAlignment="Bottom"
             HorizontalAlignment="Center" Focusable="false" IsHitTestVisible="false" Margin="0,-30,0,-30"
             Opacity="0.05" RenderTransformOrigin="0.5,0.5">
        <UIElement.RenderTransform>
          <TransformGroup>
            <ScaleTransform ScaleY="1" ScaleX="1"/>
            <SkewTransform AngleY="0" AngleX="0"/>
            <RotateTransform Angle="0"/>
            <TranslateTransform/>
          </TransformGroup>
        </UIElement.RenderTransform>
      </Image>
    </Border>
    <Grid Row="3" Column="0" Background="{DynamicResource WhiteBrush}">
      <Border x:Name="SidePanelHost" Margin="0" BorderBrush="{DynamicResource AccentColorBrush4}"
              BorderThickness="0,0,1,0" Opacity="1"
              Visibility="{Binding IsChecked, ElementName=Toggle, Converter={StaticResource BooleanToVisibilityConverter}}"/>
    </Grid>
    <userControls:CharacterProfile x:Name="CharacterProfileButton" CharacterNameClick="NavigateManage" PortraitClick="OnPortraitClick"
                                   NewCharacterClick="NewCharacterClick" Grid.Row="0" Grid.Column="1" Grid.RowSpan="2"
                                   HorizontalAlignment="Right" Margin="0,0,10,2" VerticalAlignment="Center"
                                   Visibility="{Binding IsCharacterInformationBlockVisible, Converter={StaticResource BooleanToVisibilityConverter}}"/>
    <Grid Row="1" Column="1" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,60,0"
          Visibility="{Binding IsCharacterLoaded, Converter={StaticResource BooleanToVisibilityConverter}}">
      <userControls:ExperienceProgressBar Foreground="{DynamicResource SuccessColorBrush}" Width="150" CurrentVisibility="Collapsed"
                                          TargetVisibility="Collapsed"/>
    </Grid>
    <Border Style="{StaticResource OverlayBorderStyle}" Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="3"/>
    <Border Grid.Row="2" Style="{StaticResource UnderlayBorderStyle}" Grid.ColumnSpan="3" Grid.Column="0"
            Background="{DynamicResource WhiteBrush}"/>
    <Border Grid.Row="2" Style="{StaticResource UnderlayBorderStyle}" Grid.ColumnSpan="3" Grid.Column="0"/>
    <StackPanel x:Name="SideStackPanel" Grid.Row="2" Grid.Column="0" VerticalAlignment="Top"
                Orientation="Horizontal" Width="Auto">
      <ToggleButton Click="ToggleSideBar" x:Name="Toggle" Visibility="Collapsed" ToolTip="Toggle Information Pane"
                    HorizontalAlignment="Left" IsEnabled="{Binding IsCharacterLoaded}">
        <FrameworkElement.Style>
          <Style TargetType="{x:Type ToggleButton}" BasedOn="{StaticResource ChromelessButtonStyle}">
            <Setter Property="Control.FontFamily" Value="Segoe UI Symbol"/>
            <Setter Property="Control.FontSize" Value="14"/>
            <Setter Property="FrameworkElement.Height" Value="28"/>
            <Setter Property="FrameworkElement.MinWidth" Value="28"/>
            <Style.Triggers>
              <Trigger Property="ToggleButton.IsChecked" Value="True">
                <Trigger.Setters>
                  <Setter Property="ContentControl.Content" Value=""/>
                </Trigger.Setters>
              </Trigger>
              <Trigger Property="ToggleButton.IsChecked" Value="False">
                <Trigger.Setters>
                  <Setter Property="ContentControl.Content" Value=""/>
                </Trigger.Setters>
              </Trigger>
            </Style.Triggers>
          </Style>
        </FrameworkElement.Style>
      </ToggleButton>
    </StackPanel>
    <metro:MetroTabControl x:Name="MainTabContol" Grid.Row="1" Grid.RowSpan="3" Grid.Column="1" Margin="0,0,0,0"
                           metro:TabControlHelper.Underlined="TabItems" Grid.ColumnSpan="2"
                           Style="{DynamicResource MainNavigationTabControlStyle}"
                           IsEnabled="{Binding ApplicationInitialized}" Background="{x:Null}">
      <metro:MetroTabItem Header="START">
        <Grid>
          <FrameworkElement.Resources>
            <Style TargetType="{x:Type metro:MetroTabItem}" BasedOn="{StaticResource MainNavigationChildTabItemStyle}"/>
          </FrameworkElement.Resources>
          <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <metro:MetroTabControl Grid.Column="0" Grid.Row="0" Grid.RowSpan="2" Margin="10,0,0,0" Padding="0">
            <metro:MetroTabItem Header="CHARACTER COLLECTION">
              <Grid Margin="0,2,0,0">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" MaxWidth="400"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="*"/>
                  <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Width="380" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="1" Margin="10,10,10,50"
                            HorizontalAlignment="Center">
                  <TextBlock Style="{StaticResource SectionPrimaryTextBlockStyle}" Margin="0,0,0,10" FontSize="14"
                             Text="{Binding Source={x:Static local:strings.Aurora_Start_Welcome}, Converter={StaticResource UpperCaseConverter}}"/>
                  <TextBlock Foreground="{DynamicResource SecondaryTextBrush}"
                             Text="Your characters are ready for you to load, level up, and manage."
                             Style="{StaticResource FlavorDescriptionTextBlockStyle}" Margin="0,0,0,5"/>
                  <TextBlock Foreground="{DynamicResource SecondaryTextBrush}"
                             Text="Additionally, your characters can be grouped together and those marked as favorite are listed first in the group they are in."
                             Style="{StaticResource FlavorDescriptionTextBlockStyle}" Margin="0,0,0,25"/>
                  <aurora:GraphicalButton Click="NewCharacterClick" Title="NEW CHARACTER" Description="create a new character"
                                          HorizontalAlignment="Left" ImageSource="../Resources/default-portrait.png" Margin="0,10,0,0"
                                          Height="90" Width="260"/>
                </StackPanel>
                <StackPanel Visibility="Collapsed" Grid.RowSpan="2" Grid.Row="1" Grid.Column="0" Margin="10,5,0,0" Width="400"
                            HorizontalAlignment="Left">
                  <TextBlock Text="WHAT'S NEW?" Style="{StaticResource SectionPrimaryTextBlockStyle}" Margin="0,0,0,0"
                             FontSize="14"/>
                  <TextBlock Foreground="{DynamicResource DeveloperIndicatorForegroundColorBrush}" FontSize="11"
                             FontStyle="Italic" FontFamily="Segoe UI" Style="{StaticResource FlavorDescriptionTextBlockStyle}"
                             Margin="0,0,0,5" Text="{Binding Version, StringFormat='Version {0}'}"/>
                  <StackPanel Margin="0,10,0,50" Orientation="Horizontal">
                    <aurora:CommandButton Click="BrowseChangelogClick" CommandText="Learn More..." HorizontalAlignment="Left" MinWidth="110"/>
                  </StackPanel>
                  <TextBlock Text="COMMUNITY LINKS" Style="{StaticResource SectionPrimaryTextBlockStyle}" Margin="0,0,0,0"
                             FontSize="14"/>
                  <TextBlock Text="You can exchange homebrew content, discuss, and support the project."
                             Style="{StaticResource FlavorDescriptionTextBlockStyle}" Margin="0,0,0,5"
                             Foreground="{DynamicResource SecondaryTextBrush}" FontSize="13"/>
                  <StackPanel Orientation="Horizontal">
                    <aurora:CommandButton Click="BrowseDiscordChannelClick" CommandText="Discord Channel" Margin="0,10,10,50"
                                          HorizontalAlignment="Left" MinWidth="110"/>
                    <aurora:CommandButton Click="BrowseRedditPageClick" CommandText="Reddit" Margin="0,10,10,50" HorizontalAlignment="Left"
                                          MinWidth="110"/>
                    <aurora:CommandButton Click="BrowsePatreonPageClick" CommandText="Support on Patreon" Margin="0,10,10,50"
                                          HorizontalAlignment="Left" MinWidth="110"/>
                  </StackPanel>
                </StackPanel>
                <syndication:SyndicationControl Grid.Row="1" Grid.Column="0" Margin="10,0,20,0" Width="370" HorizontalAlignment="Left"/>
                <ListView MouseDoubleClick="CharactersListViewOnMouseDoubleClick" KeyDown="CharactersListViewKeyDown"
                          Style="{StaticResource Aurora.Styles.ListView.CharacterFileCollection}" Grid.Row="0"
                          Grid.RowSpan="3" Grid.Column="1" Grid.ColumnSpan="1"
                          ScrollViewer.VerticalScrollBarVisibility="Visible" ItemsSource="{Binding Characters}"
                          SelectedItem="{Binding SelectedCharacter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                  <ItemsControl.GroupStyle>
                    <GroupStyle ContainerStyle="{StaticResource Aurora.GroupStyles.CharacterFileCollection}"/>
                  </ItemsControl.GroupStyle>
                </ListView>
              </Grid>
            </metro:MetroTabItem>
            <metro:MetroTabItem Header="SOURCES">
              <Grid Margin="10,2,0,0">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="11*"/>
                  <ColumnDefinition Width="5*"/>
                </Grid.ColumnDefinitions>
                <manage1:ManageSourcesSection Margin="0,0,0,0" Padding="0,0,0,0"/>
                <GridSplitter Grid.Row="0" Grid.Column="0" Width="2" Background="{DynamicResource AccentColorBrush4}"/>
                <Border Grid.Row="0" Grid.Column="1">
                  <controls:ElementDescriptionPanel Background="{DynamicResource DescriptionPanelBackgroundBrush}" Description="{Binding Description}"
                                                    StyleSheet="{Binding StyleSheet}">
                    <FrameworkElement.DataContext>
                      <viewModels:SourceElementDescriptionPanelViewModel IsSpeechActive="false"/>
                    </FrameworkElement.DataContext>
                  </controls:ElementDescriptionPanel>
                </Border>
              </Grid>
            </metro:MetroTabItem>
            <metro:MetroTabItem Header="ADDITIONAL CONTENT">
              <FrameworkElement.DataContext>
                <start:SourcesSectionViewModel/>
              </FrameworkElement.DataContext>
              <Grid Margin="10,2,0,0">
                <FrameworkElement.Resources>
                  <Style x:Key="BuilderDefaultFlatButton" TargetType="{x:Type Button}"
                         BasedOn="{StaticResource MetroFlatButton}">
                    <Setter Property="Control.FontSize" Value="11"/>
                    <Setter Property="metro:ControlsHelper.ContentCharacterCasing" Value="Upper"/>
