                  <TextBlock Text="REMOTE .INDEX FILE URL" Style="{StaticResource FieldHeaderTextBlockStyle}"/>
                  <StackPanel Orientation="Horizontal">
                    <TextBox BorderBrush="#FF242424" BorderThickness="1" Margin="0,0,10,0" MinWidth="500" MaxWidth="700"
                             Width="Auto" HorizontalAlignment="Left" VerticalAlignment="Center"
                             metro:TextBoxHelper.Watermark="https://"
                             Text="{Binding RemoteUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <aurora:CommandButton Style="{StaticResource SuccessCommandButtonStyle}" CommandText="Download"
                                          ToolTip="Download the .index file from the url provided." HorizontalAlignment="Left"
                                          Margin="0,0,0,0" Command="{Binding FetchCustomFileCommand}">
                      <iconPacks:PackIconMaterial Kind="FileDownload" Width="14" Height="14"/>
                    </aurora:CommandButton>
                  </StackPanel>
                  <ComboBox Width="500" HorizontalAlignment="Left" Margin="0,2,0,0"
                            Visibility="{Binding BundlesEnabled, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Text="{Binding RemoteUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                    <ComboBoxItem>
                      https://raw.githubusercontent.com/aurorabuilder/elements/master/core.index
                    </ComboBoxItem>
                    <ComboBoxItem>
                      https://raw.githubusercontent.com/aurorabuilder/elements/master/supplements.index
                    </ComboBoxItem>
                    <ComboBoxItem>
                      https://raw.githubusercontent.com/aurorabuilder/elements/master/unearthed-arcana.index
                    </ComboBoxItem>
                    <ComboBoxItem>
                      https://raw.githubusercontent.com/aurorabuilder/elements/master/third-party.index
                    </ComboBoxItem>
                    <ComboBoxItem>
                      https://raw.githubusercontent.com/community-elements/elements-reddit/master/reddit.index
                    </ComboBoxItem>
                    <ComboBoxItem>
                      https://raw.githubusercontent.com/community-elements/elements-dndwiki/master/dndwiki.index
                    </ComboBoxItem>
                  </ComboBox>
                  <TextBlock Text="*.index files only (e.g. https://website.com/files/elemental-campaign.index)"
                             Style="{StaticResource FieldHeaderTextBlockStyle}" Margin="0,0,0,25"/>
                  <TextBlock Text="UPDATE CONTENT FILES" Style="{StaticResource SectionPrimaryTextBlockStyle}" FontSize="13"
                             Margin="0,0,0,5"/>
                  <TextBlock Text="Unless disabled, the application will check in the background for updated content shortly after starting up. After content has been updated a button will be available to restart the application so the updated content can be reloaded."
                             Style="{StaticResource FlavorDescriptionTextBlockStyle}" FontSize="13" Margin="0,0,0,5"/>
                  <TextBlock Text="When you are experiencing issues with the content you can click the 'Clear Downloaded Content' button to remove content files added through the index files. Then click 'Update Content Files' to download the latest files new.."
                             Style="{StaticResource FlavorDescriptionTextBlockStyle}" FontSize="13" Margin="0,0,0,5"/>
                  <TextBlock Text="You should place your personal homebrew files in the specific 'custom\user' folder."
                             Style="{StaticResource FlavorDescriptionTextBlockStyle}" FontSize="13" Margin="0,0,0,20"/>
                  <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                    <metro:Badged BadgeBackground="{DynamicResource SuccessColorBrush}" Margin="0,0,10,0"
                                  Badge="{Binding UpdateBadgeContent}">
                      <aurora:CommandButton CommandText="Update Content Files" ToolTip="Update content files."
                                            Style="{StaticResource SuccessCommandButtonStyle}" Command="{Binding UpdateCustomFilesCommand}">
                        <iconPacks:PackIconMaterial Kind="FolderDownload"/>
                      </aurora:CommandButton>
                    </metro:Badged>
                    <metro:Badged BadgeBackground="{DynamicResource SuccessColorBrush}" Margin="0,0,10,0"
                                  Visibility="{Binding AwaitingRestart, Converter={StaticResource BooleanToVisibilityConverter}}"
                                  Badge="{Binding RestartBadgeCount}">
                      <aurora:CommandButton CommandText="Restart Application"
                                            ToolTip="Restart the application and allow updated content to be loaded."
                                            Style="{StaticResource SuccessCommandButtonStyle}" Margin="0,0,0,0"
                                            Command="{Binding RestartCommand}">
                        <iconPacks:PackIconMaterial Kind="Restart"/>
                      </aurora:CommandButton>
