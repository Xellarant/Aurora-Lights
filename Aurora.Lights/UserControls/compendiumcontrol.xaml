<UserControl x:Class="Builder.Presentation.UserControls.CompendiumControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Builder.Presentation.UserControls"
             xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls">
  <FrameworkElement.DataContext>
    <local:CompendiumControlViewModel/>
  </FrameworkElement.DataContext>
  <Grid Margin="0">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="2*"/>
      <ColumnDefinition Width="1*"/>
      <ColumnDefinition Width="1*"/>
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>
    <StackPanel>
      <TextBlock Text="SEARCH COMPENDIUM" Style="{StaticResource FieldHeaderTextBlockStyle}"/>
      <TextBox Margin="0,0,0,5" controls:TextBoxHelper.Watermark="enter a (key)word to search"
               Text="{Binding SearchCriteria, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
    </StackPanel>
    <StackPanel Margin="10,0,0,10" Grid.Row="0" Grid.Column="1">
      <TextBlock Text="SEARCH TYPE" Style="{StaticResource FieldHeaderTextBlockStyle}"/>
      <ComboBox ItemsSource="{Binding TargetTypes}"
                SelectedItem="{Binding TargetType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
    </StackPanel>
    <StackPanel Margin="10,0,0,10" Grid.Row="0" Grid.Column="2">
      <TextBlock Text="SEARCH SOURCE" Style="{StaticResource FieldHeaderTextBlockStyle}"/>
      <ComboBox ItemsSource="{Binding TargetSources}"
                SelectedItem="{Binding TargetSource, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
    </StackPanel>
    <Expander Visibility="Collapsed" Header="Advanced Options" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
              Style="{StaticResource WhiteExpanderStyle}" Margin="-7,0">
      <Grid Margin="7,0">
        <StackPanel>
          <local:DescriptionCheckBox Header="Include Spells" IsChecked="true"/>
        </StackPanel>
      </Grid>
    </Expander>
    <DataGrid KeyDown="SearchResultsDataGrid_OnKeyDown" x:Name="SearchResultsDataGrid"
              BorderBrush="{DynamicResource GrayBrush5}" BorderThickness="0" Grid.Row="2" Grid.ColumnSpan="3"
              Grid.Column="0" SelectionMode="Single" Margin="0,10,0,0" CanUserReorderColumns="true"
              Style="{StaticResource SelectionRuleExpanderGridStyle}" MinRowHeight="21"
              HeadersVisibility="Column" ItemsSource="{Binding SearchResults}"
              SelectedItem="{Binding SelectedSearchResult, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
      <DataGrid.ColumnHeaderStyle>
        <Style TargetType="{x:Type DataGridColumnHeader}" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
          <Setter Property="Control.FontSize" Value="10"/>
          <Setter Property="Control.FontWeight" Value="SemiBold"/>
          <Setter Property="Control.Padding" Value="5,2,5,3"/>
          <Setter Property="Control.Background" Value="{DynamicResource AccentColorBrush4}"/>
          <Setter Property="Control.Foreground" Value="{DynamicResource HighlightBrush}"/>
        </Style>
      </DataGrid.ColumnHeaderStyle>
      <DataGrid.Columns>
        <DataGridTextColumn x:Name="NameColumn" Header="NAME" Width="*" MinWidth="200" Binding="{Binding Name}">
          <DataGridColumn.CellStyle>
            <Style TargetType="{x:Type DataGridCell}" BasedOn="{StaticResource {x:Type DataGridCell}}">
              <Setter Property="Control.Padding" Value="5,0"/>
              <Setter Property="ContentControl.ContentTemplate">
                <Setter.Value>
                  <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                      <TextBlock Margin="0,0" VerticalAlignment="Center" Text="{Binding Name}"/>
                    </StackPanel>
                  </DataTemplate>
                </Setter.Value>
              </Setter>
            </Style>
          </DataGridColumn.CellStyle>
        </DataGridTextColumn>
        <DataGridTextColumn x:Name="TypeColumn" Header="TYPE" Width="*" MinWidth="200" Binding="{Binding Type}">
          <DataGridColumn.CellStyle>
            <Style TargetType="{x:Type DataGridCell}" BasedOn="{StaticResource {x:Type DataGridCell}}">
              <Setter Property="Control.Padding" Value="5,0"/>
              <Setter Property="ContentControl.ContentTemplate">
                <Setter.Value>
                  <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                      <TextBlock Margin="0,0" VerticalAlignment="Center" Text="{Binding Type}"/>
                    </StackPanel>
                  </DataTemplate>
                </Setter.Value>
              </Setter>
            </Style>
          </DataGridColumn.CellStyle>
        </DataGridTextColumn>
        <DataGridTextColumn x:Name="SourceColumn" Header="SOURCE" Width="Auto" MinWidth="200" Binding="{Binding Source}">
          <DataGridColumn.HeaderStyle>
            <Style TargetType="{x:Type DataGridColumnHeader}" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
              <Setter Property="Control.HorizontalContentAlignment" Value="Right"/>
              <Setter Property="Control.FontSize" Value="10"/>
              <Setter Property="Control.FontWeight" Value="SemiBold"/>
              <Setter Property="Control.Padding" Value="5,2,5,3"/>
              <Setter Property="Control.Background" Value="{DynamicResource AccentColorBrush4}"/>
              <Setter Property="Control.Foreground" Value="{DynamicResource HighlightBrush}"/>
            </Style>
          </DataGridColumn.HeaderStyle>
          <DataGridColumn.CellStyle>
            <Style TargetType="{x:Type DataGridCell}" BasedOn="{StaticResource {x:Type DataGridCell}}">
              <Setter Property="Control.Padding" Value="5,0"/>
              <Setter Property="ContentControl.ContentTemplate">
                <Setter.Value>
                  <DataTemplate>
                    <TextBlock Margin="0,0" VerticalAlignment="Center" HorizontalAlignment="Right" Text="{Binding Source}"/>
                  </DataTemplate>
                </Setter.Value>
              </Setter>
            </Style>
          </DataGridColumn.CellStyle>
        </DataGridTextColumn>
      </DataGrid.Columns>
    </DataGrid>
  </Grid>
</UserControl>