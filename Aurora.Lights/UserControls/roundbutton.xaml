<UserControl x:Class="Builder.Presentation.UserControls.RoundButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Builder.Presentation.UserControls"
             x:Name="Main">
  <Grid>
    <TextBlock Style="{StaticResource FieldHeaderCheckTextBlockStyle}" HorizontalAlignment="Center"
               VerticalAlignment="Bottom" Margin="10" Foreground="{DynamicResource AuroraGoldColorBrush}"
               Visibility="Visible" Text="{Binding OverlaySymbol, ElementName=Main, FallbackValue=X}"
               FontSize="{Binding OverlaySymbolSize, ElementName=Main}"/>
    <Button x:Name="PortraitImage" Margin="1" Background="{DynamicResource HighlightBrush}"
            Command="{Binding ButtonCommand, ElementName=Main}" Width="{Binding InnerSize, ElementName=Main}"
            Height="{Binding InnerSize, ElementName=Main}">
      <ContentControl.Content>
        <Grid>
          <Image HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="UniformToFill"
                 RenderTransformOrigin="0.5,0.5"
                 Source="{Binding ImagePath, ElementName=Main, Converter={StaticResource ImageSourceConverter}}">
            <FrameworkElement.LayoutTransform>
              <TransformGroup>
                <ScaleTransform ScaleY="0.5" ScaleX="0.5"/>
                <SkewTransform/>
                <RotateTransform/>
                <TranslateTransform/>
              </TransformGroup>
            </FrameworkElement.LayoutTransform>
          </Image>
        </Grid>
      </ContentControl.Content>
      <FrameworkElement.Style>
        <Style TargetType="{x:Type Button}" BasedOn="{StaticResource PortraitButtonStyle}">
          <Style.Triggers>
            <Trigger Property="UIElement.IsMouseOver" Value="true">
              <TriggerBase.EnterActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation From="1" To="0.25" Storyboard.TargetProperty="Opacity" Duration="0:0:0.25"/>
                  </Storyboard>
                </BeginStoryboard>
              </TriggerBase.EnterActions>
              <TriggerBase.ExitActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation From=".25" To="1" Storyboard.TargetProperty="Opacity" Duration="0:0:0.25"/>
                  </Storyboard>
                </BeginStoryboard>
              </TriggerBase.ExitActions>
            </Trigger>
          </Style.Triggers>
        </Style>
      </FrameworkElement.Style>
    </Button>
    <Ellipse Margin="0" Stroke="{DynamicResource HighlightBrush}" IsHitTestVisible="false"
             StrokeThickness="{Binding BorderSize, ElementName=Main}" Width="{Binding Size, ElementName=Main}"
             Height="{Binding Size, ElementName=Main}">
      <UIElement.Effect>
        <DropShadowEffect BlurRadius="5" Opacity="1" ShadowDepth="1"/>
      </UIElement.Effect>
    </Ellipse>
  </Grid>
</UserControl>