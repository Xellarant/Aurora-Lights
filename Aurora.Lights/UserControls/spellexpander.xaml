<UserControl x:Class="Builder.Presentation.UserControls.SpellExpander"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Builder.Presentation.UserControls"
             Background="White">
  <FrameworkElement.DataContext>
    <local:SpellExpanderViewModel/>
  </FrameworkElement.DataContext>
  <Grid>
    <Expander Style="{StaticResource WhiteExpanderStyle}" IsExpanded="true" Header="{Binding SpellElement.Name}">
      <Grid>
        <local:DescriptionPanel/>
      </Grid>
    </Expander>
  </Grid>
</UserControl>