<UserControl x:Class="Builder.Presentation.UserControls.CompanionActionsPanelContent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:Builder.Presentation.Converters"
             xmlns:system="clr-namespace:System;assembly=mscorlib"
             xmlns:mui="http://firstfloorsoftware.com/ModernUI"
             xmlns:viewModels="clr-namespace:Builder.Presentation.ViewModels"
             xmlns:content="clr-namespace:Builder.Presentation.ViewModels.Content;assembly=Aurora.Logic"
             xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:controls1="clr-namespace:Builder.Presentation.Controls">
  <Grid Margin="0,0,0,0">
    <FrameworkElement.DataContext>
      <content:CompanionTraitsPanelContentViewModel/>
    </FrameworkElement.DataContext>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <StackPanel Margin="0,0,0,0"
                Visibility="{Binding HasActions, Converter={StaticResource BooleanToVisibilityConverter}}">
      <ItemsControl Margin="0" ItemsSource="{Binding Actions}">
        <ItemsControl.ItemContainerStyle>
          <Style TargetType="{x:Type FrameworkElement}">
            <Setter Property="FrameworkElement.Margin" Value="0,0,0,2"/>
          </Style>
        </ItemsControl.ItemContainerStyle>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <controls1:AuroraPanel Background="Transparent" BorderThickness="0" Padding="0,4">
              <StackPanel>
                <RichTextBox Foreground="{StaticResource GrayBrush5}" BorderThickness="0" IsReadOnly="true" Focusable="false"
                             IsHitTestVisible="false" Background="Transparent" Padding="0" Margin="0">
                  <FlowDocument>
                    <Paragraph FontSize="11">
                      <Run FontStyle="Italic" FontWeight="SemiBold" Text="{Binding Name, Mode=OneWay, StringFormat={}{0}.}"/>
                      <Run Text="{Binding SheetDescription.Text, Mode=OneWay}"/>
                    </Paragraph>
                  </FlowDocument>
                </RichTextBox>
              </StackPanel>
            </controls1:AuroraPanel>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>
  </Grid>
</UserControl>