<UserControl x:Class="Builder.Presentation.UserControls.Filters.InlineSpellFilter"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Builder.Presentation.UserControls.Filters"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             MinWidth="500" Background="White" Padding="0">
  <FrameworkElement.DataContext>
    <local:InlineSpellFilterViewModel/>
  </FrameworkElement.DataContext>
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition MinWidth="100" Width="*"/>
      <ColumnDefinition Width="Auto"/>
      <ColumnDefinition Width="Auto"/>
      <ColumnDefinition Width="Auto"/>
      <ColumnDefinition Width="Auto"/>
    </Grid.ColumnDefinitions>
    <TextBox MinWidth="150" ToolTip="Part of the name of the spell." mah:TextBoxHelper.Watermark="filter..."
             Grid.Column="0" Margin="0,0,10,0" Grid.Row="1"
             Text="{Binding Filter.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
    <ComboBox MinWidth="150" Grid.Column="1" Margin="0,0,10,0" Grid.Row="1"
              Visibility="{Binding IsSchoolFilterAvailable, Converter={StaticResource BooleanToVisibilityConverter}}"
              ItemsSource="{Binding Schools}"
              SelectedItem="{Binding SelectedSchool, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
    <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,10,0" Grid.Row="1">
      <FrameworkElement.Resources>
        <Style TargetType="{x:Type ToggleButton}" BasedOn="{StaticResource MetroFlatToggleButton}">
          <Setter Property="FrameworkElement.Margin" Value="0,0,1,0"/>
          <Setter Property="Control.FontWeight" Value="SemiBold"/>
          <Setter Property="Control.FontSize" Value="10"/>
          <Style.Triggers>
            <Trigger Property="ToggleButton.IsChecked" Value="True"/>
            <Trigger Property="ToggleButton.IsChecked" Value="False">
              <Setter Property="UIElement.Opacity" Value=".5"/>
            </Trigger>
          </Style.Triggers>
        </Style>
      </FrameworkElement.Resources>
      <ToggleButton Content="0" ToolTip="Cantrips"
                    IsChecked="{Binding Filter.IncludeCantrips, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
      <ToggleButton Content="1" ToolTip="1st-level spells"
                    IsChecked="{Binding Filter.Include1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
      <ToggleButton Content="2" ToolTip="2nd-level spells"
                    IsChecked="{Binding Filter.Include2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
      <ToggleButton Content="3" ToolTip="3rd-level spells"
                    IsChecked="{Binding Filter.Include3, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
      <ToggleButton Content="4" ToolTip="4th-level spells"
                    IsChecked="{Binding Filter.Include4, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
      <ToggleButton Content="5" ToolTip="5th-level spells"
                    IsChecked="{Binding Filter.Include5, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
      <ToggleButton Content="6" ToolTip="6th-level spells"
                    IsChecked="{Binding Filter.Include6, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
      <ToggleButton Content="7" ToolTip="7th-level spells"
                    IsChecked="{Binding Filter.Include7, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
      <ToggleButton Content="8" ToolTip="8th-level spells"
                    IsChecked="{Binding Filter.Include8, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
      <ToggleButton Content="9" ToolTip="9th-level spells" Margin="0"
                    IsChecked="{Binding Filter.Include9, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
    </StackPanel>
    <ComboBox MinWidth="150" Margin="0,0,0,0" Grid.Column="3" Grid.Row="1"
              Visibility="{Binding IsSourceFilterAvailable, Converter={StaticResource BooleanToVisibilityConverter}}"
              ItemsSource="{Binding Schools}"
              SelectedItem="{Binding SelectedSchool, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
  </Grid>
</UserControl>