<controls:MetroWindow x:Class="Builder.Presentation.Views.CharacterViewer"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                      xmlns:local="clr-namespace:Builder.Presentation.Views"
                      xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
                      xmlns:moonPdfLib="clr-namespace:MoonPdfLib;assembly=MoonPdfLib"
                      xmlns:viewModels="clr-namespace:Builder.Presentation.ViewModels"
                      xmlns:shell="clr-namespace:Builder.Presentation.ViewModels.Shell"
                      xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
                      xmlns:userControls="clr-namespace:Builder.Presentation.UserControls"
                      xmlns:controls1="clr-namespace:Aurora.Presentation.Controls;assembly=Aurora.Presentation"
                      Title="CHARACTER SHEET VIEWER" MinHeight="480" Height="575.609" Width="368"
                      Style="{StaticResource IconlessCharacterBuilderWindowStyle}">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="60"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <Border Style="{StaticResource OverlayBorderStyle}" VerticalAlignment="Bottom"/>
    <StackPanel x:Name="CompantionInformationPanel" Grid.Row="0" Margin="0,0,10,0" Orientation="Horizontal"
                HorizontalAlignment="Right" VerticalAlignment="Center" Visibility="Collapsed">
      <StackPanel Margin="0,0,10,0" VerticalAlignment="Center">
        <TextBlock Text="WOLF" FontSize="13" HorizontalAlignment="Right" FontWeight="SemiBold"
                   Foreground="{DynamicResource GrayBrush5}"/>
        <TextBlock Text="MEDIUM BEAST, UNALIGNED" FontSize="10" HorizontalAlignment="Right" FontWeight="Normal"
                   Foreground="{DynamicResource GrayBrush5}"/>
      </StackPanel>
      <Grid>
        <Button x:Name="PortraitImage" Style="{StaticResource PortraitButtonStyle}" Margin="1"
                Background="{DynamicResource HighlightBrush}">
          <ContentControl.Content>
            <Grid>
              <Image HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="None" ToolTip="Open Quickview"
                     RenderTransformOrigin="0.5,0.5" Source="{Binding Character.PortraitFilename}">
                <FrameworkElement.LayoutTransform>
                  <TransformGroup>
                    <ScaleTransform ScaleY="0.25" ScaleX="0.25"/>
                    <SkewTransform/>
                    <RotateTransform/>
                    <TranslateTransform/>
                  </TransformGroup>
                </FrameworkElement.LayoutTransform>
              </Image>
            </Grid>
          </ContentControl.Content>
        </Button>
        <Button Content="" Foreground="{StaticResource WhiteBrush}" ToolTip="Create New Character" FontSize="10"
                FontFamily="Segoe UI Symbol" Style="{StaticResource ChromelessButtonStyle}" Padding="10" Margin="0"
                Command="{Binding NewCharacterCommand}"
                Visibility="{Binding IsCharacterLoaded, Converter={StaticResource InvertedBooleanToVisibilityConverter}}"/>
        <Ellipse StrokeThickness="1" Margin="0" Stroke="{DynamicResource HighlightBrush}">
          <UIElement.Effect>
            <DropShadowEffect BlurRadius="3" Opacity="1" ShadowDepth="1"/>
          </UIElement.Effect>
        </Ellipse>
      </Grid>
    </StackPanel>
    <StackPanel x:Name="InfoStackPanel2" Grid.Row="0" Margin="10,0,10,0" Orientation="Horizontal"
                HorizontalAlignment="Left" VerticalAlignment="Center">
      <Grid>
        <Button x:Name="PortraitImage2" Style="{StaticResource PortraitButtonStyle}" Margin="1"
                Background="{DynamicResource HighlightBrush}">
          <ContentControl.Content>
            <Grid>
              <Image HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="None" ToolTip="Open Quickview"
                     RenderTransformOrigin="0.5,0.5" Source="{Binding Character.PortraitFilename}">
                <FrameworkElement.LayoutTransform>
                  <TransformGroup>
                    <ScaleTransform ScaleY="0.25" ScaleX="0.25"/>
                    <SkewTransform/>
                    <RotateTransform/>
                    <TranslateTransform/>
                  </TransformGroup>
                </FrameworkElement.LayoutTransform>
              </Image>
            </Grid>
          </ContentControl.Content>
        </Button>
        <Ellipse StrokeThickness="1" Margin="0" Stroke="{DynamicResource HighlightBrush}">
          <UIElement.Effect>
            <DropShadowEffect BlurRadius="3" Opacity="1" ShadowDepth="1"/>
          </UIElement.Effect>
        </Ellipse>
      </Grid>
      <StackPanel Margin="10,0,10,0" VerticalAlignment="Center">
        <TextBlock FontSize="13" HorizontalAlignment="Left" FontWeight="SemiBold"
                   Foreground="{DynamicResource GrayBrush5}"
                   Text="{Binding Character.Name, Converter={StaticResource ToUpperConverter}}"/>
        <TextBlock FontSize="10" HorizontalAlignment="Left" FontWeight="Normal"
                   Foreground="{DynamicResource GrayBrush5}"
                   Text="{Binding CharacterBuild, Converter={StaticResource ToUpperConverter}}"/>
      </StackPanel>
    </StackPanel>
    <controls1:CommandButton Grid.Row="0" HorizontalAlignment="Right" Margin="10,4" ToolTip="Update Character Sheet"
                             VerticalAlignment="Center" Style="{StaticResource SuccessIconCommandButtonStyle}"
                             Command="{Binding CreateCharacterSheetCommand}">
      <iconPacks:PackIconFontAwesome Kind="RedoAltSolid"/>
    </controls1:CommandButton>
    <Grid Row="1" Background="{DynamicResource AuroraDarkColorBrush}">
      <moonPdfLib:MoonPdfPanel x:Name="ViewerPanel" ViewType="SinglePage" PageRowDisplay="ContinuousPageRows" PageMargin="0,2,4,2"
                               Margin="5,0,5,0"/>
    </Grid>
  </Grid>
</controls:MetroWindow>