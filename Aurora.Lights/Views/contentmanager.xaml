<controls:MetroWindow x:Class="Builder.Presentation.Views.ContentManager"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                      xmlns:local="clr-namespace:Builder.Presentation.Views"
                      xmlns:viewModels="clr-namespace:Builder.Presentation.ViewModels;assembly=Aurora.Logic"
                      xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
                      xmlns:converters="http://metro.mahapps.com/winfx/xaml/shared"
                      Title="CONTENT MANAGER" Height="271" Width="715" MinHeight="400"
                      Style="{StaticResource IconlessCharacterBuilderWindowStyle}">
  <FrameworkElement.DataContext>
    <viewModels:ContentManagerViewModel/>
  </FrameworkElement.DataContext>
  <controls:MetroWindow.TitleTemplate>
    <DataTemplate>
      <StackPanel Orientation="Horizontal">
        <TextBlock Text="{Binding IsInDesignMode}"/>
        <TextBlock Text="{Binding}"/>
      </StackPanel>
    </DataTemplate>
  </controls:MetroWindow.TitleTemplate>
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*"/>
      <ColumnDefinition Width="*"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="*"/>
      <RowDefinition Height="50"/>
    </Grid.RowDefinitions>
    <TreeView Margin="0" ItemsSource="{Binding Items}" Style="{x:Null}">
      <FrameworkElement.Resources>
        <HierarchicalDataTemplate 
                                  DataType="{x:Type viewModels:ContentItem}" ItemsSource="{Binding Path=Items}">
          <TreeViewItem Header="{Binding Path=DisplayName}"/>
        </HierarchicalDataTemplate>
      </FrameworkElement.Resources>
    </TreeView>
  </Grid>
</controls:MetroWindow>