<controls:Flyout x:Class="Builder.Presentation.Views.Sliders.Content.BundleContentFlyout"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:shell="clr-namespace:Builder.Presentation.ViewModels.Shell"
                 xmlns:userControls="clr-namespace:Builder.Presentation.UserControls"
                 xmlns:controls1="clr-namespace:Builder.Presentation.Controls"
                 xmlns:viewModels="clr-namespace:Builder.Presentation.ViewModels"
                 xmlns:sliders="clr-namespace:Builder.Presentation.Views.Sliders"
                 xmlns:controls2="clr-namespace:Aurora.Presentation.Controls;assembly=Aurora.Presentation"
                 MinWidth="400" MaxWidth="450" CloseButtonVisibility="Collapsed" TitleVisibility="Collapsed"
                 Position="Right" Margin="0,0,0,0" IsPinned="false" IsAutoCloseEnabled="false" Theme="Dark"
                 IsModal="false" Background="#151515">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <FrameworkElement.Resources>
      <Style x:Key="SliderHeaderBorderStyle" TargetType="{x:Type Border}">
        <Setter Property="UIElement.SnapsToDevicePixels" Value="true"/>
        <Setter Property="Border.BorderThickness" Value="1"/>
        <Setter Property="FrameworkElement.Margin" Value="20"/>
        <Setter Property="Border.BorderBrush" Value="{DynamicResource AccentColorBrush3}"/>
        <Setter Property="Border.Background" Value="{DynamicResource AccentColorBrush4}"/>
      </Style>
      <Style x:Key="SliderHeaderTextBlockStyle" TargetType="{x:Type TextBlock}"
             BasedOn="{StaticResource WindowHeaderTextBlockStyle}"/>
    </FrameworkElement.Resources>
    <controls1:SliderTitleBlock Margin="20,20,20,20" Content="BUNDLE ADDITIONAL CONTENT"/>
    <ScrollViewer Grid.Row="1" Margin="20,0,20,10" VerticalScrollBarVisibility="Hidden"
                  Style="{StaticResource FlyoutScrollviewerStyle}">
      <StackPanel Margin="0,0,0,0">
        <controls2:CommandButton CommandText="Official Core Rules" Margin="0,0,0,0"/>
        <controls2:CommandButton CommandText="Official Supplements" Margin="0,10,0,50"/>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</controls:Flyout>