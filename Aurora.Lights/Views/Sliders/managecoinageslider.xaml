<controls:Flyout x:Class="Builder.Presentation.Views.Sliders.ManageCoinageSlider"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:shell="clr-namespace:Builder.Presentation.ViewModels.Shell"
                 xmlns:userControls="clr-namespace:Builder.Presentation.UserControls"
                 xmlns:controls1="clr-namespace:Builder.Presentation.Controls"
                 xmlns:viewModels="clr-namespace:Builder.Presentation.ViewModels"
                 xmlns:sliders="clr-namespace:Builder.Presentation.Views.Sliders"
                 xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
                 Width="500" MaxHeight="300" BorderThickness="0" BorderBrush="{DynamicResource HighlightBrush}"
                 CloseButtonVisibility="Collapsed" TitleVisibility="Collapsed" Position="Top" Margin="0,200,0,0"
                 IsPinned="false" AnimateOpacity="true" IsAutoCloseEnabled="false" AreAnimationsEnabled="true"
                 Theme="Light" IsModal="true" Background="#151516">
  <FrameworkElement.DataContext>
    <sliders:ManageCoinageSliderViewModel/>
  </FrameworkElement.DataContext>
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <controls1:SliderTitleBlock Margin="20,20,20,20" Content="MANAGE COINS" Background="{DynamicResource AccentColorBrush3}"/>
    <Button Grid.Row="0" Style="{StaticResource ChromelessButtonStyle}" FontSize="11"
            HorizontalAlignment="Right" Margin="0,18,20,18" Padding="15"
            Foreground="{DynamicResource IdealForegroundColorBrush}">
      <iconPacks:PackIconFontAwesome Kind="TimesSolid" Padding="0,1" Width="16" Height="16"/>
    </Button>
    <UniformGrid Grid.Row="1" Margin="20,0,20,20" Columns="5" FirstColumn="0" VerticalAlignment="Center">
      <FrameworkElement.Resources>
        <Style TargetType="{x:Type controls:NumericUpDown}">
          <Setter Property="controls:TextBoxHelper.SelectAllOnFocus" Value="true"/>
          <Setter Property="controls:NumericUpDown.HideUpDownButtons" Value="true"/>
          <Setter Property="Control.FontWeight" Value="SemiBold"/>
          <Setter Property="controls:NumericUpDown.TextAlignment" Value="Center"/>
          <Setter Property="controls:NumericUpDown.Minimum" Value="0"/>
          <Setter Property="Control.FontSize" Value="15"/>
          <Setter Property="FrameworkElement.Margin" Value="5,5,6,5"/>
          <Setter Property="Control.Foreground" Value="{DynamicResource GrayBrush8}"/>
          <Setter Property="Control.Background" Value="{DynamicResource TransparentWhiteBrush}"/>
          <Setter Property="Control.BorderThickness" Value="0"/>
        </Style>
        <Style TargetType="{x:Type Button}" BasedOn="{StaticResource ChromelessButtonStyle}">
          <Setter Property="FrameworkElement.HorizontalAlignment" Value="Center"/>
          <Setter Property="Control.Foreground" Value="{DynamicResource IdealForegroundColorBrush}"/>
          <Setter Property="Control.FontSize" Value="11"/>
          <Setter Property="Control.Padding" Value="5"/>
        </Style>
        <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource SectionHeaderTextBlockStyle}">
          <Setter Property="FrameworkElement.HorizontalAlignment" Value="Center"/>
          <Setter Property="TextBlock.Foreground" Value="{DynamicResource GrayBrush8}"/>
          <Setter Property="FrameworkElement.Margin" Value="0,0,0,10"/>
        </Style>
      </FrameworkElement.Resources>
      <StackPanel>
        <TextBlock Text="COPPER"/>
        <Button Command="{Binding IncreaseCopperCommand}">
          <iconPacks:PackIconFontAwesome Kind="AngleUpSolid" Padding="0,2" Width="16" Height="16"/>
        </Button>
        <controls:NumericUpDown Value="{Binding Copper}"/>
        <Button Command="{Binding DecreaseCopperCommand}">
          <iconPacks:PackIconFontAwesome Kind="AngleDownSolid" Padding="0,2" Width="16" Height="16"/>
        </Button>
        <Button Foreground="{DynamicResource AuroraGoldColorBrush}" ToolTip="Exchange everything to copper coins."
                Margin="0,10,0,0" Command="{Binding ConvertCopperCommand}">
          <iconPacks:PackIconFontAwesome Kind="AngleDoubleUpSolid" Padding="0,0" Width="16" Height="16"/>
        </Button>
      </StackPanel>
      <StackPanel>
        <TextBlock Text="SILVER"/>
        <Button Command="{Binding IncreaseSilverCommand}">
          <iconPacks:PackIconFontAwesome Kind="AngleUpSolid" Padding="0,2" Width="16" Height="16"/>
        </Button>
        <controls:NumericUpDown Value="{Binding Silver}"/>
        <Button Command="{Binding DecreaseSilverCommand}">
          <iconPacks:PackIconFontAwesome Kind="AngleDownSolid" Padding="0,2" Width="16" Height="16"/>
        </Button>
        <Button Foreground="{DynamicResource AuroraGoldColorBrush}" ToolTip="Exchange everything to silver coins."
                Margin="0,10,0,0" Command="{Binding ConvertSilverCommand}">
          <iconPacks:PackIconFontAwesome Kind="AngleDoubleUpSolid" Padding="0,0" Width="16" Height="16"/>
        </Button>
      </StackPanel>
      <StackPanel>
        <TextBlock Text="ELECTRUM"/>
        <Button Command="{Binding IncreaseElectrumCommand}">
          <iconPacks:PackIconFontAwesome Kind="AngleUpSolid" Padding="0,2" Width="16" Height="16"/>
        </Button>
        <controls:NumericUpDown Value="{Binding Electrum}"/>
        <Button Command="{Binding DecreaseElectrumCommand}">
          <iconPacks:PackIconFontAwesome Kind="AngleDownSolid" Padding="0,2" Width="16" Height="16"/>
        </Button>
        <Button Foreground="{DynamicResource AuroraGoldColorBrush}"
                ToolTip="Exchange everything to electrum coins." Margin="0,10,0,0"
                Command="{Binding ConvertElectrumCommand}">
          <iconPacks:PackIconFontAwesome Kind="AngleDoubleUpSolid" Padding="0,0" Width="16" Height="16"/>
        </Button>
      </StackPanel>
      <StackPanel>
        <TextBlock Text="GOLD"/>
        <Button Command="{Binding IncreaseGoldCommand}">
          <iconPacks:PackIconFontAwesome Kind="AngleUpSolid" Padding="0,2" Width="16" Height="16"/>
        </Button>
        <controls:NumericUpDown Value="{Binding Gold}"/>
        <Button Command="{Binding DecreaseGoldCommand}">
          <iconPacks:PackIconFontAwesome Kind="AngleDownSolid" Padding="0,2" Width="16" Height="16"/>
        </Button>
        <Button Foreground="{DynamicResource AuroraGoldColorBrush}" ToolTip="Exchange everything to gold coins."
                Margin="0,10,0,0" Command="{Binding ConvertGoldCommand}">
          <iconPacks:PackIconFontAwesome Kind="AngleDoubleUpSolid" Padding="0,0" Width="16" Height="16"/>
        </Button>
      </StackPanel>
      <StackPanel>
        <TextBlock Text="PLATINUM"/>
        <Button Command="{Binding IncreasePlatinumCommand}">
          <iconPacks:PackIconFontAwesome Kind="AngleUpSolid" Padding="0,2" Width="16" Height="16"/>
        </Button>
        <controls:NumericUpDown Value="{Binding Platinum}"/>
        <Button Command="{Binding DecreasePlatinumCommand}">
          <iconPacks:PackIconFontAwesome Kind="AngleDownSolid" Padding="0,2" Width="16" Height="16"/>
        </Button>
        <Button Foreground="{DynamicResource AuroraGoldColorBrush}"
                ToolTip="Exchange everything to platinum coins." Margin="0,10,0,0"
                Command="{Binding ConvertPlatinumCommand}">
          <iconPacks:PackIconFontAwesome Kind="AngleDoubleUpSolid" Padding="0,0" Width="16" Height="16"/>
        </Button>
      </StackPanel>
    </UniformGrid>
    <StackPanel Grid.Row="2" HorizontalAlignment="Center" Width="250" Margin="20,0,20,20">
      <TextBlock Style="{StaticResource SectionHeaderTextBlockStyle}" Margin="0,0,0,2" HorizontalAlignment="Center"
                 Foreground="{DynamicResource GrayBrush6}">
        <Run Text="{Binding Coinage.DisplayCoinage, Mode=OneWay}"/>
        <Run Text="GP"/>
      </TextBlock>
    </StackPanel>
  </Grid>
</controls:Flyout>