<controls:Flyout x:Class="Builder.Presentation.Views.Sliders.NewCharacterSlider"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:shell="clr-namespace:Builder.Presentation.ViewModels.Shell"
                 xmlns:userControls="clr-namespace:Builder.Presentation.UserControls"
                 xmlns:controls1="clr-namespace:Builder.Presentation.Controls"
                 xmlns:viewModels="clr-namespace:Builder.Presentation.ViewModels"
                 xmlns:sliders="clr-namespace:Builder.Presentation.Views.Sliders"
                 xmlns:controls2="clr-namespace:Aurora.Presentation.Controls;assembly=Aurora.Presentation"
                 MinWidth="400" MaxWidth="400" CloseButtonVisibility="Collapsed" Position="Right" IsPinned="true"
                 IsAutoCloseEnabled="false" TitleVisibility="Collapsed" Theme="Light" IsModal="true"
                 Background="#151516">
  <FrameworkElement.DataContext>
    <sliders:NewCharacterSliderViewModel/>
  </FrameworkElement.DataContext>
  <Grid Margin="0,0,0,0">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <controls1:SliderTitleBlock Margin="20,20,20,0" Content="NEW CHARACTER"/>
    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="20,20" HorizontalAlignment="Center">
      <Grid Margin="10">
        <TextBlock Text="" FontSize="18" Style="{StaticResource FieldHeaderCheckTextBlockStyle}"
                   HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10"
                   Foreground="{DynamicResource AuroraGoldColorBrush}" Visibility="Visible" ToolTip="Random Portrait"/>
        <Button x:Name="PortraitImageLeft" Margin="1" Background="{DynamicResource HighlightBrush}" Width="57"
                Height="57" Command="{Binding PreviousPortraitCommand}">
          <ContentControl.Content>
            <Grid>
              <Image HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="None"
                     RenderTransformOrigin="0.5,0.5"
                     Source="{Binding PreviousPortraitPath, Converter={StaticResource PortraitImageSourceConverter}}">
                <FrameworkElement.LayoutTransform>
                  <TransformGroup>
                    <ScaleTransform ScaleY="0.30" ScaleX="0.30"/>
                    <SkewTransform/>
                    <RotateTransform/>
                    <TranslateTransform/>
                  </TransformGroup>
                </FrameworkElement.LayoutTransform>
              </Image>
            </Grid>
          </ContentControl.Content>
          <FrameworkElement.Style>
            <Style TargetType="{x:Type Button}" BasedOn="{StaticResource PortraitButtonStyle}">
              <Style.Triggers>
                <Trigger Property="UIElement.IsMouseOver" Value="true">
                  <TriggerBase.EnterActions>
                    <BeginStoryboard>
                      <Storyboard>
                        <DoubleAnimation From="1" To="0.25" Storyboard.TargetProperty="Opacity" Duration="0:0:0.25"/>
                      </Storyboard>
                    </BeginStoryboard>
                  </TriggerBase.EnterActions>
                  <TriggerBase.ExitActions>
                    <BeginStoryboard>
                      <Storyboard>
                        <DoubleAnimation From=".75" To="1" Storyboard.TargetProperty="Opacity" Duration="0:0:0.25"/>
                      </Storyboard>
                    </BeginStoryboard>
                  </TriggerBase.ExitActions>
                </Trigger>
              </Style.Triggers>
            </Style>
          </FrameworkElement.Style>
        </Button>
        <Ellipse StrokeThickness="2" Margin="0" Stroke="{DynamicResource HighlightBrush}" Width="60" Height="60"
                 IsHitTestVisible="false">
          <UIElement.Effect>
            <DropShadowEffect BlurRadius="5" Opacity="1" ShadowDepth="1"/>
          </UIElement.Effect>
        </Ellipse>
      </Grid>
      <Grid Margin="10,0">
        <TextBlock Text="" FontSize="20" Style="{StaticResource FieldHeaderCheckTextBlockStyle}"
                   HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="10"
                   Foreground="{DynamicResource AuroraGoldColorBrush}" Visibility="Visible" ToolTip="Random Portrait"/>
        <Button x:Name="PortraitImage" Margin="1" Background="{DynamicResource HighlightBrush}" Width="147"
                Height="147" Command="{Binding RandomizePortraitCommand}">
          <ContentControl.Content>
            <Grid>
              <Image HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="UniformToFill"
                     RenderTransformOrigin="0.5,0.5"
                     Source="{Binding PortraitFilePath, Converter={StaticResource PortraitImageSourceConverter}}">
                <FrameworkElement.LayoutTransform>
                  <TransformGroup>
                    <ScaleTransform ScaleY="0.5" ScaleX="0.5"/>
                    <SkewTransform/>
                    <RotateTransform/>
                    <TranslateTransform/>
                  </TransformGroup>
                </FrameworkElement.LayoutTransform>
              </Image>
            </Grid>
          </ContentControl.Content>
          <FrameworkElement.Style>
            <Style TargetType="{x:Type Button}" BasedOn="{StaticResource PortraitButtonStyle}">
              <Style.Triggers>
                <Trigger Property="UIElement.IsMouseOver" Value="true">
                  <TriggerBase.EnterActions>
                    <BeginStoryboard>
                      <Storyboard>
                        <DoubleAnimation From="1" To="0.25" Storyboard.TargetProperty="Opacity" Duration="0:0:0.25"/>
                      </Storyboard>
                    </BeginStoryboard>
                  </TriggerBase.EnterActions>
                  <TriggerBase.ExitActions>
                    <BeginStoryboard>
                      <Storyboard>
                        <DoubleAnimation From=".25" To="1" Storyboard.TargetProperty="Opacity" Duration="0:0:0.25"/>
                      </Storyboard>
                    </BeginStoryboard>
                  </TriggerBase.ExitActions>
                </Trigger>
              </Style.Triggers>
            </Style>
          </FrameworkElement.Style>
        </Button>
        <Ellipse StrokeThickness="3" Margin="0" Stroke="{DynamicResource HighlightBrush}" Width="150" Height="150"
                 IsHitTestVisible="false">
          <UIElement.Effect>
            <DropShadowEffect BlurRadius="5" Opacity="1" ShadowDepth="1"/>
          </UIElement.Effect>
        </Ellipse>
      </Grid>
      <Grid Margin="10">
        <TextBlock Text="" FontSize="18" Style="{StaticResource FieldHeaderCheckTextBlockStyle}"
                   HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10"
                   Foreground="{DynamicResource AuroraGoldColorBrush}" Visibility="Visible" ToolTip="Random Portrait"/>
        <Button x:Name="PortraitImageRight" Margin="1" Background="{DynamicResource HighlightBrush}" Width="57"
                Height="57" Command="{Binding NextPortraitCommand}">
          <ContentControl.Content>
            <Grid>
              <Image HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="None"
                     RenderTransformOrigin="0.5,0.5"
                     Source="{Binding NextPortraitsPath, Converter={StaticResource PortraitImageSourceConverter}}">
                <FrameworkElement.LayoutTransform>
                  <TransformGroup>
                    <ScaleTransform ScaleY="0.30" ScaleX="0.30"/>
                    <SkewTransform/>
                    <RotateTransform/>
                    <TranslateTransform/>
                  </TransformGroup>
                </FrameworkElement.LayoutTransform>
              </Image>
            </Grid>
          </ContentControl.Content>
          <FrameworkElement.Style>
            <Style TargetType="{x:Type Button}" BasedOn="{StaticResource PortraitButtonStyle}">
              <Style.Triggers>
                <Trigger Property="UIElement.IsMouseOver" Value="true">
                  <TriggerBase.EnterActions>
                    <BeginStoryboard>
                      <Storyboard>
                        <DoubleAnimation From="1" To="0.25" Storyboard.TargetProperty="Opacity" Duration="0:0:0.25"/>
                      </Storyboard>
                    </BeginStoryboard>
                  </TriggerBase.EnterActions>
                  <TriggerBase.ExitActions>
                    <BeginStoryboard>
                      <Storyboard>
                        <DoubleAnimation From=".75" To="1" Storyboard.TargetProperty="Opacity" Duration="0:0:0.25"/>
                      </Storyboard>
                    </BeginStoryboard>
                  </TriggerBase.ExitActions>
                </Trigger>
              </Style.Triggers>
            </Style>
          </FrameworkElement.Style>
        </Button>
        <Ellipse StrokeThickness="2" Margin="0" Stroke="{DynamicResource HighlightBrush}" Width="60" Height="60"
                 IsHitTestVisible="false">
          <UIElement.Effect>
            <DropShadowEffect BlurRadius="5" Opacity="1" ShadowDepth="1"/>
          </UIElement.Effect>
        </Ellipse>
      </Grid>
    </StackPanel>
    <StackPanel Grid.Row="2" Margin="20,0,20,0">
      <controls1:AuroraExpander IsExpanded="true" Header="Character Details" Background="Transparent" Margin="-4,0"
                                controls:ControlsHelper.HeaderFontSize="13" Style="{StaticResource FlyoutExpanderStyle}">
        <StackPanel Margin="0,-4,0,0">
          <TextBlock Text="Start with some basic details for your character."
                     Style="{StaticResource SectionSubHeaderTextBlockStyle}"/>
          <TextBlock Text="NAME" Style="{StaticResource FieldHeaderTextBlockStyle}"
                     Foreground="{DynamicResource GrayBrush2}" Margin="0,0,0,2"/>
          <TextBox controls:TextBoxHelper.Watermark="enter a character name"
                   controls:TextBoxHelper.ButtonTemplate="{StaticResource ChromelessButtonTemplate}"
                   controls:TextBoxHelper.ButtonFontFamily="Segoe UI Symbol" controls:TextBoxHelper.ButtonContent=""
                   controls:TextBoxHelper.ButtonFontSize="11" Margin="0,0,0,5" VerticalContentAlignment="Center"
                   Height="28" Style="{DynamicResource MetroButtonTextBox}"
                   Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                   controls:TextBoxHelper.ButtonCommand="{Binding RandomizeNameCommand}"/>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="20"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="STARTING LEVEL" Style="{StaticResource FieldHeaderTextBlockStyle}"
                       Foreground="{DynamicResource GrayBrush2}"/>
            <TextBlock Grid.Column="2" Text="GENDER" Style="{StaticResource FieldHeaderTextBlockStyle}"
                       Foreground="{DynamicResource GrayBrush2}"/>
            <ComboBox Grid.Row="1" SelectedIndex="0"
                      Text="{Binding Level, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
              <ComboBoxItem>1</ComboBoxItem>
              <ComboBoxItem>2</ComboBoxItem>
              <ComboBoxItem>3</ComboBoxItem>
              <ComboBoxItem>4</ComboBoxItem>
              <ComboBoxItem>5</ComboBoxItem>
              <ComboBoxItem>6</ComboBoxItem>
              <ComboBoxItem>7</ComboBoxItem>
              <ComboBoxItem>8</ComboBoxItem>
              <ComboBoxItem>9</ComboBoxItem>
              <ComboBoxItem>10</ComboBoxItem>
              <ComboBoxItem>11</ComboBoxItem>
              <ComboBoxItem>12</ComboBoxItem>
              <ComboBoxItem>13</ComboBoxItem>
              <ComboBoxItem>14</ComboBoxItem>
              <ComboBoxItem>15</ComboBoxItem>
              <ComboBoxItem>16</ComboBoxItem>
              <ComboBoxItem>17</ComboBoxItem>
              <ComboBoxItem>18</ComboBoxItem>
              <ComboBoxItem>19</ComboBoxItem>
              <ComboBoxItem>20</ComboBoxItem>
            </ComboBox>
            <ComboBox Grid.Column="2" Grid.Row="1" SelectedIndex="0"
                      Text="{Binding Gender, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
              <ComboBoxItem>Male</ComboBoxItem>
              <ComboBoxItem>Female</ComboBoxItem>
              <ComboBoxItem>Construct</ComboBoxItem>
            </ComboBox>
          </Grid>
          <TextBlock Text="ABILITIES GENERATION OPTION" Style="{StaticResource FieldHeaderTextBlockStyle}"
                     Foreground="{DynamicResource GrayBrush2}"/>
          <ComboBox Margin="0,0,0,0" ItemsSource="{Binding AbilitiesGenerationSelectionItems}"
                    SelectedItem="{Binding SelectedAbilityGenerateOption, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
          <Grid Margin="0,0,0,0"
                Visibility="{Binding IsArrayOptionSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
            <FrameworkElement.Resources>
              <Style TargetType="{x:Type controls1:AuroraPanel}" BasedOn="{StaticResource DefaultAuroraPanelStyle}">
                <Setter Property="FrameworkElement.Margin" Value="8,0"/>
                <Setter Property="Control.Padding" Value="0"/>
                <Style.Triggers>
                  <Trigger Property="UIElement.IsMouseOver" Value="true">
                    <Setter Property="Control.Background" Value="{DynamicResource AccentColorBrush}"/>
                  </Trigger>
                </Style.Triggers>
              </Style>
              <Style x:Key="NameStyle" TargetType="{x:Type TextBlock}"
                     BasedOn="{StaticResource SectionHeaderTextBlockStyle}">
                <Setter Property="FrameworkElement.Margin" Value="0,7,2,0"/>
                <Setter Property="FrameworkElement.HorizontalAlignment" Value="Center"/>
                <Setter Property="TextBlock.Foreground" Value="{DynamicResource GrayBrush6}"/>
              </Style>
              <Style x:Key="ValueStyle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource NameStyle}">
                <Setter Property="TextBlock.FontSize" Value="14"/>
                <Setter Property="FrameworkElement.Margin" Value="0,4,0,8"/>
                <Setter Property="TextBlock.Foreground" Value="{DynamicResource AuroraGoldColorBrush}"/>
              </Style>
            </FrameworkElement.Resources>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Margin="0,4,0,10" Grid.Row="0"
                       Text="Determine your ability scores by dragging and dropping them around."
                       Style="{StaticResource SectionSubHeaderTextBlockStyle}"/>
            <UniformGrid Margin="-8,0" Columns="6" Grid.Row="1" DataContext="{Binding Abilities}">
              <controls1:AuroraPanel MouseMove="UIElement_OnMouseMove" Drop="UIElement_OnDrop" AllowDrop="true"
                                     DataContext="{Binding Strength}">
                <StackPanel>
                  <TextBlock Style="{StaticResource NameStyle}"
                             Text="{Binding Abbreviation, Converter={StaticResource UpperCaseConverter}}"/>
                  <TextBlock Style="{StaticResource ValueStyle}" Text="{Binding BaseScore}"/>
                </StackPanel>
              </controls1:AuroraPanel>
              <controls1:AuroraPanel MouseMove="UIElement_OnMouseMove" Drop="UIElement_OnDrop" AllowDrop="true"
                                     DataContext="{Binding Dexterity}">
                <StackPanel>
                  <TextBlock Style="{StaticResource NameStyle}"
                             Text="{Binding Abbreviation, Converter={StaticResource UpperCaseConverter}}"/>
                  <TextBlock Style="{StaticResource ValueStyle}" Text="{Binding BaseScore}"/>
                </StackPanel>
              </controls1:AuroraPanel>
              <controls1:AuroraPanel MouseMove="UIElement_OnMouseMove" Drop="UIElement_OnDrop" AllowDrop="true"
                                     DataContext="{Binding Constitution}">
                <StackPanel>
                  <TextBlock Style="{StaticResource NameStyle}"
                             Text="{Binding Abbreviation, Converter={StaticResource UpperCaseConverter}}"/>
                  <TextBlock Style="{StaticResource ValueStyle}" Text="{Binding BaseScore}"/>
                </StackPanel>
              </controls1:AuroraPanel>
              <controls1:AuroraPanel MouseMove="UIElement_OnMouseMove" Drop="UIElement_OnDrop" AllowDrop="true"
                                     DataContext="{Binding Intelligence}">
                <StackPanel>
                  <TextBlock Style="{StaticResource NameStyle}"
                             Text="{Binding Abbreviation, Converter={StaticResource UpperCaseConverter}}"/>
                  <TextBlock Style="{StaticResource ValueStyle}" Text="{Binding BaseScore}"/>
                </StackPanel>
              </controls1:AuroraPanel>
              <controls1:AuroraPanel MouseMove="UIElement_OnMouseMove" Drop="UIElement_OnDrop" AllowDrop="true"
                                     DataContext="{Binding Wisdom}">
                <StackPanel>
                  <TextBlock Style="{StaticResource NameStyle}"
                             Text="{Binding Abbreviation, Converter={StaticResource UpperCaseConverter}}"/>
                  <TextBlock Style="{StaticResource ValueStyle}" Text="{Binding BaseScore}"/>
                </StackPanel>
              </controls1:AuroraPanel>
              <controls1:AuroraPanel MouseMove="UIElement_OnMouseMove" Drop="UIElement_OnDrop" AllowDrop="true"
                                     DataContext="{Binding Charisma}">
                <StackPanel>
                  <TextBlock Style="{StaticResource NameStyle}"
                             Text="{Binding Abbreviation, Converter={StaticResource UpperCaseConverter}}"/>
                  <TextBlock Style="{StaticResource ValueStyle}" Text="{Binding BaseScore}"/>
                </StackPanel>
              </controls1:AuroraPanel>
            </UniformGrid>
          </Grid>
        </StackPanel>
      </controls1:AuroraExpander>
    </StackPanel>
    <StackPanel Grid.Row="3" Margin="20,0">
      <TextBlock Text="CHARACTER OPTIONS" Style="{StaticResource SectionHeaderTextBlockStyle}"
                 Foreground="{DynamicResource GrayBrush6}"/>
      <TextBlock Text="These options enable or disable some options your character will have."
                 Style="{StaticResource SectionSubHeaderTextBlockStyle}"/>
    </StackPanel>
    <ScrollViewer Style="{StaticResource FlyoutScrollviewerStyle}" VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled" Grid.Row="4" Margin="20,0,20,5">
      <ItemsControl Margin="0,0,0,0" ItemsSource="{Binding Options}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Margin="0,0,0,5">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="*"/>
                  <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Margin="0"/>
                <controls1:AuroraPanel Background="{DynamicResource AccentColorBrush4}" Grid.Row="1" Grid.Column="0" Margin="0,0,0,0"
                                       Padding="8" BorderThickness="1">
                  <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,0,0,0">
                      <TextBlock FontSize="9" Foreground="{DynamicResource AuroraGoldColorBrush}" Margin="0,0" Text="CUSTOM"
                                 FontFamily="Segoe UI SemiBold"
                                 Visibility="{Binding IsCustom, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                      <TextBlock FontSize="9" Foreground="{DynamicResource DangerColorBrush}" Margin="0,0" Text="LOCKED"
                                 FontFamily="Segoe UI SemiBold"
                                 Visibility="{Binding IsEnabled, Converter={StaticResource InvertedBooleanToVisibilityConverter}}"/>
                    </StackPanel>
                    <StackPanel>
                      <StackPanel Orientation="Horizontal"/>
                      <CheckBox Foreground="{DynamicResource GrayBrush5}" FontWeight="SemiBold" IsEnabled="{Binding IsEnabled}"
                                IsChecked="{Binding IsSelected}"
                                Content="{Binding Header, Converter={StaticResource UpperCaseConverter}}"/>
                      <TextBlock LineHeight="14" LineStackingStrategy="BlockLineHeight"
                                 Style="{StaticResource SectionSubHeaderTextBlockStyle}" Margin="0,5,0,0"
                                 TextTrimming="WordEllipsis" MaxHeight="20" Text="{Binding Description}"
                                 Visibility="{Binding IsSelected, Converter={StaticResource InvertedBooleanToVisibilityConverter}}"/>
                      <TextBlock LineHeight="14" LineStackingStrategy="BlockLineHeight"
                                 Style="{StaticResource SectionSubHeaderTextBlockStyle}" Margin="0,5,0,0"
                                 TextTrimming="WordEllipsis" Text="{Binding Description}"
                                 Visibility="{Binding IsSelected, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </StackPanel>
                  </Grid>
                </controls1:AuroraPanel>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
    <UniformGrid Grid.Row="6" Margin="20,0,20,0">
      <controls2:CommandButton Click="PageCloseClicked" Content="CREATE CHARACTER" IsDefault="true"
                               Style="{StaticResource SuccessCommandButtonStyle}" Margin="0,0,10,0"
                               Command="{Binding CreateNewCommand}"/>
      <controls2:CommandButton Click="PageCloseClicked" Content="CANCEL" Margin="10,0,0,0" IsCancel="true"
                               Style="{StaticResource DangerCommandButtonStyle}" Command="{Binding CancelCommand}"/>
    </UniformGrid>
  </Grid>
</controls:Flyout>