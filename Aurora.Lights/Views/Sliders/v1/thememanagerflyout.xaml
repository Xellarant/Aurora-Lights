<controls:Flyout x:Class="Builder.Presentation.Views.Sliders.ThemeManagerFlyout"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:shell="clr-namespace:Builder.Presentation.ViewModels.Shell"
                 xmlns:userControls="clr-namespace:Builder.Presentation.UserControls"
                 xmlns:controls1="clr-namespace:Builder.Presentation.Controls"
                 xmlns:viewModels="clr-namespace:Builder.Presentation.ViewModels"
                 xmlns:sliders="clr-namespace:Builder.Presentation.Views.Sliders"
                 xmlns:controls2="clr-namespace:Aurora.Presentation.Controls;assembly=Aurora.Presentation"
                 MinWidth="400" MaxWidth="450" CloseButtonVisibility="Collapsed" TitleVisibility="Collapsed"
                 Position="Right" Margin="0,0,0,0" IsPinned="false" IsAutoCloseEnabled="false" Theme="Dark"
                 IsModal="false" Background="{DynamicResource Aurora.Brushes.Light}">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <FrameworkElement.Resources>
      <Style x:Key="SliderHeaderBorderStyle" TargetType="{x:Type Border}">
        <Setter Property="UIElement.SnapsToDevicePixels" Value="true"/>
        <Setter Property="Border.BorderThickness" Value="1"/>
        <Setter Property="FrameworkElement.Margin" Value="20"/>
        <Setter Property="Border.BorderBrush" Value="{DynamicResource AccentColorBrush3}"/>
        <Setter Property="Border.Background" Value="{DynamicResource AccentColorBrush4}"/>
      </Style>
      <Style x:Key="SliderHeaderTextBlockStyle" TargetType="{x:Type TextBlock}"
             BasedOn="{StaticResource WindowHeaderTextBlockStyle}"/>
    </FrameworkElement.Resources>
    <controls1:SliderTitleBlock Margin="20,20,20,20" Content="Aurora Theme Manager" FontSize="18"
                                BorderBrush="{DynamicResource Aurora.Brushes.Light2}"
                                Foreground="{DynamicResource Aurora.Brushes.Text.Primary}"
                                Background="{DynamicResource Aurora.Brushes.Light1}"/>
    <StackPanel Grid.Row="1" Margin="20,0,20,0">
      <Grid Margin="0,20,0,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="*"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Dark Theme" VerticalAlignment="Center"
                   Foreground="{DynamicResource Aurora.Brushes.Text.Primary}"
                   Style="{StaticResource SectionPrimaryTextBlockStyle}"/>
        <controls:ToggleSwitch Foreground="{DynamicResource Aurora.Brushes.Text.Primary}" IsChecked="True" OnLabel="Enabled"
                               OffLabel="Disabled" Style="{StaticResource MahApps.Metro.Styles.ToggleSwitch.Win10}"
                               ContentDirection="LeftToRight" FontWeight="SemiBold" ContentPadding="0,0,10,0" Grid.Row="0"
                               Grid.Column="1" UnCheckedCommand="{Binding SetLightThemeCommand}"
                               CheckedCommand="{Binding SetDarkThemeCommand}"/>
      </Grid>
      <Separator Style="{StaticResource Aurora.Styles.Separator.Flyout}"/>
    </StackPanel>
    <UniformGrid Grid.Row="3" Margin="20,0,20,20" Columns="1" FirstColumn="0">
      <controls2:CommandButton Content="CLOSE" Margin="0,0,0,0" IsCancel="true"/>
    </UniformGrid>
  </Grid>
</controls:Flyout>