<controls:Flyout x:Class="Builder.Presentation.Views.Sliders.SymbolsGallerySlider"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:shell="clr-namespace:Builder.Presentation.ViewModels.Shell"
                 xmlns:userControls="clr-namespace:Builder.Presentation.UserControls"
                 xmlns:controls1="clr-namespace:Builder.Presentation.Controls"
                 xmlns:sliders="clr-namespace:Builder.Presentation.Views.Sliders"
                 xmlns:controls2="clr-namespace:Aurora.Presentation.Controls;assembly=Aurora.Presentation"
                 xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
                 MinWidth="430" MaxWidth="460" Position="Right" CloseButtonVisibility="Collapsed"
                 TitleVisibility="Collapsed" IsAutoCloseEnabled="false" AutoCloseInterval="10000" IsPinned="false"
                 Theme="Dark" IsModal="true" Background="{DynamicResource AuroraDarkColorBrush}">
  <FrameworkElement.DataContext>
    <sliders:SymbolsGalleryViewModel/>
  </FrameworkElement.DataContext>
  <Grid Margin="0,0,0,0">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <controls1:SliderTitleBlock Margin="20" Content="ALLIES &amp; ORGANIZATIONS GALLERY"/>
    <StackPanel VerticalAlignment="Center" Margin="20,0" Grid.Row="1"
                Visibility="{Binding HasResults, Converter={StaticResource InvertedBooleanToVisibilityConverter}}">
      <TextBlock Text="No allies &amp; organization symbols found." Foreground="{DynamicResource DangerColorBrush}"
                 TextAlignment="Center" FontSize="14" MaxWidth="300" Margin="0,0,0,10"
                 Style="{StaticResource FlavorDescriptionTextBlockStyle}"/>
      <TextBlock Text="Click 'Browse' to import your own symbol." MaxWidth="350"
                 Foreground="{DynamicResource GrayBrush9}" TextAlignment="Center" FontSize="14"
                 Style="{StaticResource FlavorDescriptionTextBlockStyle}"/>
    </StackPanel>
    <ListView MouseDoubleClick="SelectPortraitClick" Margin="18,0,20,0" Grid.Row="1" Grid.Column="0"
              BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
              Background="{DynamicResource AuroraDarkColorBrush}" Padding="0"
              Visibility="{Binding HasResults, Converter={StaticResource BooleanToVisibilityConverter}}"
              ItemsSource="{Binding Portraits}"
              SelectedItem="{Binding SelectedPortrait, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
      <ItemsControl.ItemContainerStyle>
        <Style TargetType="{x:Type ListViewItem}" BasedOn="{StaticResource {x:Type ListViewItem}}">
          <Setter Property="Control.Background" Value="{DynamicResource AuroraDarkColorBrush}"/>
          <Setter Property="FrameworkElement.Margin" Value="2"/>
          <Setter Property="Control.Padding" Value="0"/>
        </Style>
      </ItemsControl.ItemContainerStyle>
      <ItemsControl.ItemsPanel>
        <ItemsPanelTemplate>
          <WrapPanel/>
        </ItemsPanelTemplate>
      </ItemsControl.ItemsPanel>
      <ItemsControl.ItemTemplate>
        <DataTemplate>
          <Grid Margin="4" ToolTip="{Binding}">
            <Border Width="120" Height="120" BorderThickness="3" BorderBrush="{DynamicResource HighlightBrush}"
                    Margin="0" Grid.Row="0" SnapsToDevicePixels="true">
              <Image Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center" Source="{Binding}"/>
            </Border>
          </Grid>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ListView>
    <StackPanel Grid.Row="2" Margin="20,20,20,20">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
      </Grid>
    </StackPanel>
    <UniformGrid Grid.Row="3" Margin="10,0,10,20" Columns="3">
      <controls2:CommandButton Click="SelectPortraitClick" Content="SELECT SYMBOL" Margin="10,0" IsDefault="true"/>
      <controls2:CommandButton Click="BrowseClick" CommandText="BROWSE" Margin="10,0" FontSize="11">
        <iconPacks:PackIconMaterial Kind="FolderSearch"/>
      </controls2:CommandButton>
      <controls2:CommandButton Click="CancelClick" Content="CANCEL" Margin="10,0" FontSize="11" IsCancel="true"
                               Style="{StaticResource DangerCommandButtonStyle}"/>
    </UniformGrid>
  </Grid>
</controls:Flyout>