<mah:MetroWindow x:Class="Builder.Presentation.Views.Tools.CreateSpellcastingWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:local="clr-namespace:Builder.Presentation.Views.Tools"
                 xmlns:controls="clr-namespace:Aurora.Presentation.Controls;assembly=Aurora.Presentation"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 Title="CreateSpellcastingWindow" Height="532.5" Width="705">
  <FrameworkElement.DataContext>
    <local:CreateSpellcastingViewModel/>
  </FrameworkElement.DataContext>
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>
    <ListView x:Name="SpellsListView" Grid.RowSpan="2" SelectionMode="Multiple" ItemsSource="{Binding Spells}"/>
    <StackPanel Grid.Row="0" Grid.Column="1" Margin="10">
      <TextBlock Text="SUPPORT NAME" Style="{StaticResource FieldHeaderTextBlockStyle}"/>
      <TextBox Text="{Binding SupportName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
    </StackPanel>
    <TextBox Grid.Row="1" Grid.Column="1" AcceptsReturn="true" AcceptsTab="true" IsReadOnly="true"
             Text="{Binding Output}"/>
    <StackPanel Grid.Row="2" Grid.ColumnSpan="2" HorizontalAlignment="Right">
      <controls:CommandButton CommandText="Generate List" Margin="10"
                              CommandParameter="{Binding ElementName=SpellsListView, Path=SelectedItems}"
                              Command="{Binding GenerateListCommand}"/>
    </StackPanel>
  </Grid>
</mah:MetroWindow>