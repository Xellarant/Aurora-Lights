<controls:MetroWindow x:Class="Builder.Presentation.Views.Development.GenerateElementWindow"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                      xmlns:local="clr-namespace:Builder.Presentation.Views.Development"
                      xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
                      xmlns:newFolder1="clr-namespace:Builder.Presentation.Models.NewFolder1"
                      xmlns:userControls="clr-namespace:Builder.Presentation.UserControls"
                      Title="Generate Element" Height="600" Width="800" MinHeight="300"
                      Style="{StaticResource IconlessCharacterBuilderWindowStyle}"
                      TitleTemplate="{StaticResource IconlessCharacterBuilderWindowTitleDataTemplate}">
  <FrameworkElement.DataContext>
    <local:GenerateElementWindowViewModel/>
  </FrameworkElement.DataContext>
  <Grid Background="{DynamicResource GrayBrush10}">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <Border BorderThickness="0,0,0,0" Background="{DynamicResource HighlightBrush}" Grid.ColumnSpan="3"
            Height="30">
      <Grid>
        <FrameworkElement.Resources>
          <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
              <ResourceDictionary Source="/Styles/Builder/MenuStyle.xaml"/>
              <ResourceDictionary Source="/Styles/Builder/MenuIcons.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style TargetType="{x:Type MenuItem}" BasedOn="{StaticResource AuroraMenuItem}">
              <Setter Property="Control.FontWeight" Value="Normal"/>
            </Style>
          </ResourceDictionary>
        </FrameworkElement.Resources>
        <Menu Margin="5,1,0,0" Background="{DynamicResource TransparentWhiteBrush}">
          <MenuItem Header="FILE" FontWeight="SemiBold">
            <MenuItem Header="NEW" Command="{Binding NewCommand}"/>
          </MenuItem>
          <MenuItem Header="EDIT" FontWeight="SemiBold" IsEnabled="false">
            <MenuItem Header="NEW" Command="{Binding NewCommand}"/>
          </MenuItem>
        </Menu>
      </Grid>
    </Border>
    <controls:MetroTabControl Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" TabStripPlacement="Left" Margin="0,10,0,5"
                              controls:TabControlHelper.Underlined="TabPanel"
                              Background="{DynamicResource TransparentWhiteBrush}"
                              Style="{DynamicResource SettingsTabControlStyle}">
      <FrameworkElement.Resources>
        <Style TargetType="{x:Type controls:MetroTabItem}" BasedOn="{StaticResource MetroTabItem}">
          <Setter Property="HeaderedContentControl.HeaderTemplate">
            <Setter.Value>
              <DataTemplate>
                <TextBlock Margin="0" FontSize="12" Padding="10,5,10,5" FontWeight="SemiBold"
                           Text="{Binding Converter={StaticResource UpperCaseConverter}}"/>
              </DataTemplate>
            </Setter.Value>
          </Setter>
        </Style>
        <Style TargetType="{x:Type ScrollViewer}">
          <Setter Property="FrameworkElement.Margin" Value="20,0,10,0"/>
        </Style>
      </FrameworkElement.Resources>
      <controls:MetroTabItem Header="Element Header">
        <ScrollViewer>
          <StackPanel Margin="0,5,20,0">
            <StackPanel Margin="0" Grid.Row="1">
              <TextBlock Text="NAME" Style="{StaticResource FieldHeaderTextBlockStyle}"/>
              <TextBox Text="{Binding Element.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
              <TextBlock Text="TYPE" Style="{StaticResource FieldHeaderTextBlockStyle}"/>
              <ComboBox IsEditable="true" Text="{Binding Element.Type}"
                        SelectedItem="{Binding SelectedInternalType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        ItemsSource="{Binding InternalTypes}"/>
              <TextBlock Text="SOURCE" Style="{StaticResource FieldHeaderTextBlockStyle}"/>
              <ComboBox IsEditable="true" Text="{Binding Element.Source}"
                        SelectedItem="{Binding SelectedInternalSource, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        ItemsSource="{Binding InternalSources}"/>
              <TextBlock Text="ID" Style="{StaticResource FieldHeaderTextBlockStyle}"/>
              <TextBox Text="{Binding Element.Id, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
          </StackPanel>
        </ScrollViewer>
      </controls:MetroTabItem>
      <controls:MetroTabItem Header="Supports">
        <ScrollViewer>
          <StackPanel Margin="0,5,20,0">
            <TextBlock Text="SUPPORTS" Style="{StaticResource FieldHeaderTextBlockStyle}"/>
            <TextBox Text="{Binding Element.Supports, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
          </StackPanel>
        </ScrollViewer>
      </controls:MetroTabItem>
      <controls:MetroTabItem Header="Prerequisites">
        <ScrollViewer>
          <StackPanel Margin="0,5,20,0">
            <TextBlock Text="PREREQUISITES" Style="{StaticResource FieldHeaderTextBlockStyle}"/>
            <TextBox Text="{Binding Element.Prerequisites, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            <TextBlock Text="REQUIREMENTS" Style="{StaticResource FieldHeaderTextBlockStyle}"/>
            <TextBox Text="{Binding Element.Requirements, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
          </StackPanel>
        </ScrollViewer>
      </controls:MetroTabItem>
      <controls:MetroTabItem Header="Description">
        <ScrollViewer>
          <StackPanel Margin="0,5,20,0">
            <StackPanel Margin="0" Grid.Row="1">
              <TextBlock Text="DESCRIPTION (HTML)" Style="{StaticResource FieldHeaderTextBlockStyle}"/>
              <TextBox AcceptsReturn="true" MinHeight="100" TextWrapping="Wrap"
                       Text="{Binding Element.Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
          </StackPanel>
        </ScrollViewer>
      </controls:MetroTabItem>
      <controls:MetroTabItem Header="Description Panel" Visibility="Collapsed">
        <ScrollViewer>
          <StackPanel Margin="0,5,20,0"/>
        </ScrollViewer>
      </controls:MetroTabItem>
      <controls:MetroTabItem Header="Sheet Description">
        <ScrollViewer>
          <StackPanel Margin="0,5,20,0">
            <TextBlock Text="ALTERNATIVE NAME ON SHEET (OPTIONAL)" Style="{StaticResource FieldHeaderTextBlockStyle}"/>
            <TextBox Text="{Binding Element.SheetAlternativeName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            <TextBlock Text="SHEET DESCRIPTION (PLAIN TEXT)" Style="{StaticResource FieldHeaderTextBlockStyle}"/>
            <TextBox MinHeight="20" TextWrapping="Wrap"
                     Text="{Binding Element.SheetDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            <userControls:DescriptionCheckBox Header="DISPLAY ON SHEET" Description=""
                                              IsChecked="{Binding Element.SheetDisplay, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
          </StackPanel>
        </ScrollViewer>
      </controls:MetroTabItem>
      <controls:MetroTabItem Header="Setters" Visibility="Collapsed">
        <ScrollViewer>
          <StackPanel Margin="0,5,20,0"/>
        </ScrollViewer>
      </controls:MetroTabItem>
      <controls:MetroTabItem Header="Rules" Visibility="Collapsed">
        <ScrollViewer>
          <StackPanel Margin="0,5,20,0"/>
        </ScrollViewer>
      </controls:MetroTabItem>
      <controls:MetroTabItem Header="Output">
        <ScrollViewer Margin="20,0,10,0">
          <Grid>
            <TextBox Margin="0,0,10,0" Grid.ColumnSpan="2" FontSize="11" TextWrapping="Wrap" AcceptsReturn="true"
                     AcceptsTab="true" IsReadOnly="true" Text="{Binding Output}"/>
          </Grid>
        </ScrollViewer>
      </controls:MetroTabItem>
      <controls:MetroTabItem Header="DEFAULT SECTION" Visibility="Collapsed">
        <ScrollViewer>
          <StackPanel Margin="0,5,10,0">
            <TextBlock Text="DEFAULT SECTION" Style="{StaticResource SectionHeaderTextBlockStyle}" Margin="0,0,0,0"/>
            <TextBlock Text="This is the default section layout. Copy this MetroTabItem to start a new section."
                       Style="{StaticResource SectionSubHeaderTextBlockStyle}"/>
          </StackPanel>
        </ScrollViewer>
      </controls:MetroTabItem>
    </controls:MetroTabControl>
    <Border Grid.Row="2" Grid.ColumnSpan="2" Grid.Column="0" SnapsToDevicePixels="true"
            BorderThickness="0,1,0,0" BorderBrush="{DynamicResource GrayBrush5}">
      <FrameworkElement.Resources>
        <Style TargetType="{x:Type Button}" BasedOn="{StaticResource MetroFlatButton}">
          <Setter Property="UIElement.SnapsToDevicePixels" Value="true"/>
          <Setter Property="FrameworkElement.Margin" Value="10"/>
          <Setter Property="Control.FontSize" Value="11"/>
          <Setter Property="FrameworkElement.MinWidth" Value="70"/>
          <Setter Property="FrameworkElement.MaxHeight" Value="25"/>
          <Setter Property="Control.Padding" Value="10,5"/>
        </Style>
      </FrameworkElement.Resources>
      <Grid Margin="0">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0">
          <Button Content="COPY OUTPUT" Command="{Binding CopyOutputCommand}"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0"/>
      </Grid>
    </Border>
  </Grid>
</controls:MetroWindow>