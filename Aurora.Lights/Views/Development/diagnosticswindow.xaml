<controls:MetroWindow x:Class="Builder.Presentation.Views.Development.DiagnosticsWindow"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                      xmlns:local="clr-namespace:Builder.Presentation.Views.Development"
                      xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
                      xmlns:userControls="clr-namespace:Builder.Presentation.UserControls"
                      xmlns:wpf="clr-namespace:TheArtOfDev.HtmlRenderer.WPF;assembly=HtmlRenderer.WPF"
                      Title="Diagnostics" MinHeight="200" MinWidth="200" Height="398" Width="726"
                      Style="{StaticResource IconlessCharacterBuilderWindowStyle}"
                      TitleTemplate="{StaticResource IconlessCharacterBuilderWindowTitleDataTemplate}"
                      WindowStartupLocation="CenterScreen">
  <FrameworkElement.DataContext>
    <local:DiagnosticsWindowViewModel/>
  </FrameworkElement.DataContext>
  <Grid>
    <FrameworkElement.Resources>
      <Style TargetType="{x:Type controls:MetroTabControl}"
             BasedOn="{StaticResource MainNavigationTabControlStyle}"/>
      <Style TargetType="{x:Type controls:MetroTabItem}" BasedOn="{StaticResource MainNavigationTabItemStyle}"/>
    </FrameworkElement.Resources>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <Border Style="{StaticResource OverlayBorderStyle}" BorderThickness="0" Height="Auto" Margin="3,0,0,0">
      <FrameworkElement.Resources>
        <ResourceDictionary Source="/Styles/Builder/MenuStyle.xaml"/>
      </FrameworkElement.Resources>
      <Menu Background="{StaticResource TransparentWhiteBrush}" VerticalAlignment="Bottom">
        <MenuItem Header="File">
          <MenuItem Click="ExitClick" Header="Exit Application"/>
        </MenuItem>
        <MenuItem Header="Logs">
          <MenuItem Header="Enabled Logger" IsCheckable="true" IsChecked="true"/>
          <MenuItem Header="Clear" Command="{Binding ClearLogsCommand}"/>
        </MenuItem>
      </Menu>
    </Border>
    <Grid Row="1" Background="{StaticResource WhiteBrush}">
      <FrameworkElement.Resources>
        <Style TargetType="{x:Type controls:MetroTabControl}"
               BasedOn="{StaticResource MainNavigationTabControlStyle}"/>
        <Style TargetType="{x:Type controls:MetroTabItem}"
               BasedOn="{StaticResource MainNavigationChildTabItemStyle}"/>
        <local:LogColorConverter x:Key="LogColorConverter"/>
      </FrameworkElement.Resources>
      <Border Style="{StaticResource UnderlayBorderStyle}"/>
      <controls:MetroTabControl Grid.Column="0" Margin="0,0,0,0">
        <controls:MetroTabItem Header="DIAGNOSTICS LOGGER">
          <Grid Background="{DynamicResource Aurora.Brushes.Light}">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
              <CheckBox Content="Debug" Margin="10"
                        IsChecked="{Binding IsDebugLogsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
              <CheckBox Content="Info" Margin="10"
                        IsChecked="{Binding IsInfoLogsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
              <CheckBox Content="Warnings" Margin="10"
                        IsChecked="{Binding IsWarningLogsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
              <CheckBox Content="Exceptions " Margin="10"
                        IsChecked="{Binding IsExceptionLogsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
            <ListView SourceUpdated="FrameworkElement_OnSourceUpdated" Style="{StaticResource DefaultListView}"
                      Margin="0,0,0,0" Grid.Row="1" BorderThickness="0" ItemsSource="{Binding Logs}">
              <ItemsControl.ItemContainerStyle>
                <Style TargetType="{x:Type ListViewItem}">
                  <Setter Property="Control.HorizontalContentAlignment" Value="Stretch"/>
                  <Setter Property="Control.Padding" Value="0"/>
                  <Setter Property="FrameworkElement.Margin" Value="0"/>
                </Style>
              </ItemsControl.ItemContainerStyle>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <TextBlock TextWrapping="Wrap" Padding="0" Margin="0" Text="{Binding Content}"
                             Foreground="{Binding Log, Converter={StaticResource LogColorConverter}}"/>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ListView>
          </Grid>
        </controls:MetroTabItem>
      </controls:MetroTabControl>
    </Grid>
    <Grid Row="2" Column="0" Background="{StaticResource Aurora.Brushes.Light1}">
      <Border BorderThickness="0,0,0,0" BorderBrush="{DynamicResource AccentColorBrush}"
              SnapsToDevicePixels="true">
        <StatusBar x:Name="StatusBar" Style="{StaticResource StatusBarDefaultStyle}"
                   Background="{DynamicResource Aurora.Brushes.Light1}">
          <StatusBarItem>
            <TextBlock Style="{StaticResource StatusBarStatusMessageStyle}" TextWrapping="NoWrap"
                       Text="{Binding StatusMessage}"/>
          </StatusBarItem>
          <StatusBarItem HorizontalContentAlignment="Right" HorizontalAlignment="Right" DockPanel.Dock="Right">
            <controls:MetroProgressBar x:Name="ProgressBarMain" Visibility="Collapsed" Style="{StaticResource StatusBarProgressBarStyle}"
                                       Value="{Binding ProgressPercentage}"/>
          </StatusBarItem>
        </StatusBar>
      </Border>
    </Grid>
  </Grid>
</controls:MetroWindow>