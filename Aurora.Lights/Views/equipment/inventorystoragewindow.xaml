<controls:MetroWindow x:Class="Builder.Presentation.Views.InventoryStorageWindow"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                      xmlns:local="clr-namespace:Builder.Presentation.Views"
                      xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
                      xmlns:system="clr-namespace:System;assembly=mscorlib"
                      xmlns:wpf="clr-namespace:TheArtOfDev.HtmlRenderer.WPF;assembly=HtmlRenderer.WPF"
                      xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
                      xmlns:viewModels="clr-namespace:Builder.Presentation.ViewModels"
                      xmlns:converters="clr-namespace:Builder.Presentation.Converters"
                      xmlns:userControls="clr-namespace:Builder.Presentation.UserControls"
                      xmlns:items="clr-namespace:Builder.Presentation.ViewModels.Shell.Items"
                      xmlns:controls1="clr-namespace:Aurora.Presentation.Controls;assembly=Aurora.Presentation"
                      Title="Manage Stored Items" ResizeMode="CanResize"
                      Style="{StaticResource IconlessCharacterBuilderWindowStyle}"
                      TitleTemplate="{StaticResource IconlessCharacterBuilderWindowTitleDataTemplate}"
                      WindowStartupLocation="CenterScreen" MinHeight="300" MinWidth="350" Height="399" Width="613">
  <FrameworkElement.Resources>
    <Style TargetType="{x:Type CheckBox}" BasedOn="{StaticResource {x:Type CheckBox}}">
      <Setter Property="FrameworkElement.Margin" Value="0,5,0,5"/>
      <Setter Property="Control.FontSize" Value="11"/>
      <Setter Property="Control.FontFamily" Value="Segoe UI SemiBold"/>
      <Setter Property="Control.Foreground" Value="#505050"/>
    </Style>
    <Style TargetType="{x:Type TextBox}" BasedOn="{StaticResource {x:Type TextBox}}">
      <Setter Property="FrameworkElement.Margin" Value="0,0,0,10"/>
    </Style>
    <Style TargetType="{x:Type ComboBox}" BasedOn="{StaticResource {x:Type ComboBox}}">
      <Setter Property="FrameworkElement.Margin" Value="0,0,0,10"/>
    </Style>
    <Style x:Key="InventoryColumnHeaderStyle" TargetType="{x:Type DataGridColumnHeader}"
           BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
      <Setter Property="Control.BorderBrush" Value="{DynamicResource Aurora.Brushes.Light2}"/>
      <Setter Property="Control.BorderThickness" Value="0,0,0,1"/>
      <Setter Property="UIElement.SnapsToDevicePixels" Value="true"/>
      <Setter Property="FrameworkElement.VerticalAlignment" Value="Center"/>
      <Setter Property="FrameworkElement.Height" Value="30"/>
      <Setter Property="FrameworkElement.MinWidth" Value="30"/>
      <Setter Property="Control.FontSize" Value="11"/>
      <Setter Property="Control.FontWeight" Value="SemiBold"/>
      <Setter Property="Control.Padding" Value="5,2,5,2"/>
      <Setter Property="Control.Background" Value="{DynamicResource Aurora.Brushes.Light}"/>
      <Setter Property="Control.Foreground" Value="{DynamicResource Aurora.Brushes.Text.Primary}"/>
    </Style>
    <Style x:Key="CenteredInventoryColumnHeaderStyle" TargetType="{x:Type DataGridColumnHeader}"
           BasedOn="{StaticResource InventoryColumnHeaderStyle}">
      <Setter Property="FrameworkElement.HorizontalAlignment" Value="Center"/>
      <Setter Property="Control.HorizontalContentAlignment" Value="Stretch"/>
    </Style>
    <Style x:Key="RightAlignedInventoryColumnHeaderStyle" TargetType="{x:Type DataGridColumnHeader}"
           BasedOn="{StaticResource InventoryColumnHeaderStyle}">
      <Setter Property="FrameworkElement.HorizontalAlignment" Value="Right"/>
    </Style>
  </FrameworkElement.Resources>
  <Grid Background="{DynamicResource Aurora.Brushes.Light}">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*"/>
      <ColumnDefinition Width="Auto"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <StackPanel Margin="20,20,0,0">
      <TextBlock Text="Primary Storage Location" Style="{StaticResource FieldHeaderTextBlockStyle}"
                 Foreground="{DynamicResource Aurora.Brushes.Text.Secondary}" FontSize="12" Margin="0,0,0,4"/>
      <TextBox Padding="4" BorderBrush="{DynamicResource Aurora.Brushes.Light2}"
               controls:TextBoxHelper.Watermark="Primary Storage"
               Text="{Binding Inventory.StoredItems1.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
      </TextBox>
    </StackPanel>
    <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,20,20,0">
      <TextBlock Text="Secondary Storage Location" Style="{StaticResource FieldHeaderTextBlockStyle}"
                 Foreground="{DynamicResource Aurora.Brushes.Text.Secondary}" FontSize="12" Margin="0,0,0,4"/>
      <TextBox Padding="4" BorderBrush="{DynamicResource Aurora.Brushes.Light2}"
               controls:TextBoxHelper.Watermark="Secondary Storage"
               Text="{Binding Inventory.StoredItems2.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
      </TextBox>
    </StackPanel>
    <DataGrid Grid.Row="1" Grid.Column="0" Background="{DynamicResource Aurora.Brushes.Light}"
              BorderBrush="{DynamicResource Aurora.Brushes.Light2}" BorderThickness="0"
              CanUserSortColumns="false" CanUserAddRows="false"
              controls:DataGridRowHelper.SelectionUnit="FullRow" ScrollViewer.VerticalScrollBarVisibility="Auto"
              SelectionMode="Single" GridLinesVisibility="Horizontal" Margin="20,0,0,0"
              HorizontalGridLinesBrush="{DynamicResource Aurora.Brushes.Light}"
              Style="{StaticResource SelectionRuleExpanderGridStyle}"
              ColumnHeaderStyle="{StaticResource InventoryColumnHeaderStyle}" MinRowHeight="21"
              HeadersVisibility="Column" ItemsSource="{Binding Inventory.StoredItems1.StoredItems}"
              SelectedItem="{Binding SelectedEquipmentItem, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
      <FrameworkElement.ContextMenu>
        <ContextMenu>
          <MenuItem Header="Edit Item Details" Command="{Binding ManageEquipmentItemCommand}"/>
          <MenuItem Header="Extract Item" Command="{Binding ExtractEquipmentItemCommand}"
                    Visibility="{Binding AllowExtractEquipmentItem, Converter={StaticResource BooleanToVisibilityConverter}}"/>
          <MenuItem Header="Add to Attacks &amp; Spellcasting" Command="{Binding AddToAttacksCommand}"
                    Visibility="{Binding AllowEquipmentItemAddToAttacks, Converter={StaticResource BooleanToVisibilityConverter}}"/>
          <Separator/>
          <MenuItem Header="Equip" Command="{Binding EquipEquipmentItemCommand}"
                    Visibility="{Binding AllowEquipEquipmentItem, Converter={StaticResource BooleanToVisibilityConverter}}"/>
          <MenuItem Header="Equip in Primary Hand" Command="{Binding EquipPrimaryEquipmentItemCommand}"
                    Visibility="{Binding AllowEquipPrimaryEquipmentItem, Converter={StaticResource BooleanToVisibilityConverter}}"/>
          <MenuItem Header="Equip in Secondary Hand" Command="{Binding EquipSecondaryEquipmentItemCommand}"
                    Visibility="{Binding AllowEquipSecondaryEquipmentItem, Converter={StaticResource BooleanToVisibilityConverter}}"/>
          <MenuItem Header="Equip as Versatile" Command="{Binding EquipVersatileEquipmentItemCommand}"
                    Visibility="{Binding AllowEquipVersatileEquipmentItem, Converter={StaticResource BooleanToVisibilityConverter}}"/>
          <Separator/>
          <MenuItem Header="Toggle Attunement" Command="{Binding ToggleAttunementEquipmentItemCommand}"/>
          <Separator/>
          <MenuItem Header="Remove Item" Command="{Binding DeleteSelectedEquipmentCommand}"/>
          <MenuItem Header="Remove Items (All Selected Stackables)"
                    Command="{Binding DeleteAllSelectedEquipmentCommand}"/>
        </ContextMenu>
      </FrameworkElement.ContextMenu>
      <UIElement.InputBindings>
        <KeyBinding Modifiers="Alt" Key="Up" Command="{Binding MoveSelectedEquipmentItemUpCommand}"/>
        <KeyBinding Modifiers="Alt" Key="Down" Command="{Binding MoveSelectedEquipmentItemDownCommand}"/>
        <KeyBinding Key="Delete" Command="{Binding DeleteSelectedEquipmentCommand}"/>
        <KeyBinding Key="Space" Command="{Binding ActivateEquipmentItemCommand}"/>
      </UIElement.InputBindings>
      <DataGrid.Columns>
        <DataGridTextColumn>
          <DataGridColumn.HeaderStyle>
            <Style TargetType="{x:Type DataGridColumnHeader}"
                   BasedOn="{StaticResource CenteredInventoryColumnHeaderStyle}"/>
          </DataGridColumn.HeaderStyle>
          <DataGridColumn.Header>
            <iconPacks:PackIconFontAwesome Kind="HashtagSolid" Height="11" Width="11" ToolTip="The amount of the particular item."
                                           HorizontalAlignment="Center" Foreground="{DynamicResource Aurora.Brushes.Text.Primary}"/>
          </DataGridColumn.Header>
          <DataGridColumn.CellStyle>
            <Style TargetType="{x:Type DataGridCell}" BasedOn="{StaticResource {x:Type DataGridCell}}">
              <Setter Property="Control.Padding" Value="0,0"/>
              <Setter Property="ContentControl.ContentTemplate">
                <Setter.Value>
                  <DataTemplate>
                    <Grid>
                      <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource Aurora.Brushes.Text.Primary}"
                                   Text="{Binding Amount}"
                                   Visibility="{Binding IsStackable, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        <TextBlock FontWeight="SemiBold" FontSize="13" Opacity=".1"
                                   Foreground="{DynamicResource Aurora.Brushes.Text.Primary}" Text="{Binding Amount}"
                                   Visibility="{Binding IsStackable, Converter={StaticResource InvertedBooleanToVisibilityConverter}}"/>
                      </StackPanel>
                    </Grid>
                  </DataTemplate>
                </Setter.Value>
              </Setter>
            </Style>
          </DataGridColumn.CellStyle>
        </DataGridTextColumn>
        <DataGridTextColumn Header="Item Name" Width="*" MinWidth="150" Binding="{Binding}">
          <DataGridColumn.CellStyle>
            <Style TargetType="{x:Type DataGridCell}" BasedOn="{StaticResource {x:Type DataGridCell}}">
              <Setter Property="Control.Padding" Value="5,0"/>
              <Setter Property="ContentControl.ContentTemplate">
                <Setter.Value>
                  <DataTemplate>
                    <StackPanel Margin="0,4">
                      <StackPanel IsHitTestVisible="false" Orientation="Horizontal">
                        <TextBlock Margin="0,0" VerticalAlignment="Center" Foreground="{DynamicResource Aurora.Brushes.Text.Primary}"
                                   FontFamily="Segoe UI" Style="{StaticResource SectionHeaderTextBlockStyle}" FontSize="12"
                                   Text="{Binding DisplayName}"
                                   Visibility="{Binding IsActivated, Converter={StaticResource InvertedBooleanToVisibilityConverter}}"/>
                        <TextBlock Opacity="1" Margin="0,0" VerticalAlignment="Center" FontFamily="Segoe UI"
                                   Foreground="{DynamicResource Aurora.Brushes.Text.Primary}" FontWeight="SemiBold"
                                   Style="{StaticResource SectionHeaderTextBlockStyle}" FontSize="12" Text="{Binding DisplayName}"
                                   Visibility="{Binding IsActivated, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                      </StackPanel>
                      <StackPanel x:Name="underline" IsHitTestVisible="false" Orientation="Horizontal" Margin="0,4,0,0"
                                  Visibility="Collapsed">
                        <TextBlock Margin="0,0" FontSize="12" FontStyle="Italic"
                                   Style="{StaticResource SectionSubHeaderTextBlockStyle}" VerticalAlignment="Center"
                                   Foreground="{DynamicResource Aurora.Brushes.Text.Secondary}" Text="{Binding Underline}"/>
                      </StackPanel>
                    </StackPanel>
                  </DataTemplate>
                </Setter.Value>
              </Setter>
              <Style.Triggers>
                <Trigger Property="DataGridCell.IsSelected" Value="true">
                  <Setter Property="ContentControl.ContentTemplate">
                    <Setter.Value>
                      <DataTemplate>
                        <StackPanel Margin="0,4">
                          <StackPanel IsHitTestVisible="false" Orientation="Horizontal">
                            <TextBlock Margin="0,0" VerticalAlignment="Center" Foreground="{DynamicResource IdealForegroundColorBrush}"
                                       FontFamily="Segoe UI" Style="{StaticResource SectionHeaderTextBlockStyle}" FontSize="12"
                                       Text="{Binding DisplayName}"
                                       Visibility="{Binding IsActivated, Converter={StaticResource InvertedBooleanToVisibilityConverter}}"/>
                            <TextBlock Opacity="1" Margin="0,0" VerticalAlignment="Center" FontFamily="Segoe UI"
                                       Foreground="{DynamicResource IdealForegroundColorBrush}" FontWeight="SemiBold"
                                       Style="{StaticResource SectionHeaderTextBlockStyle}" FontSize="12" Text="{Binding DisplayName}"
                                       Visibility="{Binding IsActivated, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                          </StackPanel>
                          <StackPanel x:Name="underline" IsHitTestVisible="false" Orientation="Horizontal" Margin="0,4,0,0"
                                      Visibility="Collapsed">
                            <TextBlock Margin="0,0" FontSize="12" FontStyle="Italic"
                                       Style="{StaticResource SectionSubHeaderTextBlockStyle}" VerticalAlignment="Center"
                                       Foreground="{DynamicResource IdealForegroundColorBrush}" Text="{Binding Underline}"/>
                          </StackPanel>
                        </StackPanel>
                      </DataTemplate>
                    </Setter.Value>
                  </Setter>
                </Trigger>
              </Style.Triggers>
            </Style>
          </DataGridColumn.CellStyle>
        </DataGridTextColumn>
      </DataGrid.Columns>
    </DataGrid>
    <DataGrid Grid.Row="1" Grid.Column="2" Background="{DynamicResource Aurora.Brushes.Light}"
              BorderBrush="{DynamicResource Aurora.Brushes.Light2}" BorderThickness="0"
              CanUserSortColumns="false" CanUserAddRows="false"
              controls:DataGridRowHelper.SelectionUnit="FullRow" ScrollViewer.VerticalScrollBarVisibility="Auto"
              SelectionMode="Single" GridLinesVisibility="Horizontal" Margin="0,0,20,0"
              HorizontalGridLinesBrush="{DynamicResource Aurora.Brushes.Light}"
              Style="{StaticResource SelectionRuleExpanderGridStyle}"
              ColumnHeaderStyle="{StaticResource InventoryColumnHeaderStyle}" MinRowHeight="21"
              HeadersVisibility="Column" ItemsSource="{Binding Inventory.StoredItems2.StoredItems}"
              SelectedItem="{Binding SelectedEquipmentItem, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
      <FrameworkElement.ContextMenu>
        <ContextMenu>
          <MenuItem Header="Edit Item Details" Command="{Binding ManageEquipmentItemCommand}"/>
          <MenuItem Header="Extract Item" Command="{Binding ExtractEquipmentItemCommand}"
                    Visibility="{Binding AllowExtractEquipmentItem, Converter={StaticResource BooleanToVisibilityConverter}}"/>
          <MenuItem Header="Add to Attacks &amp; Spellcasting" Command="{Binding AddToAttacksCommand}"
                    Visibility="{Binding AllowEquipmentItemAddToAttacks, Converter={StaticResource BooleanToVisibilityConverter}}"/>
          <Separator/>
          <MenuItem Header="Equip" Command="{Binding EquipEquipmentItemCommand}"
                    Visibility="{Binding AllowEquipEquipmentItem, Converter={StaticResource BooleanToVisibilityConverter}}"/>
          <MenuItem Header="Equip in Primary Hand" Command="{Binding EquipPrimaryEquipmentItemCommand}"
                    Visibility="{Binding AllowEquipPrimaryEquipmentItem, Converter={StaticResource BooleanToVisibilityConverter}}"/>
          <MenuItem Header="Equip in Secondary Hand" Command="{Binding EquipSecondaryEquipmentItemCommand}"
                    Visibility="{Binding AllowEquipSecondaryEquipmentItem, Converter={StaticResource BooleanToVisibilityConverter}}"/>
          <MenuItem Header="Equip as Versatile" Command="{Binding EquipVersatileEquipmentItemCommand}"
                    Visibility="{Binding AllowEquipVersatileEquipmentItem, Converter={StaticResource BooleanToVisibilityConverter}}"/>
          <Separator/>
          <MenuItem Header="Toggle Attunement" Command="{Binding ToggleAttunementEquipmentItemCommand}"/>
          <Separator/>
          <MenuItem Header="Remove Item" Command="{Binding DeleteSelectedEquipmentCommand}"/>
          <MenuItem Header="Remove Items (All Selected Stackables)"
                    Command="{Binding DeleteAllSelectedEquipmentCommand}"/>
        </ContextMenu>
      </FrameworkElement.ContextMenu>
      <UIElement.InputBindings>
        <KeyBinding Modifiers="Alt" Key="Up" Command="{Binding MoveSelectedEquipmentItemUpCommand}"/>
        <KeyBinding Modifiers="Alt" Key="Down" Command="{Binding MoveSelectedEquipmentItemDownCommand}"/>
        <KeyBinding Key="Delete" Command="{Binding DeleteSelectedEquipmentCommand}"/>
        <KeyBinding Key="Space" Command="{Binding ActivateEquipmentItemCommand}"/>
      </UIElement.InputBindings>
      <DataGrid.Columns>
        <DataGridTextColumn x:Name="ItemAmountColumn2">
          <DataGridColumn.HeaderStyle>
            <Style TargetType="{x:Type DataGridColumnHeader}"
                   BasedOn="{StaticResource CenteredInventoryColumnHeaderStyle}"/>
          </DataGridColumn.HeaderStyle>
          <DataGridColumn.Header>
            <iconPacks:PackIconFontAwesome Kind="HashtagSolid" Height="11" Width="11" ToolTip="The amount of the particular item."
                                           HorizontalAlignment="Center" Foreground="{DynamicResource Aurora.Brushes.Text.Primary}"/>
          </DataGridColumn.Header>
          <DataGridColumn.CellStyle>
            <Style TargetType="{x:Type DataGridCell}" BasedOn="{StaticResource {x:Type DataGridCell}}">
              <Setter Property="Control.Padding" Value="0,0"/>
              <Setter Property="ContentControl.ContentTemplate">
                <Setter.Value>
                  <DataTemplate>
                    <Grid>
                      <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource Aurora.Brushes.Text.Primary}"
                                   Text="{Binding Amount}"
                                   Visibility="{Binding IsStackable, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        <TextBlock FontWeight="SemiBold" FontSize="13" Opacity=".1"
                                   Foreground="{DynamicResource Aurora.Brushes.Text.Primary}" Text="{Binding Amount}"
                                   Visibility="{Binding IsStackable, Converter={StaticResource InvertedBooleanToVisibilityConverter}}"/>
                      </StackPanel>
                    </Grid>
                  </DataTemplate>
                </Setter.Value>
              </Setter>
            </Style>
          </DataGridColumn.CellStyle>
        </DataGridTextColumn>
        <DataGridTextColumn x:Name="EquipmentItemNameColumn" Header="Item Name" Width="*" MinWidth="150" Binding="{Binding}">
          <DataGridColumn.CellStyle>
            <Style TargetType="{x:Type DataGridCell}" BasedOn="{StaticResource {x:Type DataGridCell}}">
              <Setter Property="Control.Padding" Value="5,0"/>
              <Setter Property="ContentControl.ContentTemplate">
                <Setter.Value>
                  <DataTemplate>
                    <StackPanel Margin="0,4">
                      <StackPanel IsHitTestVisible="false" Orientation="Horizontal">
                        <TextBlock Margin="0,0" VerticalAlignment="Center" Foreground="{DynamicResource Aurora.Brushes.Text.Primary}"
                                   FontFamily="Segoe UI" Style="{StaticResource SectionHeaderTextBlockStyle}" FontSize="12"
                                   Text="{Binding DisplayName}"
                                   Visibility="{Binding IsActivated, Converter={StaticResource InvertedBooleanToVisibilityConverter}}"/>
                        <TextBlock Opacity="1" Margin="0,0" VerticalAlignment="Center" FontFamily="Segoe UI"
                                   Foreground="{DynamicResource Aurora.Brushes.Text.Primary}" FontWeight="SemiBold"
                                   Style="{StaticResource SectionHeaderTextBlockStyle}" FontSize="12" Text="{Binding DisplayName}"
                                   Visibility="{Binding IsActivated, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                      </StackPanel>
                      <StackPanel x:Name="underline" IsHitTestVisible="false" Orientation="Horizontal" Margin="0,4,0,0"
                                  Visibility="Collapsed">
                        <TextBlock Margin="0,0" FontSize="12" FontStyle="Italic"
                                   Style="{StaticResource SectionSubHeaderTextBlockStyle}" VerticalAlignment="Center"
                                   Foreground="{DynamicResource Aurora.Brushes.Text.Secondary}" Text="{Binding Underline}"/>
                      </StackPanel>
                    </StackPanel>
                  </DataTemplate>
                </Setter.Value>
              </Setter>
              <Style.Triggers>
                <Trigger Property="DataGridCell.IsSelected" Value="true">
                  <Setter Property="ContentControl.ContentTemplate">
                    <Setter.Value>
                      <DataTemplate>
                        <StackPanel Margin="0,4">
                          <StackPanel IsHitTestVisible="false" Orientation="Horizontal">
                            <TextBlock Margin="0,0" VerticalAlignment="Center" Foreground="{DynamicResource IdealForegroundColorBrush}"
                                       FontFamily="Segoe UI" Style="{StaticResource SectionHeaderTextBlockStyle}" FontSize="12"
                                       Text="{Binding DisplayName}"
                                       Visibility="{Binding IsActivated, Converter={StaticResource InvertedBooleanToVisibilityConverter}}"/>
                            <TextBlock Opacity="1" Margin="0,0" VerticalAlignment="Center" FontFamily="Segoe UI"
                                       Foreground="{DynamicResource IdealForegroundColorBrush}" FontWeight="SemiBold"
                                       Style="{StaticResource SectionHeaderTextBlockStyle}" FontSize="12" Text="{Binding DisplayName}"
                                       Visibility="{Binding IsActivated, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                          </StackPanel>
                          <StackPanel x:Name="underline" IsHitTestVisible="false" Orientation="Horizontal" Margin="0,4,0,0"
                                      Visibility="Collapsed">
                            <TextBlock Margin="0,0" FontSize="12" FontStyle="Italic"
                                       Style="{StaticResource SectionSubHeaderTextBlockStyle}" VerticalAlignment="Center"
                                       Foreground="{DynamicResource IdealForegroundColorBrush}" Text="{Binding Underline}"/>
                          </StackPanel>
                        </StackPanel>
                      </DataTemplate>
                    </Setter.Value>
                  </Setter>
                </Trigger>
              </Style.Triggers>
            </Style>
          </DataGridColumn.CellStyle>
        </DataGridTextColumn>
      </DataGrid.Columns>
    </DataGrid>
    <StackPanel Grid.Row="1" Grid.Column="1" Margin="4,30,4,4">
      <controls1:CommandButton Style="{StaticResource IconCommandButtonStyle}"
                               Command="{Binding StoreSelectedEquipmentAsSecondaryCommand}">
        <iconPacks:PackIconFontAwesome Kind="ArrowRightSolid"/>
      </controls1:CommandButton>
      <controls1:CommandButton Style="{StaticResource IconCommandButtonStyle}"
                               Command="{Binding StoreSelectedEquipmentAsPrimaryCommand}">
        <iconPacks:PackIconFontAwesome Kind="ArrowLeftSolid"/>
      </controls1:CommandButton>
    </StackPanel>
    <Border Grid.Row="1" Grid.Column="0" BorderThickness="0,0,1,0"
            Background="{DynamicResource Aurora.Brushes.Light1}"
            BorderBrush="{DynamicResource Aurora.Brushes.Light2}" Padding="10" Visibility="Collapsed"
            Margin="0,0,363,0" Grid.RowSpan="2">
      <StackPanel Orientation="Vertical" Margin="10,10,0,0">
        <userControls:DescriptionCheckBox Header="Include in Inventory" Margin="0,0,0,10"
                                          Description="This item will listed in your inventory."
                                          IsChecked="{Binding SelectedEquipmentItem.IncludeInEquipmentPageInventory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
        <userControls:DescriptionCheckBox Header="Show in Description Sidebar" Margin="0,10,0,10"
                                          Description="Allow the item to be listed in the 'Description Sidebar' section."
                                          IsChecked="{Binding SelectedEquipmentItem.IncludeInEquipmentPageDescriptionSidebar, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
        <userControls:DescriptionCheckBox Header="Include as Item Card" Margin="0,10,0,10"
                                          Description="Include as item card when you're displaying them."
                                          IsChecked="{Binding SelectedEquipmentItem.ShowCard, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
      </StackPanel>
    </Border>
    <Border Background="{DynamicResource Aurora.Brushes.Light1}" Grid.Row="3" SnapsToDevicePixels="true"
            BorderThickness="0,1,0,0" BorderBrush="{DynamicResource Aurora.Brushes.Light2}" Grid.ColumnSpan="3"
            Grid.Column="0">
      <FrameworkElement.Resources>
        <Style TargetType="{x:Type Button}" BasedOn="{StaticResource MetroFlatButton}">
          <Setter Property="UIElement.SnapsToDevicePixels" Value="true"/>
          <Setter Property="FrameworkElement.Margin" Value="10"/>
          <Setter Property="Control.FontSize" Value="11"/>
          <Setter Property="FrameworkElement.MinWidth" Value="70"/>
          <Setter Property="FrameworkElement.MaxHeight" Value="25"/>
          <Setter Property="Control.Padding" Value="10,5"/>
        </Style>
      </FrameworkElement.Resources>
      <Grid Margin="0">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="10,0,0,0">
          <controls1:CommandButton Content="Remove from Storage" Margin="0,10,10,10" MinWidth="80"
                                   Command="{Binding RetrieveStoredSelectedEquipmentCommand}"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0">
          <controls1:CommandButton Click="Button_Click" Content="OK" Margin="0,10,10,10" IsDefault="true" MinWidth="80"/>
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</controls:MetroWindow>