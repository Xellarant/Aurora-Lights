@page "/equipment"
@rendermode InteractiveServer
@inject WebCharacterSessionService CharacterSession

<PageTitle>Equipment</PageTitle>

<CharacterLibraryShell Title="Equipment"
                       IntroText="Review the active character's attacks, gear, currency, and inventory in the current browser session."
                       StatusMessage="@_statusMessage"
                       StatusIsError="@_failed">
    <BrowserContent>
        @if (_loading)
        {
            <p class="empty-state">Loading active character equipment...</p>
        }
        else if (_state is null)
        {
            <p class="empty-state">No character is currently active. Open one from the <a href="/characters">Characters</a> page first.</p>
        }
        else
        {
            <CharacterEquipmentWorkspace Model="_state.Equipment"
                                         Busy="_busy"
                                         OnAddItem="OpenAddItemPickerAsync"
                                         OnOpenGearSlot="OpenGearSlotPickerAsync"
                                         OnUnequipGearSlot="UnequipSlotAsync"
                                         OnRemoveItem="RemoveItemAsync"
                                         OnToggleEquipped="ToggleEquippedAsync"
                                         OnToggleAttuned="ToggleAttunedAsync"
                                         OnChangeAmount="ChangeAmountAsync"
                                         OnCoinChanged="ChangeCoinAsync"
                                         OnNoteChanged="ChangeNoteAsync" />

            @if (_pickerMode is not null)
            {
                <section class="picker-panel">
                    <div class="picker-header">
                        <div>
                            <div class="picker-title">@_pickerTitle</div>
                            <div class="picker-subtitle">@_pickerSubtitle</div>
                        </div>
                        <button type="button"
                                class="equipment-action-button secondary"
                                disabled="@_busy"
                                @onclick="CloseEquipmentPicker">
                            Done
                        </button>
                    </div>

                    <div class="picker-toolbar">
                        <label class="filter-field picker-field">
                            <span>Search</span>
                            <input class="text-filter"
                                   placeholder="Search by name"
                                   @bind="_pickerQuery" />
                        </label>

                        @if (_pickerMode == EquipmentPickerMode.AddItem)
                        {
                            <label class="filter-field picker-amount-field">
                                <span>Amount</span>
                                <input class="text-filter"
                                       type="number"
                                       min="1"
                                       max="999"
                                       @bind="_pickerAmount" />
                            </label>
                        }

                        <div class="picker-toolbar-actions">
                            <button type="button"
                                    class="equipment-action-button primary"
                                    disabled="@_busy"
                                    @onclick="SearchEquipmentPickerAsync">
                                Search
                            </button>
                        </div>
                    </div>

                    @if (_pickerMode == EquipmentPickerMode.GearSlot && _slotInventoryOptions.Count > 0)
                    {
                        <div class="picker-section">
                            <div class="picker-section-title">Use Existing Inventory</div>
                            <div class="picker-list">
                                @foreach (WebEquipmentInventoryOption option in _slotInventoryOptions)
                                {
                                    <div class="picker-result-card compact">
                                        <div>
                                            <div class="picker-result-title">@option.Name</div>
                                            <div class="picker-result-meta">Already in inventory</div>
                                        </div>
                                        <button type="button"
                                                class="equipment-action-button"
                                                disabled="@_busy"
                                                @onclick="() => EquipExistingItemAsync(option.Identifier)">
                                            Equip
                                        </button>
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    <div class="picker-section">
                        <div class="picker-section-title">
                            @(_pickerMode == EquipmentPickerMode.AddItem ? "Add New Item" : "Add and Equip New Item")
                        </div>

                        @if (_pickerResults.Count == 0)
                        {
                            <p class="picker-empty">No matching items found.</p>
                        }
                        else
                        {
                            <div class="picker-list">
                                @foreach (WebEquipmentSearchResult result in _pickerResults)
                                {
                                    <div class="picker-result-card">
                                        <div class="picker-result-body">
                                            <div class="picker-result-title">@result.Name</div>
                                            <div class="picker-result-meta">@result.Type @FormatSource(result.Source)</div>
                                            @if (!string.IsNullOrWhiteSpace(result.Description))
                                            {
                                                <div class="picker-result-description">@result.Description</div>
                                            }
                                        </div>
                                        <button type="button"
                                                class="equipment-action-button primary"
                                                disabled="@_busy"
                                                @onclick="() => ChooseEquipmentResultAsync(result.ElementId)">
                                            @(_pickerMode == EquipmentPickerMode.AddItem ? "Add" : "Add & Equip")
                                        </button>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </section>
            }
        }
    </BrowserContent>

    <DetailContent>
        <CharacterDetailPanel Title="Current Character"
                              EmptyMessage="No active character is available."
                              Fields="@DetailFields" />
    </DetailContent>
</CharacterLibraryShell>

@code {
    private WebCharacterEquipmentState? _state;
    private bool _loading = true;
    private bool _busy;
    private bool _failed;
    private string? _statusMessage;

    private EquipmentPickerMode? _pickerMode;
    private string? _pickerSlotId;
    private string _pickerTitle = string.Empty;
    private string _pickerSubtitle = string.Empty;
    private string _pickerQuery = string.Empty;
    private int _pickerAmount = 1;
    private IReadOnlyList<WebEquipmentSearchResult> _pickerResults = [];
    private IReadOnlyList<WebEquipmentInventoryOption> _slotInventoryOptions = [];

    private enum EquipmentPickerMode
    {
        AddItem,
        GearSlot
    }

    private IReadOnlyList<CharacterDetailField> DetailFields =>
        _state is null
            ? []
            : [
                new("Name", _state.Summary.DisplayName),
                new("Build", _state.Summary.DisplayBuild),
                new("Player", ValueOrDash(_state.Summary.PlayerName)),
                new("File", _state.Summary.FileName)
            ];

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        _failed = false;
        try
        {
            _state = await CharacterSession.GetCurrentEquipmentStateAsync();
            _statusMessage = _state?.StatusMessage;
        }
        catch (Exception ex)
        {
            _failed = true;
            _statusMessage = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private static string ValueOrDash(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static string FormatSource(string source) =>
        string.IsNullOrWhiteSpace(source) ? string.Empty : $"· {source}";

    private async Task OpenAddItemPickerAsync()
    {
        _pickerMode = EquipmentPickerMode.AddItem;
        _pickerSlotId = null;
        _pickerTitle = "Add Item";
        _pickerSubtitle = "Search loaded item data and add a new item to the active character.";
        _pickerQuery = string.Empty;
        _pickerAmount = 1;
        _slotInventoryOptions = [];
        await SearchEquipmentPickerAsync();
    }

    private async Task OpenGearSlotPickerAsync(string slotId)
    {
        _pickerMode = EquipmentPickerMode.GearSlot;
        _pickerSlotId = slotId;
        _pickerTitle = slotId switch
        {
            "armor" => "Equip Armor",
            "main-hand" => "Equip Main Hand",
            "off-hand" => "Equip Off Hand",
            _ => "Equip Gear"
        };
        _pickerSubtitle = "Choose an existing inventory item or add a compatible item directly into the selected gear slot.";
        _pickerQuery = string.Empty;
        _pickerAmount = 1;
        _slotInventoryOptions = await CharacterSession.GetCurrentEquipmentInventoryOptionsAsync(slotId);
        await SearchEquipmentPickerAsync();
    }

    private void CloseEquipmentPicker()
    {
        _pickerMode = null;
        _pickerSlotId = null;
        _pickerTitle = string.Empty;
        _pickerSubtitle = string.Empty;
        _pickerQuery = string.Empty;
        _pickerAmount = 1;
        _pickerResults = [];
        _slotInventoryOptions = [];
    }

    private async Task SearchEquipmentPickerAsync()
    {
        if (_pickerMode is null)
        {
            return;
        }

        try
        {
            _pickerResults = await CharacterSession.SearchCurrentEquipmentItemsAsync(
                _pickerQuery,
                _pickerMode == EquipmentPickerMode.GearSlot ? _pickerSlotId : null);
        }
        catch (Exception ex)
        {
            _failed = true;
            _statusMessage = ex.Message;
        }
    }

    private async Task ChooseEquipmentResultAsync(string elementId)
    {
        if (_pickerMode == EquipmentPickerMode.AddItem)
        {
            await RunEquipmentActionAsync(
                () => CharacterSession.AddCurrentEquipmentItemAsync(elementId, _pickerAmount),
                closePickerOnSuccess: true);
        }
        else if (_pickerSlotId is not null)
        {
            await RunEquipmentActionAsync(
                () => CharacterSession.EquipCurrentEquipmentSlotAsync(_pickerSlotId, identifier: null, elementId),
                closePickerOnSuccess: true);
        }
    }

    private async Task EquipExistingItemAsync(string identifier)
    {
        if (_pickerSlotId is null)
        {
            return;
        }

        await RunEquipmentActionAsync(
            () => CharacterSession.EquipCurrentEquipmentSlotAsync(_pickerSlotId, identifier, elementId: null),
            closePickerOnSuccess: true);
    }

    private async Task ChangeCoinAsync(EquipmentCoinChangeModel change)
    {
        await RunEquipmentActionAsync(() => CharacterSession.UpdateCurrentEquipmentCoinAsync(change), closePickerOnSuccess: false);
    }

    private async Task ChangeNoteAsync(EquipmentNoteChangeModel change)
    {
        await RunEquipmentActionAsync(() => CharacterSession.UpdateCurrentEquipmentNoteAsync(change), closePickerOnSuccess: false);
    }

    private async Task ToggleEquippedAsync(string identifier)
    {
        await RunEquipmentActionAsync(() => CharacterSession.ToggleCurrentEquipmentItemAsync(identifier, attunement: false), closePickerOnSuccess: false);
    }

    private async Task ToggleAttunedAsync(string identifier)
    {
        await RunEquipmentActionAsync(() => CharacterSession.ToggleCurrentEquipmentItemAsync(identifier, attunement: true), closePickerOnSuccess: false);
    }

    private async Task ChangeAmountAsync(EquipmentAmountChangeModel change)
    {
        await RunEquipmentActionAsync(() => CharacterSession.ChangeCurrentEquipmentAmountAsync(change), closePickerOnSuccess: false);
    }

    private async Task RemoveItemAsync(string identifier)
    {
        await RunEquipmentActionAsync(() => CharacterSession.RemoveCurrentEquipmentItemAsync(identifier), closePickerOnSuccess: false);
    }

    private async Task UnequipSlotAsync(string slotId)
    {
        await RunEquipmentActionAsync(() => CharacterSession.UnequipCurrentEquipmentSlotAsync(slotId), closePickerOnSuccess: false);
    }

    private async Task RunEquipmentActionAsync(Func<Task<WebCharacterEquipmentState>> action, bool closePickerOnSuccess)
    {
        _busy = true;
        _failed = false;
        try
        {
            _state = await action();
            _statusMessage = _state.StatusMessage;

            if (closePickerOnSuccess)
            {
                CloseEquipmentPicker();
            }
            else if (_pickerMode == EquipmentPickerMode.GearSlot && _pickerSlotId is not null)
            {
                _slotInventoryOptions = await CharacterSession.GetCurrentEquipmentInventoryOptionsAsync(_pickerSlotId);
            }
        }
        catch (Exception ex)
        {
            _failed = true;
            _statusMessage = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }
}
