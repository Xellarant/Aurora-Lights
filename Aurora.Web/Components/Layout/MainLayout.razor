@inherits LayoutComponentBase

<div class="shell">
    <aside class="shell-sidebar">
        <div class="shell-brand">
            <div class="shell-kicker">Aurora.Web</div>
            <div class="shell-title">Phase 0</div>
            <div class="shell-subtitle">Session-scoped SRD plus private upload overlay</div>
        </div>

        <nav class="shell-nav">
            <NavLink href="/" Match="NavLinkMatch.All">Overview</NavLink>
            <NavLink href="/import">Import</NavLink>
            <NavLink href="/compendium">Compendium</NavLink>
            <NavLink href="/characters">Characters</NavLink>
            <NavLink href="/manage">Manage</NavLink>
            <NavLink href="/equipment">Equipment</NavLink>
            <NavLink href="/magic">Magic</NavLink>
            <NavLink href="/studio">Studio</NavLink>
        </nav>
    </aside>

    <main class="shell-main">
        @Body
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">x</span>
</div>
