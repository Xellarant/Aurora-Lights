          <Trigger Property="UIElement.IsMouseOver" Value="true">
            <TriggerBase.EnterActions>
              <BeginStoryboard>
                <Storyboard>
                  <DoubleAnimation From=".8" To="1" Storyboard.TargetProperty="Opacity" Duration="0:0:0.20"/>
