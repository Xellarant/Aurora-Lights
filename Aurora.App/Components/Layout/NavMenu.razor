@implements IDisposable
@inject CharacterTabService Tabs
@inject UserPreferencesService Prefs
@inject DebugLogService DebugLog

<MudNavMenu>
    @* ── Global ── *@
    <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.People">
        Characters
    </MudNavLink>
    <MudNavLink Href="/preferences" Icon="@Icons.Material.Filled.Tune">
        Preferences
    </MudNavLink>
    <MudNavLink Href="/settings" Icon="@Icons.Material.Filled.Storage">
        Content DB
    </MudNavLink>
    <MudNavLink Href="/console" Icon="@Icons.Material.Filled.Terminal"
                Style="@(Prefs.DevMode ? "" : "opacity: 0.4; pointer-events: none;")">
        Console
        @if (DebugLog.Entries.Any(e => e.Level == LogLevel.Error))
        {
            <span style="margin-left: 6px; color: #f38ba8; font-size: 10px; font-weight: 700;">●</span>
        }
    </MudNavLink>

    @* ── Per-character (only shown when a character is open) ── *@
    @if (Tabs.ActiveTab != null)
    {
        bool _loading = Tabs.ActiveTab.IsLoading;
        <MudDivider Class="my-2" />
        <MudNavLink Href="/character" Icon="@Icons.Material.Filled.Person" Disabled="_loading">
            Overview
        </MudNavLink>
        <MudNavLink Href="/build" Icon="@Icons.Material.Filled.Build">
            Build
        </MudNavLink>
        <MudNavLink Href="/equipment" Icon="@Icons.Material.Filled.Shield" Disabled="_loading">
            Equipment
        </MudNavLink>
        <MudNavLink Href="/session" Icon="@Icons.Material.Filled.Favorite" Disabled="_loading">
            Session
        </MudNavLink>
        <MudNavLink Href="/magic" Icon="@Icons.Material.Filled.AutoAwesome" Disabled="_loading">
            Magic
        </MudNavLink>
        <MudNavLink Href="/manage" Icon="@Icons.Material.Filled.ManageAccounts" Disabled="_loading">
            Manage
        </MudNavLink>
        <MudNavLink Href="/sheet" Icon="@Icons.Material.Filled.Article" Disabled="_loading">
            Sheet
        </MudNavLink>
    }
</MudNavMenu>

@code {
    private bool _disposed;

    protected override void OnInitialized() => Tabs.TabsChanged += OnTabsChanged;

    private void OnTabsChanged()
    {
        if (_disposed) return;
        _ = InvokeAsync(() => { if (!_disposed) StateHasChanged(); });
    }

    public void Dispose()
    {
        _disposed = true;
        Tabs.TabsChanged -= OnTabsChanged;
    }
}
