<MudDialog Style="max-height: 90vh; width: 700px;">
    <TitleContent>
        <MudText Typo="Typo.h6" Style="font-size: 15px; font-weight: 600;">@SlotLabel</MudText>
    </TitleContent>
    <DialogContent>
        <div class="picker-layout">
            @* ── Left: inventory options + search ── *@
            <div class="picker-left">

                @* From inventory *@
                @if (InventoryOptions.Count > 0)
                {
                    <div style="font-size: 11px; color: #6c7086; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 4px;">From Inventory</div>
                    <div class="picker-list" style="max-height: 120px; margin-bottom: 10px;">
                        @foreach (var opt in InventoryOptions)
                        {
                            var sel = _mode == SelectMode.Inventory && opt.Identifier == _selectedInventory;
                            <div class="picker-item @(sel ? "picker-item-selected" : "")"
                                 @onclick="() => SelectInventory(opt)">
                                <div class="picker-item-name">@opt.Name</div>
                            </div>
                        }
                    </div>
                    <div class="gear-divider" style="margin-bottom: 10px;">— or add a new item —</div>
                }

                @* Search all *@
                <MudTextField @bind-Value="_search"
                              @bind-Value:after="RunSearch"
                              Placeholder="Search items…"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Clearable="true"
                              Immediate="true"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense" />

                @if (_search.Length < 2)
                {
                    <MudText Color="Color.Secondary" Style="padding: 12px 0; font-size: 13px;">
                        Type at least 2 characters to search.
                    </MudText>
                }
                else if (_results.Count == 0)
                {
                    <MudText Color="Color.Secondary" Style="padding: 12px 0; font-size: 13px;">
                        No items found.
                    </MudText>
                }
                else
                {
                    <div class="picker-list">
                        @foreach (var r in _results)
                        {
                            var sel = _mode == SelectMode.New && r.Id == _selectedNew;
                            <div class="picker-item @(sel ? "picker-item-selected" : "")"
                                 @onclick="() => SelectNew(r)">
                                <div class="picker-item-name">@r.Name</div>
                                <div style="font-size: 10px; color: #6c7086; margin-top: 1px;">@r.Type</div>
                            </div>
                        }
                    </div>
                }
            </div>

            @* ── Right: detail ── *@
            <div class="picker-detail">
                @if (_detailName != null)
                {
                    <div class="picker-detail-name">@_detailName</div>
                    <div style="font-size: 11px; color: #89b4fa; margin-bottom: 4px;">@_detailType</div>
                    @if (!string.IsNullOrWhiteSpace(_detailSource))
                    {
                        <div style="font-size: 10px; color: #6c7086; margin-bottom: 8px;">@_detailSource</div>
                    }

                    @if (!string.IsNullOrWhiteSpace(_detailDesc))
                    {
                        <div class="picker-detail-desc">@_detailDesc</div>
                    }
                    else if (_mode != SelectMode.Inventory)
                    {
                        <div class="picker-detail-empty">No description available.</div>
                    }
                }
                else
                {
                    <div class="picker-detail-empty">Select an item to see details.</div>
                }
            </div>
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Cancel</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="Confirm"
                   Disabled="@(_mode == SelectMode.None)">
            Equip
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public GearSlot Slot { get; set; }
    [Parameter] public IReadOnlyList<InventoryItemOption> InventoryOptions { get; set; } = [];

    private string SlotLabel => Slot switch
    {
        GearSlot.Armor    => "Equip Armor",
        GearSlot.MainHand => "Equip Main Hand",
        GearSlot.OffHand  => "Equip Off Hand",
        _                 => "Equip Item",
    };

    private enum SelectMode { None, Inventory, New }
    private SelectMode _mode = SelectMode.None;

    private string _search = "";
    private string? _selectedInventory;
    private string? _selectedNew;
    private List<ItemSearchResult> _results = [];

    // Detail panel state
    private string? _detailName;
    private string? _detailType;
    private string? _detailSource;
    private string? _detailDesc;

    private void SelectInventory(InventoryItemOption opt)
    {
        _mode              = SelectMode.Inventory;
        _selectedInventory = opt.Identifier;
        _selectedNew       = null;
        _detailName        = opt.Name;
        _detailType        = "Already in inventory";
        _detailSource      = null;
        _detailDesc        = null;
    }

    private void SelectNew(ItemSearchResult r)
    {
        _mode              = SelectMode.New;
        _selectedNew       = r.Id;
        _selectedInventory = null;
        _detailName        = r.Name;
        _detailType        = r.Type;
        _detailSource      = r.Source;
        _detailDesc        = r.Description;
    }

    private void RunSearch()
    {
        _selectedNew = null;
        if (_mode == SelectMode.New) _mode = SelectMode.None;
        if (_search.Length < 2) { _results = []; return; }
        _results = EquipmentService.SearchItemsForSlot(Slot, _search).ToList();
    }

    private void Cancel()  => MudDialog.Cancel();
    private void Confirm()
    {
        if (_mode == SelectMode.Inventory && _selectedInventory != null)
            MudDialog.Close(new GearPickerResult(_selectedInventory, null, IsNew: false));
        else if (_mode == SelectMode.New && _selectedNew != null)
            MudDialog.Close(new GearPickerResult(null, _selectedNew, IsNew: true));
    }
}
