@page "/"
@implements IDisposable
@inject CharacterService Characters
@inject CharacterTabService Tabs
@inject NavigationManager Nav
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject UserPreferencesService Prefs
@using Builder.Presentation

@if (_loading)
{
    <div style="display: flex; align-items: center; gap: 12px; margin-top: 24px;">
        <MudProgressCircular Indeterminate="true" Size="Size.Small" />
        <MudText Color="Color.Secondary">Loading characters...</MudText>
    </div>
}

@if (_error is not null)
{
    <MudAlert Severity="@(_warning ? Severity.Warning : Severity.Error)" Class="mt-4">
        <pre style="white-space: pre-wrap; font-size: 11px; max-height: 300px; overflow-y: auto; margin: 0;">@_error</pre>
    </MudAlert>
    @if (_warning)
    {
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-2" OnClick="NavigateToCharacter">Open anyway</MudButton>
    }
}
else
{
    <CharacterLibraryShell>
        <BrowserContent>
            <CharacterBrowser Characters="@BrowserEntries"
                              Title="Characters"
                              DirectoryCaption="@DirectoryCaption"
                              EmptyMessage="@EmptyMessage"
                              BusyMessage="@BusyMessage"
                              ShowCreateButton="true"
                              CreateButtonText="New Character"
                              DisableCreateButton="@_preloading"
                              OnCreate="OnNewCharacter"
                              OnSelected="OnBrowserSelected" />
        </BrowserContent>
    </CharacterLibraryShell>
}

@code {
    private List<Builder.Presentation.Models.CharacterFile> _characters = [];
    private bool _loading = true;
    private bool _preloading;
    private string? _error;
    private bool _warning;

    private IReadOnlyList<CharacterBrowserEntry> BrowserEntries =>
        _characters.Select(ToBrowserEntry).ToList();

    private string DirectoryCaption =>
        _characters.Count == 0
            ? Characters.CharactersDirectory
            : $"{_characters.Count} character{(_characters.Count == 1 ? string.Empty : "s")} - {Characters.CharactersDirectory}";

    private string EmptyMessage =>
        $"No characters found in {Characters.CharactersDirectory}. Create a character using the Aurora Builder desktop app, then return here.";

    private string? BusyMessage => _preloading ? "Loading content data..." : null;

    public void Dispose()
    {
    }

    protected override Task OnInitializedAsync()
    {
        try
        {
            _characters = Characters.LoadCharacterFiles().ToList();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }

        _ = RunPreloadAsync();
        return Task.CompletedTask;
    }

    private async Task RunPreloadAsync()
    {
        _preloading = true;
        StateHasChanged();

        try
        {
            await Characters.PreloadAsync();

            string? mruPath = Prefs.MruCharacterPath;
            if (!string.IsNullOrEmpty(mruPath))
            {
                Builder.Presentation.Models.CharacterFile? mruFile = _characters.FirstOrDefault(file => file.FilePath == mruPath);
                if (mruFile != null && Tabs.FindTab(mruFile) == null)
                {
                    Characters.BeginPreload(mruFile);
                }
            }
        }
        finally
        {
            _preloading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task OnCharacterSelected(Builder.Presentation.Models.CharacterFile characterFile)
    {
        CharacterTab? existing = Tabs.FindTab(characterFile);
        if (existing != null)
        {
            Tabs.ActivateTab(existing);
            Nav.NavigateTo("/build");
            return;
        }

        if (Characters.IsPreloaded(characterFile))
        {
            CharacterTab tab = Tabs.OpenTab(characterFile, Characters.CurrentCharacter!);
            tab.Snapshot = CharacterSnapshot.From(Characters.CurrentCharacter!);
            tab.ProgressionSnapshots = SnapshotProgressionManagers();
            tab.Session = characterFile.LoadSession();
            Nav.NavigateTo("/build");
            return;
        }

        _error = null;
        _warning = false;
        CharacterTab loadingTab = Tabs.OpenLoadingTab(characterFile);
        Nav.NavigateTo("/build");

        try
        {
            (bool success, string message) = await Characters.LoadCharacterAsync(characterFile);

            if (success && Characters.CurrentCharacter != null)
            {
                loadingTab.Character = Characters.CurrentCharacter;
                loadingTab.Snapshot = CharacterSnapshot.From(Characters.CurrentCharacter);
                loadingTab.ProgressionSnapshots = SnapshotProgressionManagers();
                loadingTab.Session = characterFile.LoadSession();
                loadingTab.IsLoading = false;
                Tabs.NotifyChanged();
                return;
            }

            if (Characters.CurrentCharacter != null)
            {
                loadingTab.Character = Characters.CurrentCharacter;
                loadingTab.Snapshot = CharacterSnapshot.From(Characters.CurrentCharacter);
                loadingTab.ProgressionSnapshots = SnapshotProgressionManagers();
                loadingTab.Session = characterFile.LoadSession();
                loadingTab.IsLoading = false;
                Tabs.NotifyChanged();
                string warningMessage = string.IsNullOrEmpty(message)
                    ? $"Warning: {characterFile.DisplayName} loaded with missing elements; some features may not display."
                    : message;
                Snackbar.Add(warningMessage, Severity.Warning);
                return;
            }

            Tabs.CloseTab(loadingTab);
            string errorMessage = string.IsNullOrEmpty(message)
                ? $"Could not load {characterFile.DisplayName}."
                : $"Could not load {characterFile.DisplayName}: {message}";
            Snackbar.Add(errorMessage, Severity.Error);
        }
        catch (Exception ex)
        {
            DebugLogService.Instance.LogException(ex, "Start.OnCharacterSelected");
            Tabs.CloseTab(loadingTab);
            Snackbar.Add($"{characterFile.DisplayName}: {ex.GetType().Name} - {ex.Message}", Severity.Error);
        }
    }

    private void NavigateToCharacter() => Nav.NavigateTo("/character");

    private async Task OnNewCharacter()
    {
        IDialogReference dialog = await DialogService.ShowAsync<NewCharacterDialog>("New Character");
        DialogResult? result = await dialog.Result;
        if (result is not { Canceled: false, Data: NewCharacterInfo info })
        {
            return;
        }

        _error = null;
        _warning = false;

        try
        {
            (Builder.Presentation.Models.CharacterFile? file, string? error) =
                await Characters.CreateNewCharacterAsync(info.Name, info.PlayerName, Prefs.DefaultHpMethod);

            if (file == null || Characters.CurrentCharacter == null)
            {
                _error = error ?? "Failed to create character.";
                StateHasChanged();
                return;
            }

            CharacterTab tab = Tabs.OpenTab(file, Characters.CurrentCharacter);
            tab.Snapshot = CharacterSnapshot.From(Characters.CurrentCharacter);
            tab.ProgressionSnapshots = SnapshotProgressionManagers();
            tab.IsNew = true;

            _characters = Characters.LoadCharacterFiles().ToList();
            Nav.NavigateTo("/build");
        }
        catch (Exception ex)
        {
            DebugLogService.Instance.LogException(ex, "Start.OnNewCharacter");
            _error = $"{ex.GetType().Name}: {ex.Message}";
            StateHasChanged();
        }
    }

    private void OnBrowserSelected(CharacterBrowserEntry entry)
    {
        Builder.Presentation.Models.CharacterFile? character = _characters.FirstOrDefault(candidate =>
            string.Equals(candidate.FilePath, entry.Id, StringComparison.Ordinal));

        if (character != null)
        {
            _ = OnCharacterSelected(character);
        }
    }

    private static IReadOnlyList<ClassProgressionSnapshot> SnapshotProgressionManagers() =>
        BuildService.SnapshotProgressionManagers();

    private static CharacterBrowserEntry ToBrowserEntry(Builder.Presentation.Models.CharacterFile character) =>
        new(
            character.FilePath,
            character.DisplayName,
            $"Level {character.DisplayLevel} - {character.DisplayRace}",
            character.DisplayClass,
            string.IsNullOrWhiteSpace(character.CollectionGroupName) ? null : character.CollectionGroupName,
            character.CollectionGroupName,
            character.IsFavorite,
            ToPortraitDataUrl(character));

    private static string? ToPortraitDataUrl(Builder.Presentation.Models.CharacterFile character)
    {
        if (!string.IsNullOrEmpty(character.DisplayPortraitBase64))
        {
            return $"data:image/png;base64,{character.DisplayPortraitBase64}";
        }

        if (!string.IsNullOrEmpty(character.DisplayPortraitFilePath))
        {
            try
            {
                if (File.Exists(character.DisplayPortraitFilePath))
                {
                    byte[] bytes = File.ReadAllBytes(character.DisplayPortraitFilePath);
                    return $"data:image/png;base64,{Convert.ToBase64String(bytes)}";
                }
            }
            catch
            {
                return null;
            }
        }

        return null;
    }
}
