@page "/"
@implements IDisposable
@inject CharacterService Characters
@inject CharacterTabService Tabs
@inject NavigationManager Nav
@using Builder.Presentation

<div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px;">
    <MudText Typo="Typo.h5">Characters</MudText>
    <button class="new-char-btn" @onclick="OnNewCharacter">
        <span class="new-char-icon">＋</span>
        New Character
    </button>
</div>

@if (_loading)
{
    <div style="display: flex; align-items: center; gap: 12px; margin-top: 24px;">
        <MudProgressCircular Indeterminate="true" Size="Size.Small" />
        <MudText Color="Color.Secondary">Loading characters…</MudText>
    </div>
}
@if (_loadingCharacter)
{
    <div class="char-load-overlay">
        <div class="char-load-box">
            <div class="char-load-name">@_loadingCharacterName</div>
            <MudProgressLinear Value="@Characters.LoadingPercent" Color="Color.Primary" Class="char-load-bar" />
            <div class="char-load-status">@(string.IsNullOrEmpty(Characters.LoadingStatus) ? "Starting…" : Characters.LoadingStatus)</div>
        </div>
    </div>
}
else if (_error is not null)
{
    <MudAlert Severity="@(_warning ? Severity.Warning : Severity.Error)" Class="mt-4">
        <pre style="white-space: pre-wrap; font-size: 11px; max-height: 300px; overflow-y: auto; margin: 0;">@_error</pre>
    </MudAlert>
    @if (_warning)
    {
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-2" OnClick="NavigateToCharacter">Open anyway</MudButton>
    }
}
else if (_characters.Count == 0)
{
    <MudText Color="Color.Secondary" Class="mt-4">
        No characters found in <code>@Characters.CharactersDirectory</code>.<br />
        Create a character using the Aurora Builder desktop app, then return here.
    </MudText>
}
else
{
    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px;">
        <MudText Typo="Typo.caption" Color="Color.Secondary">
            @_characters.Count character@(_characters.Count == 1 ? "" : "s") &middot; @Characters.CharactersDirectory
        </MudText>
        @if (_preloading)
        {
            <div style="display: flex; align-items: center; gap: 6px;">
                <MudProgressCircular Indeterminate="true" Size="Size.Small" Style="width: 14px; height: 14px;" />
                <MudText Typo="Typo.caption" Color="Color.Secondary">Loading content data…</MudText>
            </div>
        }
    </div>

    @* Favorites section *@
    @if (_favorites.Count > 0)
    {
        <div class="char-section-header">
            <span style="color: #f9e2af;">★</span> Favorites
        </div>
        <div class="char-grid mb-6">
            @foreach (var c in _favorites)
            {
                <CharacterCard Character="c" OnSelected="OnCharacterSelected" />
            }
        </div>
    }

    @* Groups *@
    @foreach (var group in _groups)
    {
        <div class="char-section-header">@group.Key</div>
        <div class="char-grid mb-6">
            @foreach (var c in group)
            {
                <CharacterCard Character="c" OnSelected="OnCharacterSelected" />
            }
        </div>
    }
}

@code {
    private List<Builder.Presentation.Models.CharacterFile> _characters = [];
    private List<Builder.Presentation.Models.CharacterFile> _favorites = [];
    private IEnumerable<IGrouping<string, Builder.Presentation.Models.CharacterFile>> _groups = [];
    private bool _loading = true;
    private bool _preloading;
    private string? _error;
    private bool _warning;
    private string _loadingCharacterName = "";

    protected override void OnInitialized()
    {
        Characters.LoadingProgressChanged += OnLoadingProgress;
    }

    private void OnLoadingProgress() => InvokeAsync(StateHasChanged);

    public void Dispose() => Characters.LoadingProgressChanged -= OnLoadingProgress;

    protected override Task OnInitializedAsync()
    {
        try
        {
            _characters = Characters.LoadCharacterFiles().ToList();
            _favorites   = _characters.Where(x => x.IsFavorite).ToList();

            _groups = _characters
                .GroupBy(x => string.IsNullOrEmpty(x.CollectionGroupName) ? "Characters" : x.CollectionGroupName)
                .OrderBy(g => g.Key);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }

        // Kick off element data loading in the background so it's ready before
        // the user clicks a character. The SemaphoreSlim in CharacterService ensures
        // LoadCharacterAsync will simply wait if preloading is still in progress.
        _ = RunPreloadAsync();

        return Task.CompletedTask;
    }

    private async Task RunPreloadAsync()
    {
        _preloading = true;
        StateHasChanged();
        try
        {
            await Characters.PreloadAsync();
        }
        finally
        {
            _preloading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private bool _loadingCharacter;

    private async Task OnCharacterSelected(Builder.Presentation.Models.CharacterFile c)
    {
        // If already open in a tab, just activate it — no reload needed.
        var existing = Tabs.FindTab(c);
        if (existing != null)
        {
            Tabs.ActivateTab(existing);
            Nav.NavigateTo("/character");
            return;
        }

        _loadingCharacter = true;
        _loadingCharacterName = c.DisplayName ?? "";
        _error = null;
        _warning = false;
        StateHasChanged();

        try
        {
            var (success, message) = await Characters.LoadCharacterAsync(c);
            if (success && Characters.CurrentCharacter != null)
            {
                var tab = Tabs.OpenTab(c, Characters.CurrentCharacter);
                tab.Snapshot = CharacterSnapshot.From(Characters.CurrentCharacter);
                tab.ProgressionSnapshots = SnapshotProgressionManagers();
                Nav.NavigateTo("/character");
                return;
            }
            // Partial load: character exists but something is missing
            if (!success && Characters.CurrentCharacter != null)
            {
                var tab = Tabs.OpenTab(c, Characters.CurrentCharacter);
                tab.Snapshot = CharacterSnapshot.From(Characters.CurrentCharacter);
                tab.ProgressionSnapshots = SnapshotProgressionManagers();
                _warning = true;
                _error = string.IsNullOrEmpty(message)
                    ? $"⚠ {c.DisplayName} loaded with missing elements — some features may not display."
                    : message;
            }
            else
            {
                _error = string.IsNullOrEmpty(message)
                    ? $"Could not load {c.DisplayName}."
                    : $"Could not load {c.DisplayName}: {message}";
            }
        }
        catch (Exception ex)
        {
            _error = $"{c.DisplayName}: {ex.GetType().Name} — {ex.Message}";
        }
        finally
        {
            _loadingCharacter = false;
            StateHasChanged();
        }
    }

    private void NavigateToCharacter() => Nav.NavigateTo("/character");

    private void OnNewCharacter()
    {
        // TODO: open new character flow
    }

    private static IReadOnlyList<ClassProgressionSnapshot> SnapshotProgressionManagers() =>
        BuildService.SnapshotProgressionManagers();
}
