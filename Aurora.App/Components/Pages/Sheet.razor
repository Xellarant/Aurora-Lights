@page "/sheet"
@implements IDisposable
@inject CharacterTabService Tabs
@inject ISnackbar Snackbar
@inject UserPreferencesService Prefs
@using Builder.Presentation
@using Builder.Presentation.Services.Data

@if (_snap is null)
{
    <div style="margin-top: 24px;">
        <MudText Color="Color.Secondary">No character loaded. Open a character from the <MudLink Href="/">Characters</MudLink> page.</MudText>
    </div>
    return;
}

<div class="page-header-row" style="margin-bottom: 16px;">
    <MudText Typo="Typo.h6" Style="margin: 0;">@_snap.Name</MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Style="margin: 0;">
        Level @_snap.Level @_snap.Race @_snap.Class
        @if (!string.IsNullOrEmpty(_snap.Archetype)) { <span> — @_snap.Archetype</span> }
    </MudText>
</div>

@if (_generating)
{
    <div class="build-saving-bar" style="margin-bottom: 12px;">
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Style="height: 2px;" />
    </div>
}

@if (_error != null)
{
    <MudAlert Severity="Severity.Error" Class="mb-3" ShowCloseIcon="true"
              CloseIconClicked="() => _error = null">
        <div><b>Failed to generate PDF</b></div>
        <div style="font-size:0.8em; word-break:break-all; white-space:pre-wrap;">@_error</div>
    </MudAlert>
}

@if (_lastSavedPath != null)
{
    <MudAlert Severity="Severity.Success" Class="mb-3" ShowCloseIcon="true"
              CloseIconClicked="() => _lastSavedPath = null">
        <div>PDF saved to <code style="font-size:0.85em;">@_lastSavedPath</code></div>
        <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Success"
                   Style="margin-top: 4px;"
                   OnClick="() => OpenContainingFolder(_lastSavedPath!)">
            Open Folder
        </MudButton>
    </MudAlert>
}

<div class="sheet-actions">
    <MudButton StartIcon="@Icons.Material.Filled.Visibility"
               Color="Color.Default"
               Variant="Variant.Outlined"
               Disabled="_generating"
               OnClick="PreviewPdfAsync">
        Preview
    </MudButton>
    <MudButton StartIcon="@Icons.Material.Filled.PictureAsPdf"
               Color="Color.Primary"
               Variant="Variant.Filled"
               Disabled="_generating"
               OnClick="GeneratePdfAsync"
               Style="margin-left: 8px;">
        Save PDF
    </MudButton>
    <MudText Typo="Typo.caption" Color="Color.Secondary" Style="margin-left: 12px; align-self: center;">
        Saves to @GetExportLocationLabel()
    </MudText>
</div>

<div class="sheet-options" style="margin-top: 20px;">
    <MudText Typo="Typo.subtitle2" Color="Color.Secondary" Style="margin-bottom: 8px;">Card Pages</MudText>
    <div class="sheet-options-row">
        <MudTooltip Text="Add a page of spell cards to the PDF">
            <MudChip T="string"
                     Icon="@(Prefs.IncludeSpellCards ? Icons.Material.Filled.CheckBox : Icons.Material.Filled.CheckBoxOutlineBlank)"
                     Color="@(Prefs.IncludeSpellCards ? Color.Primary : Color.Default)"
                     Variant="Variant.Outlined"
                     OnClick="@(() => Prefs.IncludeSpellCards = !Prefs.IncludeSpellCards)">
                Spell Cards
            </MudChip>
        </MudTooltip>
        <MudTooltip Text="Add a page of item cards to the PDF">
            <MudChip T="string"
                     Icon="@(Prefs.IncludeItemCards ? Icons.Material.Filled.CheckBox : Icons.Material.Filled.CheckBoxOutlineBlank)"
                     Color="@(Prefs.IncludeItemCards ? Color.Primary : Color.Default)"
                     Variant="Variant.Outlined"
                     OnClick="@(() => Prefs.IncludeItemCards = !Prefs.IncludeItemCards)">
                Item Cards
            </MudChip>
        </MudTooltip>
        <MudTooltip Text="Add a page of attack cards to the PDF">
            <MudChip T="string"
                     Icon="@(Prefs.IncludeAttackCards ? Icons.Material.Filled.CheckBox : Icons.Material.Filled.CheckBoxOutlineBlank)"
                     Color="@(Prefs.IncludeAttackCards ? Color.Primary : Color.Default)"
                     Variant="Variant.Outlined"
                     OnClick="@(() => Prefs.IncludeAttackCards = !Prefs.IncludeAttackCards)">
                Attack Cards
            </MudChip>
        </MudTooltip>
        <MudTooltip Text="Add a page of feature cards to the PDF">
            <MudChip T="string"
                     Icon="@(Prefs.IncludeFeatureCards ? Icons.Material.Filled.CheckBox : Icons.Material.Filled.CheckBoxOutlineBlank)"
                     Color="@(Prefs.IncludeFeatureCards ? Color.Primary : Color.Default)"
                     Variant="Variant.Outlined"
                     OnClick="@(() => Prefs.IncludeFeatureCards = !Prefs.IncludeFeatureCards)">
                Feature Cards
            </MudChip>
        </MudTooltip>
    </div>
</div>

@* Character summary card *@
<div class="sheet-summary" style="margin-top: 24px;">
    <div class="combat-strip">
        <div class="combat-stat">
            <div class="combat-stat-value">@_snap.ArmorClass</div>
            <div class="combat-stat-label">AC</div>
        </div>
        <div class="combat-sep"></div>
        <div class="combat-stat">
            <div class="combat-stat-value">@_snap.MaxHp</div>
            <div class="combat-stat-label">HP</div>
        </div>
        <div class="combat-sep"></div>
        <div class="combat-stat">
            <div class="combat-stat-value">@_snap.Initiative</div>
            <div class="combat-stat-label">Initiative</div>
        </div>
        <div class="combat-sep"></div>
        <div class="combat-stat">
            <div class="combat-stat-value">@_snap.Speed ft.</div>
            <div class="combat-stat-label">Speed</div>
        </div>
        <div class="combat-sep"></div>
        <div class="combat-stat">
            <div class="combat-stat-value">+@_snap.Proficiency</div>
            <div class="combat-stat-label">Proficiency</div>
        </div>
    </div>

    <div class="ability-grid" style="margin-top: 16px;">
        @foreach (var ability in _snap.Abilities)
        {
            <div class="ability-box">
                <div class="ability-abbr">@ability.Abbreviation.ToUpper()</div>
                <div class="ability-score">@ability.FinalScore</div>
                <div class="ability-mod">@ability.ModifierString</div>
            </div>
        }
    </div>
</div>

@code {
    private CharacterSnapshot? _snap;
    private bool   _generating;
    private string? _error;
    private string? _lastSavedPath;

    protected override void OnInitialized()
    {
        Tabs.TabsChanged += OnTabsChanged;
        _snap = Tabs.ActiveTab?.Snapshot;
    }

    private void OnTabsChanged() => InvokeAsync(() =>
    {
        _snap = Tabs.ActiveTab?.Snapshot;
        StateHasChanged();
    });

    public void Dispose() => Tabs.TabsChanged -= OnTabsChanged;

    private async Task PreviewPdfAsync()
    {
        if (_snap is null) return;
        var tab = Tabs.ActiveTab;
        if (tab is null) return;
        _generating = true;
        _error      = null;
        StateHasChanged();

        try
        {
            // Generate to a temp file on a background thread.
            // Keep the file alive so the WebView can load it; PdfPreviewPage deletes it on close.
            var (tempPath, snapCopy) = await GenerateWithContextAsync(tab, isPreview: true);

            // Open a native MAUI window on the UI thread.
            await MainThread.InvokeOnMainThreadAsync(() =>
            {
                var page = new PdfPreviewPage(tempPath, snapCopy?.Name ?? "Character",
                    saveToDocuments: async () =>
                    {
                        var safeName = string.Concat((snapCopy?.Name ?? "Character")
                            .Select(c => Path.GetInvalidFileNameChars().Contains(c) ? '_' : c));
                        var chosenPath = await FileSaveService.PickSaveLocationAsync(
                            $"{safeName}.pdf",
                            new[] { new FileSaveService.FileTypeChoice("PDF document", ".pdf") },
                            GetPreferredExportDirectory());
                        if (chosenPath is null) return null;

                        using var saveScope = await CharacterContext.EnterAsync(tab);
                        await Task.Run(() =>
                        {
                            CharacterSheetGeneratorContext.Current!.GenerateNewSheet(chosenPath, isPreview: false);
                        });
                        await InvokeAsync(() =>
                        {
                            _lastSavedPath = chosenPath;
                            StateHasChanged();
                        });
                        return chosenPath;
                    });

                Application.Current!.OpenWindow(new Window(page)
                {
                    Title  = $"Character Sheet Preview — {snapCopy?.Name}",
                    Width  = 840,
                    Height = 1000,
                });
            });
        }
        catch (Exception ex)
        {
            _error = $"{ex.GetType().Name}: {ex.Message}";
            DebugLogService.Instance.LogException(ex, "PDF preview");
        }
        finally
        {
            _generating = false;
            StateHasChanged();
        }
    }

    private async Task GeneratePdfAsync()
    {
        if (_snap is null) return;
        var tab = Tabs.ActiveTab;
        if (tab is null) return;

        string safeName = string.Concat((_snap.Name ?? "Character")
            .Select(c => Path.GetInvalidFileNameChars().Contains(c) ? '_' : c));
        string? chosenPath = await FileSaveService.PickSaveLocationAsync(
            $"{safeName}.pdf",
            new[] { new FileSaveService.FileTypeChoice("PDF document", ".pdf") },
            GetPreferredExportDirectory());

        if (chosenPath is null) return; // user cancelled

        _generating    = true;
        _error         = null;
        _lastSavedPath = null;
        StateHasChanged();

        try
        {
            using var scope = await CharacterContext.EnterAsync(tab);
            await Task.Run(() =>
            {
                CharacterSheetGeneratorContext.Current!.GenerateNewSheet(chosenPath, isPreview: false);
            });
            _lastSavedPath = chosenPath;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            DebugLogService.Instance.LogException(ex, "PDF generation");
        }
        finally
        {
            _generating = false;
            StateHasChanged();
        }
    }

    private async Task<(string Path, CharacterSnapshot? Snap)> GenerateWithContextAsync(CharacterTab tab, bool isPreview)
    {
        using var scope = await CharacterContext.EnterAsync(tab);
        return await Task.Run(() =>
        {
            var path = Path.Combine(Path.GetTempPath(), $"aurora_preview_{Guid.NewGuid():N}.pdf");
            CharacterSheetGeneratorContext.Current!.GenerateNewSheet(path, isPreview: isPreview);
            return (path, _snap);
        });
    }

    private static void OpenContainingFolder(string filePath)
    {
        try
        {
            string? folder = Path.GetDirectoryName(filePath);
            if (folder != null)
                ExternalLauncherContext.Current?.OpenPath(folder);
        }
        catch { }
    }

    private static string GetPreferredExportDirectory()
    {
        if (string.IsNullOrWhiteSpace(DataManager.Current.UserDocumentsRootDirectory))
            DataManager.Current.InitializeDirectories();

        string? folder = DataManager.Current.UserDocumentsRootDirectory;
        if (string.IsNullOrWhiteSpace(folder))
        {
            string documents = Environment.GetFolderPath(Environment.SpecialFolder.MyDocuments);
            folder = !string.IsNullOrWhiteSpace(documents)
                ? Path.Combine(documents, "Aurora Reflections")
                : Path.Combine(FileSystem.Current.AppDataDirectory, "Exports");
        }

        Directory.CreateDirectory(folder);
        return folder;
    }

    private static string GetExportLocationLabel()
    {
        string folder = GetPreferredExportDirectory();
        return Path.GetFileName(folder) is { Length: > 0 } leaf ? leaf : folder;
    }
}
