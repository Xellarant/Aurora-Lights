<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6" Style="font-size: 15px; font-weight: 600;">New Character</MudText>
    </TitleContent>
    <DialogContent>
        <div style="display: flex; flex-direction: column; gap: 14px; padding-top: 4px; min-width: 340px;">
            <MudTextField @bind-Value="_name"
                          Label="Character Name"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Immediate="true"
                          AutoFocus="true"
                          @onkeydown="OnKeyDown" />
            <MudTextField @bind-Value="_playerName"
                          Label="Player Name"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Immediate="true"
                          @onkeydown="OnKeyDown" />
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Cancel</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="Confirm"
                   Disabled="@string.IsNullOrWhiteSpace(_name)">
            Create
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;

    private string _name       = "";
    private string _playerName = "";

    private void OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_name))
            Confirm();
    }

    private void Cancel()  => MudDialog.Cancel();
    private void Confirm() => MudDialog.Close(new NewCharacterInfo(_name.Trim(), _playerName.Trim()));
}
