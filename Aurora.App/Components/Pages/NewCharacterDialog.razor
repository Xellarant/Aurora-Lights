<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6" Style="font-size: 15px; font-weight: 600;">New Character</MudText>
    </TitleContent>
    <DialogContent>
        <div style="padding-top: 4px; min-width: 340px;">
            <CharacterCreationFields Model="_model"
                                     NamePlaceholder="Character Name"
                                     PlayerNamePlaceholder="Player Name"
                                     OnKeyDown="OnKeyDown" />
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Cancel</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="Confirm"
                   Disabled="@string.IsNullOrWhiteSpace(_model.Name)">
            Create
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;

    private readonly CharacterCreationModel _model = new();

    private void OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_model.Name))
            Confirm();
    }

    private void Cancel()  => MudDialog.Cancel();
    private void Confirm() => MudDialog.Close(new NewCharacterInfo(_model.Name.Trim(), _model.PlayerName.Trim()));
}
