@page "/equipment"
@implements IDisposable
@inject CharacterTabService Tabs
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject DebugLogService DebugLog
@using Aurora.App.Services
@using Builder.Presentation.ViewModels.Shell.Items

@if (_initError is not null)
{
    <div class="page-error-box" style="margin-top: 24px;">
        <div class="page-error-title">Equipment page failed to initialize.</div>
        <pre class="page-error-detail">@_initError</pre>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2">
            This error has been captured. Enable Dev Mode in
            <MudLink Href="/preferences">Preferences</MudLink> then open the
            <MudLink Href="/console">Console</MudLink> for details.
        </MudText>
    </div>
    return;
}

@if (_snap is null)
{
    <div style="margin-top: 24px;">
        <MudText Color="Color.Secondary">No character loaded. Open a character from the <MudLink Href="/">Characters</MudLink> page.</MudText>
    </div>
    return;
}

<CharacterEquipmentWorkspace Model="@EquipmentModel"
                             OnAddItem="OpenAddItemDialog"
                             OnOpenGearSlot="OpenGearSlotDialogAsync"
                             OnUnequipGearSlot="UnequipGearAsync"
                             OnRemoveItem="RemoveItemAsync"
                             OnToggleEquipped="ToggleEquippedAsync"
                             OnToggleAttuned="ToggleAttunedAsync"
                             OnChangeAmount="ChangeAmountAsync"
                             OnCoinChanged="ChangeCoinAsync"
                             OnNoteChanged="ChangeNoteAsync" />

@code {
    private CharacterSnapshot? _snap;
    private string? _initError;

    private string? _armorName;
    private string? _mainHandName;
    private string? _offHandName;

    private EquipmentOverviewModel EquipmentModel =>
        _snap is null
            ? new EquipmentOverviewModel()
            : new()
            {
                Attacks = _snap.Attacks.Select(atk => new EquipmentAttackModel(atk.Name, atk.Attack, atk.Damage, atk.Range)).ToList(),
                GearSlots =
                [
                    new("armor", "Armor", _armorName),
                    new("main-hand", "Main Hand", _mainHandName),
                    new("off-hand", "Off Hand", _offHandName)
                ],
                InventoryItems = _snap.InventoryItems
                    .Select(item => new EquipmentInventoryItemModel(
                        item.Identifier,
                        item.Name,
                        item.Amount,
                        item.IsStackable,
                        item.IsEquipped,
                        item.EquippedLocation,
                        item.IsAttunable,
                        item.IsAttuned,
                        item.DisplayWeight,
                        item.DisplayPrice,
                        item.IsEquippable))
                    .ToList(),
                Copper = _snap.CoinCopper,
                Silver = _snap.CoinSilver,
                Electrum = _snap.CoinElectrum,
                Gold = _snap.CoinGold,
                Platinum = _snap.CoinPlatinum,
                AttunedCount = _snap.AttunedCount,
                AttunedMax = _snap.AttunedMax,
                EquipmentNotes = _snap.InventoryEquipmentText,
                TreasureNotes = _snap.InventoryTreasureText,
                QuestNotes = _snap.InventoryQuestText
            };

    protected override void OnInitialized()
    {
        Tabs.TabsChanged += OnTabsChanged;
        try
        {
            LoadFromActiveTab();
        }
        catch (Exception ex)
        {
            _initError = $"{ex.GetType().Name}: {ex.Message}\n\n{ex.StackTrace}";
            DebugLog.LogException(ex, "Equipment.OnInitialized");
        }
    }

    private void LoadFromActiveTab()
    {
        _snap = Tabs.ActiveTab?.Snapshot;
        RefreshGearNames();
    }

    private void RefreshGearNames()
    {
        try
        {
            var inv = Tabs.ActiveTab?.Character?.Inventory;
            _armorName = inv?.EquippedArmor?.DisplayName ?? inv?.EquippedArmor?.Name;
            _mainHandName = inv?.EquippedPrimary?.DisplayName ?? inv?.EquippedPrimary?.Name;
            _offHandName = inv?.EquippedSecondary?.DisplayName ?? inv?.EquippedSecondary?.Name;
        }
        catch (Exception ex)
        {
            DebugLog.LogException(ex, "Equipment.RefreshGearNames");
        }
    }

    private void OnTabsChanged() => InvokeAsync(() =>
    {
        LoadFromActiveTab();
        StateHasChanged();
    });

    public void Dispose() => Tabs.TabsChanged -= OnTabsChanged;

    private void MarkDirty()
    {
        if (Tabs.ActiveTab is { } tab)
        {
            Tabs.MarkDirty(tab);
        }
    }

    private static GearSlot ParseSlot(string slotId) => slotId switch
    {
        "armor" => GearSlot.Armor,
        "main-hand" => GearSlot.MainHand,
        "off-hand" => GearSlot.OffHand,
        _ => throw new InvalidOperationException("Unknown gear slot.")
    };

    private async Task OpenGearSlotDialogAsync(string slotId)
    {
        await OpenGearSlotDialog(ParseSlot(slotId));
    }

    private Task UnequipGearAsync(string slotId)
    {
        UnequipGear(ParseSlot(slotId));
        return Task.CompletedTask;
    }

    private async Task OpenGearSlotDialog(GearSlot slot)
    {
        if (Tabs.ActiveTab is not { Character: { } character, File: { } file, Snapshot: { } snap }) return;

        var invOptions = EquipmentService.GetInventoryItemsForSlot(character, slot);

        var parameters = new DialogParameters
        {
            [nameof(GearSlotPickerDialog.Slot)] = slot,
            [nameof(GearSlotPickerDialog.InventoryOptions)] = invOptions,
        };
        var dialog = await DialogService.ShowAsync<GearSlotPickerDialog>("", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: GearPickerResult pick })
        {
            bool ok = pick.IsNew
                ? EquipmentService.AddAndEquipToSlot(character, slot, pick.ElementId!)
                : EquipmentService.EquipToSlot(character, slot, pick.Identifier!);

            if (!ok)
            {
                Snackbar.Add("Could not equip item.", Severity.Error);
                return;
            }

            snap.RefreshEquipmentFromCharacter(character);
            _snap = snap;
            RefreshGearNames();
            file.SaveInventoryItems(character);
            MarkDirty();
            StateHasChanged();
        }
    }

    private void UnequipGear(GearSlot slot)
    {
        if (Tabs.ActiveTab is not { Character: { } character, File: { } file, Snapshot: { } snap }) return;

        EquipmentService.UnequipSlot(character, slot);
        snap.RefreshEquipmentFromCharacter(character);
        _snap = snap;
        RefreshGearNames();
        file.SaveInventoryItems(character);
        MarkDirty();
        StateHasChanged();
    }

    private async Task OpenAddItemDialog()
    {
        var dialog = await DialogService.ShowAsync<ItemPickerDialog>("Add Item");
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: ItemPickerResult pick })
        {
            if (Tabs.ActiveTab is not { Character: { } character, File: { } file, Snapshot: { } snap })
                return;

            var added = EquipmentService.AddItem(character, pick.ElementId, pick.Amount);
            if (!added)
            {
                Snackbar.Add("Could not add item - element not found.", Severity.Error);
                return;
            }

            snap.RefreshEquipmentFromCharacter(character);
            _snap = snap;
            RefreshGearNames();

            file.SaveInventoryItems(character);
            MarkDirty();
            StateHasChanged();
        }
    }

    private Task RemoveItemAsync(string identifier)
    {
        if (Tabs.ActiveTab is not { Character: { } character, File: { } file, Snapshot: { } snap })
            return Task.CompletedTask;

        EquipmentService.RemoveItem(character, identifier);
        snap.RefreshEquipmentFromCharacter(character);
        _snap = snap;
        RefreshGearNames();

        file.SaveInventoryItems(character);
        MarkDirty();
        return Task.CompletedTask;
    }

    private Task ChangeAmountAsync(EquipmentAmountChangeModel change)
    {
        if (Tabs.ActiveTab is not { Character: { } character, File: { } file, Snapshot: { } snap })
            return Task.CompletedTask;

        EquipmentService.SetAmount(character, change.Identifier, change.Amount);
        snap.RefreshEquipmentFromCharacter(character);
        _snap = snap;

        file.SaveInventoryItems(character);
        MarkDirty();
        return Task.CompletedTask;
    }

    private Task ToggleEquippedAsync(string identifier)
    {
        var item = FindLiveItem(identifier);
        if (item is null) return Task.CompletedTask;

        if (item.IsEquipped)
            item.Deactivate();
        else
            item.Activate(equip: true, attune: item.IsAttuned);

        RefreshEquipment();
        MarkDirty();
        return Task.CompletedTask;
    }

    private Task ToggleAttunedAsync(string identifier)
    {
        var item = FindLiveItem(identifier);
        if (item is null) return Task.CompletedTask;

        if (item.IsAttuned)
            item.DeactivateAttunement();
        else
            item.Activate(equip: item.IsEquipped, attune: true);

        RefreshEquipment();
        MarkDirty();
        return Task.CompletedTask;
    }

    private RefactoredEquipmentItem? FindLiveItem(string identifier) =>
        Tabs.ActiveTab?.Character?.Inventory?.Items
            .FirstOrDefault(i => i.Identifier == identifier);

    private void RefreshEquipment()
    {
        if (Tabs.ActiveTab is not { Character: { } character, Snapshot: { } snap }) return;
        snap.RefreshEquipmentFromCharacter(character);
        _snap = snap;
        RefreshGearNames();
    }

    private Task ChangeCoinAsync(EquipmentCoinChangeModel change)
    {
        if (_snap is null)
        {
            return Task.CompletedTask;
        }

        switch (change.CoinId)
        {
            case "cp":
                _snap.CoinCopper = change.Value;
                break;
            case "sp":
                _snap.CoinSilver = change.Value;
                break;
            case "ep":
                _snap.CoinElectrum = change.Value;
                break;
            case "gp":
                _snap.CoinGold = change.Value;
                break;
            case "pp":
                _snap.CoinPlatinum = change.Value;
                break;
        }

        MarkDirty();
        return Task.CompletedTask;
    }

    private Task ChangeNoteAsync(EquipmentNoteChangeModel change)
    {
        if (_snap is null)
        {
            return Task.CompletedTask;
        }

        switch (change.NoteId)
        {
            case "equipment":
                _snap.InventoryEquipmentText = change.Value;
                break;
            case "treasure":
                _snap.InventoryTreasureText = change.Value;
                break;
            case "quest":
                _snap.InventoryQuestText = change.Value;
                break;
        }

        MarkDirty();
        return Task.CompletedTask;
    }
}
