@inject MudBlazor.IDialogService DialogSvc

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@(IsEdit ? "Edit Resource" : "Add Resource")</MudText>
    </TitleContent>
    <DialogContent>
        <div style="display: flex; flex-direction: column; gap: 12px; padding-top: 4px; min-width: 280px;">
            <MudTextField @bind-Value="_name"
                          Label="Name"
                          Placeholder="e.g. Bardic Inspiration"
                          Variant="Variant.Outlined"
                          Immediate="true"
                          HelperText=" " />
            <MudNumericField @bind-Value="_max"
                             Label="Max"
                             Min="1" Max="99"
                             Variant="Variant.Outlined"
                             HelperText=" " />
            <MudSelect @bind-Value="_resetOn"
                       Label="Resets on"
                       Variant="Variant.Outlined">
                <MudSelectItem Value="@ResetOn.LongRest">Long Rest</MudSelectItem>
                <MudSelectItem Value="@ResetOn.ShortRest">Short Rest</MudSelectItem>
                <MudSelectItem Value="@ResetOn.Manual">Manual only</MudSelectItem>
            </MudSelect>
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Cancel</MudButton>
        <MudButton OnClick="Submit"
                   Variant="Variant.Filled"
                   Color="Color.Primary"
                   Disabled="@string.IsNullOrWhiteSpace(_name)">
            @(IsEdit ? "Save" : "Add")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = default!;

    /// <summary>When set, dialog is in edit mode — fields pre-populated from this resource.</summary>
    [Parameter] public CustomResource? Existing { get; set; }
    [Parameter] public bool IsEdit { get; set; }

    private string  _name    = "";
    private int     _max     = 1;
    private ResetOn _resetOn = ResetOn.LongRest;

    protected override void OnParametersSet()
    {
        if (Existing != null)
        {
            _name    = Existing.Name;
            _max     = Existing.Max;
            _resetOn = Existing.ResetOn;
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private void Submit()
    {
        if (string.IsNullOrWhiteSpace(_name)) return;

        var result = Existing != null
            ? new CustomResource { Id = Existing.Id, Name = _name.Trim(), Max = _max, Used = Existing.Used, ResetOn = _resetOn }
            : new CustomResource { Name = _name.Trim(), Max = _max, ResetOn = _resetOn };

        MudDialog.Close(DialogResult.Ok(result));
    }
}
