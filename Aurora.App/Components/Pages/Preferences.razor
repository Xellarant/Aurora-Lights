@page "/preferences"
@inject UserPreferencesService Prefs
@inject DebugLogService DebugLog
@inject CharacterService Characters
<MudText Typo="Typo.h5" Class="mb-6">Preferences</MudText>

<div class="pref-section">
    <div class="section-label">Appearance</div>

    <div class="pref-row">
        <div class="pref-row-text">
            <div class="pref-row-title">Light mode</div>
            <div class="pref-row-desc">
                Switch to a light colour palette. Most MudBlazor controls will update immediately;
                custom layout areas use the dark palette by design and are unaffected.
            </div>
        </div>
        <MudSwitch Value="Prefs.LightMode"
                   ValueChanged="@((bool v) => Prefs.LightMode = v)"
                   Color="Color.Primary" />
    </div>
</div>

<div class="pref-section" style="margin-top: 24px;">
    <div class="section-label">Build &amp; Magic</div>

    <div class="pref-row">
        <div class="pref-row-text">
            <div class="pref-row-title">Auto-save on selection change</div>
            <div class="pref-row-desc">
                When enabled, choosing a new option on the Build or Magic page immediately
                writes the character file to disk. Disable this if you want to experiment
                with different build choices and save only when satisfied.
            </div>
        </div>
        <MudSwitch Value="Prefs.AutoSaveBuildChanges"
                   ValueChanged="@((bool v) => Prefs.AutoSaveBuildChanges = v)"
                   Color="Color.Primary" />
    </div>

    <div class="pref-row" style="margin-top: 16px;">
        <div class="pref-row-text">
            <div class="pref-row-title">Default HP method for new characters</div>
            <div class="pref-row-desc">
                Average uses the fixed value for each die size (e.g. d8 → 5 per level, max at level 1).
                Rolled generates random dice values upfront and persists them. Either can be changed
                per-character on the Build page after creation.
            </div>
        </div>
        <MudRadioGroup Value="Prefs.DefaultHpMethod"
                       ValueChanged="@((HpMethod v) => Prefs.DefaultHpMethod = v)">
            <MudRadio Value="HpMethod.Average" Color="Color.Primary">Average</MudRadio>
            <MudRadio Value="HpMethod.Rolled"  Color="Color.Primary">Rolled</MudRadio>
        </MudRadioGroup>
    </div>
</div>

<div class="pref-section" style="margin-top: 24px;">
    <div class="section-label">Character Sheet</div>

    <div class="pref-row">
        <div class="pref-row-text">
            <div class="pref-row-title">Include spell cards</div>
            <div class="pref-row-desc">
                Adds a page of spell cards at the end of the generated PDF. Each spell the
                character knows or has prepared gets its own card with casting details and description.
            </div>
        </div>
        <MudSwitch Value="Prefs.IncludeSpellCards"
                   ValueChanged="@((bool v) => Prefs.IncludeSpellCards = v)"
                   Color="Color.Primary" />
    </div>

    <div class="pref-row" style="margin-top: 16px;">
        <div class="pref-row-text">
            <div class="pref-row-title">Include item cards</div>
            <div class="pref-row-desc">
                Adds a page of item cards for equipment marked to show as a card. Each item
                gets its own card with its category, description, and source.
            </div>
        </div>
        <MudSwitch Value="Prefs.IncludeItemCards"
                   ValueChanged="@((bool v) => Prefs.IncludeItemCards = v)"
                   Color="Color.Primary" />
    </div>

    <div class="pref-row" style="margin-top: 16px;">
        <div class="pref-row-text">
            <div class="pref-row-title">Include attack cards</div>
            <div class="pref-row-desc">
                Adds a page of attack cards for weapons and abilities configured to appear as cards,
                showing attack bonus, damage, range, and description.
            </div>
        </div>
        <MudSwitch Value="Prefs.IncludeAttackCards"
                   ValueChanged="@((bool v) => Prefs.IncludeAttackCards = v)"
                   Color="Color.Primary" />
    </div>

    <div class="pref-row" style="margin-top: 16px;">
        <div class="pref-row-text">
            <div class="pref-row-title">Include feature cards</div>
            <div class="pref-row-desc">
                Adds a page of feature cards for class features, racial traits, feats, and other
                abilities that are enabled to display on the character sheet.
            </div>
        </div>
        <MudSwitch Value="Prefs.IncludeFeatureCards"
                   ValueChanged="@((bool v) => Prefs.IncludeFeatureCards = v)"
                   Color="Color.Primary" />
    </div>
</div>

<div class="pref-section" style="margin-top: 24px;">
    <div class="section-label">Developer</div>

    <div class="pref-row">
        <div class="pref-row-text">
            <div class="pref-row-title">Developer / debug mode</div>
            <div class="pref-row-desc">
                Shows a Console page in the navigation menu where runtime exceptions and
                diagnostic messages are captured. Useful for diagnosing crashes.
            </div>
        </div>
        <MudSwitch Value="Prefs.DevMode"
                   ValueChanged="@((bool v) => Prefs.DevMode = v)"
                   Color="Color.Secondary" />
    </div>

    @if (Prefs.DevMode)
    {
        <div class="pref-row" style="margin-top: 16px;">
            <div class="pref-row-text">
                <div class="pref-row-title">Log entries: @DebugLog.Entries.Count</div>
                <div class="pref-row-desc">Errors: @DebugLog.Entries.Count(e => e.Level == LogLevel.Error)</div>
            </div>
            <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small"
                       Href="/console">Open Console</MudButton>
        </div>

        <div class="pref-row" style="margin-top: 16px;">
            <div class="pref-row-text">
                <div class="pref-row-title">Element data source: @Characters.ElementLoadSource</div>
                <div class="pref-row-desc">@Characters.ElementLoadSummary</div>
                @if (Characters.ElementLoadSchemaVersion.HasValue)
                {
                    <div class="pref-row-desc">Schema version: @Characters.ElementLoadSchemaVersion.Value</div>
                }
                @if (!string.IsNullOrWhiteSpace(Characters.ElementLoadDatabasePath))
                {
                    <div class="pref-row-desc" style="font-family: monospace; word-break: break-all;">
                        DB path: @Characters.ElementLoadDatabasePath
                    </div>
                }
                @if (!string.IsNullOrWhiteSpace(Characters.ElementLoadFailureReason))
                {
                    <div class="pref-row-desc">Fallback reason: @Characters.ElementLoadFailureReason</div>
                }
                @if (Characters.ElementLoadSkippedElements > 0)
                {
                    <div class="pref-row-desc">Skipped elements during DB load: @Characters.ElementLoadSkippedElements</div>
                }
            </div>
        </div>
    }
</div>

@code {
}
